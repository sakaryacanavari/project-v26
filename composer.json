{
  "name": "project-v26/project-v26",
  "description": "Project V26 browser-based political strategy and social simulation game.",
  "license": "MIT",
  "require": {
    "php": ">=8.2 <9.0",
    "twig/twig": "^3.27",
    "slim/slim": "^4.15",
    "slim/psr7": "^1.8",
    "slim/twig-view": "^3.4",
    "php-di/php-di": "^7.0",
    "illuminate/database": "^6.20.44",
    "illuminate/pagination": "^6.20.44",
    "nesbot/carbon": "^2.72.6"
  },
  "autoload": {
    "psr-4": {"App\\": "App"}
  },
  "scripts": {
    "static-analysis": "@php scripts/static-analysis.php",
    "modernization-smoke": "@php scripts/modernization-smoke.php",
    "performance-benchmark": "@php scripts/performance-benchmark.php",
    "schema-migrate": "@php scripts/schema-migrate.php",
    "regression-test": "@php scripts/authenticated-regression.php --allow-local"
  },
  "config": {
    "audit": {
      "block-insecure": false
    }
  }
}
