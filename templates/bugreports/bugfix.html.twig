<script>
  window.BugOpsV10 = (() => {

    const BASE_URL = window.location.pathname.replace('/bug-report', '');
    
    const API_CREATE = BASE_URL + '/ajax/bugs/create';
    const API_VOTE   = BASE_URL + '/ajax/bugs/vote';
    const API_SUB    = BASE_URL + '/ajax/bugs/subscribe';

    function showCyberAlert(icon, title, text) {
        Swal.fire({
            icon: icon,
            title: title,
            text: text,
            customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title', confirmButton: 'cyber-confirm-btn' },
            buttonsStyling: false,
            background: '#0a0c14',
            color: '#f8fafc'
        });
    }

    function toast(type, title, msg, ms=3000){
      showCyberAlert(type === 'err' ? 'error' : 'success', title, msg);
    }

    function debounce(func, wait) {
      let timeout;
      return function(...args) {
        clearTimeout(timeout);
        timeout = setTimeout(() => func.apply(this, args), wait);
      };
    }

    function csrfToken(){ return ''; }

    const drawerWrap = document.getElementById('drawerWrap');
    let currentStep = 1;

    function openDrawer(){
      drawerWrap?.classList.add('open');
      loadDraft();
      if(!document.getElementById('formStartedAt')?.value){
        document.getElementById('formStartedAt').value = String(Date.now());
      }
      goStep(currentStep || 1);
    }
    function closeDrawer(){ drawerWrap?.classList.remove('open'); }
    function drawerBackdrop(e){ if(e.target === drawerWrap) closeDrawer(); }
    window.addEventListener('keydown', (e)=>{ if(e.key === 'Escape' && drawerWrap?.classList.contains('open')) closeDrawer(); });

    function setStepUI(step){
      const panels = { 1: document.getElementById('panel1'), 2: document.getElementById('panel2'), 3: document.getElementById('panel3') };
      const steps  = { 1: document.getElementById('step1'), 2: document.getElementById('step2'), 3: document.getElementById('step3') };

      Object.values(panels).forEach(p=>p?.classList.remove('show'));
      if(panels[step]) {
        void panels[step].offsetWidth; // trigger reflow
        panels[step].classList.add('show');
      }

      Object.values(steps).forEach(s=>s?.classList.remove('active','done'));
      for(let i=1;i<=3;i++){
        if(i < step) steps[i]?.classList.add('done');
        if(i === step) steps[i]?.classList.add('active');
      }
    }

    function goStep(step){
      step = Number(step || 1);
      const selectedCat = document.getElementById('catSelect')?.value;

      if(step >= 2 && !selectedCat){
        toast('err','{{ t('bug.toast.warning') }}','{{ t('bug.toast.select_category') }}');
        step = 1;
      }

      if(step === 3){
        if(!validateRequired(false)){
          toast('err','{{ t('bug.toast.missing_data') }}','{{ t('bug.toast.fill_required') }}');
          step = 2;
        } else {
          fillPreview();
        }
      }

      currentStep = step;
      setStepUI(step);
      saveDraft();
    }

    function toggleReport(id, btn){
      const el = document.getElementById(id);
      if(!el) return;
      const isOpen = el.classList.contains('open');
      el.classList.toggle('open');

      if(btn){
        btn.innerHTML = isOpen
          ? '<i class="fa-solid fa-chevron-down text-sm opacity-70"></i> <span class="txt hidden sm:inline">{{ t('bug.inspect') }}</span>'
          : '<i class="fa-solid fa-chevron-up text-sm opacity-70"></i> <span class="txt hidden sm:inline">{{ t('bug.hide') }}</span>';
        btn.classList.toggle('bg-black/60', !isOpen);
        btn.classList.toggle('text-white', !isOpen);
      }

      if(!isOpen){
        setTimeout(()=>{ el.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 120);
      }
    }

    async function copyText(text){
      try{ await navigator.clipboard.writeText(text); toast('ok','{{ t('bug.toast.clipboard') }}', '{{ t('bug.toast.copied') }}'.replace(':text', text)); }
      catch(e){ toast('ok','{{ t('bug.toast.clipboard') }}', '{{ t('bug.toast.copied') }}'.replace(':text', text)); }
    }

    function escapeHtml(s){ return String(s ?? '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m])); }
    function prScore(pr){ return pr === 'critical' ? 3 : (pr === 'major' ? 2 : (pr === 'minor' ? 1 : 0)); }
    function parseCreatedTs(str){ return Date.parse(str) || 0; }

    function renderMarkdownSafe(raw){
      let s = String(raw ?? '');
      s = s.replace(/^\s*\[PRIORITY:[^\]]+\]\s*\n?/i, '');
      s = s.replace(/\n---\n\[CLIENT META\]\n([\s\S]*?)(?=\n---\n|\s*$)/g, '');
      s = s.replace(/\n---\n\[CLIENT LOG\]\n([\s\S]*?)(?=\n---\n|\s*$)/g, '');
      s = escapeHtml(s);
      s = s.replace(/^\s*---\s*$/gm, '<hr>');
      s = s.replace(/```([\s\S]*?)```/g, (m, code) => `<pre><code>${code.replace(/^\n+|\n+$/g,'')}</code></pre>`);
      s = s.replace(/`([^`\n]+)`/g, (m, code) => `<code>${code}</code>`);
      s = s.replace(/\*\*([^*\n]+)\*\*/g, (m, t) => `<strong>${t}</strong>`);
      s = s.replace(/\n/g, '<br>');
      return s;
    }

    function renderAllMarkdown(){
      document.querySelectorAll('[data-md="1"]').forEach(el => { el.innerHTML = renderMarkdownSafe(el.textContent || ''); });
    }

    const searchBox = document.getElementById('searchBox');
    const filterButtons = document.querySelectorAll('.v10-tab');
    const reportItems = document.querySelectorAll('.reportItem');
    let activeFilter = 'all';

    function applyFilters(){
      const q = (searchBox?.value || '').trim().toLowerCase();
      reportItems.forEach(item => {
        const st = item.getAttribute('data-status');
        const hay = item.getAttribute('data-q') || '';
        const okStatus = (activeFilter === 'all') || (st === String(activeFilter));
        const okQuery = !q || hay.includes(q);
        item.style.display = (okStatus && okQuery) ? '' : 'none';
      });
    }

    filterButtons.forEach(btn=>{
      btn.addEventListener('click', ()=>{
        activeFilter = btn.getAttribute('data-filter');
        applyFilters();
        filterButtons.forEach(b=>b.classList.remove('active'));
        btn.classList.add('active');
      });
    });
    searchBox?.addEventListener('input', debounce(applyFilters, 200));

    const sortSelect = document.getElementById('sortSelect');
    let activeSort = sortSelect?.value || 'newest';
    reportItems.forEach((it, idx) => it.setAttribute('data-idx', String(idx)));

    function sortReports(mode){
      activeSort = mode || activeSort;
      const listWrap = document.getElementById('reportList');
      if(!listWrap) return;
      const items = Array.from(reportItems);

      items.sort((a,b) => {
        const av = Number(a.getAttribute('data-votes') || 0);
        const bv = Number(b.getAttribute('data-votes') || 0);
        const ap = prScore(a.getAttribute('data-pr') || 'major');
        const bp = prScore(b.getAttribute('data-pr') || 'major');
        const at = parseCreatedTs(a.getAttribute('data-created') || '');
        const bt = parseCreatedTs(b.getAttribute('data-created') || '');
        const ai = Number(a.getAttribute('data-idx') || 0);
        const bi = Number(b.getAttribute('data-idx') || 0);

        switch(activeSort){
          case 'oldest': return at !== bt ? at - bt : ai - bi;
          case 'prio_critical': return bp !== ap ? bp - ap : (bv !== av ? bv - av : bt - at);
          case 'votes': return bv !== av ? bv - av : (bp !== ap ? bp - ap : bt - at);
          case 'newest': default: return bt !== at ? bt - at : ai - bi;
        }
      });
      items.forEach(it => listWrap.appendChild(it));
    }
    sortSelect?.addEventListener('change', () => { sortReports(sortSelect.value); applyFilters(); });

    function refreshCounts(){
      const counts = {0:0,1:0,2:0,3:0};
      reportItems.forEach(item => {
        const st = Number(item.getAttribute('data-status'));
        if(counts[st] !== undefined) counts[st]++;
      });
      const setTxt = (id, v) => { const el = document.getElementById(id); if(el) el.textContent = v; };
      for(let i=0; i<=3; i++){ setTxt(`cnt${i}`, counts[i]); }
    }

    function pickCat(value, btn){
      document.getElementById('catSelect').value = value;
      document.querySelectorAll('#catTiles .v10-cat').forEach(x=>x.classList.remove('active'));
      btn?.classList.add('active');
      saveDraft();
    }

    function injectTemplate(type){
      const d = document.getElementById('descBox'); if(!d) return;
      const t = {
        steps: `{{ t('bug.template.steps') }}`,
        repro: `{{ t('bug.template.repro') }}`
      };
      d.value = t[type] || t.steps;
      
      // Highlight effect
      d.style.boxShadow = '0 0 15px color-mix(in srgb, var(--brand-primary) 50%, transparent)';
      setTimeout(()=> d.style.boxShadow = 'inset 0 3px 8px rgba(0,0,0,0.6)', 500);

      saveDraft();
    }

    const draftKey = 'bugops_v10_draft';
    function saveDraft(){
      const form = document.getElementById('bugForm'); if(!form) return;
      localStorage.setItem(draftKey, JSON.stringify(Object.fromEntries(new FormData(form).entries())));
    }
    function loadDraft(){
      try{
        const data = JSON.parse(localStorage.getItem(draftKey));
        if(data){
          for(const [k,v] of Object.entries(data)){ const el = document.getElementById('bugForm').querySelector(`[name="${k}"]`); if(el) el.value = v; }
          if(data.category){ document.querySelectorAll('#catTiles .v10-cat').forEach(x=>x.classList.toggle('active', x.getAttribute('data-cat') === data.category)); }
        }
      }catch(e){}
    }
    function clearDraft(){
      localStorage.removeItem(draftKey); document.getElementById('bugForm')?.reset();
      document.querySelectorAll('#catTiles .v10-cat').forEach(x=>x.classList.remove('active'));
    }
    document.getElementById('bugForm')?.addEventListener('input', debounce(saveDraft, 500));

    function fillPreview(){
      const data = Object.fromEntries(new FormData(document.getElementById('bugForm')).entries());
      document.getElementById('pvTitle').textContent = (data.title || '-');
      document.getElementById('pvDesc').innerHTML = renderMarkdownSafe(data.description || '-');
    }

    function validateRequired(showToast=true){
      const t = document.querySelector('#bugForm [name="title"]')?.value?.trim(), d = document.getElementById('descBox')?.value?.trim();
      const ok = !!(t && d);
      if(!ok && showToast) toast('err','{{ t('bug.toast.missing_data') }}','{{ t('bug.toast.fill_required') }}');
      return ok;
    }

    function getSysInfoText(){ return `RES: ${window.innerWidth}x${window.innerHeight}\nURL: ${location.pathname}\nUA: ${navigator.userAgent || ''}\nLANG: ${navigator.language || '-'}`; }

    async function postForm(url, bodyObj){
      const fd = new FormData();
      Object.entries(bodyObj || {}).forEach(([k,v]) => fd.append(k, v));
      const res = await fetch(url, { method:'POST', body: fd, credentials:'same-origin' });
      const ct = (res.headers.get('content-type') || '').toLowerCase();
      let data = null;
      if(ct.includes('application/json')) data = await res.json(); else throw new Error(`{{ t('bug.server_error') }} (${res.status}).`);
      if(!res.ok || (data && data.error)) throw new Error(data?.message || `{{ t('bug.request_denied') }}`);
      return data;
    }

    async function voteToggle(btn){
      const rid = btn?.getAttribute('data-report'); if(!rid) return;
      btn.disabled = true; const oldTxt = btn.querySelector('.txt')?.textContent || '';
      if(btn.querySelector('.txt')) btn.querySelector('.txt').textContent = '...';
      try{
        const data = await postForm(API_VOTE, { report_id: rid });
        document.querySelectorAll(`.voteCount[data-for="${rid}"]`).forEach(el => el.textContent = String(data.votes || 0));
        const item = document.querySelector(`.reportItem[data-id="${rid}"]`);
        if(item){ item.setAttribute('data-votes', String(data.votes || 0)); item.setAttribute('data-voted', data.voted ? '1' : '0'); }
        btn.classList.toggle('primary', !!data.voted);
        if(btn.querySelector('.txt')) btn.querySelector('.txt').textContent = data.voted ? '{{ t('bug.voted') }}' : '{{ t('bug.me_too') }}';
        toast('ok','{{ t('bug.toast.notice') }}', data.voted ? '{{ t('bug.toast.vote_added') }}' : '{{ t('bug.toast.vote_removed') }}');
        refreshCounts(); sortReports(activeSort);
      }catch(e){ toast('err','{{ t('bug.toast.denied') }}', e?.message || '{{ t('bug.toast.action_failed') }}'); if(btn.querySelector('.txt')) btn.querySelector('.txt').textContent = oldTxt; }
      finally{ btn.disabled = false; }
    }

    document.getElementById('bugForm')?.addEventListener('submit', async (e)=>{
      e.preventDefault();
      if(!validateRequired(true)){ goStep(2); return; }
      
      const submitBtn = document.getElementById('bugSubmitBtn');
      if(submitBtn){ submitBtn.disabled = true; submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> {{ t('bug.submit_loading') }}'; }
      try{
        const form = document.getElementById('bugForm'), desc = document.getElementById('descBox'), pr = form.querySelector('[name="priority"]')?.value || 'major';
        let originalDesc = desc.value;
        if(desc && !desc.value.includes('[PRIORITY:')) desc.value = `[PRIORITY:${pr}]\n` + desc.value;
        if(desc && !desc.value.includes('[CLIENT META]')) desc.value += `\n\n---\n[CLIENT META]\n${getSysInfoText()}`;
        
        const fd = new FormData(form); desc.value = originalDesc;
        
        const res = await fetch(API_CREATE, { method:'POST', body: fd, credentials:'same-origin' });
        const ct = (res.headers.get('content-type') || '').toLowerCase();
        let data = null;
        if(ct.includes('application/json')) data = await res.json(); else throw new Error(`{{ t('bug.server_error') }}.`);
        if(!res.ok || (data && data.error)) throw new Error(data?.message || `{{ t('bug.toast.action_failed') }}`);
        
        toast('ok','{{ t('bug.toast.success') }}', '{{ t('bug.toast.report_sent') }}');
        localStorage.removeItem(draftKey);
        setTimeout(()=> window.location.reload(), 1500);
      }catch(err){ toast('err','{{ t('bug.toast.error') }}', err?.message || '{{ t('bug.toast.generic_problem') }}'); }
      finally{ if(submitBtn){ submitBtn.disabled = false; submitBtn.innerHTML = '{{ t('bug.submit') }} <i class="fa-solid fa-paper-plane ml-1 opacity-80"></i>'; } }
    });

    // -------- Admin Reply --------
    async function submitReply(e, form){
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      const oldHtml = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> {{ t('bug.admin.loading') }}';

      try {
        const fd = new FormData(form);
        const res = await fetch(BASE_URL + '/ajax/bugs/reply', { method:'POST', body: fd, credentials:'same-origin' });
        const ct = (res.headers.get('content-type') || '').toLowerCase();
        let data = null;
        if(ct.includes('application/json')) data = await res.json();
        else throw new Error(`{{ t('bug.invalid_response') }}`);

        if(!res.ok || (data && data.error)) throw new Error(data?.message || `{{ t('bug.request_denied') }}`);
        
        toast('ok', '{{ t('bug.admin.success') }}', data.message || '{{ t('bug.admin.updated') }}');
        setTimeout(() => window.location.reload(), 1000);
      } catch(err) {
        toast('err', '{{ t('bug.toast.denied') }}', err?.message || '{{ t('bug.toast.error') }}');
        btn.disabled = false;
        btn.innerHTML = oldHtml;
      }
    }

    // Init
    renderAllMarkdown(); refreshCounts(); sortReports(activeSort); applyFilters();
    return { openDrawer, closeDrawer, drawerBackdrop, goStep, toggleReport, copyText, pickCat, injectTemplate, clearDraft, voteToggle, submitReply };
  })();
</script>
{% endblock %}
