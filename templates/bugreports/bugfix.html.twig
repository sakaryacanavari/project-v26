{% extends isAjax ? "common/ajaxbase.html.twig" : "common/base.html.twig" %}

{% block content %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
  /* =============================
     BUG OPS v26.200 â€” PROJECT-NEXUS HUD
     ============================= */
  :root {
    --bug-accent: var(--brand-primary);
    --bug-accent-text: color-mix(in srgb, var(--brand-primary) 85%, #ffffff);
    --bug-accent-soft: color-mix(in srgb, var(--brand-primary) 12%, transparent);
    --bug-accent-border: color-mix(in srgb, var(--brand-primary) 25%, transparent);
    --bug-accent-glow: color-mix(in srgb, var(--brand-primary) 40%, transparent);
  }

  /* --- Core Layout & Glass Panel --- */
  .home-theme-surface .glass-panel {
      background: linear-gradient(145deg, rgba(6, 9, 17, 0.65) 0%, rgba(2, 4, 10, 0.9) 100%) !important;
      backdrop-filter: blur(32px);
      border: 1px solid rgba(255, 255, 255, 0.05) !important;
      box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.08), 0 20px 40px -10px rgba(0, 0, 0, 0.8);
      border-radius: 16px;
  }

  /* --- Animations --- */
  @keyframes v10-slide-up { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes v10-accIn { 0% { opacity: 0; transform: translateY(-5px); } 100% { opacity: 1; transform: translateY(0); } }

  /* Smooth Scrollbar */
  .no-scrollbar::-webkit-scrollbar { display:none; }
  .no-scrollbar { -ms-overflow-style:none; scrollbar-width:none; }
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); border-radius: 10px; }
  ::-webkit-scrollbar-thumb { background: var(--bug-accent-border); border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--bug-accent); }

  /* --- Inputs & Selects --- */
  .v10-input-wrap { position: relative; width: 100%; }
  .v10-input-wrap i.icon-left { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 12px; pointer-events: none; }
  .v10-input-wrap i.icon-right { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); font-size: 10px; pointer-events: none; }
  
  .v10-input {
    width: 100%; background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.05);
    color: #f8fafc; padding: 12px 14px; border-radius: 12px; font-size: 12px; font-weight: 600;
    transition: all 0.3s ease; outline: none;
    box-shadow: inset 0 2px 8px rgba(0,0,0,0.5);
  }
  .v10-input.has-icon-left { padding-left: 36px; }
  .v10-input:focus {
    border-color: color-mix(in srgb, var(--brand-primary) 50%, transparent);
    background: rgba(0,0,0,0.6);
    box-shadow: inset 0 2px 8px rgba(0,0,0,0.6), 0 0 0 2px color-mix(in srgb, var(--brand-primary) 15%, transparent);
  }
  .v10-input::placeholder { color: #64748b; opacity: 0.6; font-weight: 500; }
  select.v10-input { cursor: pointer; appearance: none; }
  select.v10-input option { background: #0f172a; color: #fff; }

  /* --- Accordion --- */
  .v10-acc { max-height: 0; opacity: 0; overflow: hidden; transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease; }
  .v10-acc.open { max-height: 2500px; opacity: 1; margin-top: 12px; animation: v10-accIn 0.4s ease both; }

  /* --- Drawer (Right Side Panel) --- */
  .v10-drawer-wrap { position:fixed; inset:0; z-index:10000; display:none; background: rgba(2,4,8,0.8); backdrop-filter: blur(12px); opacity: 0; transition: opacity .3s ease; }
  .v10-drawer-wrap.open { display:block; opacity: 1; }
  .v10-drawer { position:absolute; right:0; top:0; height:100%; width:min(650px, 95vw); background: linear-gradient(165deg, rgba(8, 12, 22, 0.95) 0%, rgba(2, 4, 10, 1) 100%); border-left: 1px solid rgba(255,255,255,0.05); box-shadow: -20px 0 50px rgba(0,0,0,0.9); transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1); display:flex; flex-direction:column; }
  .v10-drawer-wrap.open .v10-drawer { transform: translateX(0); }

  /* --- Wizard Panel Steps --- */
  .v10-panel { display: none; opacity: 0; }
  .v10-panel.show { display: block; animation: v10-slide-up 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
  
  .v10-step { display:inline-flex; align-items:center; gap:6px; padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,.03); background: rgba(0,0,0,.3); color: rgba(226,232,240,.5); font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; transition: all 0.3s; box-shadow: inset 0 2px 5px rgba(0,0,0,0.5); }
  .v10-step .dot { width:6px; height:6px; border-radius:50%; background: rgba(255,255,255,.2); transition: all 0.3s; }
  .v10-step.active { border-color: color-mix(in srgb, var(--brand-primary) 30%, transparent); background: color-mix(in srgb, var(--brand-primary) 10%, transparent); color: #fff; box-shadow: inset 0 2px 5px rgba(0,0,0,0.2); }
  .v10-step.active .dot { background: var(--brand-primary); transform: scale(1.2); box-shadow: 0 0 8px var(--brand-glow); }
  .v10-step.done { border-color: rgba(16, 185, 129,.3); color: rgba(16, 185, 129,.9); }
  .v10-step.done .dot { background: rgba(16, 185, 129, 0.9); }

  /* --- Category Tiles --- */
  .v10-cat { border:1px solid rgba(255,255,255,.03); background: rgba(0,0,0,.4); transition: all .3s cubic-bezier(0.2, 0.8, 0.2, 1); border-radius: 14px; cursor: pointer; position: relative; overflow: hidden; box-shadow: inset 0 2px 8px rgba(0,0,0,0.5); }
  .v10-cat::before { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, color-mix(in srgb, var(--brand-primary) 5%, transparent), transparent); opacity: 0; transition: opacity 0.3s; pointer-events: none; }
  .v10-cat:hover { transform: translateY(-2px); border-color: color-mix(in srgb, var(--brand-primary) 30%, transparent); box-shadow: 0 8px 15px rgba(0,0,0,.6); }
  .v10-cat:hover::before { opacity: 1; }
  .v10-cat.active { border-color: var(--brand-primary); box-shadow: inset 0 0 15px color-mix(in srgb, var(--brand-primary) 10%, transparent), 0 8px 15px rgba(0,0,0,.6); transform: scale(1.02); background: color-mix(in srgb, var(--brand-primary) 5%, rgba(0,0,0,0.6)); }
  .v10-cat.active::before { opacity: 1; background: linear-gradient(to top, color-mix(in srgb, var(--brand-primary) 15%, transparent), transparent); }

  /* --- Buttons --- */
  .v10-btn { display:inline-flex; align-items:center; justify-content:center; gap:8px; padding: 12px 20px; border-radius: 12px; border: none; background: rgba(255,255,255,.05); color: #cbd5e1; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; transition: all .3s cubic-bezier(0.2, 0.8, 0.2, 1); cursor: pointer; box-shadow: 0 4px 10px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05); }
  .v10-btn:hover { background: rgba(255,255,255,.08); color: #fff; transform: translateY(-1px); box-shadow: 0 6px 15px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1); }
  .v10-btn:active { transform: translateY(1px); box-shadow: 0 2px 5px rgba(0,0,0,0.4); }
  
  .v10-btn.primary { background: linear-gradient(135deg, color-mix(in srgb, var(--brand-primary) 80%, white), var(--brand-primary)); color: #0c0a09; box-shadow: 0 4px 15px color-mix(in srgb, var(--brand-primary) 20%, transparent), inset 0 1px 0 color-mix(in srgb, var(--brand-primary) 30%, rgba(255,255,255,0.2)); }
  .v10-btn.primary:hover { transform: translateY(-2px); box-shadow: 0 8px 25px color-mix(in srgb, var(--brand-primary) 30%, transparent), inset 0 1px 0 color-mix(in srgb, var(--brand-primary) 40%, rgba(255,255,255,0.3)); filter: brightness(1.05); color: #0c0a09; }
  .v10-btn.primary:active { transform: translateY(0); box-shadow: 0 2px 8px color-mix(in srgb, var(--brand-primary) 10%, transparent); }

  .bug-theme-text { color: var(--bug-accent-text); }
  .bug-theme-chip {
    background: color-mix(in srgb, var(--bug-accent) 15%, transparent);
    border-color: var(--bug-accent-border);
    color: var(--bug-accent-text);
  }

  /* --- Utilities --- */
  .v10-dot { width:8px; height:8px; border-radius:50%; display:inline-block; }
  .v10-dot.red { background: rgba(239, 68, 68, 1); box-shadow: 0 0 8px rgba(239, 68, 68, .6); }
  .v10-dot.amb { background: rgba(245, 158, 11, 1); box-shadow: 0 0 8px rgba(245, 158, 11, .6); }
  .v10-dot.gre { background: rgba(16, 185, 129, 1); box-shadow: 0 0 8px rgba(16, 185, 129, .6); }
  .v10-dot.sla { background: rgba(148, 163, 184, 1); }

  /* Modern Tabs */
  .v10-tabs { display:flex; gap:8px; }
  .v10-tab { padding: 10px 16px; border-radius: 10px; color: rgba(226,232,240,.6); font-size: 11px; font-weight: 800; cursor:pointer; transition: all .3s; display:inline-flex; align-items:center; gap:8px; text-transform: uppercase; border: 1px solid transparent; background: rgba(0,0,0,0.3); box-shadow: inset 0 2px 5px rgba(0,0,0,0.5); }
  .v10-tab:hover { background: rgba(255,255,255,.03); color: #fff; border-color: rgba(255,255,255,0.05); }
  .v10-tab.active { background: color-mix(in srgb, var(--brand-primary) 15%, transparent); color: #fff; border-color: color-mix(in srgb, var(--brand-primary) 30%, transparent); box-shadow: inset 0 0 10px color-mix(in srgb, var(--brand-primary) 10%, transparent); }

  /* Markdown & Blocks */
  .v10-md { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 13px; color: rgba(226,232,240,.9); line-height: 1.6; }
  .v10-md strong { color: #fff; font-weight: 800; }
  .v10-md code { padding: 3px 6px; border-radius: 6px; background: rgba(255,255,255,.08); color: var(--brand-primary); font-size: 12px; }
  .v10-md pre { padding: 16px; border-radius: 12px; background: rgba(0,0,0,.5); overflow:auto; margin: 12px 0; border: 1px solid rgba(255,255,255,0.05); box-shadow: inset 0 2px 10px rgba(0,0,0,0.8); }
  .v10-md hr { border: none; border-top: 1px dashed rgba(255,255,255,.1); margin: 20px 0; }

  /* SweetAlert V26 */
  .cyber-modal-popup { background: rgba(8, 10, 14, 0.98) !important; backdrop-filter: blur(32px); border: 1px solid rgba(255, 255, 255, 0.03) !important; border-radius: 20px !important; padding: 2rem 1.5rem !important; box-shadow: 0 30px 60px -15px rgba(0,0,0,0.95) !important; }
  .cyber-modal-title { color: #f8fafc !important; text-transform: uppercase !important; letter-spacing: 0.15em !important; font-weight: 900 !important; font-size: 14px !important; border-bottom: 1px solid rgba(255,255,255,0.02); padding-bottom: 14px !important; margin-bottom: 18px !important; display: flex; align-items: center; justify-content: center; gap: 8px; }
  .cyber-modal-content { color: #94a3b8 !important; font-size: 12px !important; font-weight: 600 !important; line-height: 1.6 !important; }
  .cyber-confirm-btn { background: var(--brand-primary) !important; color: #0c0a09 !important; font-weight: 900 !important; text-transform: uppercase !important; letter-spacing: 0.08em !important; border-radius: 10px !important; padding: 12px 24px !important; font-size: 11px !important; border: none !important; transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1) !important; }
  .cyber-confirm-btn:hover { transform: translateY(-1px) !important; filter: brightness(1.1); }
</style>

<div class="home-theme-surface space-y-5 animate-fade-in w-full overflow-hidden" id="bug-report-center-v10">

  {# ===== HERO TERTEMÄ°Z BAÅLIK ===== #}
  <div class="glass-panel p-6 md:p-8">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 relative z-10">
      
      <div class="flex items-center gap-5">
        <div class="w-14 h-14 rounded-[14px] bg-[color:var(--brand-primary)]/15 flex items-center justify-center shadow-[inset_0_2px_8px_rgba(0,0,0,0.6)]">
          <i class="fa-solid fa-satellite-dish text-2xl text-[color:var(--brand-primary)] drop-shadow-sm"></i>
        </div>
        <div>
          <h1 class="text-xl md:text-2xl font-black text-white tracking-wide drop-shadow-md uppercase">
            {{ t('bug.title') }}
          </h1>
          <p class="text-[11px] text-slate-400 mt-2 font-bold uppercase tracking-widest opacity-80">
            {{ t('bug.subtitle') }}
          </p>
        </div>
      </div>

      <button class="w-full md:w-auto v10-btn primary px-8 py-3.5 text-[11px]" type="button" onclick="BugOpsV10.openDrawer()">
        <i class="fa-solid fa-plus text-sm opacity-80"></i> {{ t('bug.new_report') }}
      </button>
    </div>
  </div>

  {# ===== STATUS BAR + SEARCH + SORT ===== #}
  <div class="glass-panel p-5">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-5 w-full">
      
      <div class="v10-tabs w-full lg:w-auto overflow-x-auto no-scrollbar">
        <div class="v10-tab active" data-filter="all">{{ t('bug.filter.all') }}</div>
        <div class="v10-tab" data-filter="0"><span class="v10-dot red"></span> {{ t('bug.filter.open') }} <span class="opacity-50 text-[10px] ml-1" id="cnt0">0</span></div>
        <div class="v10-tab" data-filter="1"><span class="v10-dot amb"></span> {{ t('bug.filter.reviewing') }} <span class="opacity-50 text-[10px] ml-1" id="cnt1">0</span></div>
        <div class="v10-tab" data-filter="2"><span class="v10-dot gre"></span> {{ t('bug.filter.resolved') }} <span class="opacity-50 text-[10px] ml-1" id="cnt2">0</span></div>
        <div class="v10-tab" data-filter="3"><span class="v10-dot sla"></span> {{ t('bug.filter.rejected') }} <span class="opacity-50 text-[10px] ml-1" id="cnt3">0</span></div>
      </div>

      <div class="flex flex-col sm:flex-row w-full lg:w-auto gap-4 items-center">
        <div class="v10-input-wrap lg:w-[280px]">
          <i class="fa-solid fa-magnifying-glass icon-left opacity-60" style="color: var(--brand-primary);"></i>
          <input id="searchBox" type="text" placeholder="{{ t('bug.search_placeholder') }}" class="v10-input has-icon-left">
        </div>

        <div class="v10-input-wrap lg:w-[220px] group">
          <i class="fa-solid fa-sort icon-left opacity-60 transition-transform group-hover:scale-110" style="color: var(--brand-primary);"></i>
          <select id="sortSelect" class="v10-input has-icon-left" aria-label="{{ t('bug.sort') }}">
            <option value="newest" selected>{{ t('bug.sort.newest') }}</option>
            <option value="oldest">{{ t('bug.sort.oldest') }}</option>
            <option value="prio_critical">{{ t('bug.sort.critical') }}</option>
            <option value="votes">{{ t('bug.sort.votes') }}</option>
          </select>
          <i class="fa-solid fa-chevron-down icon-right text-slate-500 opacity-60"></i>
        </div>
      </div>
    </div>
  </div>

  {# ===== REPORT LIST ===== #}
  <div class="space-y-5" id="reportList">
    {% set statusLabel = {0:t('bug.status.open'), 1:t('bug.status.reviewing'), 2:t('bug.status.resolved'), 3:t('bug.status.rejected')} %}

    {% for r in reports %}
      {% set leftBorder = '' %}
      {% set badgeCls = 'bug-theme-chip border' %}
      {% set icon = 'fa-bug bug-theme-text' %}

      {% if r.status == 0 %}
        {% set leftBorder = 'border-red-500/80' %}
        {% set badgeCls = 'bg-red-900/30 text-red-400 border border-red-500/40 shadow-inner' %}
        {% set icon = 'fa-triangle-exclamation text-red-400 opacity-80' %}
      {% elseif r.status == 1 %}
        {% set leftBorder = 'border-amber-500/80' %}
        {% set badgeCls = 'bg-amber-900/30 text-amber-400 border border-amber-500/40 shadow-inner' %}
        {% set icon = 'fa-spinner fa-spin-pulse text-amber-400 opacity-80' %}
      {% elseif r.status == 2 %}
        {% set leftBorder = 'border-emerald-500/80' %}
        {% set badgeCls = 'bg-emerald-900/30 text-emerald-400 border border-emerald-500/40 shadow-inner' %}
        {% set icon = 'fa-check-double text-emerald-400 opacity-80' %}
      {% elseif r.status == 3 %}
        {% set leftBorder = 'border-slate-500/80' %}
        {% set badgeCls = 'bg-slate-800/50 text-slate-300 border border-slate-600 shadow-inner' %}
        {% set icon = 'fa-ban text-slate-400 opacity-80' %}
      {% endif %}

      {% set pr = r.priority ?? 'major' %}
      {% if '[PRIORITY:critical]' in (r.description ?? '') %}{% set pr = 'critical' %}{% endif %}
      {% if '[PRIORITY:minor]' in (r.description ?? '') %}{% set pr = 'minor' %}{% endif %}

      {% set prCls = 'text-amber-400 bg-amber-900/20 border border-amber-500/30 shadow-[inset_0_1px_2px_rgba(0,0,0,0.5)]' %}
      {% if pr == 'critical' %}{% set prCls = 'text-red-400 bg-red-900/20 border border-red-500/30 shadow-[inset_0_1px_2px_rgba(0,0,0,0.5)]' %}{% endif %}
      {% if pr == 'minor' %}{% set prCls = 'text-slate-300 bg-slate-800/40 border border-slate-600/50 shadow-[inset_0_1px_2px_rgba(0,0,0,0.5)]' %}{% endif %}

      {% set votesCount = r.votes_count ?? 0 %}
      {% set isVoted = r.is_voted ?? false %}

      <div class="reportItem glass-panel border-l-[3px] {{ leftBorder }} p-6"
           data-status="{{ r.status }}"
           data-q="{{ (r.title ~ ' ' ~ r.category ~ ' ' ~ (r.error_code ?? '') ~ ' #' ~ r.id)|lower }}"
           data-id="{{ r.id }}"
           data-votes="{{ votesCount }}"
           data-voted="{{ isVoted ? 1 : 0 }}"
           data-pr="{{ pr }}"
           data-created="{{ r.created_at ?? '' }}">

        <div class="flex flex-col md:flex-row md:items-start justify-between gap-5">
          <div class="flex items-start gap-5 min-w-0 w-full">
            <div class="w-14 h-14 rounded-[14px] bg-black/60 border border-white/5 flex items-center justify-center shrink-0 shadow-[inset_0_2px_5px_rgba(0,0,0,0.6)]">
              <i class="fa-solid {{ icon }} text-2xl drop-shadow-sm"></i>
            </div>

            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2.5 mb-2 flex-wrap">
                <span class="text-[10px] text-slate-400 font-black tracking-widest bg-black/50 px-2.5 py-1 rounded-md border border-white/5 shadow-inner">#{{ r.id }}</span>
                <span class="text-[color:var(--brand-primary)] bg-[color:var(--brand-primary)]/10 border border-[color:var(--brand-primary)]/20 text-[10px] font-black tracking-widest uppercase px-2.5 py-1 rounded-md shadow-inner">{{ r.category|e }}</span>
                
                {% if r.error_code %}
                  <span class="text-[color:var(--brand-primary)] bg-[color:var(--brand-primary)]/10 border border-[color:var(--brand-primary)]/20 text-[10px] font-black tracking-wider px-2.5 py-1 rounded-md shadow-inner">{{ t('bug.code') }}: {{ r.error_code|e }}</span>
                {% endif %}

                <span class="text-[9px] font-black tracking-widest uppercase px-2.5 py-1 rounded-md {{ prCls }}">
                  {{ t('bug.priority') }}: {{ pr|upper }}
                </span>

                <span class="text-[color:var(--brand-primary)] bg-[color:var(--brand-primary)]/10 border border-[color:var(--brand-primary)]/20 text-[10px] font-black px-2.5 py-1 rounded-md flex items-center gap-1.5 shadow-inner">
                  <i class="fa-solid fa-arrow-up text-[9px] opacity-70"></i> <span class="voteCount" data-for="{{ r.id }}">{{ votesCount }}</span>
                </span>
              </div>

              <h3 class="text-[16px] font-black text-white pr-2 mt-1 truncate drop-shadow-sm">{{ r.title|e }}</h3>
              <p class="text-[10px] text-slate-500 font-bold tracking-widest uppercase mt-1.5"><i class="fa-regular fa-clock mr-1 opacity-50"></i> {{ r.created_at ?? t('bug.unknown') }}</p>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row items-center gap-3 shrink-0">
            <span class="px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest {{ badgeCls }}">
              {{ statusLabel[r.status] ?? t('bug.unknown') }}
            </span>

            <button class="v10-btn px-4 py-2" type="button" data-openbtn="{{ r.id }}" onclick="BugOpsV10.toggleReport('rep{{ r.id }}', this)">
              <i class="fa-solid fa-chevron-down text-xs opacity-70"></i> <span class="txt hidden sm:inline">{{ t('bug.inspect') }}</span>
            </button>
          </div>
        </div>

        <div id="rep{{ r.id }}" class="v10-acc">
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 pt-6 mt-4 border-t border-white/5">
            <div class="lg:col-span-2 space-y-5">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <div class="text-[11px] font-black text-white uppercase tracking-[0.2em] flex items-center gap-2 drop-shadow-sm">
                  <i class="fa-solid fa-align-left text-[color:var(--brand-primary)] opacity-80"></i> {{ t('bug.report_content') }}
                </div>
                
                <button class="v10-btn vote {{ isVoted ? 'primary' : '' }} px-5 py-2.5" type="button" data-report="{{ r.id }}" onclick="BugOpsV10.voteToggle(this)">
                  <i class="fa-solid fa-arrow-up opacity-80 text-xs"></i>
                  <span class="txt">{{ isVoted ? t('bug.voted') : t('bug.me_too') }}</span>
                </button>
              </div>

              <div class="v10-md bg-black/40 border border-white/5 rounded-2xl p-6 shadow-[inset_0_2px_10px_rgba(0,0,0,0.6)]" data-md="1">
                {{ r.description|default('')|e }}
              </div>

              {% if r.image_url %}
                <div class="mt-3">
                  <a href="{{ r.image_url|e }}" target="_blank" class="v10-btn px-5 py-2.5">
                    <i class="fa-solid fa-image text-[color:var(--brand-primary)] opacity-80"></i> {{ t('bug.open_attachment') }} <i class="fa-solid fa-arrow-up-right-from-square ml-1 opacity-40 text-[10px]"></i>
                  </a>
                </div>
              {% endif %}
            </div>

            <div>
              <div class="text-[11px] font-black text-white uppercase tracking-[0.2em] mb-4 flex items-center gap-2 drop-shadow-sm">
                <i class="fa-solid fa-user-shield text-[color:var(--brand-primary)] opacity-80"></i> {{ t('bug.admin_actions') }}
              </div>
              
              {% if r.replies is empty %}
