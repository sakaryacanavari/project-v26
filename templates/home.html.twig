    function renderRepliesHtml(shout) {
        var count = parseInt(shout.reply_count || 0, 10);
        var parentId = parseInt(shout.id || 0, 10);
        var isVisible = !!replyVisibility[parentId];
        var isExpanded = !!replyExpanded[parentId];
        var replies = Array.isArray(shout.replies) ? shout.replies : [];
        var visibleReplies = visibleRepliesFor(shout);
        var hiddenCount = Math.max(0, count - visibleReplies.length);
        var likedClass = shout.liked_by_me ? ' is-active' : '';

        var likeIconClass = shout.liked_by_me ? 'fa-solid fa-heart' : 'fa-regular fa-heart';
        var actions = '' +
            '<div class="reply-meta-actions">' +
                '<button type="button" class="reply-meta-btn like-meta-btn' + likedClass + '" data-action="like-shout" data-shout-id="' + parentId + '" title="' + homeI18n.shoutLike + '" aria-label="' + homeI18n.shoutLike + '">' +
                    '<i class="' + likeIconClass + '"></i><span class="count">' + parseInt(shout.likes_count || 0, 10) + '</span>' +
                '</button>' +
                '<button type="button" class="reply-meta-btn' + (isVisible ? ' is-active' : '') + '" data-action="toggle-replies" data-shout-id="' + parentId + '" title="' + replyToggleLabel(shout) + '" aria-label="' + replyToggleLabel(shout) + '">' +
                    '<i class="fa-regular fa-comment"></i><span class="count">' + count + '</span>' +
                '</button>' +
                '<button type="button" class="reply-meta-btn' + (replyComposerParentId === parentId ? ' is-active' : '') + '" data-action="reply-shout" data-shout-id="' + parentId + '" title="' + homeI18n.shoutReply + '" aria-label="' + homeI18n.shoutReply + '">' +
                    '<i class="fa-solid fa-reply"></i>' +
                '</button>' +
                (isVisible ? '<button type="button" class="reply-meta-btn" data-action="toggle-replies" data-shout-id="' + parentId + '" title="' + homeI18n.shoutReplyToggleClose + '" aria-label="' + homeI18n.shoutReplyToggleClose + '"><i class="fa-solid fa-chevron-up"></i></button>' : '') +
            '</div>';

        if (!isVisible && replyComposerParentId !== parentId) {
            return actions;
        }

        var body = '';
        if (count < 1) {
            body = '<div class="mt-3 text-[11px] font-medium text-slate-500">' + homeI18n.shoutReplyEmpty + '</div>';
        } else {
            body = visibleReplies.map(renderReplyItemHtml).join('');
            if (hiddenCount > 0) {
                body += '<button type="button" class="shout-action mt-3 px-3 py-1.5 text-[9px] font-black uppercase tracking-[0.1em]" data-action="expand-replies" data-shout-id="' + parentId + '"><span class="label">' + homeI18n.shoutReplyMore + ' (' + hiddenCount + ')</span></button>';
            } else if (count > parseInt(shout.reply_preview_limit || 3, 10) && isExpanded) {
                body += '<button type="button" class="shout-action mt-3 px-3 py-1.5 text-[9px] font-black uppercase tracking-[0.1em]" data-action="collapse-replies" data-shout-id="' + parentId + '"><span class="label">' + homeI18n.shoutReplyLess + '</span></button>';
            }
        }

        return actions +
            '<div class="reply-thread">' +
                body +
                renderReplyComposerHtml(shout) +
            '</div>';
    }

    function fetchShoutFeed(mode, page, append, options) {
        mode = mode || 'latest';
        page = Math.max(1, parseInt(page || 1, 10));
        var offset = Math.max(0, (page - 1) * Math.max(1, shoutPageSize || 8));
        options = options || {};
        append = false;
        var delayMs = parseInt(options.delayMs || 180, 10);
        var minLoadMs = parseInt(options.minLoadMs || 260, 10);
        var preserveScrollY = typeof options.preserveScrollY === 'number' ? options.preserveScrollY : null;
        var viewportAnchor = options.viewportAnchor || captureShoutViewport();
        var requestId = ++shoutFeedRequestId;
        var startedAt = Date.now();

        shoutFeedLoading = true;
        setShoutTabsDisabled(true);
        renderShoutLoadingState();

        if (shoutFeedTimer) clearTimeout(shoutFeedTimer);

        shoutFeedTimer = setTimeout(function () {
            $.ajax({
                url: baseUrl + '/api/shouts/list',
                method: 'POST',
                dataType: 'text',
                data: {
                    mode: mode,
                    page: page,
                    offset: offset,
                    csrf_token: csrfToken
                }
            }).done(function (res) {
                var payload = extractPayload(res) || {};
                var finalize = function () {
                    if (requestId !== shoutFeedRequestId) return;
                    shoutFeedLoading = false;
                    setShoutTabsDisabled(false);
                    if (payload.error === true || payload.error === 1) {
                        clearShoutLoadingState();
                        setShoutFeedback(payload.message || homeI18n.shoutFeedLoadError, true);
                        return;
                    }
                    applyShoutFeed(payload.feed || {}, false);
                    renderShouts();
                    clearShoutLoadingState();
                    if (presidentMessageShoutId > 0) {
                        var presidentItem = findShoutById(presidentMessageShoutId);
                        if (presidentItem) updatePresidentMessageCard(presidentItem);
                    }
                    flushPendingThreadTarget();
                    if (!append && preserveScrollY !== null) {
                        window.requestAnimationFrame(function () {
                            window.scrollTo({ top: preserveScrollY, behavior: 'auto' });
                            restoreShoutViewport(viewportAnchor);
                        });
                    } else {
                        restoreShoutViewport(viewportAnchor);
                    }
                };
                var elapsed = Date.now() - startedAt;
                setTimeout(finalize, Math.max(0, minLoadMs - elapsed));
            }).fail(function (xhr) {
                if (requestId !== shoutFeedRequestId) return;
                shoutFeedLoading = false;
                setShoutTabsDisabled(false);
                clearShoutLoadingState();
                if (window.console && xhr && xhr.responseText) {
                    console.warn('Shout feed request failed:', xhr.status, xhr.responseText);
                }
                setShoutFeedback(homeI18n.shoutFeedLoadError, true);
            });
        }, Math.max(0, delayMs));
    }

    function renderShouts() {
        if (!shoutFeedRoot) return;

        if (!Array.isArray(shoutItems) || !shoutItems.length) {
            shoutFeedRoot.innerHTML = '<div class="shout-empty-state px-4 py-12 text-center text-[12px] font-bold text-slate-500"><i class="fa-regular fa-comment-dots text-2xl block mb-3 opacity-30"></i>' + homeI18n.shoutEmpty + '</div>';
            updateShoutPagination();
            renderBlackoutBanner();
            return;
        }

        shoutFeedRoot.innerHTML = shoutItems.map(function (shout) {
            var canDelete = parseInt(shout.uid || 0, 10) === parseInt(currentUserId || 0, 10) || isAdminUser;
            var likedClass = shout.liked_by_me ? ' is-active' : '';
            var reportedClass = shout.reported_by_me ? ' is-active' : '';
            var reportedDisabled = shout.reported_by_me ? ' disabled' : '';
            var canEdit = !!shout.can_edit && parseInt(shout.uid || 0, 10) === parseInt(currentUserId || 0, 10);
            
            var displayBody = shout.display_body_html || escapeHtml(shout.display_body || shout.body || '');
            var revealButton = (shout.reputation && shout.reputation.is_blurred && !revealedBlurredShouts[parseInt(shout.id || 0, 10)])
                ? '<button type="button" class="shout-action mt-3 px-4 py-2 text-[9px] font-black uppercase tracking-[0.1em]" data-action="reveal-shout" data-shout-id="' + parseInt(shout.id || 0, 10) + '"><i class="fa-solid fa-eye mr-1.5 opacity-70"></i><span class="label">' + homeI18n.shoutRead + '</span></button>'
                : '';

            var newClass = parseInt(shout.id || 0, 10) === highlightedShoutId ? ' border-[color:var(--brand-primary)]/50 border-l-[color:var(--brand-primary)] shadow-[0_0_15px_color-mix(in_srgb,var(--brand-primary)_20%,transparent)] bg-[color:var(--brand-primary)]/5' : '';

            return '' +
                '<article id="shout-' + parseInt(shout.id || 0, 10) + '" class="shout-card' + newClass + '" data-shout-id="' + parseInt(shout.id || 0, 10) + '">' +
                    '<div class="relative flex items-start gap-3">' +
                        '<div class="shout-avatar h-10 w-10 shrink-0 overflow-hidden">' +
                            '<img src="' + shoutAvatar(shout) + '" onerror="this.src=\'' + defaultAvatar + '\'" class="h-full w-full object-cover" alt="avatar" loading="lazy" decoding="async">' +
                        '</div>' +
                        '<div class="min-w-0 flex-1">' +
                            '<div class="flex flex-wrap items-start justify-between gap-2.5">' +
                                '<div class="min-w-0">' +
                                    '<div class="shout-author-name text-[14px] font-black text-white">' + escapeHtml(shout.nick || '{{ t('base.sidebar.citizen')|e('js') }}') + '</div>' +
                                    '<div class="shout-badges">' + countryBadgeHtml(shout) + partyBadgeHtml(shout) + roleBadgeHtml(shout) + reputationBadgeHtml(shout) + decreeBadgeHtml(shout) + '</div>' +
                                    '<div class="mt-1 text-[9px] font-black text-slate-500 uppercase tracking-widest"><i class="fa-regular fa-clock mr-1 opacity-50"></i>' + formatShoutDate(shout) + '</div>' +
                                '</div>' +
                                '<div class="shout-card-actions flex flex-wrap items-center justify-end gap-1">' +
                                    renderTipHtml(shout) +
                                    '<button type="button" class="shout-action report-action px-2 py-1 text-[10px]' + reportedClass + '" data-action="report-shout" data-shout-id="' + parseInt(shout.id || 0, 10) + '"' + reportedDisabled + ' title="' + homeI18n.shoutReportSubmit + '" aria-label="' + homeI18n.shoutReportSubmit + '"><i class="fa-solid fa-flag"></i></button>' +
                                    (canEdit ? '<button type="button" class="shout-action px-2 py-1 text-[10px]" data-action="edit-shout" data-shout-id="' + parseInt(shout.id || 0, 10) + '" title="' + homeI18n.shoutEdit + '" aria-label="' + homeI18n.shoutEdit + '"><i class="fa-solid fa-pen"></i></button>' : '') +
                                    (canDelete ? '<button type="button" class="shout-action px-2 py-1 text-[10px] hover:text-red-400 hover:border-red-500/50" data-action="delete-shout" data-shout-id="' + parseInt(shout.id || 0, 10) + '" title="' + homeI18n.shoutDelete + '" aria-label="' + homeI18n.shoutDelete + '"><i class="fa-solid fa-trash-can"></i></button>' : '') +
                                '</div>' +
                            '</div>' +
                            '<div class="shout-body-text text-[13px] font-medium text-slate-200 break-words drop-shadow-sm">' + displayBody + '</div>' +
                            revealButton +
                            renderReportSummaryHtml(shout) +
                            renderMediaCardHtml(shout) +
                            renderPollHtml(shout) +
                            (shout.edited_at ? '<div class="mt-2.5 text-[9px] font-bold text-slate-600"><i class="fa-solid fa-pen-to-square mr-1.5 opacity-50"></i>' + homeI18n.shoutEdited + '</div>' : '') +
                            renderTipFooterHtml(shout) +
                            renderRepliesHtml(shout) +
                        '</div>' +
                    '</div>' +
                '</article>';
        }).join('');

        if (highlightedShoutId) {
            setTimeout(function () {
                var node = shoutFeedRoot.querySelector('[data-shout-id="' + highlightedShoutId + '"]');
                if (node) node.classList.remove('border-[color:var(--brand-primary)]/50', 'border-l-[color:var(--brand-primary)]', 'shadow-[0_0_15px_color-mix(in_srgb,var(--brand-primary)_20%,transparent)]', 'bg-[color:var(--brand-primary)]/5');
                highlightedShoutId = 0;
            }, 1000);
        }

        updateShoutPagination();
        renderBlackoutBanner();
        if (presidentMessageShoutId > 0) {
            var presidentItem = findShoutById(presidentMessageShoutId);
            if (presidentItem) updatePresidentMessageCard(presidentItem);
        }
        renderPresidentThread();
        window.requestAnimationFrame(rememberStableShoutAnchor);
    }

    function updateShoutCounter() {
        if (!shoutCounter || !shoutBody) return;
        var length = String(shoutBody.value || '').length;
        shoutCounter.textContent = String(length) + ' / 240';
        if (length >= 220) {
            shoutCounter.classList.add('text-rose-400', 'border-rose-400/30');
            shoutCounter.classList.remove('text-slate-500');
        } else {
            shoutCounter.classList.remove('text-rose-400', 'border-rose-400/30');
            shoutCounter.classList.add('text-slate-500');
        }
    }

    if (tabsRoot && bodyRoot) {
        tabsRoot.querySelectorAll('[data-news-target]').forEach(function (button) {
            button.addEventListener('click', function () {
                var target = button.getAttribute('data-news-target') || 'all';
                newsCurrentTarget = target;
                newsVisibleCount = 5;
                tabsRoot.querySelectorAll('[data-news-target]').forEach(function (item) { item.classList.remove('is-active'); });
                button.classList.add('is-active');
                renderFeed(target);
            });
        });
        if (newsMoreButton) {
            newsMoreButton.addEventListener('click', function () {
                newsVisibleCount += 5;
                renderFeed(newsCurrentTarget);
            });
        }
        bodyRoot.addEventListener('click', function (event) {
            var shareButton = event.target.closest('[data-news-share]');
            if (shareButton) {
                event.preventDefault();
                event.stopPropagation();
                if (!shoutBody) return;
                var shareText = (shareButton.getAttribute('data-title') || '') + ' ' + (shareButton.getAttribute('data-url') || '');
                shoutBody.value = shareText.slice(0, 240);
                shoutBody.dispatchEvent(new Event('input', { bubbles: true }));
                shoutBody.focus();
                shoutBody.scrollIntoView({ behavior: 'smooth', block: 'center' });
                setShoutFeedback(homeI18n.newsSharedToComposer, false);
                return;
            }

            var row = event.target.closest('[data-news-href]');
            if (row) {
                window.location.href = row.getAttribute('data-news-href');
            }
        });
        bodyRoot.addEventListener('keydown', function (event) {
            if (event.key !== 'Enter') return;
            var row = event.target.closest('[data-news-href]');
            if (row) {
                event.preventDefault();
                window.location.href = row.getAttribute('data-news-href');
            }
        });
        renderFeed('all');
    }

    if (shoutBody) {
        shoutBody.addEventListener('input', updateShoutCounter);
        updateShoutCounter();
    }

    window.addEventListener('scroll', scheduleStableShoutAnchorRemember, { passive: true });
    window.addEventListener('resize', scheduleStableShoutAnchorRemember);
    window.setTimeout(rememberStableShoutAnchor, 250);
    
    if (shoutHasPoll) shoutHasPoll.addEventListener('change', updateComposerAdvanced);
    if (shoutIsStateDecree) shoutIsStateDecree.addEventListener('change', updateComposerAdvanced);
    updateComposerAdvanced();

    if (shoutCancelEdit) {
        shoutCancelEdit.addEventListener('click', function () {
            setEditingState(null);
            if (shoutFeedback) shoutFeedback.textContent = '';
        });
    }

    if (shoutTabsRoot) {
        shoutTabsRoot.addEventListener('pointerdown', primeShoutViewportAnchor);
        shoutTabsRoot.addEventListener('click', function (event) {
            var button = event.target.closest('[data-mode]');
            if (!button) return;
            event.preventDefault();
            var nextMode = button.getAttribute('data-mode') || 'latest';
            if (nextMode === shoutMode || shoutFeedLoading) return;
            var navAnchor = pendingShoutNavAnchor || lastStableShoutAnchor || captureShoutViewport();
            var preserveScrollY = navAnchor ? navAnchor.scrollY : (window.scrollY || window.pageYOffset || document.documentElement.scrollTop || 0);
            pendingShoutNavAnchor = null;
            if (typeof button.blur === 'function') button.blur();
            setEditingState(null);
            shoutMode = nextMode;
            updateShoutTabs();
            fetchShoutFeed(shoutMode, 1, false, { delayMs: 180, minLoadMs: 260, preserveScrollY: preserveScrollY, viewportAnchor: navAnchor });
        });
    }

    if (shoutForm) {
        shoutForm.addEventListener('submit', function (event) {
            event.preventDefault();
            if (!shoutBody) return;
            if (shoutRestriction && shoutRestriction.is_muted) {
                setShoutFeedback((shoutRestriction.reason || homeI18n.shoutRestrictionDefault) + ' {{ t('home.shouts.restriction_remaining')|e('js') }}: ' + formatRemaining(shoutRestriction.remaining_seconds || 0) + '.', true);
                return;
            }

            var editingId = shoutEditId ? parseInt(shoutEditId.value || '0', 10) : 0;
            var refreshPresidentThread = editingId > 0 && isPresidentThreadTarget(editingId);
            setButtonLoading(shoutSubmit, true, homeI18n.shoutSending);
            if (shoutFeedback) shoutFeedback.textContent = '';

            $.post(baseUrl + (editingId > 0 ? '/api/shouts/edit' : '/api/shouts/create'), {
                shout_id: editingId,
                mode: shoutMode,
                page: shoutCurrentPage,
                offset: shoutNextOffset,
                body: shoutBody ? shoutBody.value : '',
                has_poll: shoutHasPoll && shoutHasPoll.checked ? 1 : 0,
                poll_question: shoutPollQuestion ? shoutPollQuestion.value : '',
                poll_option_1: shoutPollOption1 ? shoutPollOption1.value : '',
                poll_option_2: shoutPollOption2 ? shoutPollOption2.value : '',
                poll_option_3: shoutPollOption3 ? shoutPollOption3.value : '',
                poll_duration_hours: shoutPollDuration ? shoutPollDuration.value : '1',
                is_state_decree: shoutIsStateDecree && shoutIsStateDecree.checked ? 1 : 0,
                csrf_token: csrfToken
            }, function (res) {
                var payload = extractPayload(res) || {};
                if (payload.error === true || payload.error === 1) {
                    setButtonLoading(shoutSubmit, false, submitLabelByState());
                    setShoutFeedback(payload.message || homeI18n.shoutSendError, true);
                    if (payload.restriction) setShoutRestrictionState(payload.restriction);
                    return;
                }

                if (payload.feed && Array.isArray(payload.feed.items)) applyShoutFeed(payload.feed, false);
                if (payload.created_shout_id) highlightedShoutId = parseInt(payload.created_shout_id, 10);
                if (payload.force_mode) { shoutMode = payload.force_mode; updateShoutTabs(); }
                if (shoutBody) { shoutBody.value = ''; updateShoutCounter(); shoutBody.focus(); }

                resetComposerAdvanced();
                setEditingState(null);
                setButtonLoading(shoutSubmit, false, submitLabelByState());
                setShoutFeedback(payload.message || (editingId > 0 ? homeI18n.shoutUpdated : homeI18n.shoutShared), false);
                renderShouts();
                if (refreshPresidentThread) fetchPresidentThread(false, true);
            }).fail(function () {
                setButtonLoading(shoutSubmit, false, submitLabelByState());
                setShoutFeedback(homeI18n.shoutConnectionError, true);
            });
        });
    }

    if (shoutPaginationRoot) {
        shoutPaginationRoot.addEventListener('pointerdown', primeShoutViewportAnchor);
        shoutPaginationRoot.addEventListener('click', function (event) {
            var button = event.target.closest('[data-page]');
            if (!button || shoutFeedLoading) return;
            var targetPage = parseInt(button.getAttribute('data-page') || '1', 10);
            if (targetPage < 1 || targetPage === shoutCurrentPage) return;
            var navAnchor = pendingShoutNavAnchor || lastStableShoutAnchor || captureShoutViewport();
            var preserveScrollY = navAnchor ? navAnchor.scrollY : (window.scrollY || window.pageYOffset || document.documentElement.scrollTop || 0);
            pendingShoutNavAnchor = null;
            fetchShoutFeed(shoutMode, targetPage, false, {
                delayMs: 120,
                minLoadMs: 180,
                preserveScrollY: preserveScrollY,
                viewportAnchor: navAnchor
            });
        });
    }

    if (presidentMessageRoot && presidentMessageShoutId > 0) {
        presidentMessageRoot.addEventListener('click', function (event) {
            var button = event.target.closest('[data-action]');
            if (!button) return;

            var action = button.getAttribute('data-action') || '';
            if (action === 'president-like') {
                handleLike(button, presidentMessageShoutId);
                return;
            }

            if (action === 'president-comments') {
                if (replyVisibility[presidentMessageShoutId]) {
                    replyVisibility[presidentMessageShoutId] = false;
                    if (replyComposerParentId === presidentMessageShoutId) replyComposerParentId = 0;
                    renderPresidentThread();
                } else {
                    fetchPresidentThread(false, false);
                }
                return;
            }

            if (action === 'president-reply') {
                fetchPresidentThread(true, false);
            }
        });
    }

    if (presidentThreadRoot) {
        presidentThreadRoot.addEventListener('input', function (event) {
            var field = event.target.closest('[data-role="reply-body"]');
            if (!field) return;
            var parentId = parseInt(field.getAttribute('data-parent-id') || '0', 10);
            if (parentId < 1) return;
            replyDrafts[parentId] = field.value || '';
        });

        presidentThreadRoot.addEventListener('click', function (event) {
            var button = event.target.closest('[data-action]');
            if (!button) return;
            var shoutId = parseInt(button.getAttribute('data-shout-id') || '0', 10);
            var action = button.getAttribute('data-action') || '';
            if (shoutId < 1 || action === '') return;

            if (action === 'like-shout') { handleLike(button, shoutId); return; }
            if (action === 'expand-replies') { replyExpanded[shoutId] = true; renderPresidentThread(); return; }
            if (action === 'collapse-replies') { replyExpanded[shoutId] = false; renderPresidentThread(); return; }
            if (action === 'reply-shout') { handleReplyComposer(shoutId); return; }
            if (action === 'cancel-reply') { replyComposerParentId = 0; renderPresidentThread(); return; }
            if (action === 'submit-reply') { handleReplySubmit(shoutId, button); return; }
            if (action === 'edit-shout') { handleEdit(shoutId); return; }
            if (action === 'report-shout') { openShoutReportModal(shoutId); return; }
            if (action === 'delete-shout') { if (confirm(homeI18n.shoutDeleteConfirm)) { handleDelete(button, shoutId); } }
        });
    }

    function handlePollVote(button, shoutId) {
        var pollOptionId = parseInt(button.getAttribute('data-poll-option-id') || '0', 10);
        if (pollOptionId < 1) return;
        postShoutAction(baseUrl + '/api/shouts/vote-poll', { shout_id: shoutId, poll_option_id: pollOptionId, mode: shoutMode, offset: shoutNextOffset, csrf_token: csrfToken }, function (payload) {
            var shoutIndex = findShoutIndexById(payload.shout_id || shoutId);
            if (shoutIndex >= 0 && payload.poll) shoutItems[shoutIndex].poll = payload.poll;
            renderShouts();
        }, function (payload) { setShoutFeedback(payload.message || homeI18n.shoutGenericError, true); });
    }

    function handleTip(button, shoutId) {
        var goldAmount = parseInt(button.getAttribute('data-gold-amount') || '0', 10);
        if (goldAmount < 1) return;
        postShoutAction(baseUrl + '/api/shouts/tip', { shout_id: shoutId, gold_amount: goldAmount, mode: shoutMode, offset: shoutNextOffset, csrf_token: csrfToken }, function (payload) {
            updateShoutItemById(shoutId, function (item) {
                item.tips = item.tips || {};
                item.tips.total_gold = parseFloat(payload.tips_total_gold || 0);
                return item;
            });
            renderShouts();
        }, function (payload) { setShoutFeedback(payload.message || homeI18n.shoutGenericError, true); });
    }

    function handleArticleVote(button) {
        var articleId = parseInt(button.getAttribute('data-article-id') || '0', 10);
        if (articleId < 1) return;
        postShoutAction(baseUrl + '/api/article/vote', { id: articleId, csrf_token: csrfToken }, function () {
            shoutItems = shoutItems.map(function (item) {
                if (!item.article_card || parseInt(item.article_card.id || 0, 10) !== articleId) return item;
                item.article_card.voted_by_me = true;
                item.article_card.votes = parseInt(item.article_card.votes || 0, 10) + 1;
                return item;
            });
            renderShouts();
        }, function (payload) { setShoutFeedback(payload.message || homeI18n.shoutGenericError, true); });
    }

    function handleSubscribe(button) {
        var authorUid = parseInt(button.getAttribute('data-author-uid') || '0', 10);
        if (authorUid < 1) return;
        postShoutAction(baseUrl + '/api/newspaper/subscribe_by_author', { uid: authorUid, csrf_token: csrfToken }, function (payload) {
            var subscribed = payload.status === 'subscribed';
            shoutItems = shoutItems.map(function (item) {
                if (!item.article_card || parseInt(item.article_card.uid || 0, 10) !== authorUid) return item;
                item.article_card.subscribed_by_me = subscribed;
                return item;
            });
            renderShouts();
        }, function (payload) { setShoutFeedback(payload.message || homeI18n.shoutGenericError, true); });
    }

    function handleLike(button, shoutId) {
        postShoutAction(baseUrl + '/api/shouts/like', { shout_id: shoutId, csrf_token: csrfToken }, function (payload) {
            updateShoutItemById(shoutId, function (item) {
                item.liked_by_me = !!payload.liked;
                item.likes_count = parseInt(payload.likes_count || 0, 10);
                return item;
            });
            if (parseInt(shoutId || 0, 10) === presidentMessageShoutId) {
                updatePresidentMessageCard({
                    id: presidentMessageShoutId,
                    liked_by_me: !!payload.liked,
                    likes_count: parseInt(payload.likes_count || 0, 10),
                    reply_count: parseInt((findShoutById(shoutId) || {}).reply_count || 0, 10)
                });
            }
            renderShouts();
            if (isPresidentThreadTarget(shoutId)) renderPresidentThread();
        }, function (payload) { setShoutFeedback(payload.message || homeI18n.shoutGenericError, true); });
    }

    function handleEdit(shoutId) {
        var current = findShoutById(shoutId);
        if (current) {
            setEditingState(current);
            document.getElementById('shout-form').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    }

    function handleDelete(button, shoutId) {
        postShoutAction(baseUrl + '/api/shouts/delete', { shout_id: shoutId, mode: shoutMode, page: shoutCurrentPage, offset: shoutNextOffset, csrf_token: csrfToken }, function () {
            removeShoutItemById(shoutId);
            renderShouts();
            if (presidentThreadVisible() || parseInt(shoutId || 0, 10) === presidentMessageShoutId) {
                renderPresidentThread();
                if (presidentThreadItem) updatePresidentMessageCard(presidentThreadItem);
            }
        }, function (payload) { setShoutFeedback(payload.message || homeI18n.shoutGenericError, true); });
    }

    function handleAdminHide(button, shoutId) {
        postShoutAction(baseUrl + '/api/admin/delete-shout', { shout_id: shoutId }, function (payload) {
            updateShoutItemById(shoutId, function (item) {
                item.is_hidden = true;
                return item;
            });
            renderShouts();
            setShoutFeedback(payload.message || homeI18n.shoutReviewHide, false);
        }, function (payload) {
            setShoutFeedback(payload.message || homeI18n.shoutGenericError, true);
        });
    }

    function handleAdminReopen(button, shoutId) {
        postShoutAction(baseUrl + '/api/admin/reopen-shout', { shout_id: shoutId }, function (payload) {
            updateShoutItemById(shoutId, function (item) {
                item.is_hidden = false;
                return item;
            });
            renderShouts();
            setShoutFeedback(payload.message || homeI18n.shoutReviewReopen, false);
        }, function (payload) {
            setShoutFeedback(payload.message || homeI18n.shoutGenericError, true);
        });
    }

    function handleAdminMute(button) {
        var uid = parseInt(button.getAttribute('data-uid') || '0', 10);
        if (uid < 1) return;
        postShoutAction(baseUrl + '/api/admin/mute-shout-user', { uid: uid }, function (payload) {
            setShoutFeedback(payload.message || homeI18n.shoutReviewMute, false);
        }, function (payload) {
            setShoutFeedback(payload.message || homeI18n.shoutGenericError, true);
        });
    }

    function handleReplyToggle(shoutId) {
        shoutId = parseInt(shoutId || 0, 10);
        if (shoutId < 1) return;
        replyVisibility[shoutId] = !replyVisibility[shoutId];
        if (!replyVisibility[shoutId] && replyComposerParentId === shoutId) {
            replyComposerParentId = 0;
        }
        if (shoutId === presidentMessageShoutId) {
            renderPresidentThread();
            return;
        }
        renderShouts();
    }

    function handleReplyComposer(shoutId) {
        shoutId = parseInt(shoutId || 0, 10);
        if (shoutId < 1) return;
        replyComposerParentId = replyComposerParentId === shoutId ? 0 : shoutId;
        ensureReplySectionVisible(shoutId);
        if (shoutId === presidentMessageShoutId) {
            fetchPresidentThread(replyComposerParentId === shoutId, false);
            return;
        }
        renderShouts();
    }

    function handleReplySubmit(parentId, button) {
        parentId = parseInt(parentId || 0, 10);
        if (parentId < 1) return;

        var body = String(replyDrafts[parentId] || '').trim();
        if (body.length < 3) {
            setShoutFeedback(homeI18n.shoutSendError, true);
            return;
        }

        setButtonLoading(button, true, homeI18n.shoutSending);
        postShoutAction(baseUrl + '/api/shouts/create', {
            parent_id: parentId,
            body: body,
            mode: shoutMode,
            page: shoutCurrentPage,
            offset: shoutNextOffset,
            csrf_token: csrfToken
        }, function (payload) {
            if (payload.feed && Array.isArray(payload.feed.items)) applyShoutFeed(payload.feed, false);
            replyDrafts[parentId] = '';
            replyComposerParentId = 0;
            replyVisibility[parentId] = true;
            if (payload.created_parent_id) replyExpanded[parentId] = true;
            highlightedShoutId = parseInt(payload.created_shout_id || 0, 10);
            setShoutFeedback(payload.message || homeI18n.shoutReplyShared, false);
            renderShouts();
            if (parentId === presidentMessageShoutId) {
                fetchPresidentThread(false, true);
            }
        }, function (payload) {
            setButtonLoading(button, false, homeI18n.shoutReplySend);
            setShoutFeedback(payload.message || homeI18n.shoutGenericError, true);
        });
    }

    if (shoutReportSubmit) {
        shoutReportSubmit.addEventListener('click', function() {
            var reportReason = String((shoutReportReason && shoutReportReason.value) || '').trim();
            var refreshPresidentThread = isPresidentThreadTarget(pendingReportShoutId);
            if (pendingReportShoutId < 1) { closeShoutReportModal(); return; }
            if (reportReason.length < 5) { if(shoutReportFeedback) shoutReportFeedback.textContent = homeI18n.shoutShortReason; return; }
            setButtonLoading(shoutReportSubmit, true, homeI18n.shoutSending);
            postShoutAction(baseUrl + '/api/shouts/report', { shout_id: pendingReportShoutId, csrf_token: csrfToken, reason: reportReason }, function () {
                updateShoutItemById(pendingReportShoutId, function (item) { item.reported_by_me = true; return item; });
                closeShoutReportModal();
                renderShouts();
                if (refreshPresidentThread) renderPresidentThread();
            }, function (payload) {
                setButtonLoading(shoutReportSubmit, false, homeI18n.shoutReportSubmit);
                if(shoutReportFeedback) shoutReportFeedback.textContent = payload.message || homeI18n.shoutGenericError;
            });
        });
    }

    if (shoutFeedRoot) {
        shoutFeedRoot.addEventListener('input', function (event) {
            var field = event.target.closest('[data-role="reply-body"]');
            if (!field) return;
            var parentId = parseInt(field.getAttribute('data-parent-id') || '0', 10);
            if (parentId < 1) return;
            replyDrafts[parentId] = field.value || '';
        });

        shoutFeedRoot.addEventListener('click', function (event) {
            var button = event.target.closest('[data-action]');
            if (!button) return;
            var shoutId = parseInt(button.getAttribute('data-shout-id') || '0', 10);
            var action = button.getAttribute('data-action') || '';
            if (shoutId < 1 || action === '') return;

            if (action === 'vote-poll') { handlePollVote(button, shoutId); return; }
            if (action === 'tip-shout') { handleTip(button, shoutId); return; }
            if (action === 'vote-article') { handleArticleVote(button); return; }
            if (action === 'subscribe-newspaper') { handleSubscribe(button); return; }
            if (action === 'like-shout') { handleLike(button, shoutId); return; }
            if (action === 'toggle-replies') { handleReplyToggle(shoutId); return; }
            if (action === 'expand-replies') { replyExpanded[shoutId] = true; renderShouts(); return; }
            if (action === 'collapse-replies') { replyExpanded[shoutId] = false; renderShouts(); return; }
            if (action === 'reply-shout') { handleReplyComposer(shoutId); return; }
            if (action === 'cancel-reply') { replyComposerParentId = 0; renderShouts(); return; }
            if (action === 'submit-reply') { handleReplySubmit(shoutId, button); return; }
            if (action === 'edit-shout') { handleEdit(shoutId); return; }
            if (action === 'reveal-shout') { revealedBlurredShouts[shoutId] = true; renderShouts(); return; }
            if (action === 'report-shout') { openShoutReportModal(shoutId); return; }
            if (action === 'admin-hide-shout') { handleAdminHide(button, shoutId); return; }
            if (action === 'admin-reopen-shout') { handleAdminReopen(button, shoutId); return; }
            if (action === 'admin-mute-shout-user') { handleAdminMute(button); return; }
            if (action === 'delete-shout') { if (confirm(homeI18n.shoutDeleteConfirm)) { handleDelete(button, shoutId); } }
        });

        updateShoutTabs();
        updateShoutPagination();
        setShoutRestrictionState(shoutRestriction);
        renderShouts();
    }

    if (shoutReportCancel) shoutReportCancel.addEventListener('click', closeShoutReportModal);
    if (shoutReportClose) shoutReportClose.addEventListener('click', closeShoutReportModal);
    if (shoutReportModal) shoutReportModal.addEventListener('click', function (event) { if (event.target === shoutReportModal) closeShoutReportModal(); });
    document.addEventListener('keydown', function (event) { if (event.key === 'Escape' && shoutReportModal && shoutReportModal.classList.contains('is-open')) closeShoutReportModal(); });
});
</script>
{% endblock %}
