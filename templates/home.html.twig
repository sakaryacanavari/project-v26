                                            </a>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}

                            <div class="news-terminal-shell p-2">
                                <div class="news-terminal-pane is-active" data-news-list>
                                {% for article in latestArticles|slice(0, 5) %}
                                    <a href="{{ path_for('showArticle', {id: article.id}) }}" class="news-terminal-row group flex items-center gap-3.5">
                                        <div class="news-terminal-no flex items-center justify-center w-10 h-10 rounded-xl font-black text-[14px] transition-colors group-hover:border-[color:var(--brand-primary)]/50 group-hover:text-white">
