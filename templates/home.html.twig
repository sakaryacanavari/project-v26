    function escapeHtml(value) {
        return String(value || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
    }

    function categoryLabel(category) {
        switch (parseInt(category || 0, 10)) {
            case 1: return homeI18n.newsCategoryPolitical; case 2: return homeI18n.newsCategoryEconomy; case 3: return homeI18n.newsCategoryMilitary; case 4: return homeI18n.newsCategorySocial; default: return homeI18n.newsCategoryGeneral;
        }
    }

    function categoryIcon(category) {
        switch (parseInt(category || 0, 10)) {
            case 1: return 'fa-landmark';
            case 2: return 'fa-coins';
            case 3: return 'fa-shield-halved';
            case 4: return 'fa-users';
            default: return 'fa-handshake';
        }
    }

    function criticalLabel(type) {
        switch (String(type || '')) {
            case 'maintenance': return homeI18n.newsCriticalMaintenance;
            case 'update': return homeI18n.newsCriticalUpdate;
            case 'critical': return homeI18n.newsCriticalNotice;
            default: return '';
        }
    }

    function parseNewsDate(value) {
        if (!value) return null;
        var raw = String(value).trim();
        var parsed = new Date(raw.replace(' ', 'T'));
        return isNaN(parsed.getTime()) ? null : parsed;
    }

    function formatNewsDate(value) {
        var date = parseNewsDate(value);
        if (!date) return escapeHtml(value || homeI18n.newsToday);
        var now = new Date();
        var diffMs = now.getTime() - date.getTime();
        var diffMinutes = Math.floor(diffMs / 60000);
        var time = date.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });
        if (diffMinutes >= 0 && diffMinutes < 60) {
            return homeI18n.newsMinutesAgo.replace('__COUNT__', Math.max(diffMinutes, 1));
        }
        if (diffMinutes >= 60 && diffMinutes < 360) {
            return homeI18n.newsHoursAgo.replace('__COUNT__', Math.floor(diffMinutes / 60));
        }
        if (date.toDateString() === now.toDateString()) {
            return homeI18n.newsTodayAt.replace('__TIME__', time);
        }
        if (diffMinutes >= 0 && diffMinutes < 4320) {
            return homeI18n.newsDaysAgo.replace('__COUNT__', Math.max(1, Math.floor(diffMinutes / 1440)));
        }
        return date.toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit', year: 'numeric' }) + ' ' + time;
    }

    function extractPayload(res) {
        if (typeof res === 'string') {
            var raw = String(res).replace(/^\uFEFF/, '').trim();
            if (raw && raw[0] !== '{' && raw[0] !== '[') {
                var objectStart = raw.indexOf('{');
                var arrayStart = raw.indexOf('[');
                var start = objectStart;
                if (start === -1 || (arrayStart !== -1 && arrayStart < start)) start = arrayStart;
                if (start > 0) raw = raw.slice(start);
            }
            if (raw) {
                var objectEnd = raw.lastIndexOf('}');
                var arrayEnd = raw.lastIndexOf(']');
                var end = Math.max(objectEnd, arrayEnd);
                if (end >= 0) raw = raw.slice(0, end + 1);
            }
            try { res = raw ? JSON.parse(raw) : {}; } catch (e) { res = { error: true, message: homeI18n.shoutFeedLoadError }; }
        }
        return res && typeof res === 'object' && res.result ? res.result : res;
    }

    function renderFeed(target) {
        if (!tabsRoot || !bodyRoot) return;
        var items = Array.isArray(feeds[target]) ? feeds[target] : [];
        if (!items.length) {
            bodyRoot.innerHTML = '<div class="px-4 py-8 text-center text-[11px] font-black uppercase tracking-[0.1em] text-slate-500">' + homeI18n.newsNoCategory + '</div>';
            if (newsMoreWrap) newsMoreWrap.classList.add('hidden');
            return;
        }

        var visibleItems = items.slice(0, newsVisibleCount);
        bodyRoot.innerHTML = visibleItems.map(function (article) {
            var createdAt = formatNewsDate(article.created_at);
            var author = escapeHtml(article.author_nick || homeI18n.newsAuthor);
            var title = escapeHtml(article.title || homeI18n.newsArticle);
            var id = parseInt(article.id || 0, 10);
            var icon = categoryIcon(article.category);
            var href = articleBase + id;
            var isCritical = !!article.is_system_critical;
            var critical = criticalLabel(article.critical_type);
            var criticalBadge = isCritical && critical
                ? '<span class="news-terminal-cat is-critical"><i class="fa-solid fa-triangle-exclamation"></i>' + escapeHtml(critical) + '</span>'
                : '';

            return '' +
                '<div role="link" tabindex="0" data-news-href="' + href + '" class="news-terminal-row' + (isCritical ? ' is-critical' : '') + ' group flex items-center gap-3.5">' +
                    '<div class="news-terminal-no flex items-center justify-center w-10 h-10 rounded-xl font-black text-[14px] transition-colors group-hover:border-[color:var(--brand-primary)]/50 group-hover:text-white group-hover:bg-[color:var(--brand-primary)]/10">' +
                        '<div class="value"><i class="fa-solid ' + icon + ' text-[12px]"></i></div>' +
                    '</div>' +
                    '<div class="min-w-0 flex-1">' +
                        '<div class="news-terminal-title text-[13px] font-black text-slate-200 group-hover:text-white transition">' +
                            title +
                            '<span class="news-terminal-cat"><i class="fa-solid ' + icon + '"></i>' + categoryLabel(article.category) + '</span>' +
                            criticalBadge +
                        '</div>' +
                        '<div class="news-terminal-meta flex items-center gap-2 mt-1.5 text-[10px] font-bold text-slate-400">' +
                            '<span>' + createdAt + '</span> <span class="text-slate-600">&bull;</span> <span class="news-terminal-author"><i class="fa-solid fa-pen-nib opacity-50 mr-1"></i>' + author + '</span>' +
                        '</div>' +
                    '</div>' +
                    '<button type="button" class="news-share-action" data-news-share data-title="' + title + '" data-url="' + href + '" title="' + homeI18n.newsShareToShouts + '" aria-label="' + homeI18n.newsShareToShouts + '">' +
                        '<i class="fa-solid fa-share-nodes text-[12px]"></i>' +
                    '</button>' +
                    '<div class="news-terminal-arrow pr-2 text-sm">' +
                        '<i class="fa-solid fa-chevron-right"></i>' +
                    '</div>' +
                '</div>';
        }).join('');
        if (newsMoreWrap) newsMoreWrap.classList.toggle('hidden', items.length <= newsVisibleCount);
        if (newsMoreButton) newsMoreButton.textContent = homeI18n.newsLoadMore;
    }

    function shoutAvatar(shout) { return shout.avatar ? escapeHtml(shout.avatar) : baseUrl + '/img/avatars/' + parseInt(shout.uid || 0, 10) + '.png'; }
    function formatShoutDate(shout) { return escapeHtml(shout.created_at_label || shout.created_at || ''); }

    function setShoutFeedback(message, isError) {
        if (!shoutFeedback) return;
        shoutFeedback.textContent = message || '';
        shoutFeedback.className = 'text-[11px] font-bold ' + (isError ? 'text-rose-400' : 'text-emerald-400');
    }

    function setButtonLoading(button, loading, label) {
        if (!button) return;
        button.classList.toggle('is-loading', !!loading);
        if (loading) { button.setAttribute('disabled', 'disabled'); } else { button.removeAttribute('disabled'); }
        var labelNode = button.querySelector('.label');
        if (labelNode && label) { labelNode.textContent = label; }
    }

    function updateShoutTabs() {
        if (!shoutTabsRoot) return;
        shoutTabsRoot.querySelectorAll('[data-mode]').forEach(function (button) {
            button.classList.toggle('is-active', button.getAttribute('data-mode') === shoutMode);
        });
    }

    function updateShoutFeedCount() {
        if (!shoutFeedCount) return;
        shoutFeedCount.textContent = String(Math.max(0, parseInt(shoutTotalItems || 0, 10)));
    }

    function setShoutTabsDisabled(disabled) {
        if (!shoutTabsRoot) return;
        shoutTabsRoot.querySelectorAll('[data-mode]').forEach(function (button) {
            button.classList.toggle('is-disabled', !!disabled);
            if (disabled) { button.setAttribute('disabled', 'disabled'); } else { button.removeAttribute('disabled'); }
        });
    }

    function buildShoutPaginationPages(currentPage, totalPages) {
        currentPage = Math.max(1, parseInt(currentPage || 1, 10));
        totalPages = Math.max(1, parseInt(totalPages || 1, 10));

        var pages = [];
        var pushPage = function (value) {
            if (pages.indexOf(value) === -1) pages.push(value);
        };

        pushPage(1);
        for (var page = currentPage - 1; page <= currentPage + 1; page++) {
            if (page > 1 && page < totalPages) pushPage(page);
        }
        if (totalPages > 1) pushPage(totalPages);

        pages.sort(function (a, b) { return a - b; });
        return pages;
    }

    function updateShoutPagination() {
        if (!shoutPaginationRoot) return;
        updateShoutFeedCount();

        if (shoutTotalPages <= 1) {
            shoutPaginationRoot.innerHTML = '';
            return;
        }

        var pages = buildShoutPaginationPages(shoutCurrentPage, shoutTotalPages);
        var prevDisabled = shoutCurrentPage <= 1 ? ' disabled' : '';
        var nextDisabled = shoutCurrentPage >= shoutTotalPages ? ' disabled' : '';
        var html = '' +
            '<div class="shout-pagination-shell">' +
                '<button type="button" class="shout-page-btn inline-flex items-center justify-center text-[11px] font-black" data-page="' + Math.max(1, shoutCurrentPage - 1) + '" aria-label="' + homeI18n.shoutPrevPage + '" title="' + homeI18n.shoutPrevPage + '"' + prevDisabled + '><i class="fa-solid fa-chevron-left"></i></button>';

        pages.forEach(function (page, index) {
            var prevPage = index > 0 ? pages[index - 1] : 0;
            if (prevPage && page - prevPage > 1) {
                html += '<span class="px-1 text-[11px] font-black text-slate-600">...</span>';
            }

            var isActive = page === shoutCurrentPage;
            html += '' +
                '<button type="button" class="shout-page-btn inline-flex items-center justify-center px-3 text-[11px] font-black' + (isActive ? ' is-active' : '') +
                '" data-page="' + page + '" aria-label="' + page + '" title="' + page + '">' + page + '</button>';
        });

        html += '' +
                '<div class="shout-page-status">' + shoutCurrentPage + ' / ' + shoutTotalPages + '</div>' +
                '<button type="button" class="shout-page-btn inline-flex items-center justify-center text-[11px] font-black" data-page="' + Math.min(shoutTotalPages, shoutCurrentPage + 1) + '" aria-label="' + homeI18n.shoutNextPage + '" title="' + homeI18n.shoutNextPage + '"' + nextDisabled + '><i class="fa-solid fa-chevron-right"></i></button>' +
            '</div>';

        shoutPaginationRoot.innerHTML = html;
    }

    function renderShoutLoadingState() {
        if (!shoutFeedRoot) return;
        var hasExistingContent = !!shoutFeedRoot.children.length && !shoutFeedRoot.querySelector('.shout-loading-state');
        if (hasExistingContent) {
            shoutFeedLockedHeight = Math.max(shoutFeedLockedHeight, Math.ceil(shoutFeedRoot.getBoundingClientRect().height || 0));
            if (shoutFeedLockedHeight > 0) shoutFeedRoot.style.minHeight = shoutFeedLockedHeight + 'px';
            shoutFeedRoot.classList.add('is-refreshing');
            if (!shoutFeedRoot.querySelector('.shout-refresh-overlay')) {
                shoutFeedRoot.insertAdjacentHTML('beforeend', '<div class="shout-refresh-overlay"><div class="shout-refresh-pill"><i class="fa-solid fa-rotate"></i><span>Yenileniyor</span></div></div>');
            }
            return;
        }
        shoutFeedRoot.innerHTML =
            '<div class="shout-loading-state is-quiet"></div>';
    }

    function clearShoutLoadingState() {
        if (!shoutFeedRoot) return;
        var overlay = shoutFeedRoot.querySelector('.shout-refresh-overlay');
        if (overlay) overlay.remove();
        shoutFeedRoot.classList.remove('is-refreshing');
        shoutFeedLockedHeight = 0;
        window.requestAnimationFrame(function () {
            if (shoutFeedRoot && !shoutFeedRoot.classList.contains('is-refreshing')) {
                shoutFeedRoot.style.minHeight = '';
            }
        });
    }

    function captureShoutViewport() {
        var shell = shoutFeedRoot ? shoutFeedRoot.closest('.shout-shell') : null;
        if (!shell) return null;
        var rect = shell.getBoundingClientRect();
        return {
            top: rect.top,
            scrollY: window.scrollY || window.pageYOffset || document.documentElement.scrollTop || 0
        };
    }

    function primeShoutViewportAnchor() {
        pendingShoutNavAnchor = captureShoutViewport();
    }

    function rememberStableShoutAnchor() {
        if (shoutFeedLoading) return;
        var anchor = captureShoutViewport();
        if (!anchor) return;
        var shell = shoutFeedRoot ? shoutFeedRoot.closest('.shout-shell') : null;
        if (!shell) return;
        var rect = shell.getBoundingClientRect();
        if (rect.bottom > 80 && rect.top < window.innerHeight - 80) {
            lastStableShoutAnchor = anchor;
        }
    }

    function scheduleStableShoutAnchorRemember() {
        if (stableShoutAnchorTimer) clearTimeout(stableShoutAnchorTimer);
        stableShoutAnchorTimer = setTimeout(function () {
            stableShoutAnchorTimer = null;
            rememberStableShoutAnchor();
        }, 180);
    }

    function restoreShoutViewport(anchor) {
        if (!anchor || !shoutFeedRoot) return;
        var shell = shoutFeedRoot.closest('.shout-shell');
        if (!shell) return;
        window.requestAnimationFrame(function () {
            var currentTop = shell.getBoundingClientRect().top;
            var delta = currentTop - anchor.top;
            if (Math.abs(delta) > 1) {
                window.scrollTo({ top: Math.max(0, anchor.scrollY + delta), behavior: 'auto' });
            }
        });
    }

    function formatRemaining(seconds) {
        seconds = Math.max(0, parseInt(seconds || 0, 10));
        if (seconds < 60) return seconds + ' ' + homeI18n.shoutSecondsShort;
        var minutes = Math.floor(seconds / 60);
        if (minutes < 60) return minutes + ' ' + homeI18n.shoutMinutesShort;
        var hours = Math.floor(minutes / 60);
        if (hours < 24) return hours + ' ' + homeI18n.shoutHoursShort;
        return Math.floor(hours / 24) + ' ' + homeI18n.shoutDaysShort;
    }

    function setShoutRestrictionState(state) {
        shoutRestriction = state || { is_muted: false, remaining_seconds: 0, reason: '' };
        shoutBlackoutState = shoutRestriction.blackout || shoutBlackoutState;

        if (shoutRestrictionBox) {
            var isMuted = !!shoutRestriction.is_muted && parseInt(shoutRestriction.remaining_seconds || 0, 10) > 0;
            if (isMuted) {
                shoutRestrictionBox.classList.remove('hidden');
                shoutRestrictionBox.innerHTML = '<div class="bg-rose-500/20 w-8 h-8 flex items-center justify-center rounded-full"><i class="fa-solid fa-lock text-rose-400 text-sm"></i></div><div>' + (shoutRestriction.reason || homeI18n.shoutRestrictionDefault) + ' {{ t('home.shouts.restriction_remaining')|e('js') }}: <span class="text-white font-bold">' + formatRemaining(shoutRestriction.remaining_seconds) + '</span>.</div>';
                if (shoutBody) shoutBody.setAttribute('disabled', 'disabled');
                if (shoutSubmit) shoutSubmit.setAttribute('disabled', 'disabled');
            } else {
                shoutRestrictionBox.classList.add('hidden');
                if (shoutBody) shoutBody.removeAttribute('disabled');
                if (shoutSubmit) shoutSubmit.removeAttribute('disabled');
            }
            if (shoutHasPoll) shoutHasPoll.disabled = isMuted;
            if (shoutIsStateDecree) shoutIsStateDecree.disabled = isMuted;
        }
        renderBlackoutBanner();
    }

    function updateComposerAdvanced() {
        if (shoutPollBuilder && shoutHasPoll) {
            shoutPollBuilder.classList.toggle('is-hidden', !shoutHasPoll.checked);
        }
        if (shoutDecreeNote && shoutIsStateDecree) {
            shoutDecreeNote.classList.toggle('is-hidden', !shoutIsStateDecree.checked);
        }
    }

    function resetComposerAdvanced() {
        if (shoutHasPoll) shoutHasPoll.checked = false;
        if (shoutPollQuestion) shoutPollQuestion.value = '';
        if (shoutPollOption1) shoutPollOption1.value = '';
        if (shoutPollOption2) shoutPollOption2.value = '';
        if (shoutPollOption3) shoutPollOption3.value = '';
        if (shoutPollDuration) shoutPollDuration.value = '1';
        if (shoutIsStateDecree) shoutIsStateDecree.checked = false;
        updateComposerAdvanced();
    }

    function formatGold(value) {
        var amount = parseFloat(value || 0);
        if (!isFinite(amount)) amount = 0;
        return amount.toFixed(amount % 1 === 0 ? 0 : 2);
    }

    function setEditingState(shout) {
        var editing = !!shout;
        if (shoutEditId) shoutEditId.value = editing ? String(parseInt(shout.id || 0, 10)) : '';
        if (editing) resetComposerAdvanced();
        if (shoutCancelEdit) shoutCancelEdit.classList.toggle('hidden', !editing);
        if (shoutSubmit) {
            var submitLabel = editing ? homeI18n.shoutUpdate : homeI18n.shoutSend;
            shoutSubmit.setAttribute('title', submitLabel);
            shoutSubmit.setAttribute('aria-label', submitLabel);
        }
        if (shoutBody) {
            shoutBody.value = editing ? String(shout.body || '') : '';
            updateShoutCounter();
            if (editing) shoutBody.focus();
        }
    }

    function submitLabelByState() { return shoutEditId && parseInt(shoutEditId.value || '0', 10) > 0 ? homeI18n.shoutUpdate : homeI18n.shoutSend; }

    function applyShoutFeed(feed, append) {
        if (!feed || !Array.isArray(feed.items)) return;
        if (append) { shoutItems = shoutItems.concat(feed.items); } else { shoutItems = feed.items; }
        shoutMode = feed.mode || shoutMode;
        shoutHasMore = !!feed.has_more;
        shoutNextOffset = parseInt(feed.next_offset || shoutItems.length || 0, 10);
        shoutCurrentPage = Math.max(1, parseInt(feed.current_page || 1, 10));
        shoutTotalPages = Math.max(1, parseInt(feed.total_pages || 1, 10));
        shoutTotalItems = Math.max(0, parseInt(feed.total_items || feed.total || shoutItems.length || 0, 10));
        shoutPageSize = Math.max(1, parseInt(feed.page_size || shoutPageSize || 8, 10));
        shoutBlackoutState = feed.blackout || shoutBlackoutState;
        updateShoutTabs();
        updateShoutPagination();
        renderBlackoutBanner();
    }

    function updatePresidentMessageCard(item) {
        if (!presidentMessageRoot || !item || parseInt(item.id || 0, 10) !== presidentMessageShoutId) return;

        var likeButton = presidentMessageRoot.querySelector('[data-action="president-like"]');
        var likeCount = presidentMessageRoot.querySelector('[data-president-like-count]');
        var replyCount = presidentMessageRoot.querySelector('[data-president-reply-count]');
        var bodyNode = presidentMessageRoot.querySelector('[data-president-body]');

        if (likeButton) {
            likeButton.classList.toggle('is-active', !!item.liked_by_me);
            likeButton.innerHTML = '<i class="' + (item.liked_by_me ? 'fa-solid' : 'fa-regular') + ' fa-heart"></i><span class="count" data-president-like-count>' + parseInt(item.likes_count || 0, 10) + '</span>';
            likeButton.setAttribute('title', homeI18n.shoutLike);
        } else if (likeCount) {
            likeCount.textContent = String(parseInt(item.likes_count || 0, 10));
        }

        if (replyCount) {
            replyCount.textContent = String(parseInt(item.reply_count || 0, 10));
        }

        if (bodyNode && (typeof item.display_body_html !== 'undefined' || typeof item.body_html !== 'undefined' || typeof item.display_body !== 'undefined' || typeof item.body !== 'undefined')) {
            bodyNode.innerHTML = item.display_body_html || item.body_html || escapeHtml(item.display_body || item.body || '');
        }

        if (presidentThreadItem && parseInt(presidentThreadItem.id || 0, 10) === presidentMessageShoutId) {
            presidentThreadItem.liked_by_me = !!item.liked_by_me;
            presidentThreadItem.likes_count = parseInt(item.likes_count || 0, 10);
            presidentThreadItem.reply_count = parseInt(item.reply_count || 0, 10);
        }
    }

    function presidentThreadVisible() {
        return !!(presidentThreadRoot && !presidentThreadRoot.classList.contains('is-hidden'));
    }

    function isPresidentThreadTarget(shoutId) {
        var targetId = parseInt(shoutId || 0, 10);
        if (targetId < 1 || !presidentThreadItem) return false;
        if (parseInt(presidentThreadItem.id || 0, 10) === targetId) return true;
        return Array.isArray(presidentThreadItem.replies) && presidentThreadItem.replies.some(function (reply) {
            return parseInt(reply.id || 0, 10) === targetId;
        });
    }

    function renderPresidentThread() {
        if (!presidentThreadRoot) return;

        if (!presidentThreadItem || !replyVisibility[presidentMessageShoutId]) {
            presidentThreadRoot.innerHTML = '';
            presidentThreadRoot.classList.add('is-hidden');
            return;
        }

        var count = parseInt(presidentThreadItem.reply_count || 0, 10);
        var visibleReplies = visibleRepliesFor(presidentThreadItem);
        var hiddenCount = Math.max(0, count - visibleReplies.length);
        var body = '';

        if (count < 1) {
            body = '<div class="mt-3 text-[11px] font-medium text-slate-500">' + homeI18n.shoutReplyEmpty + '</div>';
        } else {
            body = visibleReplies.map(renderReplyItemHtml).join('');
            if (hiddenCount > 0) {
                body += '<button type="button" class="shout-action mt-3 px-3 py-1.5 text-[9px] font-black uppercase tracking-[0.1em]" data-action="expand-replies" data-shout-id="' + presidentMessageShoutId + '"><span class="label">' + homeI18n.shoutReplyMore + ' (' + hiddenCount + ')</span></button>';
            } else if (count > parseInt(presidentThreadItem.reply_preview_limit || 3, 10) && replyExpanded[presidentMessageShoutId]) {
                body += '<button type="button" class="shout-action mt-3 px-3 py-1.5 text-[9px] font-black uppercase tracking-[0.1em]" data-action="collapse-replies" data-shout-id="' + presidentMessageShoutId + '"><span class="label">' + homeI18n.shoutReplyLess + '</span></button>';
            }
        }

        presidentThreadRoot.innerHTML = '<div class="reply-thread">' + body + renderReplyComposerHtml(presidentThreadItem) + '</div>';
        presidentThreadRoot.classList.remove('is-hidden');
    }

    function fetchPresidentThread(openComposer, forceReload) {
        if (!presidentThreadRoot || presidentMessageShoutId < 1 || presidentThreadLoading) return;

        if (presidentThreadItem && !forceReload) {
            replyVisibility[presidentMessageShoutId] = true;
            if (openComposer) replyComposerParentId = presidentMessageShoutId;
            renderPresidentThread();
            if (openComposer) scrollToShoutThread(presidentMessageShoutId, true);
            return;
        }

        presidentThreadLoading = true;
        presidentThreadRoot.classList.remove('is-hidden');
        presidentThreadRoot.innerHTML = '<div class="reply-thread"><div class="mt-3 text-[11px] font-medium text-slate-500">' + homeI18n.shoutLoading + '</div></div>';

        $.post(baseUrl + '/api/shouts/thread', {
            shout_id: presidentMessageShoutId,
            csrf_token: csrfToken
        }, function (res) {
            var payload = extractPayload(res) || {};
            presidentThreadLoading = false;

            if (payload.error === true || payload.error === 1 || !payload.shout) {
                presidentThreadItem = null;
                presidentThreadRoot.innerHTML = '';
                presidentThreadRoot.classList.add('is-hidden');
                setShoutFeedback(payload.message || homeI18n.shoutFeedLoadError, true);
                return;
            }

            presidentThreadItem = payload.shout;
            replyVisibility[presidentMessageShoutId] = true;
            if (openComposer) replyComposerParentId = presidentMessageShoutId;
            updatePresidentMessageCard(presidentThreadItem);
            renderPresidentThread();
            if (openComposer) {
                window.requestAnimationFrame(function () {
                    var field = presidentThreadRoot.querySelector('[data-role="reply-body"]');
                    if (field && typeof field.focus === 'function') field.focus();
                });
            }
        }).fail(function () {
            presidentThreadLoading = false;
            presidentThreadItem = null;
            presidentThreadRoot.innerHTML = '';
            presidentThreadRoot.classList.add('is-hidden');
            setShoutFeedback(homeI18n.shoutFeedLoadError, true);
        });
    }

    function updateShoutItemById(shoutId, updater) {
        var targetId = parseInt(shoutId || 0, 10);
        shoutItems = shoutItems.map(function (item) {
            if (parseInt(item.id || 0, 10) === targetId) {
                return updater(item) || item;
            }

            if (Array.isArray(item.replies) && item.replies.length) {
                item.replies = item.replies.map(function (reply) {
                    if (parseInt(reply.id || 0, 10) !== targetId) return reply;
                    return updater(reply) || reply;
                });
            }

            return item;
        });

        if (presidentThreadItem) {
            if (parseInt(presidentThreadItem.id || 0, 10) === targetId) {
                presidentThreadItem = updater(presidentThreadItem) || presidentThreadItem;
            } else if (Array.isArray(presidentThreadItem.replies) && presidentThreadItem.replies.length) {
                presidentThreadItem.replies = presidentThreadItem.replies.map(function (reply) {
                    if (parseInt(reply.id || 0, 10) !== targetId) return reply;
                    return updater(reply) || reply;
                });
            }
        }
    }

    function removeShoutItemById(shoutId) {
        var targetId = parseInt(shoutId || 0, 10);
        shoutItems = shoutItems
            .filter(function (item) { return parseInt(item.id || 0, 10) !== targetId; })
            .map(function (item) {
                if (Array.isArray(item.replies) && item.replies.length) {
                    var nextReplies = item.replies.filter(function (reply) {
                        return parseInt(reply.id || 0, 10) !== targetId;
                    });
                    item.replies = nextReplies;
                    item.reply_count = nextReplies.length;
                }
                return item;
            });

        if (presidentThreadItem) {
            if (parseInt(presidentThreadItem.id || 0, 10) === targetId) {
                presidentThreadItem = null;
                replyVisibility[presidentMessageShoutId] = false;
                if (replyComposerParentId === presidentMessageShoutId) replyComposerParentId = 0;
            } else if (Array.isArray(presidentThreadItem.replies) && presidentThreadItem.replies.length) {
                presidentThreadItem.replies = presidentThreadItem.replies.filter(function (reply) {
                    return parseInt(reply.id || 0, 10) !== targetId;
                });
                presidentThreadItem.reply_count = presidentThreadItem.replies.length;
            }
        }
    }

    function findShoutIndexById(shoutId) {
        var targetId = parseInt(shoutId || 0, 10);
        for (var i = 0; i < shoutItems.length; i++) {
            if (parseInt(shoutItems[i].id || 0, 10) === targetId) return i;
        }
        return -1;
    }

    function findShoutById(shoutId) {
        var targetId = parseInt(shoutId || 0, 10);

        if (presidentThreadItem) {
            if (parseInt(presidentThreadItem.id || 0, 10) === targetId) return presidentThreadItem;
            if (Array.isArray(presidentThreadItem.replies)) {
                for (var k = 0; k < presidentThreadItem.replies.length; k++) {
                    if (parseInt(presidentThreadItem.replies[k].id || 0, 10) === targetId) return presidentThreadItem.replies[k];
                }
            }
        }

        for (var i = 0; i < shoutItems.length; i++) {
            if (parseInt(shoutItems[i].id || 0, 10) === targetId) return shoutItems[i];
            if (Array.isArray(shoutItems[i].replies)) {
                for (var j = 0; j < shoutItems[i].replies.length; j++) {
                    if (parseInt(shoutItems[i].replies[j].id || 0, 10) === targetId) return shoutItems[i].replies[j];
                }
            }
        }
        return null;
    }

    function scrollToShoutThread(shoutId, focusReplyField) {
        window.requestAnimationFrame(function () {
            var root = document.querySelector('[data-shout-id="' + parseInt(shoutId || 0, 10) + '"]');
            if (!root) return;
            root.scrollIntoView({ behavior: 'smooth', block: 'center' });
            if (focusReplyField) {
                var field = root.querySelector('[data-role="reply-body"]');
                if (field && typeof field.focus === 'function') field.focus();
            }
        });
    }

    function flushPendingThreadTarget() {
        if (!pendingThreadTarget) return;

        var target = pendingThreadTarget;
        var shoutId = parseInt(target.shoutId || 0, 10);
        if (shoutId < 1) {
            pendingThreadTarget = null;
            return;
        }

        if (findShoutIndexById(shoutId) < 0) {
            return;
        }

        pendingThreadTarget = null;
        replyVisibility[shoutId] = true;
        if (target.openComposer) replyComposerParentId = shoutId;
        renderShouts();
        scrollToShoutThread(shoutId, !!target.openComposer);
    }

    function openShoutThreadById(shoutId, openComposer) {
        shoutId = parseInt(shoutId || 0, 10);
        if (shoutId < 1) return;

        if (shoutId === presidentMessageShoutId && findShoutIndexById(shoutId) < 0) {
            fetchPresidentThread(!!openComposer, false);
            return;
        }

        pendingThreadTarget = { shoutId: shoutId, openComposer: !!openComposer };

        if (shoutMode !== 'latest' || findShoutIndexById(shoutId) < 0) {
            var preserveScrollY = window.scrollY || window.pageYOffset || document.documentElement.scrollTop || 0;
            shoutMode = 'latest';
            updateShoutTabs();
            fetchShoutFeed('latest', 1, false, { delayMs: 180, minLoadMs: 260, preserveScrollY: preserveScrollY });
            return;
        }

        flushPendingThreadTarget();
    }

    function ensureReplySectionVisible(parentId) {
        parentId = parseInt(parentId || 0, 10);
        if (parentId < 1) return;
        replyVisibility[parentId] = true;
    }

    function visibleRepliesFor(shout) {
        var replies = Array.isArray(shout.replies) ? shout.replies : [];
        var parentId = parseInt(shout.id || 0, 10);
        if (replyExpanded[parentId]) return replies;
        var limit = parseInt(shout.reply_preview_limit || 3, 10);
        return replies.slice(0, Math.max(0, limit));
    }

    function openShoutReportModal(shoutId) {
        pendingReportShoutId = parseInt(shoutId || 0, 10);
        if (shoutReportFeedback) shoutReportFeedback.textContent = '';
        if (shoutReportReason) shoutReportReason.value = '';
        if (shoutReportModal) {
            shoutReportModal.classList.add('is-open');
            shoutReportModal.setAttribute('aria-hidden', 'false');
        }
    }

    function closeShoutReportModal() {
        pendingReportShoutId = 0;
        if (shoutReportFeedback) shoutReportFeedback.textContent = '';
        if (shoutReportReason) shoutReportReason.value = '';
        if (shoutReportModal) {
            shoutReportModal.classList.remove('is-open');
            shoutReportModal.setAttribute('aria-hidden', 'true');
        }
        if (shoutReportSubmit) setButtonLoading(shoutReportSubmit, false, homeI18n.shoutReportSubmit);
    }

    function postShoutAction(url, data, onSuccess, onFailure) {
        $.post(url, data, function (res) {
            var payload = extractPayload(res) || {};
            if (payload.error === true || payload.error === 1) {
                if (typeof onFailure === 'function') onFailure(payload);
                else setShoutFeedback(payload.message || homeI18n.shoutActionFailed, true);
                return;
            }
            if (typeof onSuccess === 'function') onSuccess(payload);
        }).fail(function () {
            if (typeof onFailure === 'function') onFailure({ error: true, message: homeI18n.shoutConnectionError });
            else setShoutFeedback(homeI18n.shoutConnectionError, true);
        });
    }

    /* V17 KESİN ROZET İŞLEMLERİ (V16 GİBİ BOZULMAZ YAPI) */
    function countryBadgeHtml(shout) {
        var countryId = parseInt(shout.country_id || 0, 10);
        if (countryId < 1) return '';
        return '<div class="shout-badge"><img src="' + baseUrl + '/img/flags/' + countryId + '.png" alt="flag" loading="lazy" decoding="async"></div>';
    }

    function partyBadgeHtml(shout) {
        var partyName = escapeHtml(shout.party_name || '');
        if (!partyName) return '';
        var partyLogo = shout.party_logo_url ? '<img src="' + escapeHtml(shout.party_logo_url) + '" class="party-logo" alt="P" loading="lazy" decoding="async">' : '<i class="fa-solid fa-landmark-dome"></i>';
        return '<div class="shout-badge party-badge">' + partyLogo + '<span>' + partyName + '</span></div>';
    }

    function roleBadgeHtml(shout) {
