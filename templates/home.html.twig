                                <button type="button" id="shout-cancel-edit" class="hidden theme-button inline-flex items-center justify-center gap-1.5 rounded-full px-4 py-2.5 text-[9px] font-black uppercase tracking-[0.1em] text-white" aria-label="{{ t('home.shouts.cancel') }}">
                                    <span class="label">{{ t('home.shouts.cancel') }}</span>
                                </button>
                                <button type="submit" id="shout-submit" class="shout-submit inline-flex h-11 min-w-[52px] items-center justify-center gap-1.5 rounded-xl px-4 py-3 text-[12px] shadow-[0_8px_24px_color-mix(in_srgb,var(--brand-primary)_18%,transparent)]" title="{{ t('home.shouts.send') }}" aria-label="{{ t('home.shouts.send') }}" {% if shoutRestriction.is_muted %}disabled{% endif %}>
                                    <i class="fa-solid fa-rotate spinner"></i>
                                    <i class="fa-solid fa-paper-plane text-[14px] opacity-90"></i>
                                </button>
                            </div>
                        </div>

                        {# V17 ANKET BÖLÜMÜ #}
                        <div id="shout-poll-builder" class="is-hidden rounded-xl border border-white/5 bg-black/30 p-4 shadow-inner">
