                                            </div>
                                            <div class="news-terminal-meta flex items-center gap-2 mt-1.5 text-[10px] font-bold text-slate-400">
                                                <span>
                                                {% if article.created_at %}
                                                    {{ article.created_at|date('d.m.Y H:i') }}
                                                {% else %}
                                                    {{ t('home.news.today') }}
                                                {% endif %}
                                                </span>
                                                <span class="text-slate-600">&bull;</span>
                                                <span class="news-terminal-author flex items-center gap-1"><i class="fa-solid fa-pen-nib opacity-50"></i>{{ article.author_nick|default(t('home.news.author')) }}</span>
                                            </div>
                                        </div>
                                        <div class="news-terminal-arrow pr-2 text-sm">
                                            <i class="fa-solid fa-chevron-right"></i>
                                        </div>
                                    </a>
