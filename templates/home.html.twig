{% extends isAjax ? "common/ajaxbase.html.twig" : "common/base.html.twig" %}

{% block content %}
<style>
    /* --- V17 NEO-GLASS COMPACT CORE CSS --- */
    .home-theme-surface {
        --home-map-line: rgba(255,255,255,0.035);
        --home-panel-edge: rgba(255,255,255,0.105);
        --home-panel-fill: rgba(10,15,24,0.46);
        position: relative;
        isolation: isolate;
    }
    .home-theme-surface::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background:
            radial-gradient(ellipse at 18% 0%, color-mix(in srgb, var(--brand-primary) 16%, transparent), transparent 36%),
            radial-gradient(ellipse at 88% 12%, rgba(251, 194, 235, 0.09), transparent 32%),
            linear-gradient(90deg, var(--home-map-line) 1px, transparent 1px),
            linear-gradient(180deg, var(--home-map-line) 1px, transparent 1px);
        background-size: 100% 100%, 100% 100%, 48px 48px, 48px 48px;
        mask-image: linear-gradient(180deg, rgba(0,0,0,0.88), rgba(0,0,0,0.22));
        z-index: -1;
    }
    /* Removed heavy .glass-panel overrides to inherit premium global glass */
    .home-theme-surface .glass-panel {
        background:
            linear-gradient(180deg, rgba(255,255,255,0.052), rgba(0,0,0,0.22)),
            var(--home-panel-fill);
        border-color: var(--home-panel-edge);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.11), 0 24px 58px -24px rgba(0,0,0,0.92);
    }
    
    .home-theme-surface .theme-divider { border-color: rgba(255, 255, 255, 0.08) !important; }

    .home-theme-surface .theme-button {
        background:
            radial-gradient(circle at 50% 0%, color-mix(in srgb, var(--brand-primary) 10%, transparent), transparent 64%),
            linear-gradient(180deg, rgba(255,255,255,0.045) 0%, rgba(0,0,0,0.28) 100%) !important;
        border: 1px solid rgba(255, 255, 255, 0.065) !important;
        border-bottom: 2px solid rgba(0,0,0,0.6) !important;
        border-top: 1px solid rgba(255, 255, 255, 0.12) !important;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.055), inset 0 2px 10px rgba(0,0,0,0.28), 0 8px 16px rgba(0,0,0,0.24);
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
        backdrop-filter: blur(8px);
        color: #94a3b8 !important;
        position: relative;
        overflow: hidden;
    }
    .home-theme-surface .theme-button::before {
        content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, color-mix(in srgb, var(--brand-primary) 15%, transparent), transparent); opacity: 0; transition: opacity 0.3s;
    }
    .home-theme-surface .theme-button i { 
        color: color-mix(in srgb, var(--brand-primary) 80%, white);
        transition: transform 0.2s ease, filter 0.2s ease, color 0.3s ease;
        opacity: 0.7;
    }
    .home-theme-surface .theme-button:hover {
        background: linear-gradient(180deg, color-mix(in srgb, var(--brand-primary) 10%, transparent), rgba(0,0,0,0.4)) !important;
        border-top: 1px solid color-mix(in srgb, var(--brand-primary) 60%, transparent) !important;
        border-color: color-mix(in srgb, var(--brand-primary) 25%, transparent) !important;
        color: #fff !important;
        transform: translateY(-4px);
        box-shadow: 0 15px 30px -5px color-mix(in srgb, var(--brand-primary) 40%, transparent), inset 0 1px 0 rgba(255,255,255,0.2);
    }
    .home-theme-surface .theme-button:hover::before { opacity: 1; }
    .home-theme-surface .theme-button:hover i {
        opacity: 1;
        transform: scale(1.15) translateY(-1px);
        filter: drop-shadow(0 0 10px var(--brand-primary));
        color: #fff;
    }
    .home-theme-surface .is-hidden { display: none !important; }
    .home-theme-surface.gx-density-compact { gap: 12px; }
    .home-theme-surface.gx-density-compact .home-dashboard-grid,
    .home-theme-surface.gx-density-compact .home-main-stack,
    .home-theme-surface.gx-density-compact .home-side-col { gap: 12px; }
    .home-theme-surface.gx-density-compact .glass-panel { padding: 12px !important; }
    .home-theme-surface.gx-density-compact .theme-button { padding-top: 8px !important; padding-bottom: 8px !important; }
    .home-theme-surface.gx-density-comfortable { gap: 26px; }
    .home-theme-surface.gx-density-comfortable .home-dashboard-grid,
    .home-theme-surface.gx-density-comfortable .home-main-stack,
    .home-theme-surface.gx-density-comfortable .home-side-col { gap: 26px; }
    .home-theme-surface.gx-density-comfortable .glass-panel { padding: 24px !important; }
    .home-theme-surface.gx-density-comfortable .theme-button { padding-top: 14px !important; padding-bottom: 14px !important; }
    .home-theme-surface.gx-hud-compact .home-side-col { gap: 12px; }
    .home-theme-surface.gx-hud-compact .route-v2-shell { padding: 12px !important; }
    .home-theme-surface.gx-hud-compact .route-card { min-height: 0; padding: 10px !important; }
    .home-theme-surface.gx-hud-compact .route-head-v2 { padding-bottom: 10px; }
    .home-theme-surface.gx-hud-compact .route-list { margin-top: 12px; }
    .home-theme-surface.gx-motion-off *, .home-theme-surface.gx-motion-off *::before, .home-theme-surface.gx-motion-off *::after { transition: none !important; animation: none !important; scroll-behavior: auto !important; }
    .home-theme-surface.gx-motion-off .theme-button:hover, .home-theme-surface.gx-motion-off .news-terminal-row:hover, .home-theme-surface.gx-motion-off .shout-card:hover, .home-theme-surface.gx-motion-off .route-card:hover, .home-theme-surface.gx-motion-off .shout-submit:hover { transform: none !important; box-shadow: none !important; }
    .home-theme-surface.gx-motion-full .theme-button:hover,
    .home-theme-surface.gx-motion-full .shout-card:hover,
    .home-theme-surface.gx-motion-full .route-card:hover { transform: translateY(-5px); }
    .home-theme-surface .gx-priority-target { position: relative; border-color: color-mix(in srgb, var(--brand-primary) 46%, rgba(255,255,255,0.08)) !important; box-shadow: inset 0 1px 0 rgba(255,255,255,0.12), 0 0 0 1px color-mix(in srgb, var(--brand-primary) 18%, transparent), 0 18px 36px -22px color-mix(in srgb, var(--brand-primary) 58%, transparent) !important; }
    .home-theme-surface.gx-priority-shouts .shout-v10-shell { order: -1; width: 100%; min-width: 0; }
    .home-theme-surface.gx-priority-tasks .home-side-col { order: -1; grid-column: 1 / -1 !important; width: 100%; }
    .home-theme-surface.gx-priority-tasks .route-v2-shell { position: static !important; top: auto !important; }
    .home-theme-surface.gx-shout-width-compact .shout-v10-shell { width: 100%; max-width: 780px; margin-left: auto; margin-right: auto; }
    .home-theme-surface.gx-shout-width-balanced .shout-v10-shell { width: 100%; max-width: 1040px; margin-left: auto; margin-right: auto; }
    .home-theme-surface.gx-shout-width-wide .shout-v10-shell { width: 100%; max-width: none; }
    .home-theme-surface .quick-action-link { position: relative; overflow: hidden; }
    .home-theme-surface .quick-action-link.is-favorite { border-color: color-mix(in srgb, var(--brand-primary) 38%, transparent) !important; box-shadow: inset 0 1px 0 rgba(255,255,255,0.16), 0 14px 28px -22px color-mix(in srgb, var(--brand-primary) 65%, transparent); }

    .home-theme-surface .home-main-stack > :not([hidden]) ~ :not([hidden]) { margin-top: 14px !important; }
    .home-theme-surface .home-hero { padding: 12px !important; }
    .home-theme-surface .quick-action-link {
        min-height: 40px;
        padding: 9px 13px !important;
        border-radius: 12px !important;
        letter-spacing: 0.08em !important;
    }
    .home-theme-surface .quick-action-link:not(.is-favorite) { opacity: .84; }
    .home-theme-surface .quick-action-link.is-favorite {
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.12), 0 10px 22px -20px color-mix(in srgb, var(--brand-primary) 62%, transparent);
    }
    .home-theme-surface :where(a, button, input, select, textarea, [role="link"], [role="button"]):focus-visible {
        outline: 2px solid color-mix(in srgb, var(--brand-primary) 74%, #ffffff);
        outline-offset: 3px;
        box-shadow: 0 0 0 4px color-mix(in srgb, var(--brand-primary) 16%, transparent), inset 0 1px 0 rgba(255,255,255,0.08) !important;
    }
    .home-theme-surface .news-terminal-row:focus-visible,
    .home-theme-surface .route-card:focus-visible,
    .home-theme-surface .quick-action-link:focus-visible {
        outline-offset: 4px;
    }
    .home-theme-surface .shout-action:focus-visible,
    .home-theme-surface .news-share-action:focus-visible,
    .home-theme-surface .shout-filter-tab:focus-visible {
        min-width: 34px;
        min-height: 34px;
    }

    /* Gradient Text Utility */
    .text-gradient-primary {
        background: linear-gradient(135deg, #ffffff 0%, color-mix(in srgb, var(--brand-primary) 80%, white) 50%, var(--brand-primary) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: 0 4px 15px color-mix(in srgb, var(--brand-primary) 30%, transparent);
    }

    /* --- V17 NEO-HERO GRAPHICS --- */
    .home-theme-surface .home-hero {
        position: relative;
        background:
            radial-gradient(ellipse at 50% 0%, color-mix(in srgb, var(--brand-primary) 16%, transparent), transparent 58%),
            linear-gradient(180deg, rgba(255,255,255,0.055) 0%, rgba(0,0,0,0.36) 100%);
        box-shadow: inset 0 2px 20px rgba(255,255,255,0.055), 0 22px 46px -24px rgba(0,0,0,0.74);
        border-top: 1px solid rgba(255,255,255,0.14) !important;
        overflow: hidden;
    }
    .home-theme-surface .home-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: 
            linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 20px 20px, 20px 20px;
        opacity: 0.48;
        pointer-events: none;
        z-index: 0;
    }
    .home-theme-surface .home-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.075), transparent);
        transform: translateX(-75%);
        opacity: 0.32;
    }
    .home-theme-surface .home-hero > div { position: relative; z-index: 1; }

    /* --- V17 COMPACT PRESIDENT MESSAGE --- */
    .home-theme-surface .president-message-card {
        background: radial-gradient(circle at top left, color-mix(in srgb, var(--brand-primary) 15%, transparent) 0%, transparent 60%), linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.4) 100%) !important;
        border-left: 4px solid var(--brand-primary) !important;
        border-top: 1px solid rgba(255,255,255,0.1) !important;
        border-right: 1px solid rgba(255,255,255,0.03) !important;
        border-bottom: 1px solid rgba(255,255,255,0.03) !important;
        box-shadow: inset 0 2px 10px rgba(255,255,255,0.05), 0 10px 30px rgba(0,0,0,0.5);
        position: relative;
    }
    .home-theme-surface .president-message-card::after {
        content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.02) 0%, transparent 100%); pointer-events: none; border-radius: inherit; z-index: 0;
    }
    .home-theme-surface .president-message-card.is-decree {
        background: radial-gradient(circle at top left, rgba(250, 204, 21, 0.15) 0%, transparent 60%), linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.4) 100%) !important;
        border-left: 4px solid rgba(250, 204, 21, 0.9) !important;
        box-shadow: inset 0 2px 10px rgba(250,204,21,0.08), 0 10px 30px rgba(0,0,0,0.5);
    }
    .home-theme-surface .president-message-avatar {
        border: 2px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 0 20px color-mix(in srgb, var(--brand-primary) 50%, transparent), inset 0 0 10px rgba(0,0,0,0.5);
        padding: 2px;
        background: linear-gradient(135deg, color-mix(in srgb, var(--brand-primary) 50%, transparent), transparent);
    }
    .home-theme-surface .president-message-card.is-decree .president-message-avatar {
        box-shadow: 0 0 20px rgba(250, 204, 21, 0.4), inset 0 0 10px rgba(0,0,0,0.5);
        background: linear-gradient(135deg, rgba(250, 204, 21, 0.4), transparent);
    }
    .home-theme-surface .president-message-body {
        background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.5) 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-top: 1px solid rgba(255, 255, 255, 0.15);
        border-left: 2px solid color-mix(in srgb, var(--brand-primary) 40%, transparent);
        border-radius: 12px;
        box-shadow: inset 0 4px 20px rgba(0,0,0,0.5), 0 8px 24px rgba(0,0,0,0.4);
        backdrop-filter: blur(10px);
    }
    .home-theme-surface .president-message-main {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
    }
    .home-theme-surface .president-message-content {
        min-width: 0;
        flex: 1 1 auto;
    }
    .home-theme-surface .president-message-like {
        margin-left: auto;
        align-self: flex-start;
    }

    /* --- V17 COMPACT NEWS TERMINAL --- */
    .home-theme-surface .news-v10-shell,
    .home-theme-surface .shout-v10-shell {
        position: relative;
        overflow: hidden;
    }
    .home-theme-surface .news-v10-shell::before,
    .home-theme-surface .shout-v10-shell::before,
    .home-theme-surface .route-v2-shell::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: linear-gradient(90deg, color-mix(in srgb, var(--brand-primary) 52%, transparent), transparent 24%, transparent 78%, rgba(255,255,255,0.12));
        height: 1px;
        opacity: 0.75;
    }
    .home-theme-surface .news-v10-shell > *,
    .home-theme-surface .shout-v10-shell > *,
    .home-theme-surface .route-v2-shell > * {
        position: relative;
        z-index: 1;
    }
    .home-theme-surface .news-v10-shell { background: rgba(0,0,0,0.15) !important; }
    .home-theme-surface .news-terminal-shell { background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.5) 100%); border-radius: 16px; border: 1px solid rgba(255,255,255,0.06); border-top: 1px solid rgba(255,255,255,0.15); box-shadow: inset 0 6px 20px rgba(0,0,0,0.6), 0 8px 22px -8px rgba(0,0,0,0.44); backdrop-filter: blur(8px); }
    .home-theme-surface .news-terminal-tab { background: transparent; border: 1px solid transparent; color: #64748b; padding: 7px 18px; border-radius: 99px; font-size: 10px; transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1); font-weight: 900; letter-spacing: 0.1em; text-transform: uppercase; position: relative; overflow: hidden; }
    .home-theme-surface .news-terminal-tab::before { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, color-mix(in srgb, var(--brand-primary) 15%, transparent) 0%, transparent 100%); opacity: 0; transition: opacity 0.3s; border-radius: 99px; z-index: -1; }
    .home-theme-surface .news-terminal-tab:hover { color: #fff; text-shadow: 0 0 10px rgba(255,255,255,0.3); transform: translateY(-1px); }
    .home-theme-surface .news-terminal-tab:hover::before { opacity: 0.5; }
    .home-theme-surface .news-terminal-tab.is-active { color: #fff; box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 15px color-mix(in srgb, var(--brand-primary) 20%, transparent); text-shadow: 0 0 8px color-mix(in srgb, var(--brand-primary) 60%, transparent); background: linear-gradient(180deg, color-mix(in srgb, var(--brand-primary) 25%, transparent) 0%, rgba(0,0,0,0.3) 100%); border: 1px solid color-mix(in srgb, var(--brand-primary) 60%, transparent); border-top-color: color-mix(in srgb, var(--brand-primary) 80%, white); transform: translateY(-2px); }
    .home-theme-surface .news-terminal-more { border: 1px solid color-mix(in srgb, var(--brand-primary) 24%, transparent); background: color-mix(in srgb, var(--brand-primary) 8%, transparent); color: color-mix(in srgb, var(--brand-primary) 82%, white); transition: background .18s ease, border-color .18s ease, color .18s ease, transform .18s ease; }
    .home-theme-surface .news-terminal-more:hover,
    .home-theme-surface .news-terminal-more:focus-visible { background: color-mix(in srgb, var(--brand-primary) 14%, transparent); border-color: color-mix(in srgb, var(--brand-primary) 42%, transparent); color: #fff; transform: translateY(-1px); outline: none; }
    
    .home-theme-surface .news-terminal-row { border: 1px solid transparent; border-bottom: 1px solid rgba(255,255,255,0.025); transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease; margin: 3px 7px; border-radius: 13px; padding: 10px 12px; background: rgba(255,255,255,0.014); position: relative; outline: none; }
    .home-theme-surface .news-terminal-row:first-child { margin-top: 7px; padding: 14px 15px; background: linear-gradient(90deg, color-mix(in srgb, var(--brand-primary) 9%, transparent), rgba(255,255,255,0.025)); border-color: rgba(255,255,255,0.06); border-top-color: rgba(255,255,255,0.14); box-shadow: inset 3px 0 0 color-mix(in srgb, var(--brand-primary) 52%, transparent), inset 0 1px 0 rgba(255,255,255,0.06); }
    .home-theme-surface .news-terminal-row.is-critical { background: linear-gradient(90deg, rgba(245,158,11,0.08), rgba(255,255,255,0.018)); border-color: rgba(245,158,11,0.16); box-shadow: inset 3px 0 0 rgba(245,158,11,0.7), inset 0 1px 0 rgba(255,255,255,0.06); }
    .home-theme-surface .news-terminal-row:hover,
    .home-theme-surface .news-terminal-row:focus-visible { background: linear-gradient(90deg, rgba(255,255,255,0.04) 0%, rgba(0,0,0,0.3) 100%); border: 1px solid rgba(255,255,255,0.08); border-top: 1px solid rgba(255,255,255,0.16); border-left: 3px solid var(--brand-primary); transform: translateY(-1px); box-shadow: 0 10px 24px -12px rgba(0,0,0,0.72), inset 0 1px 0 rgba(255,255,255,0.1); z-index: 10; border-bottom-color: transparent; }
    .home-theme-surface .news-terminal-no { background: linear-gradient(135deg, rgba(255,255,255,0.055) 0%, rgba(0,0,0,0.72) 100%); border: 1px solid rgba(255,255,255,0.09); border-top: 1px solid rgba(255,255,255,0.16); color: #cbd5e1; box-shadow: inset 0 2px 10px rgba(0,0,0,0.72), 0 4px 10px rgba(0,0,0,0.22); text-shadow: 0 1px 2px rgba(0,0,0,0.8); transition: all 0.3s ease; }
    .home-theme-surface .news-terminal-row:first-child .news-terminal-no { color: var(--brand-primary); border-color: color-mix(in srgb, var(--brand-primary) 38%, transparent); background: color-mix(in srgb, var(--brand-primary) 9%, rgba(0,0,0,0.55)); }
    .home-theme-surface .news-terminal-row:hover .news-terminal-no,
    .home-theme-surface .news-terminal-row:focus-visible .news-terminal-no { color: #fff; border-color: color-mix(in srgb, var(--brand-primary) 50%, transparent); box-shadow: 0 0 15px color-mix(in srgb, var(--brand-primary) 30%, transparent), inset 0 2px 10px rgba(0,0,0,0.8); text-shadow: 0 0 8px var(--brand-primary); }
    .home-theme-surface .news-terminal-title { display: flex; flex-wrap: wrap; align-items: center; gap: 6px; line-height: 1.35; }
    .home-theme-surface .news-terminal-row:first-child .news-terminal-title { font-size: 14px; }
    .home-theme-surface .news-terminal-cat { display: inline-flex; align-items: center; gap: 4px; color: color-mix(in srgb, var(--brand-primary) 78%, white); background: color-mix(in srgb, var(--brand-primary) 10%, transparent); border: 1px solid color-mix(in srgb, var(--brand-primary) 24%, transparent); border-radius: 999px; padding: 2px 8px; font-size: 8.5px; font-weight: 950; line-height: 1.2; letter-spacing: .08em; text-transform: uppercase; }
    .home-theme-surface .news-terminal-cat.is-critical { color: #fde68a; background: rgba(245,158,11,0.12); border-color: rgba(245,158,11,0.26); }
    .home-theme-surface .news-summary-strip { display: grid; gap: 8px; border: 1px solid rgba(255,255,255,0.06); background: rgba(0,0,0,0.18); border-radius: 14px; padding: 10px; box-shadow: inset 0 1px 0 rgba(255,255,255,0.04); }
    .home-theme-surface .news-summary-item { display: flex; align-items: center; gap: 8px; min-width: 0; border-radius: 10px; padding: 7px 8px; color: #cbd5e1; background: rgba(255,255,255,0.018); transition: background .18s ease, color .18s ease; }
    .home-theme-surface .news-summary-item:hover,
    .home-theme-surface .news-summary-item:focus-visible { background: color-mix(in srgb, var(--brand-primary) 10%, transparent); color: #fff; outline: none; }
    .home-theme-surface .news-share-action { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.06); background: rgba(0,0,0,0.26); color: #94a3b8; transition: color .18s ease, border-color .18s ease, background .18s ease, transform .18s ease; }
    .home-theme-surface .news-share-action:hover,
    .home-theme-surface .news-share-action:focus-visible { color: var(--brand-primary); border-color: color-mix(in srgb, var(--brand-primary) 34%, transparent); background: color-mix(in srgb, var(--brand-primary) 10%, transparent); transform: translateY(-1px); outline: none; }
    .home-theme-surface .news-terminal-meta { color: #64748b; }
    .home-theme-surface .news-terminal-author { color: #94a3b8; }
    .home-theme-surface .news-terminal-arrow { opacity: .42; transform: translateX(-3px); transition: opacity .18s ease, transform .18s ease, color .18s ease; }
    .home-theme-surface .news-terminal-row:hover .news-terminal-arrow,
    .home-theme-surface .news-terminal-row:focus-visible .news-terminal-arrow { opacity: 1; transform: translateX(0); color: var(--brand-primary); }
    .home-theme-surface .news-header-actions { align-items: center; justify-content: flex-end; }
    .home-theme-surface .news-header-actions .theme-button { min-height: 34px; }

    /* --- V17 COMPACT SHOUTS --- */
    .home-theme-surface .shout-shell {
        background:
            radial-gradient(circle at 96% 0%, color-mix(in srgb, var(--brand-primary) 12%, transparent), transparent 32%),
            linear-gradient(180deg, rgba(15, 23, 42, 0.62), rgba(2, 6, 15, 0.46)) !important;
        border-color: rgba(255,255,255,0.08) !important;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), 0 18px 42px -24px rgba(0,0,0,0.84);
    }
    @media (min-width: 1280px) {
