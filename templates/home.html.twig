                                <button type="button" class="news-terminal-tab" data-news-target="economy"><i class="fa-solid fa-coins mr-1.5 opacity-70"></i>{{ t('home.news.category.economy') }}</button>
                                <button type="button" class="news-terminal-tab" data-news-target="military"><i class="fa-solid fa-shield-halved mr-1.5 opacity-70"></i>{{ t('home.news.category.military') }}</button>
