                            <div class="text-[13px] font-black uppercase tracking-[0.1em] text-slate-400"><i class="fa-regular fa-newspaper text-2xl block mb-3 opacity-30"></i>{{ t('home.news.calm') }}</div>
                            <div class="mt-1.5 text-[11px] font-medium text-slate-500">{{ t('home.news.calm_hint') }}</div>
                        </div>
                    {% endif %}
                </section>

