                                        <div class="text-[11px] font-black uppercase tracking-[0.16em] text-slate-500">{{ t('home.news.preparing') }}</div>
                                    </div>
                                {% endfor %}
                                </div>
                                <div class="hidden px-2 pb-2 pt-1 text-center" data-news-more-wrap>
                                    <button type="button" class="news-terminal-more rounded-full px-4 py-2 text-[10px] font-black uppercase tracking-[0.12em]" data-news-more>
                                        {{ t('home.news.load_more') }}
                                    </button>
                                </div>
                            </div>
                        </div>
                    {% else %}
