                                        {% for article in todaySummaryArticles|slice(0, 3) %}
                                            <a href="{{ path_for('showArticle', {id: article.id}) }}" class="news-summary-item">
                                                <i class="fa-solid {% if article.category == 1 %}fa-landmark{% elseif article.category == 2 %}fa-coins{% elseif article.category == 3 %}fa-shield-halved{% elseif article.category == 4 %}fa-users{% else %}fa-handshake{% endif %} text-[color:var(--brand-primary)] text-[11px]"></i>
