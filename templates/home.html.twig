                                        <option value="1">{{ t('home.shouts.poll_duration_1') }}</option>
                                        <option value="6">{{ t('home.shouts.poll_duration_6') }}</option>
                                        <option value="24">{{ t('home.shouts.poll_duration_24') }}</option>
                                    </select>
                                    <div class="text-[10px] font-medium text-slate-500"><i class="fa-solid fa-circle-info opacity-50 mr-1"></i> {{ t('home.shouts.poll_duration_hint') }}</div>
                                </div>
                            </div>
                        </div>

                        {% if shoutComposerMeta.can_create_state_decree %}
                            <div id="shout-decree-note" class="shout-decree-note is-hidden rounded-xl border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-[11px] font-bold text-amber-200 flex items-center gap-2">
                                <i class="fa-solid fa-circle-exclamation text-amber-400 text-lg"></i>
                                {{ t('home.shouts.decree_hint', {':country': shoutComposerMeta.decree_country_name, ':hours': shoutComposerMeta.decree_duration_hours}) }}
                            </div>
                        {% endif %}

                        <div class="min-h-[16px] px-1">
                            <div id="shout-feedback" class="text-[11px] font-bold text-slate-400"></div>
                        </div>
                    </form>

                    <div id="shout-report-modal" class="shout-report-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="shout-report-title">
                        <div class="shout-report-panel p-5">
                            <div class="flex items-center justify-between gap-4 border-b border-white/8 pb-4">
                                <div class="flex min-w-0 items-center gap-3">
                                    <div class="shout-report-icon"><i class="fa-solid fa-flag"></i></div>
                                    <div class="min-w-0">
                                        <div id="shout-report-title" class="text-[13px] font-black uppercase tracking-[0.12em] text-white">{{ t('home.shouts.report_title') }}</div>
                                        <div class="mt-1 text-[10px] font-bold text-slate-500">{{ t('home.shouts.report_hint') }}</div>
                                    </div>
                                </div>
                                <button type="button" id="shout-report-close" class="shout-report-close-btn h-9 w-9 shrink-0 rounded-xl" aria-label="{{ t('home.shouts.cancel') }}">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </div>
                            <div class="mt-4">
                                <textarea id="shout-report-reason" maxlength="240" class="shout-input shout-report-textarea min-h-[118px] w-full resize-y rounded-xl px-4 py-3 text-[13px] font-medium shadow-inner" placeholder="{{ t('home.shouts.report_placeholder') }}" aria-label="{{ t('home.shouts.report_reason') }}"></textarea>
                                <div id="shout-report-feedback" class="mt-2 min-h-[18px] text-[11px] font-bold text-slate-500"></div>
                            </div>
                            <div class="mt-5 flex items-center justify-end gap-2.5">
                                <button type="button" id="shout-report-cancel" class="shout-report-cancel-btn inline-flex h-10 items-center justify-center rounded-xl px-4 text-[10px] font-black uppercase tracking-[0.1em]">
                                    {{ t('home.shouts.cancel') }}
                                </button>
                                <button type="button" id="shout-report-submit" class="shout-submit shout-report-submit-btn inline-flex h-10 items-center justify-center gap-2 rounded-xl px-5 text-[10px] font-black uppercase tracking-[0.1em]">
                                    <i class="fa-solid fa-rotate spinner"></i>
                                    <i class="fa-solid fa-paper-plane"></i>
                                    <span class="label">{{ t('home.shouts.report_submit') }}</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="mt-0">
                        <div class="mb-2.5 flex flex-wrap items-center justify-between gap-2.5">
                            <div class="flex flex-wrap items-center gap-2" id="shout-tabs">
                            <button type="button" class="shout-filter-tab is-active font-black uppercase tracking-wider" data-mode="latest" title="{{ t('home.shouts.latest') }}" aria-label="{{ t('home.shouts.latest') }}">
                                <i class="fa-solid fa-clock text-[12px] opacity-70"></i>
                            </button>
                            <button type="button" class="shout-filter-tab font-black uppercase tracking-wider" data-mode="my-country" title="{{ t('home.shouts.country') }}" aria-label="{{ t('home.shouts.country') }}">
                                <i class="fa-solid fa-flag text-[12px] opacity-70"></i>
                            </button>
                            <button type="button" class="shout-filter-tab font-black uppercase tracking-wider" data-mode="popular" title="{{ t('home.shouts.popular') }}" aria-label="{{ t('home.shouts.popular') }}">
                                <i class="fa-solid fa-fire text-[12px] text-orange-500 opacity-90"></i>
                            </button>
                            {% if isAdminUser %}
                                <button type="button" class="shout-filter-tab !text-rose-300 border-rose-500/20 bg-rose-500/5 hover:bg-rose-500/10 font-black uppercase tracking-wider" data-mode="reported" title="{{ t('home.shouts.reported') }}" aria-label="{{ t('home.shouts.reported') }}">
                                    <i class="fa-solid fa-shield-halved text-[12px]"></i>
                                </button>
                            {% endif %}
                            </div>
                            <div class="rounded-full border border-white/5 bg-black/30 px-3 py-2 text-[10px] font-black uppercase tracking-[0.12em] text-slate-500 shadow-inner">
                                <span id="shout-feed-count">{{ initialShoutFeed.total_items|default(initialShoutFeed.total|default(shouts|length)) }}</span>
                            </div>
                        </div>

                        <div id="shout-feed" class="shout-feed-list"></div>

                        <div class="mt-4 flex justify-center">
                            <div id="shout-pagination" class="flex flex-wrap items-center justify-center gap-2"></div>
                        </div>
                    </div>
                </section>

            </div> </div>

        <aside class="home-side-col col-span-12 space-y-5">
            {# YENİ OYUNCU ROTASI V17 #}
            <section class="route-v2-shell glass-panel p-4 rounded-2xl relative overflow-hidden {{ gameExperienceSettings.home_priority|default('news') == 'tasks' ? 'gx-priority-target' : '' }}">
                <div class="route-orb"></div>

                <div class="route-head-v2 relative z-10 flex flex-col gap-3 border-b border-white/5 pb-4 lg:flex-row lg:items-center lg:justify-between">
                    <div class="route-head-copy">
                        <div class="text-[12px] font-black uppercase tracking-[0.18em] text-gradient-primary drop-shadow">{{ t('home.route.title') }}</div>
                        <p class="mt-1.5 text-[10px] font-medium leading-relaxed text-slate-400">{{ t('home.route.subtitle') }}</p>
                        <div class="route-guide-note"><i class="fa-solid fa-route"></i>{{ completedOnboarding }}/{{ onboardingTotal }} {{ t('home.route.status_done') }}</div>
                    </div>
                    <div class="onboarding-summary w-full rounded-2xl p-3 lg:max-w-[214px] border border-white/5">
                        <div class="flex items-start justify-between gap-2">
                            <div class="min-w-0">
                                <div class="text-[9px] font-black uppercase tracking-[0.2em] text-[color:var(--brand-primary)]">{{ t('home.route.progress') }}</div>
                                <div class="mt-1 flex items-end gap-1">
                                    <span class="text-[28px] font-black leading-none text-white drop-shadow-md">{{ onboardingProgress|default(0) }}</span>
                                    <span class="pb-1 text-[11px] font-black text-slate-500">%</span>
                                </div>
                            </div>
                            <div class="route-progress-chip rounded-xl px-2.5 py-1.5 text-center">
                                <div class="text-[8px] font-black uppercase tracking-[0.15em] text-slate-500">{{ t('home.route.step_count') }}</div>
                                <div class="mt-0.5 text-[13px] font-black text-white">{{ completedOnboarding }}/{{ onboardingTotal }}</div>
                            </div>
                        </div>
                        <div class="onboarding-progress mt-3">
                            <div class="onboarding-progress-bar h-full" style="width: {{ onboardingProgress|default(0) }}%"></div>
                        </div>
                        {% if onboardingComplete|default(false) %}
                            <div class="mt-2 text-[9px] font-black uppercase tracking-[0.12em] text-emerald-300">{{ t('home.route.completed') }}</div>
                        {% endif %}
                    </div>
                </div>

                {% if onboardingComplete|default(false) %}
                    <div class="mt-3 rounded-xl border border-emerald-500/20 bg-emerald-500/8 px-3 py-2.5 text-[10px] font-bold leading-5 text-emerald-100 relative z-10">
                        <i class="fa-solid fa-circle-check mr-1.5 text-emerald-300"></i>{{ t('home.route.completed_next') }}
                    </div>
                {% endif %}

                <div class="route-list mt-4 space-y-2.5 relative z-10">
                    {% for step in onboardingSteps %}
                        {% set isNextRoute = (not step.done and step.key == onboardingNextKey|default('')) %}
                        {% set isSecondaryRoute = (not step.done and not isNextRoute) %}
                        {% set routeStatusLabel = step.done ? t('home.route.status_done') : (isNextRoute ? t('home.route.status_active') : (step.optional ? t('home.route.optional') : (step.daily ? t('home.route.daily') : t('home.route.recommended')))) %}
                        <a href="{{ step.href }}" class="route-card {{ step.done ? 'is-done' : '' }} {{ isNextRoute ? 'is-next-route' : '' }} {{ isSecondaryRoute ? 'is-secondary-route' : '' }} block px-3.5 py-3" aria-label="{{ step.label }} - {{ routeStatusLabel }}">
                            <div class="flex items-start gap-3">
                                <div class="route-icon h-9 w-9 shrink-0 rounded-xl flex items-center justify-center text-[12px]">
                                    <i class="fa-solid {{ step.done ? 'fa-check' : (isNextRoute ? 'fa-arrow-right' : (step.daily ? 'fa-calendar-day' : (step.optional ? 'fa-compass' : step.icon))) }}"></i>
                                </div>
                                <div class="min-w-0 flex-1 pt-0.5">
                                    <div class="flex items-center justify-between gap-2 flex-wrap">
