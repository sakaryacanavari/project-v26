<div class="home-theme-surface space-y-5 w-full overflow-hidden gx-density-{{ gameExperienceSettings.ui_density|default('balanced') }} gx-motion-{{ gameExperienceSettings.animation_level|default('balanced') }} gx-hud-{{ gameExperienceSettings.left_hud|default('detailed') }} gx-shout-width-{{ gameExperienceSettings.shout_width|default('balanced') }} gx-home-layout-{{ gameExperienceSettings.home_layout|default('wide') }} gx-priority-{{ gameExperienceSettings.home_priority|default('news') }}">
    <section class="home-hero glass-panel p-3 md:p-4 rounded-2xl">
        <div class="grid grid-cols-2 md:grid-cols-4 xl:grid-cols-8 gap-2.5">
                {% for link in quickLinks|default([]) %}
                    <a href="{{ link.href }}" class="quick-action-link {{ link.is_favorite|default(false) ? 'is-favorite' : 'is-secondary' }} theme-button inline-flex w-full items-center justify-center gap-1.5 rounded-xl px-3 py-2.5 text-[10px] font-black uppercase tracking-[0.1em] text-white">
                        <i class="fa-solid {{ link.icon }}"></i> {{ t(link.label_key) }}
                    </a>
                {% endfor %}
        </div>
    </section>

    <div class="home-dashboard-grid grid grid-cols-12 gap-5">
        <div class="home-primary-col col-span-12">
            <div class="home-main-stack w-full space-y-5">
            
                {# BAŞKAN MESAJI V17 #}
                {% if presidentMessage %}
                    <section id="shout-{{ presidentMessage.id }}" class="president-message-card glass-panel {{ presidentMessage.is_state_decree ? 'is-decree' : '' }} p-5 rounded-2xl" data-president-shout-id="{{ presidentMessage.id }}">
                        <div class="president-message-main theme-divider relative z-[1] border-b pb-4">
                            <div class="president-message-content flex items-center gap-4">
                                <div class="president-message-avatar h-14 w-14 shrink-0 rounded-full relative flex items-center justify-center">
                                    <img src="{{ presidentMessage.avatar ?: (base_url() ~ '/img/avatars/' ~ presidentMessage.uid ~ '.png') }}" onerror="this.src='{{ base_url() }}/img/default_avatar.jpg'" class="h-full w-full rounded-full object-cover" alt="{{ presidentMessage.nick }}" loading="lazy" decoding="async">
                                </div>
                                <div class="min-w-0">
                                    <div class="president-message-title flex items-center gap-1.5 text-[10px] font-black uppercase tracking-[0.2em] text-white opacity-90">
                                        {% if presidentMessage.is_state_decree %}
                                            <i class="fa-solid fa-thumbtack text-yellow-400 drop-shadow-[0_0_4px_rgba(250,204,21,0.8)]"></i> {{ t('home.president.decree') }}
                                        {% else %}
                                            <i class="fa-solid fa-bullhorn text-[color:var(--brand-primary)] drop-shadow-[0_0_4px_color-mix(in_srgb,var(--brand-primary)_80%,transparent)]"></i> {{ t('home.president.message') }}
                                        {% endif %}
                                    </div>
                                    <div class="mt-1.5 flex flex-wrap items-center gap-2">
                                        <div class="text-[15px] font-black text-white tracking-wide text-shadow-sm">{{ presidentMessage.nick }}</div>
                                        <div class="shout-badge"><img src="{{ base_url() }}/img/flags/{{ presidentMessage.country_id }}.png" alt="flag" loading="lazy" decoding="async"></div>
                                    </div>
                                    <div class="mt-1.5 text-[9px] font-bold text-slate-400">{{ presidentMessage.created_at_label }} &bull; {{ presidentMessage.is_state_decree ? t('home.president.decree_meta') : t('home.president.message_meta') }}</div>
                                </div>
                            </div>
                        </div>
                        <div class="president-message-body relative z-[1] mt-4 p-4 text-[13px] font-medium leading-relaxed text-slate-200" data-president-body>
                            {{ presidentMessage.body_html|default(presidentMessage.body|e)|raw }}
                        </div>
                        <div class="mt-4 flex items-center justify-between gap-3">
                            <div class="reply-meta-actions">
                                <button type="button" class="reply-meta-btn like-meta-btn {{ presidentMessage.liked_by_me ? 'is-active' : '' }}" data-action="president-like" data-shout-id="{{ presidentMessage.id }}" title="{{ t('home.shouts.like') }}" aria-label="{{ t('home.shouts.like') }}">
                                    <i class="{{ presidentMessage.liked_by_me ? 'fa-solid' : 'fa-regular' }} fa-heart"></i>
                                    <span class="count" data-president-like-count>{{ presidentMessage.likes_count|default(0) }}</span>
                                </button>
                                <button type="button" class="reply-meta-btn" data-action="president-comments" data-shout-id="{{ presidentMessage.id }}" title="{{ t('home.shouts.replies') }}" aria-label="{{ t('home.shouts.replies') }}">
                                    <i class="fa-regular fa-comment"></i>
                                    <span class="count" data-president-reply-count>{{ presidentMessage.reply_count|default(0) }}</span>
                                </button>
                                <button type="button" class="reply-meta-btn" data-action="president-reply" data-shout-id="{{ presidentMessage.id }}" title="{{ t('home.shouts.reply') }}" aria-label="{{ t('home.shouts.reply') }}">
                                    <i class="fa-solid fa-reply"></i>
                                </button>
                            </div>
                        </div>
                        <div id="president-thread" class="is-hidden"></div>
                    </section>
                {% endif %}

                {# HABERLER V17 #}
                <section class="shout-shell news-v10-shell glass-panel rounded-2xl p-5 {{ gameExperienceSettings.home_priority|default('news') == 'news' ? 'gx-priority-target' : '' }}">
                    <div class="panel-head-v10 flex flex-col gap-3 pb-2 lg:flex-row lg:items-center lg:justify-between">
                        <div>
                            <div class="flex items-center gap-2.5">
                                <div class="panel-title-icon">
                                    <i class="fa-solid fa-newspaper text-[13px]"></i>
                                </div>
                                <h2 class="text-[18px] font-black uppercase tracking-[0.15em] text-gradient-primary">{{ t('home.news.title') }}</h2>
                                <span class="relative flex h-2 w-2 ml-1">
                                    <span class="animate-ping-slow absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                                    <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500 shadow-[0_0_8px_rgba(239,68,68,1)]"></span>
                                </span>
                            </div>
                        </div>
                        <div class="news-header-actions flex flex-wrap items-center gap-2">
                            <a href="{{ path_for('newspaperList') }}" class="theme-button inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-[10px] font-black uppercase tracking-[0.1em] text-white">
                                <i class="fa-solid fa-list"></i> {{ t('home.news.all') }}
                            </a>
                            <a href="{% if myNewspaper %}{{ path_for('showNewspaper', {id: myNewspaper.id}) }}{% else %}{{ path_for('createNewspaper') }}{% endif %}" class="theme-button inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-[10px] font-black uppercase tracking-[0.1em] text-[color:var(--brand-primary)] border-[color:var(--brand-primary)]/40 bg-[color:var(--brand-primary)]/10">
                                <i class="fa-solid {% if myNewspaper %}fa-newspaper{% else %}fa-feather-pointed{% endif %}"></i> {% if myNewspaper %}{{ t('home.news.my_newspaper') }}{% else %}{{ t('home.news.create') }}{% endif %}
                            </a>
                        </div>
                    </div>

                    {% if latestArticles|length > 0 %}
                        <div class="mt-4 news-terminal-body" data-news-body>
                            <div class="flex flex-wrap gap-2 mb-4 border-b border-white/5 pb-2" data-news-tabs>
                                <button type="button" class="news-terminal-tab is-active" data-news-target="all"><i class="fa-solid fa-layer-group mr-1.5 opacity-70"></i>{{ t('home.news.filter.all') }}</button>
