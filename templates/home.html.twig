                                    <input type="checkbox" id="shout-has-poll" value="1" class="peer sr-only" {% if shoutRestriction.is_muted %}disabled{% endif %}>
                                    <span class="inline-flex h-6 w-6 items-center justify-center rounded-lg bg-[color:var(--brand-primary)]/18 text-[color:var(--brand-primary)] shadow-[0_0_10px_color-mix(in_srgb,var(--brand-primary)_18%,transparent)] transition peer-checked:bg-[color:var(--brand-primary)] peer-checked:text-black peer-checked:shadow-[0_0_14px_color-mix(in_srgb,var(--brand-primary)_45%,transparent)]">
                                        <i class="fa-solid fa-square-poll-horizontal text-[11px]"></i>
