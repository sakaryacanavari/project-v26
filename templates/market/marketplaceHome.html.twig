{% extends isAjax ? "common/ajaxbase.html.twig" : "common/base.html.twig" %}

{% block content %}
<div class="market-home space-y-5 w-full" id="marketHomeRoot">
    {% if marketStatus and marketMessage %}
        <div class="market-shell {% if marketStatus == 'success' %}market-status-success{% else %}market-status-error{% endif %}">
            <div class="market-status-text">{{ marketMessage }}</div>
        </div>
    {% endif %}

    <section class="market-shell market-hero">
        <div class="market-shell-glow market-shell-glow-right"></div>
        <div class="market-shell-line"></div>

        <div class="market-hero-row">
            <div class="market-hero-brand">
                <div class="market-hero-icon">
                    <div class="market-hero-icon-pulse"></div>
                    <i class="fa-solid fa-store market-hero-icon-mark"></i>
                </div>

                <div>
                    <h1 class="market-hero-title">{{ t('marketplace.hero.title') }}</h1>
                    <div class="market-hero-subtitle">
                        <span class="market-dot">
                            <span class="market-dot-ping"></span>
                            <span class="market-dot-core"></span>
                        </span>
                        {{ t('marketplace.hero.subtitle') }}
                    </div>
                </div>
            </div>

            <div class="market-country-wrap">
                <div class="market-country-box">
                    <i class="fa-solid fa-globe market-country-icon"></i>
                    <div class="market-country-select">
                        {% include 'widgets/countrySelector.html.twig' %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="market-shell">
        <div class="market-shell-glow market-shell-glow-left"></div>

        <h2 class="market-section-title">
            <i class="fa-solid fa-boxes-stacked"></i>
            {{ t('marketplace.category.title') }}
        </h2>

        <div class="market-product-grid">
            {% for product in products %}
                <button type="button" data-action="show-product-catalogue" data-id="{{ product.id }}" class="product-tile group">
                    <img src="img/products/{{ product.id }}.png" class="w-9 h-9" alt="{{ product.name }}">
                    <span class="name">{{ product.name }}</span>
                </button>
            {% endfor %}
        </div>
    </section>

    <section id="product-catalogue" class="market-shell hidden">
        <div class="market-shimmer"></div>

        <div class="market-quality-row">
            <span class="market-section-title market-section-title-inline">
                <i class="fa-solid fa-star"></i>
                {{ t('marketplace.quality.title') }}
            </span>
            <div class="market-quality-list" id="qualityList"></div>
        </div>
    </section>

    <section class="market-shell market-table-shell">
        <div class="market-table-wrap">
            <table id="item-results" class="market-table">
                <thead>
                    <tr>
                        <th>{{ t('marketplace.table.product') }}</th>
                        <th>{{ t('marketplace.table.seller') }}</th>
                        <th class="text-center">{{ t('marketplace.table.stock') }}</th>
                        <th class="text-center">{{ t('marketplace.table.price') }}</th>
                        <th class="text-right">{{ t('marketplace.table.order') }}</th>
                    </tr>
                </thead>
                <tbody id="offers-table-body">
                    {% if offers is defined and offers|length > 0 %}
                        <tr id="initial-showcase-msg">
                            <td colspan="5" class="market-showcase-cell">
                                <i class="fa-solid fa-chart-line mr-2"></i> {{ t('marketplace.table.showcase') }}
                            </td>
                        </tr>

                        {% for offer in offers %}
                            <tr id="offer-{{ offer.id }}" class="market-offer-row">
                                <td class="market-cell market-cell-product">
                                    <div class="market-product-box">
                                        <img src="img/products/{{ offer.item }}.png" class="w-8 h-8" alt="">
                                    </div>
                                    <div class="market-product-meta">
                                        <span class="market-product-name">{{ t('marketplace.table.unit') }} #{{ offer.item }}</span>
                                        <span class="market-product-quality">Q{{ offer.quality }} - {{ t('marketplace.table.logistics') }}</span>
                                    </div>
                                </td>
                                <td class="market-cell">
                                    <a href="#" class="market-seller-link">
                                        <span class="market-seller-dot"></span>
                                        <span>{{ offer.seller.nick }}</span>
                                    </a>
                                </td>
                                <td class="market-cell text-center">
                                    <div class="market-stock-pill">
                                        <span class="market-stock-value">{{ offer.quantity }}</span>
                                        <span class="market-stock-label">{{ t('marketplace.table.quantity') }}</span>
                                    </div>
                                </td>
                                <td class="market-cell text-center">
                                    <div class="market-price-pill">
                                        <span class="market-price-value">{{ offer.price }}</span>
                                        <span class="market-price-currency">{% filter upper %}{{ offer.country.currency }}{% endfilter %}</span>
                                    </div>
                                </td>
                                <td class="market-cell text-right">
                                    <form action="{{ path_for('marketBuyPage') }}" method="post" class="market-buy-box">
                                        <input type="hidden" name="id" value="{{ offer.id }}">
                                        <input name="quantity" type="number" value="1" min="1" max="{{ offer.quantity }}" class="market-qty-input">
                                        <button type="submit" class="market-buy-btn" title="{{ t('marketplace.table.buy') }}" aria-label="{{ t('marketplace.table.buy') }}">
                                            <span class="market-buy-shine"></span>
                                            <i class="fa-solid fa-cart-arrow-down"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="5" class="market-empty-cell">
                                <div class="market-state-icon">
                                    <div class="market-state-ring"></div>
                                    <i class="fa-solid fa-radar"></i>
                                </div>
                                <div class="market-state-title">{{ t('marketplace.empty.title') }}</div>
                                <p class="market-state-copy">{{ t('marketplace.empty.copy') }}</p>
                            </td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </section>
</div>

<template id="tpl-item-quality">
    <a href="javascript:void(0);" data-url-template="{{ path_for('marketplaceOffers', {'item':'__ITEM__', 'quality':'__Q__'}) }}" class="q-btn">
        <span class="q-label"></span>
    </a>
</template>

<style>
    #marketHomeRoot {
        --market-accent: var(--brand-primary);
        --market-glow: var(--brand-glow);
        --market-surface: rgba(15, 23, 42, 0.78);
        --market-surface-strong: rgba(9, 14, 26, 0.92);
        --market-card: rgba(30, 41, 59, 0.72);
        --market-card-hover: color-mix(in srgb, var(--brand-primary) 14%, rgba(30, 41, 59, 0.94));
        --market-border: color-mix(in srgb, var(--brand-primary) 24%, rgba(255,255,255,0.06));
        --market-border-soft: rgba(255,255,255,0.08);
        --market-text-soft: #cbd5e1;
        --market-text-muted: #94a3b8;
        --market-success: #34d399;
        --market-gold: #fbbf24;
    }

    html.theme-oled #marketHomeRoot {
        --market-surface: rgba(3, 4, 6, 0.94);
        --market-surface-strong: rgba(0, 0, 0, 0.98);
        --market-card: rgba(8, 10, 12, 0.96);
        --market-card-hover: color-mix(in srgb, var(--brand-primary) 10%, rgba(8, 10, 12, 1));
        --market-border-soft: rgba(255,255,255,0.06);
    }

    html.theme-dim #marketHomeRoot {
        --market-surface: rgba(30, 41, 59, 0.84);
        --market-surface-strong: rgba(15, 23, 42, 0.96);
        --market-card: rgba(17, 24, 39, 0.82);
    }

    html.theme-magma #marketHomeRoot {
        --market-surface: rgba(41, 12, 12, 0.88);
        --market-surface-strong: rgba(25, 6, 6, 0.96);
        --market-card: rgba(58, 16, 16, 0.78);
        --market-text-soft: #fde7d7;
        --market-text-muted: #fca57f;
        --market-border-soft: rgba(249, 115, 22, 0.14);
    }

    html.theme-aurora #marketHomeRoot {
        --market-surface: rgba(31, 15, 43, 0.84);
        --market-surface-strong: rgba(18, 8, 29, 0.95);
        --market-card: rgba(44, 20, 60, 0.72);
        --market-text-soft: #f5e9ff;
        --market-text-muted: #d8b4fe;
        --market-border-soft: rgba(236, 72, 153, 0.12);
    }

    @keyframes marketFadeIn { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes marketShimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    @keyframes marketPing { 75%, 100% { transform: scale(1.8); opacity: 0; } }
    @keyframes marketShine { 100% { transform: translateX(100%); } }

    .market-home { animation: marketFadeIn .35s ease-out forwards; }
    .market-shell { position: relative; overflow: hidden; padding: 20px; border-radius: 18px; background: linear-gradient(180deg, color-mix(in srgb, var(--market-surface) 78%, transparent), var(--market-surface-strong)); border: 1px solid var(--market-border); box-shadow: 0 18px 42px rgba(0,0,0,.28), inset 0 1px 0 rgba(255,255,255,.06); backdrop-filter: blur(16px); }
    .market-status-success { border-color: color-mix(in srgb, #22c55e 35%, transparent); background: linear-gradient(180deg, rgba(6, 36, 25, 0.82), rgba(5, 20, 16, 0.95)); }
    .market-status-error { border-color: color-mix(in srgb, #ef4444 35%, transparent); background: linear-gradient(180deg, rgba(60, 12, 18, 0.84), rgba(26, 8, 12, 0.96)); }
    .market-status-text { position: relative; z-index: 1; color: #fff; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: .18em; }
    .market-shell-glow { position: absolute; width: 260px; height: 260px; border-radius: 999px; pointer-events: none; background: color-mix(in srgb, var(--market-accent) 20%, transparent); filter: blur(70px); opacity: .55; }
    .market-shell-glow-right { top: -140px; right: -90px; }
    .market-shell-glow-left { left: -100px; bottom: -140px; }
    .market-shell-line { position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--market-accent) 65%, transparent), transparent); }
    .market-hero-row, .market-quality-row { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .market-hero-brand { display: flex; align-items: center; gap: 16px; }
    .market-hero-icon { position: relative; width: 56px; height: 56px; border-radius: 16px; display: flex; align-items: center; justify-content: center; color: color-mix(in srgb, var(--market-accent) 72%, white); background: linear-gradient(145deg, color-mix(in srgb, var(--market-accent) 12%, rgba(255,255,255,.04)), rgba(15,23,42,.72)); border: 1px solid color-mix(in srgb, var(--market-accent) 38%, rgba(255,255,255,.08)); box-shadow: 0 0 22px color-mix(in srgb, var(--market-accent) 18%, transparent), inset 0 1px 0 rgba(255,255,255,.12); overflow: hidden; }
    .market-hero-icon-pulse { position: absolute; inset: 0; background: color-mix(in srgb, var(--market-accent) 18%, transparent); opacity: .8; }
    .market-hero-icon-mark { position: relative; z-index: 1; font-size: 22px; text-shadow: 0 0 14px color-mix(in srgb, var(--market-accent) 55%, transparent); }
    .market-hero-title { margin: 0; color: #fff; font-size: 16px; font-weight: 900; text-transform: uppercase; letter-spacing: .18em; }
    .market-hero-subtitle { display: flex; align-items: center; gap: 8px; margin-top: 6px; color: color-mix(in srgb, var(--market-accent) 65%, white); font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: .22em; }
    .market-dot { position: relative; display: inline-flex; width: 10px; height: 10px; }
    .market-dot-ping, .market-dot-core { position: absolute; inset: 0; border-radius: 999px; }
    .market-dot-ping { background: color-mix(in srgb, var(--market-accent) 55%, transparent); animation: marketPing 1.8s cubic-bezier(0, 0, .2, 1) infinite; }
    .market-dot-core { background: var(--market-accent); box-shadow: 0 0 10px var(--market-glow); }
    .market-country-wrap { width: 100%; max-width: 248px; }
    .market-country-box { display: flex; align-items: center; gap: 12px; width: 100%; padding: 8px 12px; border-radius: 14px; background: color-mix(in srgb, var(--market-surface-strong) 82%, transparent); border: 1px solid var(--market-border-soft); box-shadow: inset 0 1px 0 rgba(255,255,255,.05); }
    .market-country-icon { color: color-mix(in srgb, var(--market-accent) 65%, white); font-size: 12px; }
    .market-country-select { width: 100%; }
    #marketHomeRoot select { width: 100%; appearance: none; border: 0; outline: 0; background: transparent; color: #fff; font-size: 11px; font-weight: 800; text-transform: uppercase; }
    #marketHomeRoot select option { background: #111827; color: #f8fafc; font-weight: 700; }
    .market-section-title { position: relative; z-index: 1; display: flex; align-items: center; gap: 10px; margin: 0 0 16px; padding-bottom: 12px; border-bottom: 1px solid var(--market-border-soft); color: var(--market-text-soft); font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: .2em; }
    .market-section-title-inline { margin: 0; padding: 0; border: 0; }
    .market-section-title i { color: var(--market-accent); text-shadow: 0 0 10px color-mix(in srgb, var(--market-accent) 45%, transparent); }
    .market-product-grid { position: relative; z-index: 1; display: flex; flex-wrap: wrap; gap: 12px; }
    .product-tile { width: 86px; height: 86px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; border-radius: 15px; border: 1px solid var(--market-border-soft); background: linear-gradient(145deg, color-mix(in srgb, var(--market-card) 80%, transparent), rgba(15,23,42,.9)); box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 8px 18px rgba(0,0,0,.22); transition: .22s ease; cursor: pointer; overflow: hidden; }
    .product-tile img { opacity: .75; filter: grayscale(100%); transition: .22s ease; }
    .product-tile .name { color: var(--market-text-muted); font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: .05em; transition: .22s ease; }
    .product-tile:hover, .product-tile.active-market-btn { transform: translateY(-3px); border-color: color-mix(in srgb, var(--market-accent) 60%, transparent); background: linear-gradient(145deg, var(--market-card-hover), rgba(15,23,42,.98)); box-shadow: inset 0 1px 0 rgba(255,255,255,.12), 0 14px 24px rgba(0,0,0,.28), 0 0 18px color-mix(in srgb, var(--market-accent) 22%, transparent); }
    .product-tile:hover img, .product-tile.active-market-btn img { opacity: 1; filter: grayscale(0%) drop-shadow(0 0 10px color-mix(in srgb, var(--market-accent) 50%, transparent)); transform: scale(1.12); }
    .product-tile:hover .name, .product-tile.active-market-btn .name { color: #fff; }
    #product-catalogue { animation: marketFadeIn .25s ease-out forwards; }
    .market-shimmer { position: absolute; inset: 0; pointer-events: none; background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--market-accent) 8%, transparent), transparent); background-size: 220% 100%; animation: marketShimmer 7s linear infinite; opacity: .6; }
    .market-quality-list { position: relative; z-index: 1; display: flex; flex-wrap: wrap; gap: 8px; }
    .q-btn { display: inline-flex; align-items: center; justify-content: center; min-width: 64px; padding: 10px 16px; border-radius: 12px; border: 1px solid var(--market-border-soft); background: linear-gradient(180deg, color-mix(in srgb, var(--market-card) 88%, transparent), rgba(15,23,42,.92)); color: var(--market-text-soft); font-size: 11px; font-weight: 900; letter-spacing: .16em; text-transform: uppercase; transition: .2s ease; }
    .q-btn:hover, .q-btn.active-q { color: #fff; border-color: color-mix(in srgb, var(--market-accent) 65%, transparent); background: color-mix(in srgb, var(--market-accent) 12%, var(--market-surface-strong)); box-shadow: 0 0 16px color-mix(in srgb, var(--market-accent) 18%, transparent); }
    .market-table-shell { padding: 6px; }
    .market-table-wrap { position: relative; z-index: 1; overflow-x: auto; padding: 8px; }
    .market-table { width: 100%; min-width: 760px; border-collapse: separate; border-spacing: 0 8px; color: #fff; }
    .market-table thead th { padding: 14px 12px; background: color-mix(in srgb, var(--market-card) 92%, transparent); border-top: 1px solid var(--market-border-soft); border-bottom: 1px solid var(--market-border-soft); color: color-mix(in srgb, var(--market-accent) 30%, white); font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: .16em; }
    .market-table thead th:first-child { border-left: 1px solid var(--market-border-soft); border-radius: 12px 0 0 12px; }
    .market-table thead th:last-child { border-right: 1px solid var(--market-border-soft); border-radius: 0 12px 12px 0; }
    .market-showcase-cell { padding: 14px; border-radius: 12px; text-align: center; background: color-mix(in srgb, var(--market-accent) 10%, transparent); border: 1px dashed color-mix(in srgb, var(--market-accent) 25%, transparent); color: color-mix(in srgb, var(--market-accent) 72%, white); font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: .28em; }
    .market-offer-row { transition: .2s ease; }
    .market-offer-row:hover { transform: translateY(-1px); }
    .market-cell { padding: 14px 12px; background: color-mix(in srgb, var(--market-card) 86%, transparent); border-top: 1px solid var(--market-border-soft); border-bottom: 1px solid var(--market-border-soft); color: #fff; vertical-align: middle; }
    .market-cell:first-child { border-left: 1px solid var(--market-border-soft); border-radius: 14px 0 0 14px; }
    .market-cell:last-child { border-right: 1px solid var(--market-border-soft); border-radius: 0 14px 14px 0; }
    .market-offer-row:hover .market-cell { border-color: color-mix(in srgb, var(--market-accent) 45%, transparent); background: color-mix(in srgb, var(--market-accent) 8%, var(--market-card)); }
    .market-cell-product { display: flex; align-items: center; gap: 14px; }
    .market-product-box { display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 14px; background: color-mix(in srgb, var(--market-surface-strong) 88%, transparent); border: 1px solid var(--market-border-soft); box-shadow: inset 0 1px 0 rgba(255,255,255,.06); }
    .market-product-meta { display: flex; flex-direction: column; gap: 4px; }
    .market-product-name { color: #fff; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: .14em; }
    .market-product-quality { color: color-mix(in srgb, var(--market-accent) 70%, white); font-size: 8px; font-weight: 900; text-transform: uppercase; letter-spacing: .18em; }
    .market-seller-link { display: inline-flex; align-items: center; gap: 8px; color: var(--market-text-soft); font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: .12em; }
    .market-seller-link:hover { color: #fff; }
    .market-seller-dot { width: 8px; height: 8px; border-radius: 999px; background: var(--market-success); box-shadow: 0 0 10px rgba(52, 211, 153, .55); }
    .market-stock-pill, .market-price-pill { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 9px 12px; border-radius: 12px; border: 1px solid var(--market-border-soft); background: color-mix(in srgb, var(--market-surface-strong) 88%, transparent); box-shadow: inset 0 1px 0 rgba(255,255,255,.05); }
    .market-stock-value, .market-price-value { font-family: "JetBrains Mono", monospace; font-size: 13px; font-weight: 900; color: #fff; }
    .market-stock-label { color: var(--market-text-muted); font-size: 8px; font-weight: 800; text-transform: uppercase; letter-spacing: .16em; }
    .market-price-pill { border-color: color-mix(in srgb, var(--market-gold) 32%, transparent); background: color-mix(in srgb, var(--market-gold) 10%, var(--market-surface-strong)); }
    .market-price-value, .market-price-currency { color: var(--market-gold); }
    .market-price-currency { font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: .14em; }
    .market-buy-box { display: flex; align-items: center; justify-content: flex-end; gap: 10px; }
    .market-qty-input { width: 64px; padding: 10px 8px; border-radius: 12px; border: 1px solid var(--market-border-soft); background: color-mix(in srgb, var(--market-surface-strong) 92%, transparent); color: #fff; font-size: 11px; font-weight: 900; text-align: center; outline: none; }
    .market-qty-input:focus { border-color: color-mix(in srgb, var(--market-accent) 60%, transparent); box-shadow: 0 0 0 1px color-mix(in srgb, var(--market-accent) 30%, transparent); }
    .market-buy-btn { position: relative; z-index: 12; pointer-events: auto; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; padding: 0; overflow: hidden; border-radius: 14px; border: 1px solid color-mix(in srgb, var(--market-accent) 45%, transparent); background: linear-gradient(180deg, color-mix(in srgb, var(--market-accent) 90%, white), color-mix(in srgb, var(--market-accent) 76%, black)); color: #fff; font-size: 14px; box-shadow: 0 10px 22px color-mix(in srgb, var(--market-accent) 28%, transparent), inset 0 1px 0 rgba(255,255,255,.25); transition: .2s ease; }
    .market-buy-btn:hover { transform: translateY(-1px); box-shadow: 0 14px 28px color-mix(in srgb, var(--market-accent) 36%, transparent), inset 0 1px 0 rgba(255,255,255,.3); }
    .market-buy-shine { position: absolute; inset: 0 auto 0 -130%; width: 75%; background: linear-gradient(90deg, transparent, rgba(255,255,255,.32), transparent); }
    .market-buy-btn:hover .market-buy-shine { animation: marketShine 1.1s ease; }
    .market-empty-cell { padding: 76px 16px; text-align: center; }
    .market-state-icon { position: relative; display: inline-flex; align-items: center; justify-content: center; width: 82px; height: 82px; margin-bottom: 18px; border-radius: 999px; border: 1px solid color-mix(in srgb, var(--market-accent) 30%, transparent); background: color-mix(in srgb, var(--market-accent) 10%, var(--market-surface-strong)); color: color-mix(in srgb, var(--market-accent) 65%, white); box-shadow: 0 0 30px color-mix(in srgb, var(--market-accent) 15%, transparent); }
    .market-state-icon i { font-size: 30px; text-shadow: 0 0 14px color-mix(in srgb, var(--market-accent) 35%, transparent); }
    .market-state-ring { position: absolute; inset: 0; border-radius: 999px; border: 2px solid color-mix(in srgb, var(--market-accent) 24%, transparent); animation: marketPing 2s cubic-bezier(0, 0, .2, 1) infinite; }
    .market-state-title { color: #fff; font-size: 13px; font-weight: 900; text-transform: uppercase; letter-spacing: .35em; margin-bottom: 8px; }
    .market-state-copy { color: var(--market-text-muted); font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: .14em; }
    @media (max-width: 768px) {
        .market-shell { padding: 16px; border-radius: 16px; }
        .market-hero-title { font-size: 14px; }
        .market-country-wrap { max-width: 100%; }
        .market-cell-product { min-width: 220px; }
        .market-buy-box { min-width: 170px; }
    }
</style>

<script>
$(document).ready(function() {
    const ROOT_ID = 'marketHomeRoot';
    const MAX_Q = 5;

    function getSelectedCountry() {
        const urlParams = new URLSearchParams(window.location.search);
        const countryId = urlParams.get('country');
        if (countryId && !isNaN(parseInt(countryId, 10))) {
            return parseInt(countryId, 10);
        }
        return 1;
    }

    function buildOffersUrl(tpl, itemId, q) {
        let url = String(tpl || '');
        url = decodeURIComponent(url);
        url = url.replace('__ITEM__', String(itemId)).replace('__Q__', String(q));
        const c = getSelectedCountry();
        url += (url.includes('?') ? '&' : '?') + 'country=' + encodeURIComponent(String(c));
        return url;
    }

    function renderState(type, title, copy) {
        const tbody = document.getElementById('offers-table-body');
        let icon = 'fa-radar';

        if (type === 'error') {
            icon = 'fa-triangle-exclamation';
        }

        tbody.innerHTML = `
            <tr>
                <td colspan="5" class="market-empty-cell">
                    <div class="market-state-icon">
                        <div class="market-state-ring"></div>
                        <i class="fa-solid ${icon}"></i>
                    </div>
                    <div class="market-state-title">${title}</div>
                    <p class="market-state-copy">${copy}</p>
                </td>
            </tr>
        `;
    }

    function fetchMarketData(url, btnElement) {
        const tbody = document.getElementById('offers-table-body');

        document.querySelectorAll('.q-btn').forEach(b => b.classList.remove('active-q'));
        if (btnElement) btnElement.classList.add('active-q');

        renderState('loading', '{{ t('marketplace.js.loading_title') }}', '{{ t('marketplace.js.loading_copy') }}');

        $.ajax({
            url: url,
            type: 'GET',
            success: function(response) {
                window.history.pushState({path: url}, '', url);
                let $parsed = $('<div>').html(response);
                let $newRows = $parsed.find('#item-results tbody').html();

                if ($newRows && $newRows.trim() !== '') {
                    $newRows = $newRows.replace(/<tr id="initial-showcase-msg">.*?<\/tr>/s, '');
                    $(tbody).html($newRows);
                } else {
                    renderState('empty', '{{ t('marketplace.js.empty_title') }}', '{{ t('marketplace.js.empty_copy') }}');
                }

            },
            error: function() {
                renderState('error', '{{ t('marketplace.js.error_title') }}', '{{ t('marketplace.js.error_copy') }}');
            }
        });
    }

    function renderQualities(itemId) {
        const catalogue = document.getElementById('product-catalogue');
        const list = document.getElementById('qualityList');
        const tpl = document.getElementById('tpl-item-quality');

        if (!catalogue || !list || !tpl) return;

        list.innerHTML = '';

        for (let q = 0; q <= MAX_Q; q++) {
            const node = tpl.content.cloneNode(true);
            const a = node.querySelector('a');
            const span = node.querySelector('.q-label');
            const finalUrl = buildOffersUrl(a.getAttribute('data-url-template'), itemId, q);

            a.onclick = function(e) {
                e.preventDefault();
                fetchMarketData(finalUrl, this);
            };

            span.textContent = 'Q' + q;
            list.appendChild(node);
        }

        catalogue.classList.remove('hidden');
    }

    function activateBtn(btn) {
        document.querySelectorAll('[data-action="show-product-catalogue"]').forEach(b => b.classList.remove('active-market-btn'));
        btn.classList.add('active-market-btn');
    }

    function bind() {
        const root = document.getElementById(ROOT_ID);
        if (!root) return;

        root.querySelectorAll('[data-action="show-product-catalogue"]').forEach(btn => {
            btn.addEventListener('click', function() {
                activateBtn(btn);
                renderQualities(btn.getAttribute('data-id'));
            });
        });

        if (typeof window.peque !== 'undefined' && window.peque.market) {
        }
    }

    bind();
});
</script>
