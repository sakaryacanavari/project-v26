<!DOCTYPE html>
<html lang="{{ lang|default('tr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token|default('') }}">
    <base href="{{ base_url() }}/">
    <title>S-REPUBLIK | V7.0 OMNI-COMMAND</title>

    {% set v26Css = vite_asset('app.css') %}
    {% set v26Js = vite_asset('app.js') %}
    {% if v26Css %}<link rel="stylesheet" href="{{ v26Css }}">{% endif %}
    {% if v26Js %}<script type="module" src="{{ v26Js }}" defer></script>{% endif %}

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/1.12.1/jquery.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    {% include 'common/omni-themes.html.twig' %}

    <style>
        * { font-style: normal !important; box-sizing: border-box; outline: none; }

        body {
            background-color: var(--bg-deep, #020617);
            background-image: 
                radial-gradient(ellipse at 10% 20%, rgba(0, 242, 254, 0.15), transparent 40%),
                radial-gradient(ellipse at 90% 80%, rgba(251, 194, 235, 0.15), transparent 40%),
                radial-gradient(ellipse at 50% 50%, rgba(10, 15, 20, 0.9), var(--bg-deep, #020617));
            color: #f8fafc;
            font-family: 'Inter', sans-serif;
            margin: 0;
            overflow-x: hidden;
            padding-bottom: 8px;
            transition: background-color 0.4s ease;
        }
        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23ffffff" fill-opacity="0.03"%3E%3Cpath d="M30 30h30v30H30zM0 0h30v30H0z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');
            z-index: -1;
        }

        .glass-panel {
            background: rgba(10, 15, 20, 0.35);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 20px;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.1), 0 20px 44px -18px rgba(0,0,0,0.72);
            backdrop-filter: blur(16px) saturate(130%);
            -webkit-backdrop-filter: blur(16px) saturate(130%);
            transition: background-color 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
        }

        .main-container { width: 100%; max-width: 1550px; margin: 0 auto; display: flex; padding: 24px 24px 8px; gap: 24px; }
        @media (min-width: 1920px) { .main-container { max-width: 1840px; } }
        .hud-stack.gx-hud-compact { width: 17rem; gap: 8px; }
        .hud-stack.gx-hud-compact .hud-panel { padding: 11px !important; border-radius: 14px; }
        .hud-stack.gx-hud-compact .avatar-box { width: 64px; height: 64px; border-radius: 18px; }
        .hud-stack.gx-hud-compact .avatar-box img { border-radius: 16px; }
        .hud-stack.gx-hud-compact .hud-stat-card { padding: 8px !important; min-width: 0; }
        .hud-stack.gx-hud-compact .hud-kicker { font-size: 8px; }
        .hud-stack.gx-hud-compact .hud-meta { font-size: 9px; }
        .hud-stack.gx-hud-compact .hud-value { font-size: 13px; }
        .hud-stack.gx-hud-compact .hud-row { gap: 8px; }
        .hud-stack.gx-hud-compact .hud-chip { padding: 5px 8px; font-size: 9px; }
        .hud-stack.gx-hud-compact .hud-icon { width: 28px; height: 28px; flex: 0 0 28px; }
        .hud-stack.gx-hud-compact .hud-resource-row,
        .hud-stack.gx-hud-compact .hud-money-row { min-height: 34px; padding: 8px; }
        .hud-stack.gx-hud-compact .hud-resource-label,
        .hud-stack.gx-hud-compact .hud-money-label { font-size: 9px; gap: 6px; }
        .hud-stack.gx-hud-compact .hud-stat-card span,
        .hud-stack.gx-hud-compact .hud-row > span,
        .hud-stack.gx-hud-compact .hud-value { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .hud-stack.gx-hud-compact .hud-stat-card .hud-row > span:first-child { flex: 1 1 auto; }

        .nav-item { position: relative; height: 100%; display: flex; align-items: center; }
        .top-nav-link {
            padding: 0 18px;
            color: #94a3b8;
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
            height: 100%;
            cursor: pointer;
        }
        .nav-item::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: var(--brand-primary);
            transform: scaleX(0);
            transition: 0.3s ease;
            box-shadow: 0 -2px 10px var(--brand-glow);
        }
        .nav-item:hover::after { transform: scaleX(1); }
        .nav-item:hover .top-nav-link {
            color: #fff;
            background: color-mix(in srgb, var(--brand-primary) 10%, transparent);
        }

        .dropdown-v6 {
            position: absolute;
            top: 100%;
            left: 0;
            width: 240px;
            background: rgba(10, 15, 30, 0.95);
            backdrop-filter: blur(12px);
            border: 1px solid color-mix(in srgb, var(--brand-primary) 20%, transparent);
            border-top: none;
            border-radius: 0 0 16px 16px;
            padding: 12px;
            z-index: 100;
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
        }
        .nav-item:hover .dropdown-v6 { opacity: 1; visibility: visible; transform: translateY(0); }

        .drop-link {
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #94a3b8;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            border-radius: 10px;
            transition: all 0.2s;
        }
        .drop-link:hover {
            background: linear-gradient(90deg, color-mix(in srgb, var(--brand-primary) 15%, transparent) 0%, transparent 100%);
            color: #fff;
            padding-left: 22px;
            border-left: 2px solid var(--brand-primary);
        }

        .avatar-box {
            width: 96px;
            height: 96px;
            border-radius: 28px;
            border: 1px solid rgba(255,255,255,0.15);
            padding: 4px;
            background: linear-gradient(145deg, rgba(255,255,255,0.1) 0%, rgba(0,0,0,0.3) 100%);
            box-shadow: inset 0 2px 15px rgba(255,255,255,0.05), 0 15px 30px -5px rgba(0,0,0,0.5);
            transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
        }
        .avatar-box:hover {
            transform: translateY(-2px);
            box-shadow: inset 0 2px 15px rgba(255,255,255,0.1), 0 14px 28px -14px rgba(0,0,0,0.54), 0 0 14px color-mix(in srgb, var(--brand-primary) 22%, transparent);
            border-color: rgba(255,255,255,0.3);
        }
        .avatar-box img { width: 100%; height: 100%; border-radius: 22px; object-fit: cover; }
        .avatar-box + .text-center > .text-lg {
            text-transform: uppercase !important;
            letter-spacing: 0.05em !important;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
        }

        .glass-inset {
            background: linear-gradient(180deg, rgba(255,255,255,0.03) 0%, rgba(0,0,0,0.4) 100%);
            border: 1px solid rgba(255,255,255,0.05);
            border-top: 1px solid rgba(255,255,255,0.12);
            border-radius: 12px;
            box-shadow: inset 0 2px 20px rgba(0,0,0,0.5), 0 4px 15px rgba(0,0,0,0.3);
            backdrop-filter: blur(4px);
            transition: transform 0.22s ease, border-color 0.22s ease, background 0.22s ease, box-shadow 0.22s ease;
        }
        .glass-inset:hover {
            border-color: rgba(255,255,255,0.2);
            border-top-color: rgba(255,255,255,0.3);
            background: linear-gradient(180deg, rgba(255,255,255,0.06) 0%, rgba(0,0,0,0.5) 100%);
            box-shadow: inset 0 2px 10px rgba(255,255,255,0.05), 0 6px 16px rgba(0,0,0,0.4);
            transform: translateY(-1px);
        }

        .bar-container { height: 6px; border-radius: 99px; background: rgba(0,0,0,0.5); overflow: hidden; border: 1px solid rgba(255,255,255,0.08); box-shadow: inset 0 1px 3px rgba(0,0,0,0.5); }
        .bar-xp { background: linear-gradient(90deg, #3b82f6, #93c5fd); height: 100%; box-shadow: 0 0 10px rgba(59,130,246,0.8); }
        .bar-energy { background: linear-gradient(90deg, #f59e0b, #fde68a); height: 100%; box-shadow: 0 0 10px rgba(245,158,11,0.8); }
        .status-dot { width: 8px; height: 8px; border-radius: 99px; background: #10b981; box-shadow: 0 0 12px rgba(16,185,129,0.9); border: 1px solid rgba(255,255,255,0.3); }
        .hud-stack {
            position: sticky;
            top: 96px;
            max-height: calc(100vh - 140px);
            gap: 9px;
            overflow-y: auto;
            overflow-x: hidden;
            padding-right: 5px;
            padding-bottom: 12px;
            scrollbar-width: thin;
            scrollbar-color: color-mix(in srgb, var(--brand-primary) 24%, rgba(148,163,184,.18)) transparent;
        }
        .hud-stack::-webkit-scrollbar { width: 4px; }
        .hud-stack::-webkit-scrollbar-thumb {
            border-radius: 999px;
            background: color-mix(in srgb, var(--brand-primary) 22%, rgba(148,163,184,.2));
        }
        .hud-panel {
            position: relative;
            flex: 0 0 auto;
            overflow: hidden;
            background:
                radial-gradient(circle at 16% 0%, color-mix(in srgb, var(--brand-primary) 12%, transparent), transparent 42%),
                linear-gradient(180deg, rgba(255,255,255,0.052), rgba(0,0,0,0.26)),
                rgba(10, 15, 24, 0.48);
            border-color: rgba(255,255,255,0.078);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.085), 0 14px 32px -24px rgba(0,0,0,0.9);
        }
        .hud-panel::before {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            height: 1px;
            background: linear-gradient(90deg, color-mix(in srgb, var(--brand-primary) 65%, transparent), transparent 72%);
            opacity: 0.75;
        }
        .hud-panel > * { position: relative; z-index: 1; }
        .hud-kicker { font-size: 9px; font-weight: 950; letter-spacing: .14em; text-transform: uppercase; color: color-mix(in srgb, var(--text-muted, #94a3b8) 88%, #fff); }
        .hud-meta { font-size: 10px; font-weight: 800; line-height: 1.35; color: color-mix(in srgb, var(--text-muted, #94a3b8) 82%, #fff); }
        .hud-value { font-family: 'JetBrains Mono', monospace; font-weight: 950; color: var(--text-main, #fff); font-variant-numeric: tabular-nums; }
        .hud-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            min-width: 0;
        }
        .hud-chip {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            min-height: 24px;
            padding: 0 9px;
            border-radius: 999px;
            background: rgba(0,0,0,.28);
            border: 1px solid rgba(255,255,255,.08);
            color: #cbd5e1;
            font-size: 9px;
            font-weight: 950;
            letter-spacing: .1em;
            text-transform: uppercase;
            white-space: nowrap;
        }
        .hud-stat-card {
            min-width: 0;
            border-radius: 11px;
            border: 1px solid rgba(255,255,255,0.065);
            background: linear-gradient(180deg, rgba(255,255,255,.035), rgba(0,0,0,.2));
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
        }
        .hud-avatar {
            width: 74px;
            height: 74px;
            border-radius: 20px;
        }
        .hud-progress {
            height: 7px;
            border-radius: 999px;
            overflow: hidden;
            background: rgba(0,0,0,.58);
            border: 1px solid rgba(255,255,255,.08);
            box-shadow: inset 0 1px 4px rgba(0,0,0,.55);
        }
        .hud-progress > span {
            display: block;
            height: 100%;
            width: var(--hud-progress, 0%);
            border-radius: inherit;
            background: linear-gradient(90deg, color-mix(in srgb, var(--brand-primary) 60%, white), var(--brand-primary));
            box-shadow: 0 0 12px color-mix(in srgb, var(--brand-primary) 45%, transparent);
        }
        .hud-progress.energy > span { background: linear-gradient(90deg, #f59e0b, #fde68a); box-shadow: 0 0 12px rgba(245,158,11,.45); }
        .hud-progress.daily > span { background: linear-gradient(90deg, #22c55e, #a7f3d0); box-shadow: 0 0 12px rgba(34,197,94,.35); }
        .hud-icon {
            width: 30px;
            height: 30px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(0,0,0,.3);
            border: 1px solid rgba(255,255,255,.08);
            color: var(--brand-primary);
            flex: 0 0 auto;
        }
        .hud-resource-row,
        .hud-money-row {
            min-height: 36px;
            border-radius: 11px;
            border: 1px solid rgba(255,255,255,0.06);
            background: linear-gradient(180deg, rgba(255,255,255,.028), rgba(2,6,23,.20));
            padding: 9px 10px;
        }
        .hud-resource-label,
        .hud-money-label {
            display: inline-flex;
            align-items: center;
            min-width: 0;
            gap: 8px;
            color: color-mix(in srgb, var(--text-main, #e5e7eb) 84%, var(--text-muted, #94a3b8));
            font-size: 10px;
            font-weight: 950;
            letter-spacing: .08em;
            text-transform: uppercase;
        }
        .hud-section-tight { padding: 12px !important; }
        .hud-logout-link {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 38px;
            letter-spacing: .12em;
        }

        .ticker-v6 {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 35px;
            background: rgba(0, 0, 0, 0.9);
            z-index: 1000;
            display: flex;
            align-items: center;
            overflow: hidden;
            box-shadow: none;
        }
        @keyframes ticker-scroll { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }
        .ticker-content { white-space: nowrap; animation: ticker-scroll 40s linear infinite; display: flex; gap: 60px; }
        .mono-font { font-family: 'JetBrains Mono', monospace; }

        .omni-ico {
            position: relative;
            width: 42px;
            height: 42px;
            border-radius: 13px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(180deg, rgba(15, 23, 42, .72), rgba(2, 6, 23, .72));
            border: 1px solid rgba(148, 163, 184, .14);
            color: #e5e7eb;
            transition: .18s ease;
            user-select: none;
        }
        .omni-ico:hover, .omni-ico:focus-visible {
            transform: translateY(-1px);
            border-color: rgba(34, 211, 238, .34);
            color: #fff;
            box-shadow: 0 12px 24px rgba(8, 145, 178, .18);
            outline: none;
        }
        .omni-logout {
            color: #fca5a5;
            border-color: rgba(248, 113, 113, .24);
            background: linear-gradient(180deg, rgba(69, 10, 10, .24), rgba(15, 23, 42, .76));
        }
        .omni-logout:hover, .omni-logout:focus-visible {
            border-color: rgba(248, 113, 113, .48);
            color: #fff;
            box-shadow: 0 12px 24px rgba(220, 38, 38, .16);
        }
        .omni-badge {
            position: absolute;
            top: -6px;
            right: -6px;
            min-width: 20px;
            height: 20px;
            border-radius: 999px;
            background: linear-gradient(180deg, #ffdd7a, #d68a00);
            color: #2b1600;
            font-weight: 900;
            font-size: 11px;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 0 6px;
            border: 1px solid rgba(0,0,0,.35);
            box-shadow: 0 0 14px rgba(255,221,122,.22);
        }
        .omni-drop {
            position: absolute;
            right: 0;
            top: calc(100% + 16px);
            width: min(420px, calc(100vw - 24px));
            border-radius: 18px;
            overflow: hidden;
            background: linear-gradient(180deg, rgba(10, 15, 28, 0.98) 0%, rgba(3, 7, 18, 0.99) 100%);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(148,163,184,0.14);
            display: none;
            z-index: 10000;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.04), 0 18px 40px -20px rgba(0,0,0,0.78);
            transform-origin: top right;
            animation: omniPop .2s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        @keyframes omniPop { from { opacity:0; transform: translateY(10px) scale(.95); } to { opacity:1; transform: translateY(0) scale(1); } }

        .omni-top {
            padding: 14px 14px 12px;
            background: rgba(15, 23, 42, .72);
            border-bottom: 1px solid rgba(148,163,184,.12);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }
        .omni-top .ttl {
            font-weight: 950;
            letter-spacing: .14em;
            text-transform: uppercase;
            font-size: 10px;
            color: #dbeafe;
            white-space: nowrap;
        }
        .omni-top .right { display: flex; align-items: center; gap: 8px; }

        .omni-mini {
            height: 32px;
            min-width: 32px;
            padding: 0 10px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(2,6,23,.46);
            border: 1px solid rgba(148,163,184,.14);
            color: #cbd5e1;
            font-weight: 950;
            font-size: 10px;
            letter-spacing: .12em;
            text-transform: uppercase;
            transition: .16s ease;
            user-select: none;
        }
        .omni-mini:hover, .omni-mini:focus-visible {
            color: #fff;
            border-color: color-mix(in srgb, var(--brand-primary) 34%, rgba(255,255,255,.10));
            background: color-mix(in srgb, var(--brand-primary) 10%, rgba(2,6,23,.64));
            outline: none;
        }

        .omni-tabs {
            padding: 10px 14px;
            display: flex;
            gap: 8px;
            background: rgba(2,6,23,.5);
            border-bottom: 1px solid rgba(148,163,184,.10);
        }
        .omni-tab {
            flex: 1;
            height: 38px;
            border-radius: 10px;
            border: 1px solid rgba(148,163,184,.08);
            background: rgba(15,23,42,.34);
            color: #7f8ea3;
            font-weight: 950;
            font-size: 10px;
            letter-spacing: .14em;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all .3s cubic-bezier(0.2, 0.8, 0.2, 1);
            user-select: none;
            position: relative;
            overflow: hidden;
        }
        .omni-tab:hover, .omni-tab:focus-visible {
            color: #e5e7eb;
            border-color: rgba(148,163,184,.20);
            background: rgba(15,23,42,.62);
            outline: none;
        }
        .omni-tab.active {
            color: #fff;
            border-color: color-mix(in srgb, var(--brand-primary) 36%, rgba(255,255,255,.08));
            background: linear-gradient(180deg, color-mix(in srgb, var(--brand-primary) 16%, rgba(15,23,42,.85)), rgba(2,6,23,.78));
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.10), 0 8px 18px color-mix(in srgb, var(--brand-primary) 10%, transparent);
        }

        .omni-pane { display: none; }
        .omni-pane.active { display: block; }

        .omni-list { max-height: min(360px, calc(100vh - 230px)); overflow: auto; padding: 8px; }
        .omni-list::-webkit-scrollbar { width: 10px; }
        .omni-list::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,.10);
            border: 2px solid rgba(0,0,0,.25);
            border-radius: 999px;
        }

        .omni-item {
            position: relative;
            display: flex;
            gap: 12px;
            align-items: flex-start;
            padding: 11px 12px;
            border: 1px solid rgba(148,163,184,.08);
            border-radius: 13px;
            color: #e5e7eb;
            text-decoration: none;
            transition: .14s ease;
            background: rgba(15,23,42,.28);
            margin-bottom: 7px;
            min-width: 0;
        }
        .omni-item:last-child { margin-bottom: 0; }
        .omni-item:hover, .omni-item:focus-visible {
            background: color-mix(in srgb, var(--brand-primary) 8%, rgba(15,23,42,.46));
            border-color: color-mix(in srgb, var(--brand-primary) 18%, rgba(148,163,184,.12));
            transform: translateY(-1px);
            outline: none;
        }
        .omni-item.unread::before {
            content: '';
            position: absolute;
            left: 0;
            top: 12px;
            bottom: 12px;
            width: 3px;
            border-radius: 0 999px 999px 0;
            background: var(--brand-primary);
            box-shadow: 0 0 10px color-mix(in srgb, var(--brand-primary) 32%, transparent);
        }

        .omni-i {
            width: 36px;
            height: 36px;
            border-radius: 12px;
            background: rgba(2,6,23,.48);
            border: 1px solid rgba(148,163,184,.12);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #cbd5e1;
            flex: 0 0 auto;
        }
        .omni-i.unread {
            color: var(--brand-primary);
            border-color: color-mix(in srgb, var(--brand-primary) 34%, transparent);
            box-shadow: 0 0 12px color-mix(in srgb, var(--brand-primary) 14%, transparent);
        }

        .omni-c { min-width: 0; flex: 1 1 auto; }
        .omni-title {
            font-weight: 950;
            font-size: 12.5px;
            color: #f8fafc;
            line-height: 1.18rem;
            display: flex;
            align-items: center;
            gap: 8px;
            min-width: 0;
            overflow-wrap: anywhere;
        }
        .omni-sub {
            margin-top: 4px;
            font-weight: 650;
            font-size: 11px;
            color: #a8b3c3;
            line-height: 1.25rem;
            display: -webkit-box;
            -webkit-box-orient: vertical;
            -webkit-line-clamp: 2;
            overflow: hidden;
            overflow-wrap: anywhere;
        }
        .omni-meta {
            margin-top: 6px;
            font-weight: 900;
            font-size: 10px;
            letter-spacing: .10em;
            text-transform: uppercase;
            color: #64748b;
        }
        .omni-pill {
            margin-left: auto;
            font-weight: 950;
            font-size: 9px;
            border-radius: 999px;
            padding: 2px 7px;
            white-space: nowrap;
            background: color-mix(in srgb, var(--brand-primary) 16%, rgba(2,6,23,.7));
            color: #dffdf2;
            border: 1px solid color-mix(in srgb, var(--brand-primary) 28%, transparent);
        }
        .omni-empty {
            justify-content: center;
            text-align: center;
            padding: 18px 14px;
        }
        .omni-empty .omni-title { justify-content: center; }
        .omni-empty .omni-sub { -webkit-line-clamp: 1; }
        .omni-refreshing i {
            animation: spin .65s linear infinite;
        }

        .omni-foot {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            padding: 10px 14px;
            background: rgba(2,6,23,.62);
            border-top: 1px solid rgba(148,163,184,.10);
        }

        .omni-skel { padding: 8px; }
        .sk {
            height: 10px;
            border-radius: 999px;
            background: linear-gradient(90deg, rgba(255,255,255,.06), rgba(255,255,255,.10), rgba(255,255,255,.06));
            background-size: 240% 100%;
            animation: sk 1.6s infinite;
            margin: 10px 4px;
            margin-bottom: 10px;
        }
        .sk.w70 { width:70%; }
        .sk.w55 { width:55%; }
        .sk.w85 { width:85%; }
        @keyframes sk { 0% { background-position: 0% 0; } 100% { background-position: 220% 0; } }
        @media (max-width: 520px) {
            .omni-drop {
                position: fixed;
                left: 12px;
                right: 12px;
                top: 68px;
                width: auto;
                transform-origin: top right;
            }
            .omni-top, .omni-tabs, .omni-foot { padding-left: 12px; padding-right: 12px; }
            .omni-list { max-height: calc(100vh - 220px); }
            .omni-ico { width: 40px; height: 40px; }
        }

        .animate-spin-slow {
            animation: spin 3s linear infinite;
        }
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>
</head>
