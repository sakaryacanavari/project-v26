                {% endif %}
            </div>
        </div>

        {# Çalışma durumu HUD kartı kaldırıldı. #}
        {#
        <div class="glass-panel hud-panel hud-section-tight">
            <div class="hud-kicker">{{ t('base.sidebar.work_status') }}</div>
            <div class="mt-2.5 flex items-start gap-3">
                <span class="hud-icon"><i class="fa-solid fa-briefcase"></i></span>
                <div class="min-w-0 flex-1">
                    <div class="truncate text-[12px] font-black uppercase text-[color:var(--text-main,#fff)]">{{ hudJob.title|default(t('base.sidebar.active_contract_missing')) }}</div>
                    <div class="hud-meta mt-1 truncate uppercase">{{ hudJob.company|default(t('base.sidebar.company_info_missing')) }}</div>
                    {% if hudJob.hasJob|default(false) %}
                        <div class="mt-2 text-[10px] font-black uppercase tracking-widest {{ hudJob.workedToday|default(false) ? 'text-emerald-300' : 'text-amber-300' }}">
                            {{ hudJob.status }}{% if hudJob.salary|default(0) > 0 %} · {{ hudJob.salary|number_format(2) }} {{ hudJob.currency }}{% endif %}
                        </div>
                    {% else %}
                        <div class="hud-meta mt-2 font-black uppercase tracking-widest">{{ hudJob.status|default(t('base.sidebar.no_active_job')) }}</div>
                    {% endif %}
                </div>
            </div>
        </div>
        #}

        <div class="glass-panel hud-panel hud-section-tight space-y-2">
            <div class="hud-row hud-money-row">
                <span class="hud-money-label"><i class="fa-solid fa-coins text-yellow-400"></i>Gold</span>
                <span class="hud-value">{{ hudMoney.gold|default(0)|number_format(2) }}</span>
            </div>
            <div class="hud-row hud-money-row">
                <span class="hud-money-label">
                    {% if hudLocation.countryId|default(0) %}<img src="img/flags/{{ hudLocation.countryId }}.png" class="h-4 w-6 rounded-sm object-cover" alt="" loading="lazy" decoding="async" onerror="this.style.display='none'">{% endif %}
                    {{ hudMoney.localCurrency|default('') ?: 'LOCAL' }}
                </span>
                <span class="hud-value">{{ hudMoney.local|default(0)|number_format(2) }}</span>
            </div>
        </div>

        <a href="{{ path_for('logout') }}" class="glass-panel hud-panel hud-logout-link border-red-900/40 bg-red-950/20 px-3 py-2.5 text-center text-[10px] font-black uppercase text-red-400 transition-all hover:bg-red-600 hover:text-white"><i class="fa-solid fa-right-from-bracket"></i>{{ t('base.sidebar.disconnect') }}</a>
    </aside>
    {% endif %}

    <main class="flex-1 min-w-0 w-full">
        {% block content %}{% endblock %}
    </main>
</div>

<div class="ticker-v6">
    <div class="ticker-content">
        {% set tickerHud = sidebarHud|default({}) %}
        {% set tickerUser = tickerHud.user|default({}) %}
        {% set tickerMoney = tickerHud.money|default({}) %}
        {% set tickerInventory = tickerHud.inventory|default({}) %}
        {% set tickerLocation = tickerHud.location|default({}) %}
        <span class="flex items-center gap-2 text-[10px] font-black text-slate-400 uppercase tracking-widest"><i class="fa-solid fa-coins text-yellow-500"></i> GOLD <span class="text-white ml-1">{{ tickerMoney.gold|default(0)|number_format(2) }}</span></span>
        <span class="flex items-center gap-2 text-[10px] font-black text-slate-400 uppercase tracking-widest"><i class="fa-solid fa-building-columns text-cyan-400"></i> {{ tickerMoney.localCurrency|default('LOCAL') }} <span class="text-white ml-1">{{ tickerMoney.local|default(0)|number_format(2) }}</span></span>
        <span class="flex items-center gap-2 text-[10px] font-black text-slate-400 uppercase tracking-widest"><i class="fa-solid fa-utensils text-indigo-400"></i> {{ t('base.sidebar.bread') }} <span class="text-white ml-1">{{ tickerInventory.bread|default(0) }}</span></span>
        <span class="flex items-center gap-2 text-[10px] font-black text-slate-400 uppercase tracking-widest"><i class="fa-solid fa-gun text-red-500"></i> {{ t('base.sidebar.weapon') }} <span class="text-white ml-1">{{ tickerInventory.weapons|default(0) }}</span></span>
        <span class="flex items-center gap-2 text-[10px] font-black text-slate-400 uppercase tracking-widest"><i class="fa-solid fa-location-dot text-emerald-400"></i> {{ tickerLocation.country|default('-') }} <span class="text-white ml-1">{{ tickerLocation.region|default('') }}</span></span>
        <span class="flex items-center gap-2 text-[10px] font-black text-slate-400 uppercase tracking-widest"><i class="fa-solid fa-bolt text-amber-400"></i> {{ t('base.sidebar.energy') }} <span class="text-white ml-1">{{ tickerUser.energy|default(0) }}/100</span></span>
        <span class="text-[10px] font-black uppercase tracking-[0.2em]" style="color: var(--brand-primary);">{{ t('base.ticker.online') }}</span>
    </div>
</div>

<script>
    window.CSRF_TOKEN = "{{ csrf_token|default('')|e('js') }}";

    if (window.jQuery && window.CSRF_TOKEN) {
        $.ajaxSetup({
            headers: {
                'X-CSRF-Token': window.CSRF_TOKEN
            }
        });
    }

    function updateClock() {
        const time = new Date().toLocaleTimeString('tr-TR', { hour12: false });
        const liveClock = document.getElementById('live-clock');
        const headerClock = document.getElementById('header-clock');

        if (liveClock) {
            liveClock.textContent = time;
        }

        if (headerClock) {
            headerClock.textContent = time;
        }
    }

    setInterval(updateClock, 1000);
    updateClock();

    document.addEventListener('DOMContentLoaded', function () {
        if (!window.CSRF_TOKEN) {
            return;
        }

        var forms = document.querySelectorAll('form[method="post"], form[method="POST"]');
        for (var i = 0; i < forms.length; i++) {
            if (forms[i].querySelector('input[name="csrf_token"]')) {
                continue;
            }

            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'csrf_token';
            input.value = window.CSRF_TOKEN;
            forms[i].appendChild(input);
        }
    });
</script>

<script>
$(function(){
    const BASE = "{{ base_url() }}".replace(/\/+$/, '');
    const NOTIF_ALL = "{{ path_for('notifications') }}";
    const MSG_ALL = "{{ path_for('messages') }}";

    function setBadge($el, n){
        n = parseInt(n || 0, 10);
        if(n > 0){
            $el.text(n > 99 ? '99+' : n);
            $el.css('display', 'inline-flex');
        } else {
            $el.hide();
        }
    }

    function escapeText(s){
        return String(s || '').replace(/[&<>"']/g, function(c){
            return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]);
        });
    }

    function skel(){
        return (
            '<div class="omni-skel">' +
                '<div class="sk w70"></div>' +
                '<div class="sk w85"></div>' +
                '<div class="sk w55"></div>' +
            '</div>'
        );
    }

    function notifIcon(type){
        type = String(type || '').toLowerCase();
        if(!type) return 'fa-solid fa-bolt';
        if(type.indexOf('war') !== -1 || type.indexOf('battle') !== -1 || type.indexOf('country_critical') !== -1) return 'fa-solid fa-crosshairs';
        if(type.indexOf('party') !== -1 || type.indexOf('clan') !== -1 || type.indexOf('coalition') !== -1) return 'fa-solid fa-users';
        if(type.indexOf('message') !== -1 || type.indexOf('reply') !== -1 || type.indexOf('mention') !== -1) return 'fa-solid fa-message';
        if(type.indexOf('system') !== -1 || type.indexOf('decree') !== -1 || type.indexOf('announcement') !== -1 || type.indexOf('restriction') !== -1) return 'fa-solid fa-bullhorn';
        return 'fa-solid fa-bolt';
    }

    function openDrop(){
        $('#omni-drop').show();
        $('#btn-bell').attr('aria-expanded', 'true');
        refreshDropdown();
    }

    function closeDrop(){
        $('#omni-drop').hide();
        $('#btn-bell').attr('aria-expanded', 'false');
    }

    function isOpen(){
        return $('#omni-drop').is(':visible');
    }

    function setTab(tab){
        $('.omni-tab').removeClass('active').attr('aria-pressed', 'false');
        $('.omni-tab[data-tab="'+tab+'"]').addClass('active').attr('aria-pressed', 'true');
        $('.omni-pane').removeClass('active');
        $('.omni-pane[data-pane="'+tab+'"]').addClass('active');
    }

    function renderNotifs(items){
        var $root = $('#drop-notifs').empty();

        if(!items || !items.length){
            $root.append(
                '<a class="omni-item omni-empty" href="'+NOTIF_ALL+'">' +
                    '<div class="omni-i"><i class="fa-regular fa-bell-slash"></i></div>' +
                    '<div class="omni-c">' +
                        '<div class="omni-title">Şu an yeni bildirim yok</div>' +
                        '<div class="omni-sub">OMNI hattı temiz.</div>' +
                    '</div>' +
                '</a>'
            );
            return;
        }

        for(var i=0;i<items.length;i++){
            var n = items[i] || {};
            var url = n.url ? n.url : NOTIF_ALL;
            var title = escapeText(n.title || '{{ t('base.dropdown.notifications')|e('js') }}');
            var body = escapeText(n.body || '');
            var meta = escapeText(n.created_at || '');
            var notifId = parseInt(n.id || 0, 10);
            var unread = parseInt(n.is_read || 0, 10) === 0;
            var iconClass = unread ? 'omni-i unread' : 'omni-i';
            var itemClass = unread ? 'omni-item omni-notif-item unread' : 'omni-item omni-notif-item';
            var icon = notifIcon(n.type || '');

            $root.append(
                '<a class="'+itemClass+'" href="'+url+'" data-id="'+notifId+'">' +
                    '<div class="'+iconClass+'"><i class="'+icon+'"></i></div>' +
                    '<div class="omni-c">' +
                        '<div class="omni-title">'+title+(unread?'<span class="omni-pill">YENİ</span>':'')+'</div>' +
                        (body ? '<div class="omni-sub">'+body+'</div>' : '') +
                        '<div class="omni-meta">'+meta+'</div>' +
                    '</div>' +
                '</a>'
            );
        }
    }

    function renderDMs(threads){
        var $root = $('#drop-dms').empty();

        if(!threads || !threads.length){
            $root.append(
                '<a class="omni-item omni-empty" href="'+MSG_ALL+'">' +
                    '<div class="omni-i"><i class="fa-regular fa-envelope"></i></div>' +
                    '<div class="omni-c">' +
                        '<div class="omni-title">DM yok</div>' +
                        '<div class="omni-sub">Aktif konuşma bulunamadı.</div>' +
                    '</div>' +
                '</a>'
            );
            return;
        }

        for(var i=0;i<threads.length;i++){
            var t = threads[i] || {};
            var otherUid = parseInt(t.other_uid || 0, 10);
            var name = escapeText(t.other_name || ('User #' + otherUid));
            var snippet = escapeText(t.last_body || '');
            var meta = escapeText(t.last_at || '');
            var unread = parseInt(t.unread || 0, 10);

            var href = BASE + '/messages/' + otherUid;
            var pill = unread > 0 ? '<span class="omni-pill">'+(unread>99?'99+':unread)+'</span>' : '';
            var iconClass = unread > 0 ? 'omni-i unread' : 'omni-i';
            var itemClass = unread > 0 ? 'omni-item unread' : 'omni-item';

            $root.append(
                '<a class="'+itemClass+'" href="'+href+'">' +
                    '<div class="'+iconClass+'"><i class="fa-solid fa-user"></i></div>' +
                    '<div class="omni-c">' +
                        '<div class="omni-title">'+name+pill+'</div>' +
                        (snippet ? '<div class="omni-sub">'+snippet+'</div>' : '') +
                        '<div class="omni-meta">'+meta+'</div>' +
                    '</div>' +
                '</a>'
            );
        }
    }

    function pollBadges(){
        $.post(BASE + '/api/notifications/unread-count', {})
            .done(function(res){
                if(typeof res === 'string'){
                    try { res = JSON.parse(res); } catch(e){ res = {}; }
                }

                var badges = res && res.badges ? res.badges : {};
                setBadge($('#badge-notify'), badges.notifications || 0);
                setBadge($('#badge-dm'), badges.messages || 0);
            })
            .fail(function(){
                setBadge($('#badge-notify'), 0);
                setBadge($('#badge-dm'), 0);
            });
    }

    function refreshDropdown(){
        if(!isOpen()) return;

        $('#omni-refresh').addClass('omni-refreshing').prop('disabled', true);
        $('#drop-notifs').html(skel());
        $('#drop-dms').html(skel());

        $.when(
            $.post(BASE + '/api/notifications/list', { limit: 6 }),
            $.post(BASE + '/api/messages/threads', { limit: 6 })
        ).done(function(notifRes, dmRes){
            var notifPayload = notifRes && notifRes[0] ? notifRes[0] : {};
            var dmPayload = dmRes && dmRes[0] ? dmRes[0] : {};

            if(typeof notifPayload === 'string'){
                try { notifPayload = JSON.parse(notifPayload); } catch(e){ notifPayload = {}; }
            }

            if(typeof dmPayload === 'string'){
                try { dmPayload = JSON.parse(dmPayload); } catch(e){ dmPayload = {}; }
            }

            renderNotifs(notifPayload && notifPayload.items ? notifPayload.items : []);
            renderDMs(dmPayload && dmPayload.threads ? dmPayload.threads : []);

            if(notifPayload && notifPayload.items && notifPayload.items.length){
                var unreadCount = 0;
                for(var i=0;i<notifPayload.items.length;i++){
                    if(parseInt(notifPayload.items[i].is_read || 0, 10) === 0){
                        unreadCount++;
                    }
                }

                if(unreadCount > 0){
                    $.post(BASE + '/api/notifications/mark-all-read', {})
                        .always(function(){
                            pollBadges();
                        });
                } else {
                    pollBadges();
                }
            } else {
                pollBadges();
            }
        }).fail(function(){
            renderNotifs([]);
            renderDMs([]);
        }).always(function(){
            $('#omni-refresh').removeClass('omni-refreshing').prop('disabled', false);
        });
    }

    $('#btn-bell').on('click', function(e){
        e.preventDefault();
        e.stopPropagation();

        if(isOpen()) closeDrop();
        else openDrop();
    });

    $(document).on('click', function(e){
        if(!$(e.target).closest('#omni-comms').length) closeDrop();
    });

    $(document).on('keydown', function(e){
        if(e.key === 'Escape') closeDrop();
    });

    $(document).on('click', '.omni-tab', function(){
        setTab($(this).data('tab'));
    });

    $(document).on('click', '.omni-notif-item', function(){
        var id = parseInt($(this).attr('data-id') || '0', 10);
        if(id > 0){
            $.post(BASE + '/api/notifications/mark-read', { id: id })
                .always(function(){
                    pollBadges();
                });
        }
    });

    $('#omni-refresh').on('click', function(){
        refreshDropdown();
        pollBadges();
    });

    $('#omni-close').on('click', function(){
        closeDrop();
    });

    pollBadges();
    setInterval(pollBadges, 15000);
});
</script>

</body>
</html>
