{% set __defaultTheme = 'dark_cyan' %}
{% set __rawTheme = themeState.combined|default(my.theme|default(__defaultTheme)) %}
{% set __themeParts = __rawTheme|split('_') %}
{% set __serverMode = __themeParts[0]|default('dark') %}
{% set __serverColor = __themeParts[1]|default('cyan') %}

<script>
    (function () {
        const VALID_MODES = ['dark', 'oled', 'dim', 'magma', 'aurora'];
        const VALID_COLORS = ['cyan', 'diamond', 'blue', 'mono', 'red', 'amber', 'purple', 'pink', 'lavender', 'overdrive', 'blood', 'matrix'];

        const DEFAULT_MODE = 'dark';
        const DEFAULT_COLOR = 'cyan';

        const serverModeRaw = '{{ __serverMode|e('js') }}';
        const serverColorRaw = '{{ __serverColor|e('js') }}';

        const storedModeRaw = localStorage.getItem('omni_mode');
        const storedColorRaw = localStorage.getItem('omni_color');

        function sanitizeMode(mode) {
            return VALID_MODES.indexOf(mode) !== -1 ? mode : DEFAULT_MODE;
        }

        function sanitizeColor(color) {
            return VALID_COLORS.indexOf(color) !== -1 ? color : DEFAULT_COLOR;
        }

        const resolvedMode = sanitizeMode(storedModeRaw || serverModeRaw || DEFAULT_MODE);
        const resolvedColor = sanitizeColor(storedColorRaw || serverColorRaw || DEFAULT_COLOR);

        localStorage.setItem('omni_mode', resolvedMode);
        localStorage.setItem('omni_color', resolvedColor);

        document.documentElement.setAttribute('data-theme', resolvedColor);
        document.documentElement.setAttribute('data-mode', resolvedMode);

        document.documentElement.classList.remove(
            'theme-dark',
            'theme-oled',
            'theme-dim',
            'theme-magma',
            'theme-aurora'
        );

        if (resolvedMode !== 'dark') {
            document.documentElement.classList.add('theme-' + resolvedMode);
        }
    })();
</script>

