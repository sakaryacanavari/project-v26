{% set __defaultTheme = 'dark_purple' %}
{% set __rawTheme = themeState.combined|default(my.theme|default(__defaultTheme)) %}
{% set __themeParts = __rawTheme|split('_') %}
{% set __serverMode = __themeParts[0]|default('dark') %}
{% set __serverColor = __themeParts[1]|default('purple') %}
{% set __serverEyeComfort = __themeParts[2]|default('balanced') %}

<script>
    (function () {
        const VALID_MODES = ['dark', 'command', 'neon', 'war', 'archive'];
        const VALID_COLORS = ['purple', 'blue', 'diamond', 'amber', 'red', 'matrix', 'mono', 'lavender'];
        const VALID_EYE_COMFORT_LEVELS = ['light', 'balanced', 'intense'];
        const LEGACY_MODES = { oled: 'command', dim: 'archive', magma: 'war', aurora: 'neon' };
        const LEGACY_COLORS = { cyan: 'blue', pink: 'lavender', overdrive: 'amber', blood: 'red' };

        const DEFAULT_MODE = 'dark';
        const DEFAULT_COLOR = 'purple';
        const DEFAULT_EYE_COMFORT_LEVEL = 'balanced';

        const serverModeRaw = '{{ __serverMode|e('js') }}';
        const serverColorRaw = '{{ __serverColor|e('js') }}';
        const serverEyeComfortRaw = '{{ __serverEyeComfort|e('js') }}';

        const storedModeRaw = localStorage.getItem('omni_mode');
        const storedColorRaw = localStorage.getItem('omni_color');
        const storedEyeComfortRaw = localStorage.getItem('omni_eye_comfort_level');

        function sanitizeMode(mode) {
            if (LEGACY_MODES[mode]) return LEGACY_MODES[mode];
            return VALID_MODES.indexOf(mode) !== -1 ? mode : DEFAULT_MODE;
        }

        function sanitizeColor(color) {
            if (LEGACY_COLORS[color]) return LEGACY_COLORS[color];
            return VALID_COLORS.indexOf(color) !== -1 ? color : DEFAULT_COLOR;
        }

        function sanitizeEyeComfortLevel(level) {
            return VALID_EYE_COMFORT_LEVELS.indexOf(level) !== -1 ? level : DEFAULT_EYE_COMFORT_LEVEL;
        }

        const resolvedMode = sanitizeMode(storedModeRaw || serverModeRaw || DEFAULT_MODE);
        const resolvedColor = resolvedMode === 'archive' ? 'amber' : sanitizeColor(storedColorRaw || serverColorRaw || DEFAULT_COLOR);
        const resolvedEyeComfortLevel = sanitizeEyeComfortLevel(storedEyeComfortRaw || serverEyeComfortRaw || DEFAULT_EYE_COMFORT_LEVEL);

        localStorage.setItem('omni_mode', resolvedMode);
        localStorage.setItem('omni_color', resolvedColor);
        localStorage.setItem('omni_eye_comfort_level', resolvedEyeComfortLevel);

        document.documentElement.setAttribute('data-theme', resolvedColor);
        document.documentElement.setAttribute('data-mode', resolvedMode);
        document.documentElement.setAttribute('data-eye-comfort', resolvedEyeComfortLevel);

        document.documentElement.classList.remove(
            'theme-dark',
            'theme-command',
            'theme-neon',
            'theme-war',
            'theme-archive',
            'theme-oled',
            'theme-dim',
            'theme-magma',
            'theme-aurora'
        );

        if (resolvedMode !== 'dark') {
            document.documentElement.classList.add('theme-' + resolvedMode);
        }
    })();
</script>

