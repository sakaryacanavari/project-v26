{% block dualColumn %}
    <div id="wrapper" class="flex max-w-[1900px] mx-auto w-full p-6 gap-6">
        
        <aside id="left-column" class="w-72 hidden lg:block shrink-0 space-y-6">
            <div class="hud-panel p-5 border-l-2 border-cyan-500 bg-black/40">
                <h2 class="heading-tactical text-[10px] text-cyan-500 mb-4 tracking-widest">SİSTEM_KİMLİĞİ</h2>
                
                <div class="profile-section flex items-center gap-4 mb-6">
                    <div class="relative group">
                        <img class="avatar w-14 h-14 rounded border border-cyan-500/30 p-0.5 bg-black/60 shadow-[0_0_15px_rgba(34,211,238,0.2)] group-hover:border-cyan-400 transition" src="/img/default_avatar.jpg">
                        <div class="absolute -bottom-1 -right-1 w-3 h-3 bg-green-500 rounded-full border-2 border-[#020617] animate-pulse shadow-[0_0_5px_#22c55e]"></div>
                    </div>
                    <div class="overflow-hidden">
                        <a href="" class="text-sm font-black text-white hover:text-cyan-400 transition uppercase tracking-tight block truncate">{{ my.nick }}</a>
                        <div class="flex gap-2 mt-2">
                            <button class="bg-cyan-950/40 hover:bg-cyan-500 hover:text-black border border-cyan-500/30 w-6 h-6 flex items-center justify-center rounded-sm transition"><i class="fa fa-envelope-o text-[10px]"></i></button>
                            <button class="bg-cyan-950/40 hover:bg-cyan-500 hover:text-black border border-cyan-500/30 w-6 h-6 flex items-center justify-center rounded-sm transition"><i class="fa fa-bell-o text-[10px]"></i></button>
                        </div>
                    </div>
                </div>

                <div class="space-y-4">
                    <div class="flex items-center gap-3 text-[10px] font-bold text-slate-300">
                        <img class="icon small w-5 shadow-sm" src="/img/flags/{{ my.location.country.id }}.png">
                        <span class="truncate">{{ my.location.country.name }}, {{ my.location.name }}</span>
                    </div>
                    
                    <div class="bg-black/40 p-3 rounded border border-white/5 space-y-3 shadow-inner">
                        <div class="flex justify-between items-center text-[11px] font-bold">
                            <span class="text-yellow-500 flex items-center gap-2 uppercase tracking-tighter">
                                <img class="icon small w-3" src="/img/icons/gold.png"> Gold
                            </span>
                            <span class="text-white">{{ my.money.gold }}</span>
                        </div>
                        <div class="flex justify-between items-center text-[11px] font-bold border-t border-white/5 pt-3">
                            <span class="text-cyan-400 flex items-center gap-2 uppercase tracking-tighter">
                                <img class="icon small w-3" src="/img/flags/{{ my.location.country.id }}.png">
                                {% filter upper %}{{ my.location.country.currency }}{% endfilter %}
                            </span>
                            <span class="text-white">{{ my.money[my.location.country.currency] }}</span>
                        </div>
                    </div>

                    <div class="pt-2">
                        <div class="flex justify-between text-[9px] font-black mb-1.5 text-slate-400 uppercase tracking-widest">
                            <span>Operasyonel Sağlık</span>
                            <span class="text-cyan-400">70%</span>
                        </div>
                        <div class="relative h-2 bg-slate-900 rounded-sm overflow-hidden border border-white/5">
                            <progress id="max-health" value="70" max="100" class="absolute inset-0 w-full h-full opacity-0 z-10 cursor-help"></progress>
                            <div class="absolute top-0 left-0 h-full bg-gradient-to-r from-cyan-600 to-cyan-400 shadow-[0_0_10px_rgba(34,211,238,0.4)]" style="width: 70%"></div>
                            <div class="absolute top-0 left-0 h-full w-full bg-[linear-gradient(90deg,transparent_0%,rgba(255,255,255,0.1)_50%,transparent_100%)] animate-[shimmer_2s_infinite]"></div>
                        </div>
                    </div>
                </div>
            </div>
        </aside>

        <div id="right-column" class="flex-1 min-w-0 space-y-6">
            
            <div id="header" class="hud-panel px-6 py-1 border-b-2 border-cyan-500/50 flex justify-between items-center bg-black/60 backdrop-blur-md">
                <ul id="top-menu" class="dropdown flex gap-1 items-center">
                    <li class="relative group">
                        <a href="{{ path_for('home') }}" class="flex items-center gap-2 px-4 py-3 text-[10px] font-black text-cyan-400 uppercase tracking-widest hover:bg-cyan-500/10 transition">
                            <i class="fa fa-home text-xs"></i> {% trans %}Home{% endtrans %}
                        </a>
                    </li>
                    
                    <li class="relative group">
                        <button class="flex items-center gap-2 px-4 py-3 text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-cyan-400 transition">
                            <i class="fa fa-flag-o"></i> {% trans %}My Places{% endtrans %}
                        </button>
                        <ul class="absolute hidden group-hover:block bg-[#0f172a] border border-cyan-500/20 min-w-[180px] shadow-2xl z-[100] top-full">
                            <li><a href="{{ path_for('myCompanies') }}" class="block px-4 py-3 text-[9px] font-bold text-slate-300 hover:bg-cyan-500/10 hover:text-cyan-400 border-b border-white/5 uppercase transition">{% trans %}Companies{% endtrans %}</a></li>
                            <li><a href="{{ path_for('gyms') }}" class="block px-4 py-3 text-[9px] font-bold text-slate-300 hover:bg-cyan-500/10 hover:text-cyan-400 border-b border-white/5 uppercase transition">{% trans %}Training grounds{% endtrans %}</a></li>
                            <li><a href="{{ path_for('storage') }}" class="block px-4 py-3 text-[9px] font-bold text-slate-300 hover:bg-cyan-500/10 hover:text-cyan-400 border-b border-white/5 uppercase transition">{% trans %}Storage{% endtrans %}</a></li>
                            <li><a href="#" class="block px-4 py-3 text-[9px] font-bold text-slate-300 hover:bg-cyan-500/10 hover:text-cyan-400 uppercase transition">{% trans %}Change location{% endtrans %}</a></li>
                        </ul>
                    </li>

                    <li class="relative group">
                        <a href="{{ path_for('wars') }}" class="flex items-center gap-2 px-4 py-3 text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-cyan-400 transition">
                            <i class="fa fa-crosshairs"></i> {% trans %}Wars{% endtrans %}
                        </a>
                    </li>

                    <li class="relative group">
                        <button class="flex items-center gap-2 px-4 py-3 text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-cyan-400 transition">
                            <i class="fa fa-shopping-cart"></i> {% trans %}Market{% endtrans %}
                        </button>
                        <ul class="absolute hidden group-hover:block bg-[#0f172a] border border-cyan-500/20 min-w-[180px] shadow-2xl z-[100] top-full">
                            <li><a href="{{ path_for('marketplace') }}" class="block px-4 py-3 text-[9px] font-bold text-slate-300 hover:bg-cyan-500/10 hover:text-cyan-400 border-b border-white/5 uppercase transition">{% trans %}Marketplace{% endtrans %}</a></li>
                            <li><a href="{{ path_for('workOffers') }}" class="block px-4 py-3 text-[9px] font-bold text-slate-300 hover:bg-cyan-500/10 hover:text-cyan-400 border-b border-white/5 uppercase transition">{% trans %}Job market{% endtrans %}</a></li>
                            <li><a href="#" class="block px-4 py-3 text-[9px] font-bold text-slate-300 hover:bg-cyan-500/10 hover:text-cyan-400 border-b border-white/5 uppercase transition">{% trans %}Monetary market{% endtrans %}</a></li>
                            <li><a href="#" class="block px-4 py-3 text-[9px] font-bold text-slate-300 hover:bg-cyan-500/10 hover:text-cyan-400 uppercase transition">{% trans %}Companies for sale{% endtrans %}</a></li>
                        </ul>
                    </li>

                    <li class="relative group">
                        <button class="flex items-center gap-2 px-4 py-3 text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-cyan-400 transition">
                            <i class="fa fa-users"></i> {% trans %}Community{% endtrans %}
                        </button>
                        <ul class="absolute hidden group-hover:block bg-[#0f172a] border border-cyan-500/20 min-w-[180px] shadow-2xl z-[100] top-full">
                            <li><a href="{{ path_for('partyList') }}" class="block px-4 py-3 text-[9px] font-bold text-slate-300 hover:bg-cyan-500/10 hover:text-cyan-400 border-b border-white/5 uppercase transition">{% trans %}Political parties{% endtrans %}</a></li>
                            <li><a href="{{ path_for('congressHome') }}" class="block px-4 py-3 text-[9px] font-bold text-slate-300 hover:bg-cyan-500/10 hover:text-cyan-400 uppercase transition">{% trans %}Congress{% endtrans %}</a></li>
                        </ul>
                    </li>
                </ul>

                <a class="logout-link text-[10px] font-black text-red-500 hover:text-white border border-red-500/30 px-4 py-2 rounded-sm hover:bg-red-600 transition flex items-center gap-2 uppercase tracking-widest" href="{{ path_for('logout') }}">
                    <i class="fa fa-power-off"></i> {% trans %}Logout{% endtrans %}
                </a>
            </div>

            <div id="main-container" class="animate-fade-in">
                {{ block('content') }}
            </div>
        </div>
    </div>

    <style>
        @keyframes shimmer { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
        .animate-fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        /* Dropdown Fix */
        .group:hover ul { display: block !important; }
        #top-menu > li > a, #top-menu > li > button { position: relative; }
        #top-menu > li:hover > a::after, #top-menu > li:hover > button::after {
            content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 2px;
            background: #22d3ee; box-shadow: 0 0 10px #22d3ee;
        }
    </style>
{% endblock %}