                        <i class="fa-solid fa-sack-dollar text-lg" style="color: color-mix(in srgb, var(--brand-primary) 70%, #fbbf24);"></i>
                    </div>
                </div>
                
                <div class="relative grid grid-cols-2 gap-2 mb-4">
                    <div class="treasury-stat-card rounded-lg p-3">
                        <div class="text-[9px] font-black uppercase tracking-[0.16em] text-slate-500">Gunluk Aidat</div>
                        <div class="mt-2 text-[16px] font-black text-white">{{ party.daily_fee|default('0.00') }} <span class="text-[10px] text-fuchsia-400 uppercase tracking-wider">Gold</span></div>
                    </div>
                    <div class="treasury-stat-card rounded-lg p-3">
                        <div class="text-[9px] font-black uppercase tracking-[0.16em] text-slate-500">{{ t('party.profile.member_count') }}</div>
                        <div class="mt-1.5 flex flex-col items-start">
                            <span class="text-[18px] font-black leading-none text-white">{{ party.members_count|default('0') }}</span>
                        </div>
                    </div>
                    <p class="text-[9px] text-fuchsia-400 font-bold uppercase tracking-widest"><i class="fa-solid fa-file-invoice-dollar mr-1"></i> Günlük Aidat: {{ party.daily_fee|default('0.00') }} GOLD</p>
                </div>
                
                {% if party.is_leader %}
                <div class="relative mb-4 rounded-xl border border-amber-500/15 bg-black/25 p-3">
                    <div class="flex items-center justify-between gap-3">
                        <div class="text-[9px] font-black uppercase tracking-[0.16em] text-amber-400">Reklam Paketleri</div>
                        <div id="party-ad-selection-label" class="text-[8px] font-black uppercase tracking-[0.14em] text-slate-500">{{ party.ad_campaigns[0].label }} / {{ party.ad_campaigns[0].cost|number_format(0, '.', '') }} Gold</div>
                    </div>
