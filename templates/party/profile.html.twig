                            <div class="flex gap-2">
                                <button onclick="handleInvite({{ invite.invite_id }}, 'accept')" class="w-8 h-8 rounded bg-green-500/20 border border-green-500/30 text-green-400 hover:bg-green-500 hover:text-white transition-all flex justify-center items-center" title="Kabul Et"><i class="fa-solid fa-check"></i></button>
                                <button onclick="handleInvite({{ invite.invite_id }}, 'reject')" class="w-8 h-8 rounded bg-red-500/20 border border-red-500/30 text-red-400 hover:bg-red-500 hover:text-white transition-all flex justify-center items-center" title="Reddet"><i class="fa-solid fa-xmark"></i></button>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    {% endif %}

    {# --- REKLAM PANELİ --- #}
    {% if party.is_leader and party.ad_until and party.ad_until > "now"|date("Y-m-d H:i:s") %}
        <div class="glass-panel p-4 border-l-4 border-amber-500 bg-amber-950/20 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 shadow-[0_0_20px_rgba(245,158,11,0.1)] mb-6">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-amber-500/20 border border-amber-500/30 flex items-center justify-center text-amber-400 shadow-[0_0_15px_rgba(245,158,11,0.2)]">
                    <i class="fa-solid fa-bullhorn text-xl animate-pulse"></i>
                </div>
                <div>
                    <h4 class="text-[11px] font-black text-amber-400 uppercase tracking-widest">Aktif Reklam Kampanyası</h4>
                    <p class="text-[9px] text-amber-500/70 mt-1 uppercase tracking-widest">{{ t('party.profile.ad_highlighted') }}</p>
                </div>
            </div>
            <div class="text-left md:text-right bg-black/40 p-3 rounded-xl border border-amber-500/20 w-full md:w-auto">
                <div class="text-[8px] text-amber-500/60 uppercase tracking-widest mb-1">Kampanya Bitiş Tarihi</div>
                <div class="text-[12px] font-black text-white flex items-center gap-2">
                    <i class="fa-regular fa-clock text-amber-400"></i> {{ party.ad_until|date("d.m.Y - H:i") }}
                </div>
            </div>
        </div>
    {% endif %}

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mt-6">
        {# --- SOL SÜTUN --- #}
        <section class="col-span-12 lg:col-span-8 space-y-6">
            <div class="glass-panel p-6 border-t-2 border-fuchsia-500 bg-black/40">
                <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] mb-4 border-b border-white/5 pb-3 flex items-center gap-2">
                    <i class="fa-solid fa-scroll text-fuchsia-400"></i> {{ t('party.profile.manifesto') }}
                </h2>
                <div class="text-slate-300 text-xs leading-relaxed font-bold tracking-[0.08em] italic bg-black/20 p-5 rounded-xl border border-white/5 whitespace-pre-wrap">{{ (party.description is not empty ? party.description|nl2br : t('party.profile.role.leader') ~ ' henüz bir vizyon belirlemedi.')|raw }}</div>
            </div>

            <div class="hidden glass-panel p-6 border-t-2 border-sky-500 bg-black/40">
                <div class="flex items-center justify-between gap-3 mb-4 border-b border-white/5 pb-3">
                    <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] flex items-center gap-2">
                        <i class="fa-solid fa-timeline text-sky-400"></i> {{ t('party.profile.logs') }}
                    </h2>
                    <span class="text-[9px] font-black uppercase tracking-[0.18em] text-slate-500">Son 10 kayit</span>
                </div>
                <div class="space-y-3">
                    {% if party.logs %}
                        {% for log in party.logs %}
                            <div class="rounded-xl border border-white/5 bg-black/25 px-4 py-3">
                                <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                                    <div class="text-[12px] font-bold text-slate-200 leading-6">{{ log.message }}</div>
                                    <div class="text-[9px] font-black uppercase tracking-[0.16em] text-slate-500 shrink-0">
                                        {% if log.created_at %}{{ log.created_at|date('d.m.Y H:i') }}{% else %}Kayit zamani yok{% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="rounded-xl border border-white/5 bg-black/20 px-4 py-4 text-[12px] font-bold text-slate-500">
                            {{ t('party.profile.no_party_log') }}
                        </div>
                    {% endif %}
                </div>
            </div>
            
            <div class="hidden glass-panel p-6 border-t-2 border-blue-500 bg-black/40">
                <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] mb-4 border-b border-white/5 pb-3 flex items-center gap-2">
                    <i class="fa-solid fa-users-viewfinder text-blue-400"></i> Parti Üyeleri
                </h2>
                <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
                    {% for member in party.member_list %}
                        <div class="bg-black/40 border border-white/5 p-3 rounded-xl flex items-center justify-between group hover:border-blue-500/30 transition-all xl:max-w-[420px]">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-lg bg-slate-800 overflow-hidden border border-white/10 shrink-0">
                                    <img src="{% if member.avatar %}{{ member.avatar }}{% else %}{{ base_url() }}/img/avatars/{{ member.uid }}.png{% endif %}" onerror="this.src='{{ base_url() }}/img/default_avatar.jpg'" class="w-full h-full object-cover">
                                </div>
                                <div>
                                    <div class="text-[11px] font-bold text-white tracking-wide">{{ member.nick|default(member.name) }}</div>
                                    <div class="text-[9px] font-black uppercase tracking-widest mt-0.5
                                        {% if member.uid == party.uid %} text-yellow-500
                                        {% elseif member.level == 2 %} text-fuchsia-400
                                        {% elseif member.level == 1 %} text-blue-400
                                        {% else %} text-slate-500 {% endif %}">
                                        {% if member.uid == party.uid %} <i class="fa-solid fa-crown mr-1"></i> {{ t('party.profile.role.leader') }}
                                        {% elseif member.level == 2 %} <i class="fa-solid fa-star mr-1"></i> {{ t('party.profile.role.secretary') }}
                                        {% elseif member.level == 1 %} <i class="fa-solid fa-bullhorn mr-1"></i> Sözcü
                                        {% else %} <i class="fa-solid fa-user mr-1"></i> Üye {% endif %}
                                    </div>
                                </div>
                            </div>
                            {% if party.is_leader and member.uid != party.uid %}
                                <div class="opacity-0 group-hover:opacity-100 transition-opacity flex gap-1.5">
                                    <button onclick="assignRole({{ member.uid }}, 2)" class="bg-fuchsia-600/20 hover:bg-fuchsia-500 text-fuchsia-400 hover:text-white w-7 h-7 rounded flex items-center justify-center text-[10px] border border-fuchsia-500/30"><i class="fa-solid fa-star"></i></button>
                                    <button onclick="assignRole({{ member.uid }}, 1)" class="bg-blue-600/20 hover:bg-blue-500 text-blue-400 hover:text-white w-7 h-7 rounded flex items-center justify-center text-[10px] border border-blue-500/30"><i class="fa-solid fa-bullhorn"></i></button>
                                    <button onclick="assignRole({{ member.uid }}, 0)" class="bg-slate-600/20 hover:bg-slate-500 text-slate-400 hover:text-white w-7 h-7 rounded flex items-center justify-center text-[10px] border border-slate-500/30"><i class="fa-solid fa-user-minus"></i></button>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
        
