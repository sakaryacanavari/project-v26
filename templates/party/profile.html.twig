                                            <div class="mt-3 grid grid-cols-2 gap-2">
                                                <button type="button" onclick="reviewApplication({{ application.id }}, 'approve')" class="side-action-btn rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-3 py-2.5 text-[10px] font-black uppercase text-emerald-300 inline-flex justify-center items-center gap-2 hover:bg-emerald-500 hover:text-white">
                                                    <i class="fa-solid fa-check"></i> Kabul Et
                                                </button>
                                                <button type="button" onclick="reviewApplication({{ application.id }}, 'reject')" class="side-action-btn rounded-lg border border-red-500/30 bg-red-500/10 px-3 py-2.5 text-[10px] font-black uppercase text-red-300 inline-flex justify-center items-center gap-2 hover:bg-red-500 hover:text-white">
                                                    <i class="fa-solid fa-xmark"></i> Reddet
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="rounded-xl border border-white/5 bg-black/20 px-4 py-4 text-[12px] font-bold text-slate-500">
                                {{ t('party.profile.applications_none') }}
                            </div>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="rounded-xl border border-amber-500/20 bg-amber-500/10 px-4 py-4">
                        <div class="text-[10px] font-black uppercase tracking-[0.16em] text-amber-400">{{ t('party.profile.application_processing') }}</div>
                        <div class="mt-2 text-[12px] leading-6 font-bold text-slate-200">
                            {{ t('party.profile.application_processing_text') }}
                        </div>
                    </div>
                {% endif %}
            </div>
            {% endif %}

            <div class="glass-panel p-5 border-l-4 border-blue-500 bg-blue-500/5">
                <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] mb-4 border-b border-white/5 pb-3 flex items-center gap-2">
                    <i class="fa-solid fa-users-viewfinder text-blue-400"></i> {{ t('party.profile.members') }}
                </h2>
                <div class="space-y-3">
                    {% for member in party.member_list %}
                        <div class="bg-black/40 border border-white/5 p-3 rounded-xl flex items-center justify-between gap-3 group hover:border-blue-500/30 transition-all">
                            <div class="min-w-0 flex items-center gap-3">
                                <div class="w-10 h-10 rounded-lg bg-slate-800 overflow-hidden border border-white/10 shrink-0">
                                    <img src="{% if member.avatar %}{{ member.avatar }}{% else %}{{ base_url() }}/img/avatars/{{ member.uid }}.png{% endif %}" onerror="this.src='{{ base_url() }}/img/default_avatar.jpg'" class="w-full h-full object-cover">
                                </div>
                                <div class="min-w-0">
                                    <div class="text-[12px] font-bold text-white tracking-wide truncate">{{ member.nick|default(member.name) }}</div>
                                    <div class="text-[9px] font-black uppercase tracking-widest mt-0.5{% if member.uid == party.uid %} text-yellow-500{% elseif member.level == 2 %} text-fuchsia-400{% elseif member.level == 1 %} text-blue-400{% else %} text-slate-500{% endif %}">
                                        {% if member.uid == party.uid %}<i class="fa-solid fa-crown mr-1"></i> {{ t('party.profile.role.leader') }}{% elseif member.level == 2 %}<i class="fa-solid fa-star mr-1"></i> {{ t('party.profile.role.secretary') }}{% elseif member.level == 1 %}<i class="fa-solid fa-bullhorn mr-1"></i> {{ t('party.profile.role.spokesman') }}{% else %}<i class="fa-solid fa-user mr-1"></i> {{ t('party.profile.role.member') }}{% endif %}
                                    </div>
                                </div>
                            </div>
                            {% if party.is_leader and member.uid != party.uid %}
                                <div class="shrink-0 opacity-0 group-hover:opacity-100 transition-opacity flex gap-1.5">
                                    <button onclick="removeMember({{ member.uid }}, '{{ member.nick|default(member.name)|escape('js') }}')" class="bg-red-600/20 hover:bg-red-500 text-red-400 hover:text-white w-8 h-8 rounded flex items-center justify-center text-[11px] border border-red-500/30" title="{{ t('party.profile.kick_member') }}"><i class="fa-solid fa-user-slash"></i></button>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
            <div id="treasury-panel" class="glass-panel p-5 border-l-4 relative overflow-hidden transition-all duration-500" style="border-color: color-mix(in srgb, var(--brand-primary) 72%, #f59e0b); background: linear-gradient(180deg, color-mix(in srgb, var(--brand-primary) 10%, rgba(15, 23, 42, 0.92)) 0%, rgba(2, 6, 23, 0.9) 100%);">
