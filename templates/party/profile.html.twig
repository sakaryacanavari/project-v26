                            <div class="flex items-center gap-2 text-[9px] font-black uppercase tracking-[0.16em] text-slate-500">
                                <i class="fa-solid fa-vault text-yellow-500"></i>
                                <span>{{ t('party.profile.coalition_treasury_lower') }}</span>
                            </div>
                            <div class="mt-2 text-[16px] font-black text-yellow-400">{{ party.coalition.treasury|default('0.00') }} <span class="text-[10px] uppercase tracking-wider text-yellow-500">Altin</span></div>
                        </div>
                        <div class="treasury-stat-card rounded-lg p-3">
                            <div class="flex items-center gap-2 text-[9px] font-black uppercase tracking-[0.16em] text-slate-500">
                                <i class="fa-solid fa-building-shield text-cyan-400"></i>
                                <span>{{ t('party.profile.linked_party') }}</span>
                            </div>
                            <div class="mt-2 text-[18px] font-black text-white">{{ party.coalition.members ? party.coalition.members|length : 0 }}</div>
                        </div>
                    </div>

                    <p class="px-1 text-[10px] leading-5 text-slate-500 font-bold">{{ t('party.profile.coalition_controls_help') }}</p>

                    <div class="grid grid-cols-2 gap-2">
                        {% if party.is_leader %}
                            <button onclick="fundCoalition()" id="fund-btn" class="coalition-action-btn w-full rounded-lg px-3 py-2.5 text-[9px] font-black uppercase border inline-flex justify-center items-center gap-2">
                                <i class="fa-solid fa-money-bill-transfer"></i> Kasa Aktar
                            </button>
                        {% endif %}

                        {% if party.is_leader %}
                            <button onclick="leaveCoalition()" class="w-full rounded-lg px-3 py-2.5 text-[9px] font-black uppercase border border-red-500/30 bg-red-500/10 text-red-400 hover:bg-red-500 hover:text-white transition-all inline-flex justify-center items-center gap-2">
                                <i class="fa-solid fa-right-from-bracket"></i> {{ t('party.profile.leave_short') }}
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="glass-panel p-5 border-l-4 border-sky-500 bg-sky-500/5">
                <div class="flex items-center justify-between gap-3 mb-4 border-b border-white/5 pb-3">
                    <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] flex items-center gap-2">
                        <i class="fa-solid fa-timeline text-sky-400"></i> {{ t('party.profile.logs') }}
                    </h2>
                    <span class="text-[9px] font-black uppercase tracking-[0.16em] text-slate-500">Son 10 kayit</span>
                </div>
                <div class="space-y-3">
                    {% if party.logs %}
                        {% for log in party.logs %}
                            <div class="rounded-xl border border-white/5 bg-black/30 px-4 py-3">
                                <div class="text-[11px] leading-6 font-bold text-slate-200">{{ log.message }}</div>
                                <div class="mt-2 text-[8px] font-black uppercase tracking-[0.16em] text-slate-500">
                                    {% if log.created_at %}{{ log.created_at|date('d.m.Y H:i') }}{% else %}Kayit zamani yok{% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="rounded-xl border border-white/5 bg-black/20 px-4 py-4 text-[12px] font-bold text-slate-500">
                            {{ t('party.profile.no_party_log') }}
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="hidden glass-panel p-5 border-l-4 border-blue-500 bg-blue-500/5">
                <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] mb-4 border-b border-white/5 pb-3 flex items-center gap-2">
                    <i class="fa-solid fa-users-viewfinder text-blue-400"></i> Parti Ãœyeleri
                </h2>
                <div class="space-y-3">
                    {% for member in party.member_list %}
                        <div class="bg-black/40 border border-white/5 p-3 rounded-xl flex items-center justify-between gap-3 group hover:border-blue-500/30 transition-all">
                            <div class="min-w-0 flex items-center gap-3">
                                <div class="w-10 h-10 rounded-lg bg-slate-800 overflow-hidden border border-white/10 shrink-0">
                                    <img src="{% if member.avatar %}{{ member.avatar }}{% else %}{{ base_url() }}/img/avatars/{{ member.uid }}.png{% endif %}" onerror="this.src='{{ base_url() }}/img/default_avatar.jpg'" class="w-full h-full object-cover">
                                </div>
                                <div class="min-w-0">
                                    <div class="text-[12px] font-bold text-white tracking-wide truncate">{{ member.nick|default(member.name) }}</div>
                                    <div class="text-[9px] font-black uppercase tracking-widest mt-0.5
                                        {% if member.uid == party.uid %} text-yellow-500
                                        {% elseif member.level == 2 %} text-fuchsia-400
                                        {% elseif member.level == 1 %} text-blue-400
                                        {% else %} text-slate-500 {% endif %}">
                                        {% if member.uid == party.uid %} <i class="fa-solid fa-crown mr-1"></i> {{ t('party.profile.role.leader') }}
                                        {% elseif member.level == 2 %} <i class="fa-solid fa-star mr-1"></i> {{ t('party.profile.role.secretary') }}
                                        {% elseif member.level == 1 %} <i class="fa-solid fa-bullhorn mr-1"></i> SÃ¶zcÃ¼
                                        {% else %} <i class="fa-solid fa-user mr-1"></i> Ãœye {% endif %}
                                    </div>
                                </div>
                            </div>
                            {% if party.is_leader and member.uid != party.uid %}
                                <div class="shrink-0 opacity-0 group-hover:opacity-100 transition-opacity flex gap-1.5">
                                    <button onclick="assignRole({{ member.uid }}, 2)" class="bg-fuchsia-600/20 hover:bg-fuchsia-500 text-fuchsia-400 hover:text-white w-7 h-7 rounded flex items-center justify-center text-[10px] border border-fuchsia-500/30"><i class="fa-solid fa-star"></i></button>
                                    <button onclick="assignRole({{ member.uid }}, 1)" class="bg-blue-600/20 hover:bg-blue-500 text-blue-400 hover:text-white w-7 h-7 rounded flex items-center justify-center text-[10px] border border-blue-500/30"><i class="fa-solid fa-bullhorn"></i></button>
                                    <button onclick="assignRole({{ member.uid }}, 0)" class="bg-slate-600/20 hover:bg-slate-500 text-slate-400 hover:text-white w-7 h-7 rounded flex items-center justify-center text-[10px] border border-slate-500/30"><i class="fa-solid fa-user-minus"></i></button>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="hidden glass-panel p-5 border-l-4 border-blue-500 bg-blue-500/5">
                <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] mb-4 border-b border-white/5 pb-3 flex items-center gap-2">
                    <i class="fa-solid fa-users-viewfinder text-blue-400"></i> {{ t('party.profile.members') }}
                </h2>
                <div class="space-y-3">
                    {% for member in party.member_list %}
                        <div class="bg-black/40 border border-white/5 p-3 rounded-xl flex items-center justify-between gap-3 group hover:border-blue-500/30 transition-all">
                            <div class="min-w-0 flex items-center gap-3">
                                <div class="w-10 h-10 rounded-lg bg-slate-800 overflow-hidden border border-white/10 shrink-0">
                                    <img src="{% if member.avatar %}{{ member.avatar }}{% else %}{{ base_url() }}/img/avatars/{{ member.uid }}.png{% endif %}" onerror="this.src='{{ base_url() }}/img/default_avatar.jpg'" class="w-full h-full object-cover">
                                </div>
                                <div class="min-w-0">
                                    <div class="text-[12px] font-bold text-white tracking-wide truncate">{{ member.nick|default(member.name) }}</div>
                                    <div class="text-[9px] font-black uppercase tracking-widest mt-0.5{% if member.uid == party.uid %} text-yellow-500{% elseif member.level == 2 %} text-fuchsia-400{% elseif member.level == 1 %} text-blue-400{% else %} text-slate-500{% endif %}">
                                        {% if member.uid == party.uid %}<i class="fa-solid fa-crown mr-1"></i> {{ t('party.profile.role.leader') }}{% elseif member.level == 2 %}<i class="fa-solid fa-star mr-1"></i> {{ t('party.profile.role.secretary') }}{% elseif member.level == 1 %}<i class="fa-solid fa-bullhorn mr-1"></i> {{ t('party.profile.role.spokesman') }}{% else %}<i class="fa-solid fa-user mr-1"></i> {{ t('party.profile.role.member') }}{% endif %}
                                    </div>
                                </div>
                            </div>
                            {% if party.is_leader and member.uid != party.uid %}
                                <div class="shrink-0 opacity-0 group-hover:opacity-100 transition-opacity flex gap-1.5">
                                    <button onclick="assignRole({{ member.uid }}, 2)" class="bg-fuchsia-600/20 hover:bg-fuchsia-500 text-fuchsia-400 hover:text-white w-7 h-7 rounded flex items-center justify-center text-[10px] border border-fuchsia-500/30"><i class="fa-solid fa-star"></i></button>
                                    <button onclick="assignRole({{ member.uid }}, 1)" class="bg-blue-600/20 hover:bg-blue-500 text-blue-400 hover:text-white w-7 h-7 rounded flex items-center justify-center text-[10px] border border-blue-500/30"><i class="fa-solid fa-bullhorn"></i></button>
                                    <button onclick="assignRole({{ member.uid }}, 0)" class="bg-slate-600/20 hover:bg-slate-500 text-slate-400 hover:text-white w-7 h-7 rounded flex items-center justify-center text-[10px] border border-slate-500/30"><i class="fa-solid fa-user-minus"></i></button>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="hidden glass-panel p-6 border-l-4 border-indigo-500 bg-indigo-500/5">
                <h2 class="text-[11px] font-black text-indigo-400 uppercase tracking-[0.2em] mb-4 text-center">{{ t('party.profile.congress_candidacy') }}</h2>
                {% if party.affiliation %}
                    <button id="v11-congress-btn" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white py-3.5 rounded-xl font-black text-[10px] uppercase border border-indigo-400/30 shadow-lg shadow-indigo-500/10 transition-all">{{ t('party.profile.start_candidacy') }}</button>
                {% else %}
                    <div class="p-4 bg-black/60 rounded-xl border border-red-500/20 text-center">
                        <p class="text-[9px] text-red-400 font-black uppercase">{{ t('party.profile.register_first') }}</p>
                    </div>
                {% endif %}
            </div>
        </aside>
    </div>

    <script>
        $.ajaxSetup({
            headers: {
                'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content')
            }
        });

        $(document).ready(function() {
            const partyId = {{ party.id|default('0') }};
            const $coalitionFeedback = $('#coalition-create-feedback');
            const $coalitionName = $('#coalition-name');
            const $coalitionManifesto = $('#coalition-manifesto');

            function setCoalitionFeedback(type, message) {
                var isError = type === 'error';
                $coalitionFeedback
                    .removeClass('hidden border-red-500/40 bg-red-500/10 text-red-300 border-emerald-500/40 bg-emerald-500/10 text-emerald-300')
                    .addClass(isError ? 'border-red-500/40 bg-red-500/10 text-red-300' : 'border-emerald-500/40 bg-emerald-500/10 text-emerald-300')
                    .text(message);
            }

            function resetCoalitionFeedback() {
                $coalitionFeedback.addClass('hidden').text('');
                $coalitionName.removeClass('border-red-500/60');
                $coalitionManifesto.removeClass('border-red-500/60');
            }

            $coalitionName.on('input', function() {
                $(this).removeClass('border-red-500/60');
            });

            $coalitionManifesto.on('input', function() {
                $(this).removeClass('border-red-500/60');
            });

            $('#open-coalition-btn').click(function() { resetCoalitionFeedback(); $('#coalition-create-modal').removeClass('hidden').css('display', 'flex'); });
            $('#close-coalition-btn').click(function() { resetCoalitionFeedback(); $('#coalition-create-modal').addClass('hidden').css('display', 'none'); });
            $('#open-settings-btn').click(function() { $('#party-settings-modal').removeClass('hidden').css('display', 'flex'); });
            $('#close-settings-btn').click(function() { $('#party-settings-modal').addClass('hidden').css('display', 'none'); });

            $('#create-coalition-form').on('submit', function(e) {
                e.preventDefault();
                resetCoalitionFeedback();

                var $btn = $(this).find('button[type="submit"]');
                var defaultBtnHtml = $btn.html();
                var data = {
                    name: $coalitionName.val().trim(),
                    logo: $('#coalition-logo').val().trim(),
                    manifesto: $coalitionManifesto.val().trim()
                };

                $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner animate-spin mr-2"></i> {{ t('party.profile.building') }}');

                $.post("{{ base_url() }}/api/party/create-coalition", data, function(res) {
                    if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }

                    if (res && res.error > 0) {
                        if (res.field === 'name') {
                            $coalitionName.addClass('border-red-500/60').focus();
                        } else if (res.field === 'manifesto') {
                            $coalitionManifesto.addClass('border-red-500/60').focus();
                        }

                        setCoalitionFeedback('error', res.message || '{{ t('party.profile.coalition_create_failed') }}');
                        $btn.prop('disabled', false).html(defaultBtnHtml);
                        return;
                    }

                    setCoalitionFeedback('success', '{{ t('party.profile.coalition_created') }}');
                    window.location.reload();
                }).fail(function() {
                    setCoalitionFeedback('error', '{{ t('party.profile.coalition_create_server_failed') }}');
                    $btn.prop('disabled', false).html(defaultBtnHtml);
                });
            });

            $('#v13-settings-form').on('submit', function(e) {
                e.preventDefault();
                var $btn = $(this).find('button[type="submit"]');
                $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner animate-spin"></i> {{ t('party.profile.saving') }}');
                
                var data = { 
                    id: partyId, 
                    ideology: $('#set-ideology').val(), 
                    economy_stance: $('#set-economy').val(), 
                    cover_pic: $('#set-cover').val().trim(), 
                    logo_url: $('#set-logo-url').val().trim(),
                    description: $('#set-desc').val().trim(),
                    daily_fee: $('#set-fee').val()
                };
                
                $.post("{{ base_url() }}/api/party/update", data, function(res) { 
                    if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                    
                    if (res && res.error > 0) {
                        alert("{{ t('party.profile.error_prefix') }}: " + res.message);
                        $btn.prop('disabled', false).html('<i class="fa-solid fa-floppy-disk mr-2"></i> {{ t('party.profile.save_doctrine') }}');
                    } else {
                        window.location.reload(); 
                    }
                }).fail(function(){ 
                    alert("{{ t('party.profile.connection_server_unreachable') }}"); 
                    $btn.prop('disabled', false).html('<i class="fa-solid fa-floppy-disk mr-2"></i> {{ t('party.profile.save_doctrine') }}');
                });
            });

            $('#v14-buy-ad-btn').click(function() {
                if(confirm("{{ t('party.profile.buy_ad_confirm_old') }}")) {
                    var $btn = $(this);
                    $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner animate-spin"></i> İŞLENİYOR...');
                    $.post("{{ base_url() }}/api/party/buy-ad", { id: partyId }, function(res) {
                        if(res.error) { alert("Hata: " + (res.message || "{{ t('party.profile.error_insufficient') }}")); $btn.prop('disabled', false).html('<i class="fa-solid fa-bullhorn"></i> {{ t('party.profile.buy_ad') }}'); }
                        else { window.location.reload(); }
                    }).fail(function() {
                        alert("{{ t('party.profile.connection_generic') }}");
                        $btn.prop('disabled', false).html('<i class="fa-solid fa-bullhorn"></i> {{ t('party.profile.buy_ad') }}');
                    });
                }
            });

            $('[data-ad-plan]').on('click', function() {
                var $plan = $(this);
                $('[data-ad-plan]').removeClass('is-active');
                $plan.addClass('is-active');
                $('#party-ad-selected-days').val($plan.data('days'));
                $('#party-ad-selection-label').text($plan.data('label') + ' / ' + $plan.data('cost') + ' Gold');
            });

            $('#v14-buy-ad-btn').off('click').on('click', function() {
                var selectedDays = parseInt($('#party-ad-selected-days').val() || '1', 10);
                var $selectedPlan = $('[data-ad-plan].is-active').first();
                var selectedCost = $selectedPlan.data('cost') || 20;
                var selectedLabel = $selectedPlan.data('label') || (selectedDays + ' Gun');

                if (confirm('{{ t('party.profile.ad_confirm_dynamic') }}'.replace('%label%', selectedLabel).replace('%cost%', selectedCost))) {
                    var $btn = $(this);
                    $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner animate-spin"></i> {{ t('party.profile.processing') }}');

                    $.post("{{ base_url() }}/api/party/buy-ad", { id: partyId, days: selectedDays }, function(res) {
                        if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                        if (res && res.error) {
                            alert('Hata: ' + (res.message || '{{ t('party.profile.error_insufficient') }}'));
                            $btn.prop('disabled', false).html('<i class="fa-solid fa-bullhorn"></i> {{ t('party.profile.buy_ad') }}');
                            return;
                        }
                        window.location.reload();
                    }).fail(function() {
                        alert('{{ t('party.profile.connection_error_short') }}');
                        $btn.prop('disabled', false).html('<i class="fa-solid fa-bullhorn"></i> {{ t('party.profile.buy_ad') }}');
                    });
                }
            });

            window.donateMoney = function() {
                var m = prompt("Parti Kasasına Bağış Miktarı (Altın):", "10");
                if (m && parseFloat(m) > 0) {
                    var $btn = $('#donate-btn');
                    $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner animate-spin"></i> {{ t('party.profile.transferring') }}');
                    $.post("{{ base_url() }}/api/party/donate", { id: partyId, amount: m }, function(res) {
                        if(res.error) {
                            alert("{{ t('party.profile.error_prefix') }}: " + res.message);
                            $btn.prop('disabled', false).html('<i class="fa-solid fa-coins"></i> {{ t('party.profile.donate') }}');
                            return;
                        }
                        var newTotal = res.result || res;
                        $('#treasury-amount').text(parseFloat(newTotal).toFixed(2));
                        $('#treasury-panel').addClass('ring-4 ring-yellow-500 bg-yellow-500/20');
                        setTimeout(function() {
                            $('#treasury-panel').removeClass('ring-4 ring-yellow-500 bg-yellow-500/20');
                            $btn.prop('disabled', false).html('<i class="fa-solid fa-coins"></i> {{ t('party.profile.donate') }}');
                        }, 1000);
                    }).fail(function(){ 
                        alert("Bağlantı hatası: İşlem başarısız.");
                        $btn.prop('disabled', false).html('<i class="fa-solid fa-coins"></i> {{ t('party.profile.donate') }}');
                    });
                }
            };

            window.fundCoalition = function() {
                var m = prompt("Parti kasanızdan {{ t('party.profile.coalition_treasury') }}na ne kadar ALTIN aktarmak istiyorsunuz?", "10");
                if (m && parseFloat(m) > 0) {
                    var $btn = $('#fund-btn');
                    var $panel = $('#coalition-panel');
                    $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner animate-spin"></i> {{ t('party.profile.transferring') }}');
                    $.post("{{ base_url() }}/api/coalition/donate", { amount: m }, function(res) {
                        if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                        if (res.error > 0) {
                            alert("Hata: " + (res.message || "İşlem reddedildi."));
                            $btn.prop('disabled', false).html('<i class="fa-solid fa-money-bill-transfer mr-1"></i> {{ t('party.profile.transfer_to_coalition') }}');
                        } else {
                            $panel.addClass('ring-4 ring-cyan-500 bg-cyan-500/20');
                            setTimeout(function() { window.location.reload(); }, 500);
                        }
                    }).fail(function() { 
                        alert("{{ t('party.profile.connection_generic') }}"); 
                        $btn.prop('disabled', false).html('<i class="fa-solid fa-money-bill-transfer mr-1"></i> {{ t('party.profile.transfer_to_coalition') }}'); 
                    });
                }
            };
        });

        function joinParty() {
            var note = prompt("{{ t('party.profile.note_prompt') }}", "");
            if (note === null) {
                return;
            }

            $.post("{{ base_url() }}/api/party/join", { id: {{ party.id|default('0') }}, message: note }, function(res) {
                if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                if (res && res.error > 0) {
                    alert("{{ t('party.profile.error_prefix') }}: " + (res.message || "{{ t('party.profile.member_application_failed') }}"));
                    return;
                }
                alert(res.message || "{{ t('party.profile.member_application_sent') }}");
                window.location.reload();
            }).fail(function() {
                alert("{{ t('party.profile.connection_error_short') }}: {{ t('party.profile.member_application_failed') }}");
            });
        }

        function leaveParty() { if(confirm("{{ t('party.profile.leave_confirm') }}")) $.post("{{ base_url() }}/api/party/leave", { id: {{ party.id|default('0') }} }, function() { window.location.href = "{{ path_for('partyList') }}"; }); }
        function leaveCoalition() { if(confirm("{{ t('party.profile.leave_coalition_confirm') }}")) $.post("{{ base_url() }}/api/coalition/leave", { party_id: {{ party.id|default('0') }} }, function() { window.location.reload(); }); }
        function assignRole(targetUid, newRole) { if(confirm("{{ t('party.profile.change_rank_confirm') }}")) $.post("{{ base_url() }}/api/party/assign-role", { party_id: {{ party.id|default('0') }}, target_uid: targetUid, new_role: newRole }, function() { window.location.reload(); }); }
        function removeMember(targetUid, memberName) {
            if (!confirm((memberName || '{{ t('party.profile.role.member') }}') + " partiden cikarilsin mi?")) {
                return;
            }

            $.post("{{ base_url() }}/api/party/remove-member", { party_id: {{ party.id|default('0') }}, target_uid: targetUid }, function(res) {
                if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                if (res && res.error > 0) {
                    alert("{{ t('party.profile.error_prefix') }}: " + (res.message || "{{ t('party.profile.member_remove_failed') }}"));
                    return;
                }
                window.location.reload();
            }).fail(function() {
                alert("{{ t('party.profile.connection_error_short') }}: {{ t('party.profile.member_remove_failed') }}");
            });
        }
        function reviewApplication(applicationId, action) {
            var question = action === 'approve' ? "{{ t('party.profile.review_approve') }}" : "{{ t('party.profile.review_reject') }}";
            if (!confirm(question)) {
                return;
            }

            $.post("{{ base_url() }}/api/party/review-application", { application_id: applicationId, action: action }, function(res) {
                if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                if (res && res.error > 0) {
                    alert("{{ t('party.profile.error_prefix') }}: " + (res.message || "{{ t('party.profile.review_failed') }}"));
                    return;
                }
                window.location.reload();
            }).fail(function() {
                alert("{{ t('party.profile.connection_error_short') }}: {{ t('party.profile.review_failed') }}");
            });
        }

        window.inviteById = function() {
            var targetId = prompt("{{ t('party.profile.invite_party_prompt') }}");
            if(targetId && parseInt(targetId) > 0) {
                $.post("{{ base_url() }}/api/coalition/invite", { target_party_id: parseInt(targetId) }, function(res) {
                    if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                    if (res && res.error > 0) alert("Hata: " + (res.message || "Davet gönderilemedi."));
                    else alert("{{ t('party.profile.invite_sent') }}");
                }).fail(function() { alert("{{ t('party.profile.connection_generic') }}"); });
            }
        };

        window.inviteToCoalition = function(targetPartyId) {
            if(confirm("{{ t('party.profile.invite_coalition_confirm') }}")) {
                $.post("{{ base_url() }}/api/coalition/invite", { target_party_id: targetPartyId }, function(res) {
                    if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                    if (res && res.error > 0) alert("{{ t('party.profile.error_prefix') }}: " + (res.message || "{{ t('party.profile.permission_denied') }}"));
                    else { alert("{{ t('party.profile.diplomatic_sent') }}"); window.location.reload(); }
                }).fail(function() { alert("{{ t('party.profile.connection_server_failed') }}"); });
            }
        };

        window.handleInvite = function(inviteId, action) {
            var url = action === 'accept' ? "/api/coalition/accept" : "/api/coalition/reject";
            var msg = action === 'accept' ? "{{ t('party.profile.handle_invite_accept') }}" : "{{ t('party.profile.handle_invite_reject') }}";
            if(confirm(msg)) {
                $.post("{{ base_url() }}" + url, { invite_id: inviteId }, function(res) { window.location.reload(); });
            }
        };

        window.distributeFund = function(targetPartyId, targetName) {
            var m = prompt("{{ t('party.profile.distribute_fund_prompt') }}".replace('%party%', targetName), "10");
            if (m && parseFloat(m) > 0) {
                $.post("{{ base_url() }}/api/coalition/distribute", { target_party_id: targetPartyId, amount: m }, function(res) {
                    if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                    if (res && res.error > 0) {
                        alert("Hata: " + (res.message || "İşlem reddedildi."));
                    } else {
                        alert("İşlem Başarılı: " + targetName + " partisine " + m + " Altın aktarıldı.");
                        window.location.reload();
                    }
                }).fail(function() { alert("{{ t('party.profile.connection_generic') }}"); });
            }
        };

        window.toggleEmbargo = function(targetPartyId, action) {
            var url = action === 'add' ? "/api/coalition/embargo/add" : "/api/coalition/embargo/remove";
            var msg = action === 'add' 
                ? "DİKKAT: Bu partiye Siyasi Ambargo uygulamak, {{ t('party.profile.coalition_treasury') }}ndan 50 ALTIN eksiltecektir. Onaylıyor musunuz?" 
                : "Bu parti üzerindeki ambargoyu kaldırmak istiyor musunuz?";

            if(confirm(msg)) {
                $.post("{{ base_url() }}" + url, { target_party_id: targetPartyId }, function(res) {
                    if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                    if (res && res.error > 0) {
                        alert("Hata: " + (res.message || "{{ t('party.profile.unauthorized_or_insufficient') }}"));
                    } else {
                        window.location.reload();
                    }
                }).fail(function() { alert("{{ t('party.profile.connection_generic') }}"); });
            }
        };
        leaveParty = function() {
            if (!confirm("AyrÄ±lmak istediÄŸinize emin misiniz?")) {
                return;
            }

            $.post("{{ base_url() }}/api/party/leave", { id: {{ party.id|default('0') }} }, function(res) {
                if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                if (res && res.error > 0) {
                    alert("{{ t('party.profile.error_prefix') }}: " + (res.message || "{{ t('party.profile.leave_failed') }}"));
                    return;
                }
                window.location.href = "{{ path_for('partyList') }}";
            }).fail(function() {
                alert("{{ t('party.profile.connection_error_short') }}: {{ t('party.profile.leave_failed') }}");
            });
        };
        leaveParty = function() {
            if (!confirm("{{ t('party.profile.leave_confirm') }}")) {
                return;
            }

            $.post("{{ base_url() }}/api/party/leave", { id: {{ party.id|default('0') }} }, function(res) {
                if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                if (res && res.error > 0) {
                    alert("{{ t('party.profile.error_prefix') }}: " + (res.message || "{{ t('party.profile.leave_failed') }}"));
                    return;
                }
                window.location.href = "{{ path_for('partyList') }}";
            }).fail(function() {
                alert("{{ t('party.profile.connection_error_short') }}: {{ t('party.profile.leave_failed') }}");
            });
        };
    </script>
</div>
{% endblock %}







