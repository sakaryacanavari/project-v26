                        <i class="fa-solid fa-coins"></i> Bagis Yap
                    </button>
                {% endif %}

                <button
                    id="v14-buy-ad-btn"
                    class="side-action-btn side-action-btn--amber w-full rounded-lg px-3 py-2.5 font-black text-[9px] uppercase border inline-flex justify-center items-center gap-2 {% if not party.is_leader or party.ad_purchase_locked %}opacity-50 cursor-not-allowed saturate-50{% endif %}"
                    {% if not party.is_leader or party.ad_purchase_locked %}disabled title="{% if party.ad_purchase_locked %}{{ t('party.profile.ad_lock') }}{% else %}{{ t('party.profile.only_leader_can_ad') }}{% endif %}"{% endif %}>
                    <i class="fa-solid {% if party.is_leader and not party.ad_purchase_locked %}fa-bullhorn{% else %}fa-lock{% endif %}"></i>
                    {{ t('party.profile.buy_ad') }}
                </button>
                </div>
            </div>

            {% if party.coalition %}
