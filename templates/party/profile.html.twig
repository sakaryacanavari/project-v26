{% extends isAjax ? "common/ajaxbase.html.twig" : "common/base.html.twig" %}

{% block content %}
<style>
    .coalition-action-btn {
        position: relative;
        overflow: hidden;
        background-color: color-mix(in srgb, var(--brand-primary) 18%, transparent);
        color: var(--brand-primary);
        border-color: color-mix(in srgb, var(--brand-primary) 34%, transparent);
        box-shadow: 0 0 18px color-mix(in srgb, var(--brand-primary) 18%, transparent);
        transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease, border-color 180ms ease, color 180ms ease;
    }

    .coalition-action-btn::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(120deg, transparent 0%, color-mix(in srgb, white 28%, transparent) 48%, transparent 100%);
        opacity: 0;
        transform: translateX(-120%);
        transition: transform 240ms ease, opacity 180ms ease;
        pointer-events: none;
    }

    .coalition-action-btn:hover {
        transform: translateY(-1px);
        background-color: color-mix(in srgb, var(--brand-primary) 28%, transparent);
        border-color: color-mix(in srgb, var(--brand-primary) 52%, transparent);
        box-shadow: 0 0 26px color-mix(in srgb, var(--brand-primary) 30%, transparent);
        color: color-mix(in srgb, var(--brand-primary) 82%, white);
    }

    .coalition-action-btn:hover::before {
        opacity: 0.75;
        transform: translateX(120%);
    }

    .coalition-action-btn:active {
        transform: translateY(0) scale(0.97);
        box-shadow: 0 0 12px color-mix(in srgb, var(--brand-primary) 20%, transparent);
    }

    .side-action-btn {
        position: relative;
        overflow: hidden;
        min-height: 34px;
        transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease, border-color 180ms ease, color 180ms ease;
    }

    .side-action-btn:hover {
        transform: translateY(-1px);
    }

    .side-action-btn:active {
        transform: translateY(0) scale(0.98);
    }

    .side-action-btn--brand {
        background-color: color-mix(in srgb, var(--brand-primary) 16%, transparent);
        color: color-mix(in srgb, var(--brand-primary) 84%, white);
        border-color: color-mix(in srgb, var(--brand-primary) 34%, transparent);
        box-shadow: 0 0 18px color-mix(in srgb, var(--brand-primary) 18%, transparent);
    }

    .side-action-btn--brand:hover {
        background-color: color-mix(in srgb, var(--brand-primary) 28%, transparent);
        border-color: color-mix(in srgb, var(--brand-primary) 48%, transparent);
        box-shadow: 0 0 24px color-mix(in srgb, var(--brand-primary) 26%, transparent);
    }

    .side-action-btn--amber {
        background-color: rgba(245, 158, 11, 0.12);
        color: #fbbf24;
        border-color: rgba(245, 158, 11, 0.28);
        box-shadow: 0 0 18px rgba(245, 158, 11, 0.14);
    }

    .side-action-btn--amber:hover {
        background-color: rgba(245, 158, 11, 0.2);
        border-color: rgba(245, 158, 11, 0.42);
        box-shadow: 0 0 24px rgba(245, 158, 11, 0.22);
    }

    .treasury-stat-card {
        background: linear-gradient(180deg, rgba(15, 23, 42, 0.88) 0%, rgba(2, 6, 23, 0.72) 100%);
        border: 1px solid rgba(255, 255, 255, 0.06);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    }

    .party-entry-btn {
        position: relative;
        overflow: hidden;
        transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease, border-color 180ms ease;
    }

    .party-entry-btn::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.12) 48%, transparent 100%);
        opacity: 0;
        transform: translateX(-120%);
        transition: transform 260ms ease, opacity 180ms ease;
        pointer-events: none;
    }

    .party-entry-btn:hover {
        transform: translateY(-1px);
    }

    .party-entry-btn:hover::before {
        opacity: 0.7;
        transform: translateX(120%);
    }

    .party-entry-btn:active {
        transform: translateY(0) scale(0.98);
    }

    .party-entry-btn--leave:hover {
        box-shadow: 0 0 22px rgba(239, 68, 68, 0.24);
    }

    .party-entry-btn--join:hover {
        box-shadow: 0 0 22px rgba(192, 38, 211, 0.26);
    }

    .ad-plan-btn {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(245, 158, 11, 0.16);
        background: rgba(15, 23, 42, 0.72);
        transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease, background-color 180ms ease, color 180ms ease;
    }

    .ad-plan-btn:hover {
        transform: translateY(-1px);
        border-color: rgba(245, 158, 11, 0.34);
        box-shadow: 0 0 18px rgba(245, 158, 11, 0.14);
    }

    .ad-plan-btn.is-active {
        border-color: rgba(245, 158, 11, 0.5);
        background: rgba(245, 158, 11, 0.14);
        box-shadow: 0 0 22px rgba(245, 158, 11, 0.18);
    }

    #treasury-panel > .relative.grid.grid-cols-2.gap-2.mb-4 > p {
        display: none;
    }
</style>
<div class="space-y-6 animate-fade-in w-full">
    
    {# YENİ: AMBARGO UYARISI BANNER'I #}
    {% if party.embargoes %}
        <div class="bg-red-900/40 border-l-4 border-red-500 p-4 rounded-r-xl shadow-[0_0_20px_rgba(239,68,68,0.2)] flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-red-500/20 flex items-center justify-center text-red-500 text-2xl shrink-0 border border-red-500/50">
                <i class="fa-solid fa-ban"></i>
            </div>
            <div>
                <h3 class="text-red-500 font-black uppercase text-sm tracking-widest">{{ t('party.profile.embargoed') }}</h3>
                <p class="text-white text-[11px] font-bold mt-1">{{ t('party.profile.embargoed_text') }} 
                    {% for e in party.embargoes %} <span class="text-red-400 bg-black/40 px-2 py-0.5 rounded ml-1">{{ e.coalition_name }}</span> {% endfor %}
                </p>
            </div>
        </div>
    {% endif %}

    {# --- ÜST BANNER --- #}
    <div class="glass-panel border-l-4 border-fuchsia-500 overflow-hidden relative">
        <div class="h-48 w-full bg-slate-900 relative">
            {% if party.cover_pic %}
                <img src="{% if party.cover_pic starts with 'http' %}{{ party.cover_pic }}{% else %}{{ base_url() }}/img/parties/covers/{{ party.cover_pic }}{% endif %}" class="w-full h-full object-cover opacity-60">
            {% else %}
                <div class="absolute inset-0 bg-gradient-to-r from-fuchsia-900/80 to-indigo-900/80"></div>
                <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-20"></div>
            {% endif %}
            
            <div class="absolute top-4 right-4 flex gap-3 z-10">
                {% if party.is_leader %}
                    <button id="open-settings-btn" class="bg-slate-900/80 hover:bg-slate-800 text-white px-5 py-2 rounded-lg font-black text-[10px] uppercase backdrop-blur-md transition-all shadow-lg flex items-center gap-2 border border-slate-500/50">
                        <i class="fa-solid fa-gear animate-[spin_4s_linear_infinite]"></i> {{ t('party.profile.settings') }}
                    </button>
                {% endif %}

                {% if party.affiliation %}
                    <button onclick="leaveParty()" class="party-entry-btn party-entry-btn--leave bg-red-600/80 hover:bg-red-500 text-white px-6 py-2 rounded-lg font-black text-[10px] uppercase backdrop-blur-md transition-all shadow-lg flex items-center gap-2 border border-red-400/50">
                        <i class="fa-solid fa-right-from-bracket"></i> {{ t('party.profile.leave_party') }}
                    </button>
                {% elseif party.my_pending_application %}
                    <button type="button" class="party-entry-btn bg-amber-500/20 text-amber-300 px-6 py-2 rounded-lg font-black text-[10px] uppercase backdrop-blur-md transition-all shadow-lg flex items-center gap-2 border border-amber-400/30 cursor-not-allowed">
                        <i class="fa-solid fa-hourglass-half"></i> {{ t('party.profile.application_pending') }}
                    </button>
                {% else %}
                    <button onclick="joinParty()" class="party-entry-btn party-entry-btn--join bg-fuchsia-600/90 hover:bg-fuchsia-500 text-white px-8 py-2 rounded-lg font-black text-[11px] uppercase backdrop-blur-md transition-all shadow-[0_0_20px_rgba(192,38,211,0.5)] border border-fuchsia-400/50">
                        <i class="fa-solid fa-paper-plane"></i> {{ t('party.profile.apply') }}
                    </button>
                {% endif %}
            </div>
        </div>

        <div class="px-6 pb-6 relative">
            <div class="flex flex-col md:flex-row gap-6">
                <div class="-mt-12 w-28 h-28 rounded-2xl bg-black border-4 border-fuchsia-500/50 shadow-[0_0_30px_rgba(217,70,239,0.4)] overflow-hidden relative z-10 shrink-0">
                    <img src="{% if party.logo_url %}{{ party.logo_url }}{% else %}{{ base_url() }}/img/parties/{{ party.id }}.png{% endif %}" onerror="this.src='{{ base_url() }}/img/default_avatar.jpg'" class="w-full h-full object-cover">
                </div>
                
                <div class="pt-2 flex-1 flex flex-col md:flex-row justify-between items-start md:items-end">
                    <div>
                        <div class="text-[10px] font-black text-fuchsia-400 uppercase tracking-[0.3em] mb-1">
                            {% if party.is_leader %}<span class="text-yellow-500"><i class="fa-solid fa-crown mr-1"></i> {{ t('party.profile.leader') }} </span> | {% endif %}
                            {{ t('party.profile.official_org') }}
                        </div>
                        <h1 class="text-3xl font-black text-white tracking-[0.08em] leading-none mb-3">{{ party.name }}</h1>
                        
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="px-3 py-1 rounded-md bg-white/5 border border-white/10 text-[10px] font-bold text-slate-300 tracking-wide">
                                <i class="fa-solid fa-scale-balanced text-indigo-400 mr-1"></i> {{ party.ideology }}
                            </span>
                            <span class="px-3 py-1 rounded-md bg-white/5 border border-white/10 text-[10px] font-bold text-slate-300 tracking-wide">
                                <i class="fa-solid fa-coins text-yellow-500 mr-1"></i> {{ party.economy_stance }}
                            </span>
                            <span class="px-3 py-1 rounded-md bg-fuchsia-500/20 border border-fuchsia-500/30 text-[10px] font-black text-fuchsia-400 uppercase tracking-tighter shadow-inner">
                                <i class="fa-solid fa-user-group mr-1"></i> {{ party.members_count|default('0') }} - ÜYE
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# --- AYARLAR MODALİ --- #}
    {% if party.is_leader %}
    <div id="party-settings-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4 animate-fade-in">
        <div class="glass-panel w-full max-w-2xl border-t-4 border-fuchsia-500 p-6 relative">
            <button id="close-settings-btn" class="absolute top-4 right-4 text-slate-400 hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
            <h2 class="text-xl font-black text-white uppercase tracking-widest mb-6 border-b border-white/10 pb-4">
                <i class="fa-solid fa-sliders text-fuchsia-500 mr-2"></i> {{ t('party.profile.settings_title') }}
            </h2>
            <form id="v13-settings-form" class="space-y-5">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{ t('party.profile.ideology') }}</label>
                        <select id="set-ideology" class="w-full bg-black/60 border border-white/10 text-white p-3 rounded-xl text-xs font-bold outline-none focus:border-fuchsia-500 transition-all">
                            <option value="Merkez" {% if party.ideology == 'Merkez' %}selected{% endif %}>Merkez (Ilımlı)</option>
                            <option value="Merkez Sağ" {% if party.ideology == 'Merkez Sağ' %}selected{% endif %}>Merkez Sağ</option>
                            <option value="Merkez Sol" {% if party.ideology == 'Merkez Sol' %}selected{% endif %}>Merkez Sol</option>
                            <option value="Muhafazakar" {% if party.ideology == 'Muhafazakar' %}selected{% endif %}>Muhafazakar</option>
                            <option value="Liberal" {% if party.ideology == 'Liberal' %}selected{% endif %}>Liberal</option>
                            <option value="Sosyalist" {% if party.ideology == 'Sosyalist' %}selected{% endif %}>Sosyalist</option>
                            <option value="Milliyetçi" {% if party.ideology == 'Milliyetçi' %}selected{% endif %}>Milliyetçi</option>
                            <option value="Aşırı Sağ" {% if party.ideology == 'Aşırı Sağ' %}selected{% endif %}>Aşırı Sağ</option>
                            <option value="Aşırı Sol" {% if party.ideology == 'Aşırı Sol' %}selected{% endif %}>Aşırı Sol</option>
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{ t('party.profile.economy') }}</label>
                        <select id="set-economy" class="w-full bg-black/60 border border-white/10 text-white p-3 rounded-xl text-xs font-bold outline-none focus:border-fuchsia-500 transition-all">
                            <option value="Karma Ekonomi" {% if party.economy_stance == 'Karma Ekonomi' %}selected{% endif %}>Karma Ekonomi</option>
                            <option value="Serbest Piyasa" {% if party.economy_stance == 'Serbest Piyasa' %}selected{% endif %}>Serbest Piyasa</option>
                            <option value="Kapitalist" {% if party.economy_stance == 'Kapitalist' %}selected{% endif %}>Kapitalist</option>
                            <option value="Devletçi" {% if party.economy_stance == 'Devletçi' %}selected{% endif %}>Devletçi</option>
                            <option value="Komünist" {% if party.economy_stance == 'Komünist' %}selected{% endif %}>Komünist</option>
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{ t('party.profile.daily_fee') }}</label>
                        <input id="set-fee" type="number" step="0.1" min="0" max="10" value="{{ party.daily_fee|default('0.00') }}" class="w-full bg-black/60 border border-white/10 text-white p-3 rounded-xl text-xs font-bold outline-none focus:border-fuchsia-500 transition-all">
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{ t('party.profile.cover_link') }}</label>
                    <input id="set-cover" type="text" value="{{ party.cover_pic }}" placeholder="https://i.imgur.com/foto.jpg" class="w-full bg-black/60 border border-white/10 text-white p-3 rounded-xl text-xs font-bold outline-none focus:border-fuchsia-500 transition-all">
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{ t('party.profile.logo_link') }}</label>
                    <input id="set-logo-url" type="text" value="{{ party.logo_url|default('') }}" placeholder="https://i.imgur.com/logo.png" class="w-full bg-black/60 border border-white/10 text-white p-3 rounded-xl text-xs font-bold outline-none focus:border-fuchsia-500 transition-all">
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{ t('party.profile.manifesto') }}</label>
                    <textarea id="set-desc" class="w-full min-h-[120px] bg-black/60 border border-white/10 text-white p-4 rounded-xl text-[11px] font-bold outline-none focus:border-fuchsia-500 transition-all resize-none">{{ party.description }}</textarea>
                </div>
                <button type="submit" class="w-full bg-fuchsia-700 hover:bg-fuchsia-600 text-white py-4 rounded-xl font-black text-[11px] uppercase border border-fuchsia-400/30 transition-all shadow-lg active:scale-95">
                    <i class="fa-solid fa-floppy-disk mr-2"></i> {{ t('party.profile.save_doctrine') }}
                </button>
            </form>
        </div>
    </div>
    {% endif %}

    {# --- KOALİSYON KURMA MODALİ --- #}
    {% if party.is_leader and not party.coalition %}
    <div id="coalition-create-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4 animate-fade-in">
        <div class="glass-panel w-full max-w-lg border-t-4 border-cyan-500 p-6 relative">
            <button id="close-coalition-btn" class="absolute top-4 right-4 text-slate-400 hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
            <h2 class="text-xl font-black text-white uppercase tracking-widest mb-6 border-b border-white/10 pb-4">
                <i class="fa-solid fa-handshake-simple text-cyan-500 mr-2"></i> {{ t('party.profile.create_coalition') }}
            </h2>
            <form id="create-coalition-form" class="space-y-5">
                <div id="coalition-create-feedback" class="hidden rounded-xl border px-4 py-3 text-[11px] font-bold"></div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{ t('party.profile.coalition_name') }}</label>
                    <input id="coalition-name" type="text" required placeholder="Örn: Büyük İttifak" class="w-full bg-black/60 border border-white/10 text-white p-3 rounded-xl text-xs font-bold outline-none focus:border-cyan-500 transition-all">
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{ t('party.profile.coalition_logo') }}</label>
                    <input id="coalition-logo" type="text" placeholder="https://i.imgur.com/logo.png" class="w-full bg-black/60 border border-white/10 text-white p-3 rounded-xl text-xs font-bold outline-none focus:border-cyan-500 transition-all">
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{ t('party.profile.coalition_manifesto') }}</label>
                    <textarea id="coalition-manifesto" class="w-full min-h-[100px] bg-black/60 border border-white/10 text-white p-4 rounded-xl text-[11px] font-bold outline-none focus:border-cyan-500 transition-all resize-none" placeholder="{{ t('party.profile.coalition_manifesto_placeholder') }}"></textarea>
                </div>
                <button type="submit" class="w-full bg-cyan-700 hover:bg-cyan-600 text-white py-4 rounded-xl font-black text-[11px] uppercase border border-cyan-400/30 transition-all shadow-lg active:scale-95">
                    <i class="fa-solid fa-check mr-2"></i> {{ t('party.profile.create_coalition_submit') }}
                </button>
            </form>
        </div>
    </div>
    {% endif %}

    {# --- DİPLOMASİ: KOALİSYON DURUM & MERKEZ BANKASI PANELİ --- #}
    {% if party.coalition %}
        <div id="coalition-panel" class="hidden glass-panel p-5 border-l-4 border-cyan-500 bg-cyan-900/10 mb-2 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 shadow-[0_0_20px_rgba(6,182,212,0.1)] transition-all duration-500">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-cyan-500/20 border border-cyan-500/30 flex items-center justify-center text-cyan-400 shadow-[0_0_15px_rgba(6,182,212,0.2)]">
                    <i class="fa-solid fa-handshake-angle text-2xl"></i>
                </div>
                <div>
                    <h4 class="text-[11px] font-black text-cyan-400 uppercase tracking-widest">{{ t('party.profile.coalition_alliance') }}</h4>
                    <p class="text-[16px] font-black text-white mt-0.5 mb-2">{{ party.coalition.name }}</p>
                    
                    <div class="bg-black/40 border border-cyan-500/30 px-3 py-1.5 rounded-lg inline-flex items-center gap-2 shadow-inner">
                        <i class="fa-solid fa-vault text-yellow-500 text-lg"></i>
                        <div>
                            <div class="text-[9px] text-cyan-200 font-bold uppercase tracking-wider leading-none">{{ t('party.profile.coalition_treasury') }}</div>
                            <div class="text-[14px] font-black text-yellow-500 leading-none mt-0.5">
                                <span id="coalition-treasury-amount">{{ party.coalition.treasury|default('0.00') }}</span> Altın
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="flex flex-col items-end gap-3 w-full md:w-auto">
                <div class="flex items-center gap-3">
                    {% if party.coalition.members %}
                        {% for allied in party.coalition.members %}
                            <div class="relative inline-block group">
                                <a href="{{ path_for('party', {'id': allied.id, 'slug': allied.slug|default('party')}) }}" class="block">
                                    <img src="{{ base_url() }}/img/parties/{{ allied.id }}.png" onerror="this.src='{{ base_url() }}/img/default_avatar.jpg'" class="w-10 h-10 rounded-lg bg-black border border-cyan-500/30 group-hover:border-cyan-400 transition-all object-cover shadow-lg">
                                </a>
                                <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 bg-black text-white text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 whitespace-nowrap pointer-events-none z-10 border border-white/10 font-bold">{{ allied.name }}</div>
                                
                                {% if party.coalition.is_founder %}
                                    <button onclick="distributeFund({{ allied.id }}, '{{ allied.name|escape('js') }}')" class="absolute -top-2 -right-2 w-5 h-5 bg-yellow-600 border border-yellow-400 rounded-full text-[10px] text-white flex items-center justify-center hover:bg-yellow-500 hover:scale-110 transition-all shadow-[0_0_10px_rgba(234,179,8,0.5)] z-20" title="Partiye Teşvik Fonu Aktar">
                                        <i class="fa-solid fa-coins"></i>
                                    </button>
                                {% endif %}
                            </div>
                        {% endfor %}
                    {% endif %}
                    
                    {% if party.is_leader %}
                        <button onclick="leaveCoalition()" class="ml-2 w-10 h-10 rounded-lg bg-red-500/20 border border-red-500/30 text-red-400 hover:bg-red-500 hover:text-white transition-all flex items-center justify-center shadow-lg" title="Koalisyondan Ayrıl">
                            <i class="fa-solid fa-xmark text-lg"></i>
                        </button>
                    {% endif %}
                </div>

                {% if party.is_leader %}
                    <button onclick="fundCoalition()" id="fund-btn" class="coalition-action-btn w-full md:w-auto px-4 py-2 rounded-lg text-[10px] font-black uppercase border shadow-lg flex items-center justify-center gap-2">
                        <i class="fa-solid fa-money-bill-transfer mr-1"></i> {{ t('party.profile.transfer_to_coalition') }}
                    </button>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div class="glass-panel p-4 border-l-4 border-slate-700 bg-black/40 mb-2 space-y-4">
            <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div class="flex items-center gap-3">
                    <i class="fa-solid fa-handshake-simple text-slate-500 text-xl"></i>
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{{ t('party.profile.no_coalition') }}</span>
                </div>
                
                <div class="flex flex-wrap gap-2 md:justify-end">
                    {% if party.is_leader %}
                        <button id="open-coalition-btn" class="coalition-action-btn px-4 py-2 rounded-lg font-black text-[10px] uppercase border shadow-lg">
                            <i class="fa-solid fa-plus mr-1"></i> {{ t('party.profile.coalition_create_short') }}
                        </button>
                    {% endif %}
                    {% if party.can_invite_to_coalition %}
                        <button onclick="inviteToCoalition({{ party.id }})" class="bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg font-black text-[10px] uppercase border border-indigo-400/30 transition-all shadow-lg shadow-indigo-500/20">
                            <i class="fa-solid fa-envelope-open-text mr-1"></i> {{ t('party.profile.invite_alliance') }}
                        </button>
