                                        </div>
                                        <div class="min-w-0 flex-1">
                                            <div class="flex items-center justify-between gap-2">
                                    <div class="text-[12px] font-bold text-white truncate">{{ application.nick|default(t('party.profile.role.member') ~ ' #' ~ application.uid) }}</div>
                                                <div class="text-[8px] font-black uppercase tracking-[0.16em] text-slate-500 shrink-0">
                                                    {% if application.created_at %}{{ application.created_at|date('d.m H:i') }}{% endif %}
                                                </div>
                                            </div>
                                            <div class="mt-2 rounded-lg border border-emerald-500/10 bg-emerald-500/5 px-3 py-2 text-[11px] leading-5 text-slate-300 font-bold whitespace-pre-wrap">
