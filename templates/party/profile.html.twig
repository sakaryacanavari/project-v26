                                data-days="{{ campaign.days }}"
                                data-cost="{{ campaign.cost|number_format(0, '.', '') }}"
                                data-label="{{ campaign.label }}"
                                {% if party.ad_purchase_locked %}disabled{% endif %}>
                                <div class="text-[9px] font-black uppercase tracking-[0.12em] text-white">{{ campaign.label }}</div>
                                <div class="mt-1 text-[11px] font-black text-amber-400">{{ campaign.cost|number_format(0, '.', '') }} Gold</div>
                                <div class="mt-1 text-[8px] font-black uppercase tracking-[0.12em] text-slate-500">{{ campaign.badge }}</div>
                            </button>
