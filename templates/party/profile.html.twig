                <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] mb-4 border-b border-white/5 pb-3 flex items-center gap-2">
                    <i class="fa-solid fa-envelope-open-text text-emerald-400"></i> {{ t('party.profile.applications') }}
                </h2>
                {% if party.is_leader %}
                    <div class="space-y-3">
                        {% if party.join_applications %}
                            {% for application in party.join_applications %}
                                <div class="rounded-xl border border-white/5 bg-black/35 p-3">
