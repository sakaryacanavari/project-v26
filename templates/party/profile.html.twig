                                type="button"
                                class="ad-plan-btn {% if loop.first %}is-active{% endif %} rounded-lg px-2 py-2.5 text-left {% if party.ad_purchase_locked %}opacity-50 cursor-not-allowed saturate-50{% endif %}"
