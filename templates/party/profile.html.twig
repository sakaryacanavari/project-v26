                        Reklam kilidi aktif. Tekrar: {{ party.ad_purchase_available_at|date('d.m.Y H:i') }}
                    </div>
                    {% endif %}
                </div>
                {% endif %}

                <div class="relative grid grid-cols-2 gap-2">
                {% if party.affiliation %}
