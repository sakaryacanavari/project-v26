{% extends isAjax ? "common/ajaxbase.html.twig" : "common/base.html.twig" %}

{% block content %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
    /* =============================
       GYM v26.300 â€” SHARP-GLASS HUD (Net ve Keskin)
       ============================= */
    :root {
        --bug-accent: var(--brand-primary);
        --bug-accent-text: color-mix(in srgb, var(--brand-primary) 90%, #ffffff);
        --bug-accent-border: color-mix(in srgb, var(--brand-primary) 30%, transparent);
    }

    /* --- Core Layout & Sharp Glass Panel --- */
    .home-theme-surface .glass-panel {
        background: linear-gradient(145deg, rgba(8, 12, 20, 0.85) 0%, rgba(2, 4, 10, 0.98) 100%) !important;
        backdrop-filter: blur(12px); /* BulanÄ±klÄ±k dÃ¼ÅŸÃ¼rÃ¼ldÃ¼, netlik artÄ±rÄ±ldÄ± */
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        box-shadow: 0 15px 35px -10px rgba(0, 0, 0, 0.8);
        border-radius: 16px;
    }

    /* --- Table Rows (Sharp & Compact) --- */
    .v2-table-row {
        background: rgba(0, 0, 0, 0.4);
        transition: all 0.2s ease;
    }
    .v2-table-row:hover {
        background: color-mix(in srgb, var(--brand-primary) 8%, rgba(0,0,0,0.6));
        transform: translateX(4px);
    }
    .v2-table-row td {
        border-top: 1px solid rgba(255,255,255,0.03);
        border-bottom: 1px solid rgba(255,255,255,0.03);
        padding: 12px 14px;
    }
    .v2-table-row:hover td {
        border-color: color-mix(in srgb, var(--brand-primary) 25%, transparent);
    }
    .v2-table-row td:first-child {
        border-left: 3px solid transparent;
        border-top-left-radius: 12px;
        border-bottom-left-radius: 12px;
    }
    .v2-table-row:hover td:first-child {
        border-left: 3px solid var(--brand-primary);
    }
    .v2-table-row td:last-child {
        border-right: 1px solid rgba(255,255,255,0.03);
        border-top-right-radius: 12px;
        border-bottom-right-radius: 12px;
    }
    .v2-table-row:hover td:last-child {
        border-right-color: color-mix(in srgb, var(--brand-primary) 25%, transparent);
    }

    /* --- Zarif Scrollbar Sadece Mobilde Ã‡Ä±ksÄ±n Diye --- */
    .custom-scrollbar::-webkit-scrollbar { height: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); border-radius: 4px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: color-mix(in srgb, var(--brand-primary) 30%, transparent); border-radius: 4px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: var(--brand-primary); }

    /* --- Badges & Pills --- */
    .tech-badge {
        display: inline-flex; align-items: center; justify-content: center; gap: 6px;
        padding: 6px 12px; border-radius: 8px; font-family: 'JetBrains Mono', 'Courier New', monospace;
        font-weight: 900; font-size: 12px; border: 1px solid transparent;
        background: rgba(0,0,0,0.3);
    }
    .tech-badge.green { color: #34d399; border-color: rgba(16, 185, 129, 0.2); }
    .tech-badge.red { color: #f87171; border-color: rgba(239, 68, 68, 0.2); }
    .tech-badge.gold { color: #facc15; border-color: rgba(234, 179, 8, 0.2); }
    .tech-badge.neutral { color: #cbd5e1; border-color: rgba(255, 255, 255, 0.1); }

    /* --- Buttons --- */
    .btn-create-primary {
        background: var(--brand-primary);
        color: #000;
        font-weight: 900;
        transition: all 0.2s ease;
        border: none;
    }
    .btn-create-primary:hover:not(:disabled) {
        filter: brightness(1.1);
        transform: translateY(-2px);
    }
    .btn-create-primary:active:not(:disabled) {
        transform: translateY(0);
    }
    .btn-create-primary:disabled { opacity: 0.4; cursor: not-allowed; }
    .game-action-hero { padding: 22px; }
    .game-action-title { color: var(--text-main, #fff); }
    .game-action-copy { color: color-mix(in srgb, var(--text-muted, #94a3b8) 86%, #fff); line-height: 1.45; }
    .game-action-panel { padding: 18px; }
    .game-status-note { color: color-mix(in srgb, var(--text-muted, #94a3b8) 82%, #fff); }

    @media (max-width: 768px) {
        .game-action-hero { padding: 18px; }
        .game-action-panel { padding: 14px; }
        .btn-create-primary { min-height: 42px; width: 100%; justify-content: center; }
        .v2-table-row td { padding: 10px 12px; }
        .tech-badge { width: auto !important; min-width: 82px; }
    }

    /* SweetAlert V26 Sharp */
    .cyber-modal-popup { background: rgba(12, 16, 24, 0.98) !important; border: 1px solid rgba(255, 255, 255, 0.05) !important; border-radius: 16px !important; padding: 2rem 1.5rem !important; }
    .cyber-modal-title { color: #f8fafc !important; text-transform: uppercase !important; letter-spacing: 0.15em !important; font-weight: 900 !important; font-size: 14px !important; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 14px !important; margin-bottom: 18px !important; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .cyber-modal-content { color: #94a3b8 !important; font-size: 12px !important; font-weight: 600 !important; }
    .cyber-confirm-btn { background: var(--brand-primary) !important; color: #000 !important; font-weight: 900 !important; text-transform: uppercase !important; border-radius: 8px !important; padding: 12px 24px !important; font-size: 11px !important; border: none !important; }
</style>

<div class="home-theme-surface space-y-6 animate-fade-in w-full max-w-[1400px] mx-auto overflow-hidden">
    
    {# ===== HERO PANEL ===== #}
    <div class="glass-panel game-action-hero flex flex-col md:flex-row justify-between items-start md:items-center gap-5 relative">
        <i class="fa-solid fa-dumbbell absolute -right-6 -bottom-6 text-[100px] text-[color:var(--brand-primary)] opacity-[0.03] pointer-events-none rotate-[-15deg]"></i>

        <div class="flex items-center gap-4 relative z-10">
            <div class="w-12 h-12 rounded-xl bg-[color:var(--brand-primary)]/10 flex items-center justify-center">
                <i class="fa-solid fa-dumbbell text-2xl text-[color:var(--brand-primary)]"></i>
            </div>
            <div>
                <h1 class="game-action-title text-xl font-black uppercase tracking-wider leading-tight">
                    {{ t('gyms.hero.title') }}
                </h1>
                <p class="text-[10px] text-[color:var(--brand-primary)] font-bold uppercase tracking-[0.15em] mt-1.5 flex items-center gap-2">
                    <span class="w-1.5 h-1.5 bg-[color:var(--brand-primary)] rounded-full animate-pulse shadow-[0_0_5px_var(--brand-primary)]"></span> {{ t('gyms.hero.subtitle') }}
                </p>
                <p class="game-action-copy text-[10px] font-bold tracking-widest mt-1.5 uppercase">
                    {{ t('gyms.hero.limit') }}
                </p>
            </div>
        </div>

        <div class="flex flex-col md:items-end w-full md:w-auto relative z-10">
            <span class="text-[8px] text-slate-500 font-black uppercase tracking-[0.2em] mb-2 flex items-center gap-1.5">
                <i class="fa-solid fa-rotate text-[color:var(--brand-primary)] opacity-70"></i> {{ t('gyms.hero.reset') }}
            </span>
            <div class="bg-black/40 px-5 py-2.5 rounded-xl flex items-center gap-3 border border-white/5">
                <i class="fa-solid fa-clock text-[color:var(--brand-primary)] animate-pulse text-sm"></i>
                <span id="reset-timer" class="font-mono text-lg font-black tracking-widest text-white">00:00:00</span>
            </div>
        </div>
    </div>

    {# ===== TABLE PANEL ===== #}
    <div class="glass-panel game-action-panel">
        <h2 class="text-[11px] font-black text-[color:var(--text-main,#fff)] uppercase tracking-[0.18em] flex items-center gap-2 mb-4 border-b border-white/5 pb-3">
            <i class="fa-solid fa-server text-[color:var(--brand-primary)] opacity-80"></i> {{ t('gyms.panel.title') }}
        </h2>

        <div class="w-full overflow-x-auto custom-scrollbar pb-2">
            <table class="w-full text-left border-collapse whitespace-nowrap lg:whitespace-normal" style="border-spacing: 0 6px; border-collapse: separate;">
                <thead class="text-[9px] font-black text-slate-500 uppercase tracking-widest">
                    <tr>
                        <th class="p-3 pl-5 bg-black/40 rounded-l-[12px] border-y border-l border-white/5">{{ t('gyms.table.level') }}</th>
                        <th class="p-3 bg-black/40 border-y border-white/5 text-center">{{ t('gyms.table.strength') }}</th>
                        <th class="p-3 bg-black/40 border-y border-white/5 text-center">{{ t('gyms.table.energy') }}</th>
                        <th class="p-3 bg-black/40 border-y border-white/5 text-center">{{ t('gyms.table.cost') }}</th>
                        <th class="p-3 pr-5 bg-black/40 rounded-r-[12px] border-y border-r border-white/5 text-right">{{ t('gyms.table.status') }}</th>
                    </tr>
                </thead>
                <tbody class="text-[11px] font-bold text-white">
                    {% for quality, gym in gyms %}
                        <tr class="v2-table-row group">
                            <td class="p-3 pl-5">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 bg-black/60 rounded-[10px] flex items-center justify-center group-hover:bg-black/80 transition-colors">
                                        <img src="img/gyms/{{ gym.quality }}.png" class="w-6 h-6 opacity-90 group-hover:scale-110 transition-transform">
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="uppercase tracking-widest text-[12px] text-slate-200 font-black group-hover:text-white transition-colors">{% filter upper %}{{ quality }}{% endfilter %}</span>
                                        <span class="text-[color:var(--brand-primary)] text-[8px] font-black mt-1 tracking-widest uppercase opacity-80">{{ t('gyms.table.approved') }}</span>
                                    </div>
                                </div>
                            </td>

                            <td class="p-3 text-center">
                                <div class="tech-badge green w-24 mx-auto">
                                    <img class="w-3.5 h-3.5 opacity-90" src="img/icons/strength.png" alt="GÃ¼Ã§">
                                    <span class="text-[12px]">+{{ gym.strength }}</span>
                                </div>
                            </td>

                            <td class="p-3 text-center">
                                <div class="tech-badge red w-24 mx-auto">
                                    <i class="fa-solid fa-bolt text-[10px] opacity-80"></i>
                                    <span class="text-[12px]">-{{ gym.energy }}</span>
                                </div>
                            </td>

                            <td class="p-3 text-center">
                                {% if gym.cost > 0 %}
                                    <div class="tech-badge gold w-24 mx-auto">
                                        <span class="text-[12px]">{{ gym.cost }}</span>
                                        <img class="w-3.5 h-3.5" src="img/icons/gold.png" alt="AltÄ±n">
                                    </div>
                                {% else %}
                                    <div class="tech-badge neutral w-24 mx-auto text-[9px]">
                                        {{ t('gyms.table.free') }}
                                    </div>
                                {% endif %}
                            </td>

                            <td class="p-3 text-right pr-5">
                                {% if gym.hasTrainedToday %}
                                    {% if gym.trainedQualityToday %}
                                        <span class="inline-flex items-center gap-2 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-4 py-2.5 rounded-xl text-[9px] font-black uppercase tracking-widest" title="{{ t('gyms.table.done') }}">
                                            <i class="fa-solid fa-check"></i> {{ t('gyms.table.done') }}
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center gap-2 bg-amber-500/10 text-amber-400 border border-amber-500/20 px-4 py-2.5 rounded-xl text-[9px] font-black uppercase tracking-widest" title="{{ t('gyms.table.limit_full') }}">
                                            <i class="fa-solid fa-lock"></i> {{ t('gyms.table.limit_full') }}
                                        </span>
                                    {% endif %}
                                {% else %}
                                    <button onclick="window.startTraining({{ gym.quality }})" class="btn-create-primary px-6 py-2.5 rounded-xl font-black text-[10px] uppercase tracking-[0.1em] flex items-center justify-end ml-auto gap-2">
                                        <i class="fa-solid fa-play opacity-80 text-[10px]"></i> {{ t('gyms.table.start') }}
                                    </button>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# ===== WARNING PANEL ===== #}
    <div class="glass-panel p-4 bg-red-950/20 border-t-2 border-red-500/40 flex items-center justify-center gap-3">
        <i class="fa-solid fa-triangle-exclamation text-red-500 text-lg animate-pulse"></i>
        <p class="game-status-note text-[10px] font-bold uppercase tracking-[0.12em] leading-relaxed">
            <span class="text-white font-black">{{ t('gyms.warning.title') }}</span> {{ t('gyms.warning.copy') }}
        </p>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            function updateResetTimer() {
                const now = new Date();
                const tomorrow = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);
                const diff = tomorrow - now;

                if (diff <= 0) {
                    document.getElementById('reset-timer').innerText = "00:00:00";
                    setTimeout(() => location.reload(), 2000);
                    return;
                }

                const h = Math.floor((diff / (1000 * 60 * 60)) % 24).toString().padStart(2, '0');
                const m = Math.floor((diff / 1000 / 60) % 60).toString().padStart(2, '0');
                const s = Math.floor((diff / 1000) % 60).toString().padStart(2, '0');

                document.getElementById('reset-timer').innerText = `${h}:${m}:${s}`;
            }

            updateResetTimer();
            setInterval(updateResetTimer, 1000);
        });

        // SweetAlert2 V26 Uyumlu Ã‡aÄŸrÄ±lar
        window.startTraining = function(quality) {
            Swal.fire({
                title: '<i class="fa-solid fa-fingerprint text-[color:var(--brand-primary)] mr-2"></i> EÄŸitim BaÅŸlatÄ±lÄ±yor',
                html: '<div class="text-[12px] font-bold text-slate-400 mt-2 uppercase tracking-widest">Biyometrik veriler iÅŸleniyor, lÃ¼tfen bekleyin.</div>',
                showConfirmButton: false,
                allowOutsideClick: false,
                customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title' },
                background: '#0a0c14',
                color: '#f8fafc',
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            $.ajax({
                url: "{{ base_url() }}/api/gym/train",
                type: "POST",
                data: {
                    quality: quality,
                    csrf_token: $('meta[name="csrf-token"]').attr('content')
                },
                success: function(res) {
                    if (typeof res === 'string') {
                        try { res = JSON.parse(res); } catch (e) {}
                    }

                    if (res.error) {
                        Swal.fire({
                            icon: 'error',
                            title: '<i class="fa-solid fa-ban text-red-500 mr-2"></i> EÄÄ°TÄ°M BAÅARISIZ',
                            text: res.message,
                            customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title', confirmButton: 'cyber-confirm-btn' },
                            background: '#0a0c14', color: '#f8fafc'
                        });
                    } else {
                        Swal.fire({
                            icon: 'success',
                            title: '<i class="fa-solid fa-check-circle text-[color:var(--brand-primary)] mr-2"></i> EÄÄ°TÄ°M TAMAMLANDI',
                            html: '<div class="text-emerald-400 font-mono text-[16px] font-black mt-3">+ GÃœÃ‡ KAZANILDI</div>',
                            timer: 2000,
                            showConfirmButton: false,
                            customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title' },
                            background: '#0a0c14', color: '#f8fafc'
                        }).then(() => location.reload());
                    }
                },
                error: function() {
                    Swal.fire({
                        icon: 'error',
                        title: '<i class="fa-solid fa-plug-circle-xmark text-red-500 mr-2"></i> BAÄLANTI HATASI',
                        text: 'Sunucuya ulaÅŸÄ±lamadÄ±.',
                        customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title', confirmButton: 'cyber-confirm-btn' },
                        background: '#0a0c14', color: '#f8fafc'
                    });
                }
            });
        };

        $(function () {
            if (typeof peque !== 'undefined' && peque.gym) {
                peque.gym.init();
            }
        });
    </script>
</div>
{% endblock %}
