        .theme-radio:checked + .theme-card { background: color-mix(in srgb, currentColor 10%, rgba(0,0,0,0.7)); border-color: currentColor; box-shadow: 0 8px 18px -14px currentColor, inset 2px 0 0 currentColor; }
