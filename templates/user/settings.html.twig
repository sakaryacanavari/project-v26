    window.applyTheme = function() {
        const selectedModeEl = document.querySelector('input[name="mode"]:checked');
        const selectedColorEl = document.querySelector('input[name="theme"]:checked');
        const selectedEyeComfortEl = document.querySelector('input[name="eye_comfort_level"]:checked');

        if (!selectedModeEl || !selectedColorEl) {
            Swal.fire({
                icon: 'warning',
                title: '{{ t("settings.js.missing_selection_title") }}',
                text: '{{ t("settings.js.missing_selection_text") }}',
                background: '#0f172a',
                color: '#fff'
            });
            return;
        }

        const selectedMode = selectedModeEl.value;
        const selectedColor = selectedMode === 'archive' ? 'amber' : selectedColorEl.value;
        const selectedEyeComfortLevel = selectedEyeComfortEl ? selectedEyeComfortEl.value : 'balanced';

        $.ajax({
            url: "{{ base_url() }}/api/user/settings/theme",
            type: "POST",
            dataType: "json",
            data: {
                mode: selectedMode,
                color: selectedColor,
                eye_comfort_level: selectedEyeComfortLevel,
                csrf_token: getCsrfToken()
            },
            success: function(res) {
                if (res && res.error) {
                    Swal.fire({
                        icon: 'error',
                        title: '{{ t("home.shouts.generic_error") }}',
                        text: res.message || '{{ t("settings.js.theme_error") }}',
                        background: '#0f172a',
                        color: '#fff'
                    });
                    return;
                }

                const mode = (res && res.theme && res.theme.mode) ? res.theme.mode : selectedMode;
                const color = (res && res.theme && res.theme.color) ? res.theme.color : selectedColor;
                const eyeComfortLevel = (res && res.theme && res.theme.eye_comfort_level) ? res.theme.eye_comfort_level : selectedEyeComfortLevel;

                syncThemeCache(mode, color, eyeComfortLevel);

                showSettingsToast('{{ t("settings.js.theme_saved_text") }}', '{{ t("settings.js.theme_saved_title") }}');
                window.setTimeout(function() {
                    location.reload();
                }, 900);
            },
            error: function(xhr) {
                let message = '{{ t("settings.js.theme_error") }}';

                if (xhr && xhr.responseText) {
                    try {
                        const parsed = JSON.parse(xhr.responseText);
                        if (parsed && parsed.message) {
                            message = parsed.message;
                        }
                    } catch (e) {}
                }

                Swal.fire({
                    icon: 'error',
                    title: '{{ t("settings.js.connection_error") }}',
                    text: message,
                    background: '#0f172a',
                    color: '#fff'
                });
            }
        });
    };

