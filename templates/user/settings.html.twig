        if (strengthText) strengthText.textContent = 'Sifre gucu: bekleniyor';
        if (matchNote) matchNote.classList.remove('is-visible');
        document.querySelectorAll('[data-caps-warning]').forEach(function(warning) {
            warning.classList.remove('is-visible');
        });
    }

