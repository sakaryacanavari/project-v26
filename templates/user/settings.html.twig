    $(document).ready(function() {
        function activateSettingsTab(tab) {
            $('.tab-btn').removeClass('active');
            $('.tab-btn').attr('aria-selected', 'false');
            $(tab).addClass('active').attr('aria-selected', 'true');
            $('.tab-content').removeClass('active');
            $('#' + $(tab).data('target')).addClass('active');
        }

        $('.tab-btn').on('click', function() {
            activateSettingsTab(this);
        });

        $('.tab-btn').on('keydown', function(event) {
            if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                activateSettingsTab(this);
            }
        });

        const resolvedTheme = getResolvedThemeState();

        syncThemeCache(resolvedTheme.mode, resolvedTheme.color);

        $('#mode-' + resolvedTheme.mode).prop('checked', true);
        $('#theme-' + resolvedTheme.color).prop('checked', true);
        setupLanguageControls();
        setupSettingsDirtyState();
        setupSecretActions();
        setupProfileUx();
        setupPasswordUx();
        setupNotificationSettings();
        setupDmPrivacySettings();
        setupGameExperienceSettings();
    });

    function setupProfileUx() {
        const avatarInput = document.getElementById('input-avatar');
        const avatarImg = document.getElementById('settings-avatar-preview-img');
        const avatarFallback = document.getElementById('settings-avatar-fallback');
        const emailInput = document.getElementById('input-email');
        const emailNote = document.getElementById('email-change-note');
        const initialEmail = emailInput ? emailInput.value : '';

        const showAvatarFallback = function() {
            if (avatarImg) avatarImg.style.display = 'none';
            if (avatarFallback) avatarFallback.style.display = 'flex';
        };

        const updateAvatarPreview = function() {
            const value = avatarInput ? avatarInput.value.trim() : '';
            if (!value || !avatarImg) {
                showAvatarFallback();
                return;
            }

            if (avatarFallback) avatarFallback.style.display = 'none';
            avatarImg.style.display = 'block';
            avatarImg.src = value;
        };

        if (avatarImg) avatarImg.addEventListener('error', showAvatarFallback);
        if (avatarInput) avatarInput.addEventListener('input', updateAvatarPreview);
        if (emailInput && emailNote) {
            emailInput.addEventListener('input', function() {
                emailNote.classList.toggle('hidden', emailInput.value === initialEmail);
            });
        }

        updateAvatarPreview();
    }

    function setupPasswordUx() {
        const oldInput = document.getElementById('input-old-password');
        const newInput = document.getElementById('input-new-password');
        const confirmInput = document.getElementById('input-new-password-confirm');
        const strengthBar = document.getElementById('password-strength-bar');
        const strengthText = document.getElementById('password-strength-text');
        const matchNote = document.getElementById('password-match-note');

        const getStrength = function(value) {
            let score = 0;
            if (value.length >= 6) score++;
            if (value.length >= 10) score++;
            if (/[A-Z]/.test(value) && /[a-z]/.test(value)) score++;
            if (/\d/.test(value)) score++;
            if (/[^A-Za-z0-9]/.test(value)) score++;
            return Math.min(score, 5);
        };

        const updateStrength = function() {
            if (!newInput || !strengthBar || !strengthText) return;
            const score = getStrength(newInput.value);
            const labels = ['bekleniyor', 'zayif', 'orta', 'iyi', 'guclu', 'cok guclu'];
            strengthBar.style.width = (score * 20) + '%';
            strengthText.textContent = 'Sifre gucu: ' + labels[score];
        };

        const updateMatch = function() {
            if (!newInput || !confirmInput || !matchNote) return;
            const mismatch = confirmInput.value.length > 0 && newInput.value !== confirmInput.value;
            matchNote.classList.toggle('is-visible', mismatch);
        };

        const updateCaps = function(event) {
            const wrapper = event.target.closest('.settings-field');
            const warning = wrapper ? wrapper.querySelector('[data-caps-warning]') : null;
            if (!warning || !event.getModifierState) return;
            warning.classList.toggle('is-visible', event.getModifierState('CapsLock'));
        };

        [oldInput, newInput, confirmInput].forEach(function(input) {
            if (!input) return;
            input.addEventListener('keyup', updateCaps);
            input.addEventListener('keydown', updateCaps);
            input.addEventListener('blur', function() {
                const wrapper = input.closest('.settings-field');
                const warning = wrapper ? wrapper.querySelector('[data-caps-warning]') : null;
                if (warning) warning.classList.remove('is-visible');
            });
        });

        if (newInput) newInput.addEventListener('input', function() { updateStrength(); updateMatch(); });
        if (confirmInput) confirmInput.addEventListener('input', updateMatch);
        updateStrength();
        updateMatch();
    }

    function resetPasswordUx() {
        const strengthBar = document.getElementById('password-strength-bar');
        const strengthText = document.getElementById('password-strength-text');
