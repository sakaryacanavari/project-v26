        .eye-comfort-level-panel { display: none; border: 1px solid color-mix(in srgb, var(--settings-accent) 16%, rgba(255,255,255,0.06)); background: color-mix(in srgb, var(--settings-accent) 5%, rgba(0,0,0,0.20)); border-radius: 12px; padding: 12px; }
