        .eye-comfort-card:hover { border-color: color-mix(in srgb, var(--settings-accent) 24%, transparent); background: color-mix(in srgb, var(--settings-accent) 7%, rgba(0,0,0,0.22)); }
        .eye-comfort-radio:checked + .eye-comfort-card { border-color: var(--settings-accent); background: color-mix(in srgb, var(--settings-accent) 12%, rgba(0,0,0,0.28)); box-shadow: inset 2px 0 0 var(--settings-accent), 0 8px 18px -14px var(--settings-accent-glow); }
