                avatar: $('#input-avatar').val(),
                csrf_token: getCsrfToken()
            },
            success: function(res) {
                if (res && res.error) {
                    Swal.fire({ icon: 'error', title: '{{ t("home.shouts.generic_error") }}', text: res.message, background: '#0f172a', color: '#fff' });
                } else {
                    showSettingsToast('{{ t("settings.js.profile_saved") }}').then(function() { location.reload(); });
                }
            },
            error: function(xhr) {
                let message = '{{ t("settings.js.profile_error") }}';

                if (xhr && xhr.responseText) {
                    try {
                        const parsed = JSON.parse(xhr.responseText);
                        if (parsed && parsed.message) {
                            message = parsed.message;
                        }
                    } catch (e) {}
                }

                Swal.fire({ icon: 'error', title: '{{ t("home.shouts.generic_error") }}', text: message, background: '#0f172a', color: '#fff' });
            }
        });
    };

    window.updatePassword = function(e) {
        e.preventDefault();

        if ($('#input-new-password').val() !== $('#input-new-password-confirm').val()) {
            Swal.fire({ icon: 'warning', title: '{{ t("settings.js.password_mismatch_title") }}', text: '{{ t("settings.js.password_mismatch_text") }}', background: '#0f172a', color: '#fff' });
            return;
        }

        Swal.fire({
            icon: 'warning',
            title: '{{ t("settings.security.change_password") }}',
            text: '{{ t("settings.common.password_confirm") }}',
            background: '#0f172a',
            color: '#fff',
            showCancelButton: true,
            confirmButtonText: '{{ t("settings.common.confirm") }}',
            cancelButtonText: '{{ t("settings.common.cancel") }}'
        }).then(function(result) {
            if (!result.isConfirmed) return;

            $.ajax({
                url: "{{ base_url() }}/api/user/settings/password",
                type: "POST",
                dataType: "json",
                data: {
                    old_password: $('#input-old-password').val(),
                    new_password: $('#input-new-password').val(),
                    csrf_token: getCsrfToken()
                },
                success: function(res) {
                    if (res && res.error) {
                        Swal.fire({ icon: 'error', title: '{{ t("home.shouts.generic_error") }}', text: res.message, background: '#0f172a', color: '#fff' });
                    } else {
                        showSettingsToast('{{ t("settings.js.password_saved") }}').then(function() {
                            document.getElementById('security-settings-form').reset();
                            resetPasswordUx();
                            const passwordButton = document.getElementById('password-save-btn');
                            if (passwordButton) passwordButton.disabled = true;
                        });
                    }
                },
                error: function(xhr) {
                    let message = '{{ t("settings.js.password_error") }}';

                    if (xhr && xhr.responseText) {
                        try {
                            const parsed = JSON.parse(xhr.responseText);
                            if (parsed && parsed.message) {
                                message = parsed.message;
                            }
                        } catch (e) {}
                    }

                    Swal.fire({ icon: 'error', title: '{{ t("home.shouts.generic_error") }}', text: message, background: '#0f172a', color: '#fff' });
                }
            });
        });
    };
</script>
{% endblock %}

