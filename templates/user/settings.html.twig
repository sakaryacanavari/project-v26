    function setupGameExperienceSettings() {
        const form = document.getElementById('game-experience-form');
        const buttons = document.querySelectorAll('.game-experience-save-btn');
        const hint = document.getElementById('game-experience-save-hint');
        const hintCopies = document.querySelectorAll('.game-experience-save-hint-copy');
        const favoritesHint = document.getElementById('game-favorites-hint');

        if (!form || !buttons.length) return;

        const getCheckedValue = function(name, fallback) {
            const checked = document.querySelector('input[name="' + name + '"]:checked');
            return checked ? checked.value : fallback;
        };

        const getFavorites = function() {
            return Array.prototype.slice.call(document.querySelectorAll('input[name="quick_favorites[]"]:checked')).map(function(input) {
                return input.value;
            });
        };

        const serializeState = function() {
            return [
                getCheckedValue('ui_density', 'balanced'),
                getCheckedValue('animation_level', 'balanced'),
                getCheckedValue('left_hud', 'detailed'),
                getCheckedValue('shout_width', 'balanced'),
                getCheckedValue('home_layout', 'wide'),
                getCheckedValue('home_priority', 'news'),
                getFavorites().join(',')
            ].join('|');
        };

        let initial = serializeState();

        const sync = function() {
            const favorites = getFavorites();
            const favoriteChecks = document.querySelectorAll('input[name="quick_favorites[]"]');
            favoriteChecks.forEach(function(input) {
                input.disabled = favorites.length >= 4 && !input.checked;
            });

            const changed = serializeState() !== initial;
            buttons.forEach(function(button) {
                button.disabled = !changed;
            });
            if (hint) {
                hint.textContent = changed ? 'Kaydetmeye hazir.' : 'Degisiklik yok.';
                hint.classList.toggle('is-ready', changed);
            }
            hintCopies.forEach(function(copy) {
                copy.textContent = changed ? 'Kaydetmeye hazir.' : 'Degisiklik yok.';
                copy.classList.toggle('is-ready', changed);
            });
            if (favoritesHint) {
                favoritesHint.textContent = favorites.length >= 4 ? 'Favori limiti dolu.' : 'En fazla 4 favori secilebilir.';
                favoritesHint.classList.toggle('is-ready', favorites.length >= 4);
            }
        };

        $(document).on('change', '#game-experience-form input, input[form="game-experience-form"]', sync);
        form._resetGameExperienceInitial = function() {
            initial = serializeState();
            sync();
        };

        sync();
    }

    function applyGameExperienceState(preferences) {
        if (!preferences) return;

        const checkRadio = function(name, value) {
            const input = document.querySelector('input[name="' + name + '"][value="' + value + '"]');
            if (input) input.checked = true;
        };

        checkRadio('ui_density', preferences.ui_density || 'balanced');
        checkRadio('animation_level', preferences.animation_level || 'balanced');
        checkRadio('left_hud', preferences.left_hud || 'detailed');
        checkRadio('shout_width', preferences.shout_width || 'balanced');
        checkRadio('home_layout', preferences.home_layout || 'wide');
        checkRadio('home_priority', preferences.home_priority || 'news');

        const favorites = Array.isArray(preferences.quick_favorites) ? preferences.quick_favorites : [];
        document.querySelectorAll('input[name="quick_favorites[]"]').forEach(function(input) {
            input.checked = favorites.indexOf(input.value) !== -1;
        });

