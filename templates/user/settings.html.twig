    function getServerThemeState() {
        const root = document.getElementById('v2-settings-center');

        return {
            mode: root && root.dataset ? (root.dataset.serverMode || 'dark') : 'dark',
            color: root && root.dataset ? (root.dataset.serverColor || 'purple') : 'purple',
            eyeComfortLevel: root && root.dataset ? (root.dataset.serverEyeComfort || 'balanced') : 'balanced'
        };
    }

    function getResolvedThemeState() {
        const serverState = getServerThemeState();

        return {
            mode: serverState.mode || localStorage.getItem('omni_mode') || 'dark',
            color: serverState.color || localStorage.getItem('omni_color') || 'purple',
            eyeComfortLevel: serverState.eyeComfortLevel || localStorage.getItem('omni_eye_comfort_level') || 'balanced'
        };
    }

    function syncThemeCache(mode, color, eyeComfortLevel) {
        localStorage.setItem('omni_mode', mode);
        localStorage.setItem('omni_color', color);
        localStorage.setItem('omni_eye_comfort_level', eyeComfortLevel || 'balanced');
    }

