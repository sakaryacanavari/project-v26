{% extends isAjax ? "common/ajaxbase.html.twig" : "common/base.html.twig" %}

{% block content %}
<div
    class="space-y-4 animate-fade-in w-full overflow-hidden gx-density-{{ gameExperienceSettings.ui_density|default('balanced') }} gx-motion-{{ gameExperienceSettings.animation_level|default('balanced') }}"
    id="v2-settings-center"
    data-server-mode="{{ themeState.mode|default('dark') }}"
    data-server-color="{{ themeState.color|default('purple') }}"
    data-server-eye-comfort="{{ themeState.eye_comfort_level|default('balanced') }}"
>
    
    <style>
        #v2-settings-center {
            --settings-accent: var(--brand-primary);
            --settings-accent-text: color-mix(in srgb, var(--brand-primary) 78%, #ffffff);
            --settings-accent-soft: color-mix(in srgb, var(--brand-primary) 14%, transparent);
            --settings-accent-border: color-mix(in srgb, var(--brand-primary) 32%, transparent);
            --settings-accent-glow: var(--brand-glow);
            max-width: 1320px;
            margin: 0 auto;
        }

        #v2-settings-center .holo-panel { background: linear-gradient(145deg, color-mix(in srgb, var(--settings-accent) 8%, rgba(15, 23, 42, 0.82)), rgba(2, 6, 23, 0.94)); backdrop-filter: blur(12px); border: 1px solid color-mix(in srgb, var(--settings-accent) 13%, rgba(255,255,255,0.06)); box-shadow: 0 10px 24px rgba(0, 0, 0, 0.34), inset 0 1px 0 rgba(255,255,255,0.08); border-radius: 12px; overflow: hidden; position: relative; transition: all 0.25s ease; }
        #v2-settings-center .holo-panel::after { content: ""; position: absolute; inset: 0; pointer-events: none; background-image: repeating-linear-gradient(transparent, transparent 2px, rgba(0,0,0,0.1) 2px, rgba(0,0,0,0.1) 4px); opacity: 0.5; }
        #v2-settings-center .settings-compact-panel { padding: 16px; }
        #v2-settings-center .settings-tight-stack { gap: 14px; }

        .tech-border-top-emerald { border-top: 2px solid var(--settings-accent); box-shadow: inset 0 15px 15px -15px var(--settings-accent-glow); }
        .tech-border-top-cyan { border-top: 2px solid var(--settings-accent); box-shadow: inset 0 15px 15px -15px var(--settings-accent-glow); }
        .tech-border-top-red { border-top: 2px solid #ef4444; box-shadow: inset 0 15px 15px -15px rgba(239, 68, 68, 0.3); }
        .tech-border-top-indigo { border-top: 2px solid var(--settings-accent); box-shadow: inset 0 15px 15px -15px var(--settings-accent-glow); }
        .tech-border-top-amber { border-top: 2px solid #f59e0b; box-shadow: inset 0 15px 15px -15px rgba(245, 158, 11, 0.3); }
        .tech-border-top-crimson { border-top: 2px solid #991b1b; box-shadow: inset 0 15px 15px -15px rgba(153, 27, 27, 0.5); }
        .tech-border-top-purple { border-top: 2px solid var(--settings-accent); box-shadow: inset 0 15px 15px -15px var(--settings-accent-glow); }

        .cyber-input, .cyber-select { background: color-mix(in srgb, var(--settings-accent) 5%, rgba(0, 0, 0, 0.48)); border: 1px solid color-mix(in srgb, var(--settings-accent) 16%, rgba(255,255,255,0.08)); color: #e2e8f0; font-family: 'Courier New', monospace; font-weight: bold; transition: all 0.22s ease; width: 100%; border-radius: 10px; outline: none; appearance: none; }
        .cyber-input:disabled { background-color: rgba(15, 23, 42, 0.4) !important; color: #94a3b8 !important; }
        .cyber-input:hover, .cyber-select:hover { border-color: color-mix(in srgb, var(--settings-accent) 34%, rgba(255,255,255,0.12)); background: color-mix(in srgb, var(--settings-accent) 8%, rgba(0, 0, 0, 0.55)); }
        .cyber-input:focus, .cyber-select:focus { border-color: var(--brand-primary); background: color-mix(in srgb, var(--settings-accent) 9%, rgba(0, 0, 0, 0.72)); box-shadow: 0 0 0 1px color-mix(in srgb, var(--settings-accent) 35%, transparent), 0 0 18px var(--brand-glow), inset 0 0 10px var(--settings-accent-soft); }
        .cyber-input.input-red:focus { border-color: #ef4444; box-shadow: 0 0 15px rgba(239, 68, 68, 0.3), inset 0 0 10px rgba(239, 68, 68, 0.1); }

        .select-wrapper { position: relative; }
        .select-wrapper::after { content: '\f078'; font-family: 'Font Awesome 6 Free'; font-weight: 900; position: absolute; right: 16px; top: 50%; transform: translateY(-50%); pointer-events: none; color: #94a3b8; font-size: 12px; }
        .cyber-select option { background: #0f172a; color: #fff; }

        .cyber-btn { position: relative; overflow: hidden; font-weight: 900; text-transform: uppercase; letter-spacing: 1.6px; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); z-index: 10; display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 11px 18px; border-radius: 10px; font-size: 10px; cursor: pointer; border: none; min-height: 42px; }
        .cyber-btn::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); transition: all 0.5s; z-index: -1; }
        .cyber-btn:hover::before { left: 100%; }
        .cyber-btn:disabled { opacity: 0.52; cursor: not-allowed; filter: grayscale(0.25); transform: none !important; box-shadow: none !important; }
        .cyber-btn:disabled::before { display: none; }
        
        .btn-cyan { background: var(--brand-primary); color: #fff; border: 1px solid var(--brand-primary); box-shadow: 0 0 15px var(--brand-glow); }
        .btn-cyan:hover { filter: brightness(1.2); box-shadow: 0 0 25px var(--brand-glow); transform: translateY(-2px); }
        
        .btn-red { background: #dc2626; color: #fff; border: 1px solid #ef4444; box-shadow: 0 0 15px rgba(239, 68, 68, 0.4); }
        .btn-red:hover { background: #b91c1c; box-shadow: 0 0 25px rgba(239, 68, 68, 0.6); transform: translateY(-2px); }
        
        .btn-amber { background: #d97706; color: #fff; border: 1px solid #f59e0b; box-shadow: 0 0 15px rgba(245, 158, 11, 0.4); }
        .btn-amber:hover { background: #b45309; box-shadow: 0 0 25px rgba(245, 158, 11, 0.6); transform: translateY(-2px); }
        
        .btn-crimson { background: #7f1d1d; color: #fff; border: 1px solid #991b1b; box-shadow: 0 0 15px rgba(153, 27, 27, 0.4); }
        .btn-crimson:hover { background: #450a0a; box-shadow: 0 0 25px rgba(153, 27, 27, 0.8); transform: translateY(-2px); }

        .toggle-checkbox:checked { right: 0; border-color: var(--settings-accent); }
        .toggle-checkbox:checked + .toggle-label { background-color: var(--settings-accent); }
        .toggle-checkbox:disabled { opacity: 0.55; cursor: not-allowed; }
        .toggle-checkbox:disabled + .toggle-label { opacity: 0.5; cursor: not-allowed; }
        .settings-status-note { color: #94a3b8; font-size: 8px; font-weight: 900; letter-spacing: 0.12em; text-transform: uppercase; }
        .settings-soon { border: 1px solid color-mix(in srgb, var(--settings-accent) 22%, transparent); background: color-mix(in srgb, var(--settings-accent) 8%, transparent); color: var(--settings-accent-text); border-radius: 999px; padding: 3px 7px; font-size: 7px; font-weight: 900; letter-spacing: 0.12em; text-transform: uppercase; white-space: nowrap; }
        .settings-secret-actions { display: flex; gap: 8px; margin-top: 8px; }
        .settings-action-btn { border: 1px solid color-mix(in srgb, var(--settings-accent) 24%, transparent); background: color-mix(in srgb, var(--settings-accent) 10%, transparent); color: var(--settings-accent-text); border-radius: 8px; padding: 8px 10px; font-size: 9px; font-weight: 900; letter-spacing: 0.1em; text-transform: uppercase; }
        .settings-upcoming-sections { display: grid; grid-template-columns: repeat(1, minmax(0, 1fr)); gap: 14px; }
        .settings-upcoming-section { border: 1px solid color-mix(in srgb, var(--settings-accent) 14%, rgba(255,255,255,0.06)); background: color-mix(in srgb, var(--settings-accent) 5%, rgba(0,0,0,0.18)); border-radius: 12px; padding: 12px; }
        .settings-upcoming-section-title { display: flex; align-items: center; gap: 8px; color: #fff; font-size: 10px; font-weight: 900; letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 10px; padding-bottom: 9px; border-bottom: 1px solid rgba(255,255,255,0.06); }
        .settings-upcoming-grid { display: grid; grid-template-columns: repeat(1, minmax(0, 1fr)); gap: 10px; }
        .settings-upcoming-card { border: 1px solid color-mix(in srgb, var(--settings-accent) 16%, transparent); background: color-mix(in srgb, var(--settings-accent) 6%, rgba(0,0,0,0.22)); border-radius: 10px; padding: 12px; min-height: 0; }
        .settings-upcoming-card h3 { color: var(--settings-accent-text); font-size: 9px; font-weight: 900; letter-spacing: 0.13em; text-transform: uppercase; display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 8px; }
        .settings-upcoming-card h3 span:first-child { display: inline-flex; align-items: center; gap: 8px; min-width: 0; }
        .settings-upcoming-card p { color: #94a3b8; font-size: 8px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; line-height: 1.5; }
        .settings-upcoming-badge { border: 1px solid color-mix(in srgb, var(--settings-accent) 24%, transparent); background: color-mix(in srgb, var(--settings-accent) 9%, transparent); color: var(--settings-accent-text); border-radius: 999px; padding: 3px 7px; font-size: 7px; font-weight: 900; letter-spacing: 0.11em; text-transform: uppercase; white-space: nowrap; flex: 0 0 auto; }
        .settings-hero { border-left: 4px solid var(--settings-accent); padding: 14px 16px; background: linear-gradient(135deg, color-mix(in srgb, var(--settings-accent) 16%, transparent), rgba(0,0,0,0.12)); }
        .settings-hero-icon { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 18px; background-color: color-mix(in srgb, var(--settings-accent) 18%, transparent); color: var(--settings-accent); border: 1px solid var(--settings-accent); box-shadow: 0 0 14px var(--settings-accent-glow); }
        .settings-tabs { padding: 6px; gap: 6px; border: 1px solid color-mix(in srgb, var(--settings-accent) 12%, rgba(255,255,255,0.06)); }
        .settings-card { padding: 18px; border-top: 2px solid var(--settings-accent); }
        .settings-card-title { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 14px; padding-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.06); }
        .settings-card-title h2 { display: flex; align-items: center; gap: 9px; font-size: 11px; font-weight: 900; letter-spacing: 0.18em; text-transform: uppercase; color: #e2e8f0; }
        .settings-card-title p { color: #94a3b8; font-size: 9px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; line-height: 1.45; }
        .settings-system-layout { align-items: start; }
        .settings-system-panel { align-self: start; }
        .settings-system-stack { display: grid; gap: 12px; }
        .settings-system-control {
            border: 1px solid color-mix(in srgb, var(--settings-accent) 12%, rgba(255,255,255,0.06));
            background: color-mix(in srgb, var(--settings-accent) 4%, rgba(0,0,0,0.22));
            border-radius: 14px;
            padding: 12px;
        }
        .settings-system-control-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; margin-bottom: 10px; }
        .settings-system-control-title { display: flex; align-items: center; gap: 7px; color: #e2e8f0; font-size: 9px; font-weight: 950; letter-spacing: 0.12em; text-transform: uppercase; line-height: 1.25; }
        .settings-system-control .settings-primary-action { width: 100%; min-height: 42px; justify-content: center; }
        .settings-system-control .settings-action-hint { margin-top: 8px; text-align: center; line-height: 1.35; }
        .settings-system-control .select-wrapper { margin-bottom: 10px; }
        .settings-system-control .settings-helper,
        .settings-system-control .settings-action-hint { text-transform: none; letter-spacing: 0.02em; font-size: 10px; font-weight: 750; }
        .settings-system-control .cyber-btn:disabled {
            opacity: 0.72;
            color: #cbd5e1;
            background: color-mix(in srgb, var(--settings-accent) 8%, rgba(15,23,42,0.58)) !important;
            border: 1px solid color-mix(in srgb, var(--settings-accent) 16%, rgba(255,255,255,0.08)) !important;
        }
        .settings-form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
        .settings-field { min-width: 0; }
        .settings-field.is-wide { grid-column: 1 / -1; }
        .settings-label { color: #cbd5e1; font-size: 9px; font-weight: 900; letter-spacing: 0.13em; text-transform: uppercase; margin-bottom: 7px; display: flex; align-items: center; gap: 7px; }
        .settings-action-row { margin-top: 14px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.06); }
        .settings-action-hint { color: #94a3b8; font-size: 8px; font-weight: 850; letter-spacing: 0.1em; text-transform: uppercase; line-height: 1.4; margin-top: 8px; text-align: center; opacity: 0.88; }
        .settings-action-hint.is-ready { color: var(--settings-accent-text); }
        .settings-primary-action { width: 100%; min-height: 46px; box-shadow: 0 0 20px var(--settings-accent-glow), inset 0 1px 0 rgba(255,255,255,0.18); }
        .settings-password-action { width: 100%; min-height: 46px; }
        .settings-secret-toggle { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); width: 30px; height: 30px; display: inline-flex; align-items: center; justify-content: center; color: #94a3b8; border-radius: 8px; transition: all 0.2s ease; }
        .settings-secret-toggle:hover { color: #fff; background: color-mix(in srgb, var(--settings-accent) 12%, transparent); }
        .settings-helper { color: #94a3b8; font-size: 8px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; line-height: 1.45; margin-top: 7px; }
        .settings-helper.is-warn { color: var(--settings-accent-text); }
        .settings-avatar-preview { display: flex; align-items: center; gap: 12px; padding: 10px; border: 1px solid color-mix(in srgb, var(--settings-accent) 18%, rgba(255,255,255,0.06)); border-radius: 12px; background: color-mix(in srgb, var(--settings-accent) 7%, rgba(0,0,0,0.24)); }
        .settings-avatar-preview img, .settings-avatar-fallback { width: 46px; height: 46px; border-radius: 12px; border: 1px solid color-mix(in srgb, var(--settings-accent) 30%, transparent); object-fit: cover; flex: 0 0 auto; }
        .settings-avatar-fallback { display: none; align-items: center; justify-content: center; color: var(--settings-accent-text); background: color-mix(in srgb, var(--settings-accent) 14%, transparent); font-size: 18px; }
        .settings-strength { height: 6px; border-radius: 999px; overflow: hidden; background: rgba(255,255,255,0.08); margin-top: 9px; }
        .settings-strength-bar { height: 100%; width: 0; background: var(--settings-accent); box-shadow: 0 0 12px var(--settings-accent-glow); transition: width 0.2s ease; }
        .settings-strength-text { margin-top: 7px; color: #94a3b8; font-size: 8px; font-weight: 900; letter-spacing: 0.1em; text-transform: uppercase; }
        .settings-inline-alert { display: none; color: var(--settings-accent-text); font-size: 8px; font-weight: 900; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 7px; }
        .settings-inline-alert.is-visible { display: block; }
        .settings-toggle-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 10px; border-radius: 10px; border: 1px solid color-mix(in srgb, var(--settings-accent) 14%, rgba(255,255,255,0.06)); background: color-mix(in srgb, var(--settings-accent) 5%, rgba(0,0,0,0.22)); }
        .settings-toggle-title { color: #e2e8f0; font-size: 9px; font-weight: 900; letter-spacing: 0.12em; text-transform: uppercase; }
        .settings-toggle-desc { color: #94a3b8; font-size: 8px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; line-height: 1.45; margin-top: 3px; }
        .settings-switch { position: relative; display: inline-flex; width: 44px; height: 24px; flex: 0 0 auto; }
        .settings-switch input { position: absolute; opacity: 0; pointer-events: none; }
        .settings-switch span { width: 100%; height: 100%; border-radius: 999px; background: rgba(255,255,255,0.12); border: 1px solid color-mix(in srgb, var(--settings-accent) 15%, rgba(255,255,255,0.08)); transition: all 0.2s ease; cursor: pointer; }
        .settings-switch span::after { content: ""; position: absolute; width: 18px; height: 18px; left: 3px; top: 3px; border-radius: 999px; background: #fff; transition: all 0.2s ease; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }
        .settings-switch input:checked + span { background: var(--settings-accent); box-shadow: 0 0 14px var(--settings-accent-glow); }
        .settings-switch input:checked + span::after { transform: translateX(20px); }
        .settings-switch input:disabled + span { opacity: 0.55; cursor: not-allowed; }
        .settings-time-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
        .settings-passive-note { border: 1px solid color-mix(in srgb, var(--settings-accent) 14%, rgba(255,255,255,0.06)); background: color-mix(in srgb, var(--settings-accent) 5%, rgba(0,0,0,0.2)); border-radius: 10px; padding: 10px; color: #94a3b8; font-size: 8px; font-weight: 850; letter-spacing: 0.09em; text-transform: uppercase; line-height: 1.45; }
        .settings-simple-row { padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
        .settings-simple-row:last-of-type { border-bottom: none; }
        .settings-info-badge { display: inline-flex; align-items: center; gap: 6px; border: 1px solid color-mix(in srgb, var(--settings-accent) 18%, transparent); background: color-mix(in srgb, var(--settings-accent) 7%, transparent); color: var(--settings-accent-text); border-radius: 999px; padding: 6px 9px; font-size: 8px; font-weight: 900; letter-spacing: 0.09em; text-transform: uppercase; white-space: nowrap; }
        .settings-choice-desc { margin-top: 9px; color: var(--settings-accent-text); font-size: 8px; font-weight: 900; letter-spacing: 0.09em; text-transform: uppercase; line-height: 1.45; }
        .settings-option-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }
        .settings-option-grid.is-two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .dm-privacy-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
        .dm-privacy-card { min-height: 76px; justify-content: flex-start; align-items: flex-start; flex-direction: column; gap: 6px; text-align: left; }
        .dm-privacy-card strong { color: #f8fafc; font-size: 9px; font-weight: 950; letter-spacing: 0.08em; text-transform: uppercase; }
        .dm-privacy-card span { color: #94a3b8; font-size: 8px; font-weight: 800; letter-spacing: 0.055em; text-transform: uppercase; line-height: 1.35; }
        .dm-privacy-card.is-preview { cursor: not-allowed; opacity: 0.72; border-style: dashed; }
        .dm-request-preview { padding: 10px 0; }
        .dm-request-empty { display: flex; align-items: center; gap: 10px; padding-top: 8px; }
        .dm-request-empty-icon { width: 32px; height: 32px; border-radius: 10px; display: inline-flex; align-items: center; justify-content: center; color: var(--settings-accent-text); background: color-mix(in srgb, var(--settings-accent) 10%, transparent); border: 1px solid color-mix(in srgb, var(--settings-accent) 16%, transparent); flex: 0 0 auto; }
        .settings-choice-radio,
        .mode-radio,
        .theme-radio,
        .eye-comfort-radio,
        .settings-favorite-check {
            position: absolute;
            width: 1px;
            height: 1px;
            opacity: 0;
            pointer-events: none;
        }
        .settings-choice-card { display: flex; align-items: center; justify-content: center; min-height: 46px; border-radius: 12px; border: 1px solid color-mix(in srgb, var(--settings-accent) 14%, rgba(255,255,255,0.06)); background: color-mix(in srgb, var(--settings-accent) 5%, rgba(0,0,0,0.22)); color: #94a3b8; padding: 8px; text-align: center; font-size: 9px; font-weight: 900; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; transition: all 0.18s ease; }
        .settings-choice-card:hover { color: #fff; border-color: color-mix(in srgb, var(--settings-accent) 28%, transparent); }
        .settings-choice-radio:checked + .settings-choice-card { color: #fff; border-color: var(--settings-accent); background: color-mix(in srgb, var(--settings-accent) 13%, rgba(0,0,0,0.28)); box-shadow: inset 0 0 14px color-mix(in srgb, var(--settings-accent) 10%, transparent); }
        .settings-choice-radio:focus-visible + .settings-choice-card,
        .mode-radio:focus-visible + .mode-card,
        .theme-radio:focus-visible + .theme-card,
        .eye-comfort-radio:focus-visible + .eye-comfort-card,
        .settings-favorite-check:focus-visible + .settings-favorite-chip {
            outline: 2px solid color-mix(in srgb, var(--settings-accent) 70%, #ffffff);
            outline-offset: 3px;
            box-shadow: 0 0 0 4px color-mix(in srgb, var(--settings-accent) 15%, transparent), inset 0 0 14px color-mix(in srgb, var(--settings-accent) 9%, transparent);
        }
        .game-settings-layout { align-items: start; }
        .game-settings-panel { border-radius: 14px; background: rgba(0,0,0,0.16); padding: 4px 0; }
        .game-settings-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 14px; padding-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.06); }
        .game-settings-head h2 { color: #f8fafc; font-size: 11px; font-weight: 950; letter-spacing: 0.16em; text-transform: uppercase; }
        .game-settings-head p { margin-top: 4px; color: #94a3b8; font-size: 9px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; line-height: 1.45; }
        .game-settings-badge { display: inline-flex; align-items: center; gap: 6px; border-radius: 999px; border: 1px solid color-mix(in srgb, var(--settings-accent) 25%, transparent); background: color-mix(in srgb, var(--settings-accent) 8%, transparent); color: var(--settings-accent-text); padding: 6px 9px; font-size: 8px; font-weight: 950; letter-spacing: 0.1em; text-transform: uppercase; white-space: nowrap; }
        .game-setting-group { padding: 14px 10px; border-bottom: 1px solid rgba(255,255,255,0.06); }
        .game-setting-group:last-child { border-bottom: 0; }
        .game-setting-group + .game-setting-group { margin-top: 0; }
        .game-setting-group .settings-label { margin-bottom: 0; color: #e2e8f0; }
        .game-setting-group .settings-helper { margin-top: 5px; margin-bottom: 10px; letter-spacing: 0.075em; }
        .game-setting-group .settings-choice-card { min-height: 44px; border-radius: 11px; background: rgba(0,0,0,0.18); }
        .game-setting-group .settings-choice-radio:checked + .settings-choice-card { box-shadow: inset 0 0 12px color-mix(in srgb, var(--settings-accent) 12%, transparent); }
