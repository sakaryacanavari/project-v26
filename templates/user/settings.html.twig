                    <div id="game-experience-save-hint" class="settings-action-hint">Degisiklik yok.</div>
                    <button form="game-experience-form" type="submit" class="cyber-btn btn-cyan settings-primary-action game-experience-save-btn" disabled>
                        <i class="fa-solid fa-gamepad"></i> Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="tab-system" class="tab-content space-y-4" role="tabpanel">
        <div class="settings-system-layout grid grid-cols-1 xl:grid-cols-[300px_minmax(0,1fr)] gap-4">
            <div class="holo-panel settings-card settings-system-panel relative">
                <h2 class="text-[10px] font-black text-slate-300 uppercase tracking-[0.18em] flex items-center gap-2 mb-4 border-b border-white/5 pb-3">
                    <i class="fa-solid fa-language" style="color: var(--brand-primary);"></i> Gorunum ve Dil
                </h2>
                <div class="settings-system-stack">
                    <div class="settings-system-control">
                        <div class="settings-system-control-head">
                            <div>
                                <div class="settings-system-control-title"><i class="fa-solid fa-language text-slate-500"></i> Dil</div>
                                <div class="settings-helper mt-1">Kaydedilince sayfa yeni secimle yenilenir.</div>
                            </div>
                        </div>
                        <div class="select-wrapper">
                            <select id="input-language" class="cyber-select py-3 px-4" aria-describedby="language-save-hint">
                                <option value="tr" {% if languageState == "tr" %}selected{% endif %}>{{ t('settings.language.tr') }}</option>
                                <option value="en" {% if languageState == "en" %}selected{% endif %}>{{ t('settings.language.en') }}</option>
                            </select>
                        </div>
                        <button type="button" id="language-save-btn" onclick="window.updateLanguage()" class="cyber-btn btn-cyan settings-primary-action" aria-describedby="language-save-hint" disabled>
                            <i class="fa-solid fa-language"></i> {{ t('settings.localization.apply_language') }}
                        </button>
                        <div id="language-save-hint" class="settings-action-hint">Dil degisince kaydetme aktif olur.</div>
                    </div>

                    <div class="settings-system-control">
                        <div class="settings-system-control-head">
                            <div>
                                <div class="settings-system-control-title"><i class="fa-solid fa-floppy-disk text-slate-500"></i> Tema</div>
                                <div class="settings-helper mt-1">Arayuz modu ve renk paleti secimlerini uygular.</div>
                            </div>
                        </div>
                        <button type="button" id="theme-save-btn" onclick="window.applyTheme()" class="cyber-btn btn-cyan settings-primary-action" style="background:var(--brand-primary); border-color:var(--brand-primary);" aria-describedby="theme-save-hint" disabled>
                            <i class="fa-solid fa-floppy-disk"></i> Tema Kaydet
                        </button>
                        <div id="theme-save-hint" class="settings-action-hint">Arayuz veya renk secimi degisince aktif olur.</div>
                    </div>

                </div>
            </div>

            <div class="holo-panel settings-card relative">
                <h2 class="text-[10px] font-black text-slate-300 uppercase tracking-[0.18em] flex items-center gap-2 mb-4 border-b border-white/5 pb-3">
                    <i class="fa-solid fa-desktop" style="color: var(--brand-primary);"></i> {{ t('settings.system.interface_mode') }}
                </h2>
                <div class="space-y-3">
                    <div class="rounded-xl border border-white/5 bg-black/20 p-3 space-y-3">
                        <label id="settings-interface-mode-label" class="settings-label mb-0">
                            <i class="fa-solid fa-circle-half-stroke text-slate-500"></i> {{ t('settings.system.interface_mode') }}
                        </label>
                        <div class="settings-helper">Arayuz Modu arka plan ve panel tonunu degistirir.</div>

                        <div class="mode-grid">
                            {% for modeKey, modeMeta in themeConfig.modes %}
                                <input
                                    type="radio"
                                    name="mode"
                                    id="mode-{{ modeKey }}"
                                    class="mode-radio"
                                    value="{{ modeKey }}"
                                    {% if themeState.mode|default('dark') == modeKey %}checked{% endif %}
                                >
                                <label for="mode-{{ modeKey }}" class="mode-card">
                                    <i class="{{ modeMeta.icon }} mode-icon"></i>
                                    <span class="mode-name">{{ modeMeta.name }}</span>
                                </label>
                            {% endfor %}
                        </div>

                        <div id="eye-comfort-level-panel" class="eye-comfort-level-panel {% if themeState.mode|default('dark') == 'archive' %}is-visible{% endif %}">
                            <label class="settings-label mb-1">
                                <i class="fa-solid fa-eye text-slate-500"></i> Göz Konforu Modu Seviyesi
                            </label>
                            <div class="settings-helper mb-2">Sadece Göz Konforu Modu seçiliyken uygulanır.</div>
                            <div class="eye-comfort-level-grid">
                                {% for levelKey, levelMeta in themeConfig.eyeComfortLevels %}
                                    <input
                                        type="radio"
                                        name="eye_comfort_level"
                                        id="eye-comfort-{{ levelKey }}"
                                        class="eye-comfort-radio"
                                        value="{{ levelKey }}"
                                        {% if themeState.eye_comfort_level|default('balanced') == levelKey %}checked{% endif %}
                                    >
                                    <label for="eye-comfort-{{ levelKey }}" class="eye-comfort-card">
                                        <strong>{{ levelMeta.name }}</strong>
                                        <span>{{ levelMeta.description }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <div class="rounded-xl border border-white/5 bg-black/20 p-3 space-y-3">
                        <label id="settings-color-palette-label" class="settings-label mb-0">
                            <i class="fa-solid fa-palette text-slate-500"></i> {{ t('settings.system.color_palette') }}
                        </label>
                        <div class="settings-helper">Sistem Renk Paleti vurgu rengi, buton ve aktif durumlari degistirir.</div>
                        <div id="eye-comfort-palette-note" class="settings-helper {% if themeState.mode|default('dark') != 'archive' %}hidden{% endif %}">Göz Konforu Modu'nda renk paleti otomatik olarak daha sıcak ve düşük parlaklıkta uygulanır.</div>

                        <div id="normal-theme-palette" class="theme-grid {% if themeState.mode|default('dark') == 'archive' %}hidden{% endif %}">
                            {% for colorKey, colorMeta in themeConfig.colors %}
                                <input
                                    type="radio"
                                    name="theme"
                                    id="theme-{{ colorKey }}"
                                    class="theme-radio"
                                    value="{{ colorKey }}"
                                    {% if themeState.color|default('purple') == colorKey %}checked{% endif %}
                                >
                                <label for="theme-{{ colorKey }}" class="theme-card tc-{{ colorKey }}">
                                    <i class="{{ colorMeta.icon }} theme-icon"></i>
                                    <span class="theme-name">{{ colorMeta.name }}</span>
                                </label>
                            {% endfor %}
                        </div>
                        <div id="eye-comfort-locked-palette" class="eye-comfort-locked-palette {% if themeState.mode|default('dark') == 'archive' %}is-visible{% endif %}">
                            <i class="fa-solid fa-lock"></i>
                            <div>
                                <strong>Göz Konforu Modu Paleti</strong>
                                <span>Sıcak tonlar ve düşük parlaklık için otomatik uygulanır.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="tab-communication" class="tab-content space-y-4" role="tabpanel">
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 items-start">
            <div class="holo-panel settings-card relative self-start">
                <h2 class="text-[10px] font-black text-slate-300 uppercase tracking-[0.18em] flex items-center gap-2 mb-4 border-b border-white/5 pb-3">
                    <i class="fa-solid fa-bell" style="color: var(--brand-primary);"></i> Bildirim Tercihleri
                </h2>
                <form id="notification-settings-form" class="rounded-xl border border-white/5 bg-black/20 p-3 space-y-3" onsubmit="window.updateNotificationSettings(event)">
                    <div>
                        <div class="text-[9px] font-black uppercase tracking-[0.14em] text-white flex items-center gap-2"><i class="fa-solid fa-bell" style="color: var(--brand-primary);"></i> Bildirim Tercihleri</div>
                        <div class="settings-helper">Kritik sistem duyurulari tamamen kapatilamaz.</div>
                    </div>

                    <label class="settings-toggle-row">
                        <span>
                            <span class="settings-toggle-title">DM bildirimleri</span>
                            <span class="settings-toggle-desc">Yeni direkt mesaj bildirimleri.</span>
                        </span>
                        <span class="settings-switch"><input type="checkbox" id="notif-dm" name="dm_enabled" {% if notificationSettings.dm_enabled|default(1) %}checked{% endif %}><span></span></span>
                    </label>

                    <label class="settings-toggle-row">
                        <span>
                            <span class="settings-toggle-title">Haber bildirimleri</span>
                            <span class="settings-toggle-desc">Takip edilen gazete haberleri.</span>
                        </span>
                        <span class="settings-switch"><input type="checkbox" id="notif-news" name="news_enabled" {% if notificationSettings.news_enabled|default(1) %}checked{% endif %}><span></span></span>
                    </label>

                    <label class="settings-toggle-row">
                        <span>
                            <span class="settings-toggle-title">Sistem duyurulari</span>
                            <span class="settings-toggle-desc">Kritik duyurular her zaman kayda alinir.</span>
                        </span>
                        <span class="settings-switch"><input type="checkbox" id="notif-system" name="system_enabled" {% if notificationSettings.system_enabled|default(1) %}checked{% endif %}><span></span></span>
                    </label>

                    <label class="settings-toggle-row">
                        <span>
                            <span class="settings-toggle-title">Sessiz saatler</span>
                            <span class="settings-toggle-desc">Bu aralikta bildirimler okunmus kaydedilir.</span>
                        </span>
                        <span class="settings-switch"><input type="checkbox" id="notif-quiet" name="quiet_hours_enabled" {% if notificationSettings.quiet_hours_enabled|default(0) %}checked{% endif %}><span></span></span>
                    </label>

                    <div class="settings-time-grid">
                        <div>
                            <label class="settings-label">Baslangic</label>
                            <input type="time" id="notif-quiet-start" class="cyber-input py-3 px-4" value="{{ notificationSettings.quiet_start|default('22:00') }}">
                        </div>
                        <div>
                            <label class="settings-label">Bitis</label>
                            <input type="time" id="notif-quiet-end" class="cyber-input py-3 px-4" value="{{ notificationSettings.quiet_end|default('08:00') }}">
                        </div>
                    </div>

                    <button type="submit" id="notification-save-btn" class="cyber-btn btn-cyan settings-primary-action" disabled>
                        <i class="fa-solid fa-bell"></i> Bildirimleri Kaydet
                    </button>
                    <div id="notification-save-hint" class="settings-action-hint">Degisiklik yok.</div>
                </form>
            </div>

            <div class="holo-panel settings-card relative">
                <h2 class="text-[10px] font-black text-slate-300 uppercase tracking-[0.18em] flex items-center gap-2 mb-4 border-b border-white/5 pb-3">
                    <i class="fa-solid fa-user-shield" style="color: var(--brand-primary);"></i> {{ t('settings.dm.title') }}
                </h2>
                <form id="dm-privacy-form" class="space-y-1" onsubmit="window.updateDmPrivacySettings(event)">
                    <div>
                        <div class="text-[9px] font-black uppercase tracking-[0.14em] text-white flex items-center gap-2"><i class="fa-solid fa-user-shield" style="color: var(--brand-primary);"></i> {{ t('settings.dm.title') }}</div>
                        <div class="settings-helper">{{ t('settings.dm.subtitle') }}</div>
                    </div>

                    <div class="settings-simple-row">
                        <label id="dm-allow-label" class="settings-label">{{ t('settings.dm.question') }}</label>
                        {% set dmAllow = dmPrivacySettings.allow_from|default('everyone') %}
                        {% if dmAllow == 'party' and not dmPrivacySupport.party %}
                            {% set dmAllow = 'everyone' %}
                        {% endif %}
                        <input type="hidden" id="dm-allow-from" name="allow_from" value="{{ dmAllow in ['everyone', 'party', 'nobody'] ? dmAllow : 'everyone' }}">
                        <div class="dm-privacy-grid" role="radiogroup" aria-labelledby="dm-allow-label">
                            <input type="radio" id="dm-allow-everyone" name="dm_allow_from_ui" class="settings-choice-radio dm-allow-radio" value="everyone" {% if dmAllow == 'everyone' %}checked{% endif %}>
                            <label for="dm-allow-everyone" class="settings-choice-card dm-privacy-card">
                                <strong>{{ t('settings.dm.option.everyone') }}</strong>
                                <span>{{ t('settings.dm.desc.everyone') }}</span>
                            </label>

                            <input type="radio" id="dm-allow-connections" name="dm_allow_from_ui" class="settings-choice-radio dm-allow-radio" value="party" {% if dmAllow == 'party' %}checked{% endif %} {% if not dmPrivacySupport.party %}disabled{% endif %}>
                            <label for="dm-allow-connections" class="settings-choice-card dm-privacy-card {% if not dmPrivacySupport.party %}is-preview{% endif %}">
                                <strong>{{ t('settings.dm.option.connections') }}</strong>
                                <span>{% if dmPrivacySupport.party %}{{ t('settings.dm.desc.connections') }}{% else %}{{ t('settings.dm.unavailable.connections') }}{% endif %}</span>
                            </label>

                            <input type="radio" id="dm-allow-approved" name="dm_allow_from_ui" class="settings-choice-radio" value="approved_only" disabled>
                            <label for="dm-allow-approved" class="settings-choice-card dm-privacy-card is-preview">
                                <strong>{{ t('settings.dm.option.approved_only') }}</strong>
                                <span>{{ t('settings.dm.unavailable.approved_only') }}</span>
                            </label>

                            <input type="radio" id="dm-allow-off" name="dm_allow_from_ui" class="settings-choice-radio dm-allow-radio" value="nobody" {% if dmAllow == 'nobody' %}checked{% endif %}>
                            <label for="dm-allow-off" class="settings-choice-card dm-privacy-card">
                                <strong>{{ t('settings.dm.option.off') }}</strong>
                                <span>{{ t('settings.dm.desc.off') }}</span>
                            </label>
                        </div>
                        <div id="dm-allow-desc" class="settings-choice-desc">{{ t('settings.dm.desc.' ~ (dmAllow == 'party' ? 'connections' : (dmAllow == 'nobody' ? 'off' : 'everyone'))) }}</div>
                    </div>

                    <div class="settings-simple-row dm-request-preview">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <div class="settings-toggle-title">{{ t('settings.dm.requests.title') }}</div>
                                <div class="settings-toggle-desc">{{ t('settings.dm.requests.preview_desc') }}</div>
                            </div>
                            <span class="settings-info-badge"><i class="fa-solid fa-clock"></i> {{ t('settings.dm.preview_badge') }}</span>
                        </div>
                        <input type="hidden" id="dm-message-requests" name="message_requests_enabled" value="0">
                        <div class="dm-request-empty">
                            <div class="dm-request-empty-icon"><i class="fa-solid fa-inbox"></i></div>
                            <div class="min-w-0">
                                <div class="settings-toggle-title">{{ t('settings.dm.requests.empty_title') }}</div>
                                <div class="settings-toggle-desc">{{ t('settings.dm.requests.empty') }}</div>
                            </div>
                        </div>
                    </div>

                    <div class="settings-simple-row">
                        <div class="settings-toggle-title">{{ t('settings.dm.blocked.title') }}</div>
                        <div class="settings-toggle-desc">{{ t('settings.dm.blocked.preview') }}</div>
                    </div>

                    <button type="submit" id="dm-privacy-save-btn" class="cyber-btn btn-cyan settings-primary-action" disabled>
                        <i class="fa-solid fa-user-shield"></i> {{ t('settings.dm.save') }}
                    </button>
                    <div id="dm-privacy-save-hint" class="settings-action-hint">{{ t('settings.common.no_changes') }}</div>
                </form>
            </div>
        </div>
    </div>

    <div id="tab-game-experience" class="tab-content space-y-4" role="tabpanel">
        <div class="game-settings-layout grid grid-cols-1 xl:grid-cols-2 gap-4">
            <div class="holo-panel settings-card relative">
                <div class="game-settings-head">
                    <div>
                        <h2 class="flex items-center gap-2"><i class="fa-solid fa-gamepad" style="color: var(--brand-primary);"></i> Oyun Deneyimi</h2>
                        <p>Arayuz hissi, animasyon ve panel yogunlugunu ayarla.</p>
                    </div>
                    <span class="game-settings-badge"><i class="fa-solid fa-check"></i> Aktif</span>
                </div>
                <form id="game-experience-form" class="game-settings-panel" onsubmit="window.updateGameExperienceSettings(event)">
                    <div class="game-setting-group">
                        <label class="settings-label">Arayuz yogunlugu</label>
                        <div class="settings-helper mb-2">Ayarlar ve ana sayfada kart bosluklarini kucuk olcekte etkiler.</div>
                        <div class="settings-option-grid">
                            <input class="settings-choice-radio" type="radio" name="ui_density" id="gx-density-compact" value="compact" {% if gameExperienceSettings.ui_density|default('balanced') == 'compact' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-density-compact">Kompakt</label>
                            <input class="settings-choice-radio" type="radio" name="ui_density" id="gx-density-balanced" value="balanced" {% if gameExperienceSettings.ui_density|default('balanced') == 'balanced' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-density-balanced">Dengeli</label>
                            <input class="settings-choice-radio" type="radio" name="ui_density" id="gx-density-comfortable" value="comfortable" {% if gameExperienceSettings.ui_density|default('balanced') == 'comfortable' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-density-comfortable">Ferah</label>
                        </div>
                    </div>

                    <div class="game-setting-group">
                        <label class="settings-label">Animasyon yogunlugu</label>
                        <div class="settings-helper mb-2">Kapali secimi gereksiz hover, glow ve gecisleri azaltir.</div>
                        <div class="settings-option-grid">
                            <input class="settings-choice-radio" type="radio" name="animation_level" id="gx-motion-off" value="off" {% if gameExperienceSettings.animation_level|default('balanced') == 'off' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-motion-off">Kapali</label>
                            <input class="settings-choice-radio" type="radio" name="animation_level" id="gx-motion-balanced" value="balanced" {% if gameExperienceSettings.animation_level|default('balanced') == 'balanced' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-motion-balanced">Dengeli</label>
                            <input class="settings-choice-radio" type="radio" name="animation_level" id="gx-motion-full" value="full" {% if gameExperienceSettings.animation_level|default('balanced') == 'full' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-motion-full">Tam</label>
                        </div>
                    </div>

                    <div class="game-setting-group">
                        <label class="settings-label">Sol HUD gorunumu</label>
                        <div class="settings-helper mb-2">Kompakt mod ana sayfa yan panel kart bosluklarini azaltir.</div>
                        <div class="settings-option-grid is-two">
                            <input class="settings-choice-radio" type="radio" name="left_hud" id="gx-hud-detailed" value="detailed" {% if gameExperienceSettings.left_hud|default('detailed') == 'detailed' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-hud-detailed">Detayli</label>
                            <input class="settings-choice-radio" type="radio" name="left_hud" id="gx-hud-compact" value="compact" {% if gameExperienceSettings.left_hud|default('detailed') == 'compact' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-hud-compact">Kompakt</label>
                        </div>
                    </div>

                    <div class="game-setting-group">
                        <label class="settings-label">Shouts genisligi</label>
                        <div class="settings-helper mb-2">Ana sayfadaki Shouts kartinin yatay kapladigi alani ayarlar.</div>
                        <div class="settings-option-grid">
                            <input class="settings-choice-radio" type="radio" name="shout_width" id="gx-shout-width-compact" value="compact" {% if gameExperienceSettings.shout_width|default('balanced') == 'compact' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-shout-width-compact">Kompakt</label>
                            <input class="settings-choice-radio" type="radio" name="shout_width" id="gx-shout-width-balanced" value="balanced" {% if gameExperienceSettings.shout_width|default('balanced') == 'balanced' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-shout-width-balanced">Dengeli</label>
                            <input class="settings-choice-radio" type="radio" name="shout_width" id="gx-shout-width-wide" value="wide" {% if gameExperienceSettings.shout_width|default('balanced') == 'wide' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-shout-width-wide">Genis</label>
                        </div>
                    </div>
                </form>
            </div>

            <div class="holo-panel settings-card relative">
                <div class="game-settings-head">
                    <div>
                        <h2 class="flex items-center gap-2"><i class="fa-solid fa-bolt" style="color: var(--brand-primary);"></i> Ana Sayfa Tercihleri</h2>
                        <p>Ilk gorunen bolumleri ve hizli menuyu duzenle.</p>
                    </div>
                    <span class="game-settings-badge"><i class="fa-solid fa-home"></i> Ana sayfa</span>
                </div>
                <div class="game-settings-panel">
                    <div class="game-setting-group">
                        <label class="settings-label">Ana sayfa duzeni</label>
                        <div class="settings-helper mb-2">Kompakt kolon modunda Haberler solda kuculur, Shouts orta alana iner, Gorevler sag kolona adapte olur.</div>
                        <div class="settings-option-grid is-two">
                            <input form="game-experience-form" class="settings-choice-radio" type="radio" name="home_layout" id="gx-home-layout-wide" value="wide" {% if gameExperienceSettings.home_layout|default('wide') == 'wide' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-home-layout-wide">Genis akis</label>
                            <input form="game-experience-form" class="settings-choice-radio" type="radio" name="home_layout" id="gx-home-layout-compact-columns" value="compact_columns" {% if gameExperienceSettings.home_layout|default('wide') == 'compact_columns' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-home-layout-compact-columns">Kompakt kolon</label>
                        </div>
                    </div>

                    <div class="game-setting-group">
                        <label class="settings-label">Ana sayfa oncelikli alan</label>
                        <div class="settings-helper mb-2">Ana sayfada ilgili bolum yukariya alinir ve kucuk vurgu uygulanir.</div>
                        <div class="settings-option-grid">
                            <input form="game-experience-form" class="settings-choice-radio" type="radio" name="home_priority" id="gx-priority-news" value="news" {% if gameExperienceSettings.home_priority|default('news') == 'news' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-priority-news">Haberler</label>
                            <input form="game-experience-form" class="settings-choice-radio" type="radio" name="home_priority" id="gx-priority-shouts" value="shouts" {% if gameExperienceSettings.home_priority|default('news') == 'shouts' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-priority-shouts">Shouts</label>
                            <input form="game-experience-form" class="settings-choice-radio" type="radio" name="home_priority" id="gx-priority-tasks" value="tasks" {% if gameExperienceSettings.home_priority|default('news') == 'tasks' %}checked{% endif %}>
                            <label class="settings-choice-card" for="gx-priority-tasks">Gorevler</label>
                        </div>
                    </div>

                    <div class="game-setting-group">
                        <label class="settings-label">Hizli aksiyon favorileri</label>
                        <div class="settings-helper mb-2">En fazla 4 secim. Ana sayfa ust hizli menusu favorileri once gosterir.</div>
                        <div class="settings-favorite-grid" id="game-favorites-grid">
                            {% for actionKey, actionMeta in gameExperienceQuickActions %}
                                <input form="game-experience-form" class="settings-favorite-check" type="checkbox" name="quick_favorites[]" id="gx-fav-{{ actionKey }}" value="{{ actionKey }}" {% if actionKey in gameExperienceSettings.quick_favorites|default([]) %}checked{% endif %}>
                                <label class="settings-favorite-chip" for="gx-fav-{{ actionKey }}"><i class="fa-solid {{ actionMeta.icon }}"></i> {{ t(actionMeta.label_key) }}</label>
