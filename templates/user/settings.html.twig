        const themeButton = document.getElementById('theme-save-btn');
        const profileHint = document.getElementById('profile-save-hint');
        const passwordHint = document.getElementById('password-save-hint');
        const languageHint = document.getElementById('language-save-hint');
        const themeHint = document.getElementById('theme-save-hint');
        const eyeComfortPanel = document.getElementById('eye-comfort-level-panel');
        const eyeComfortPaletteNote = document.getElementById('eye-comfort-palette-note');
        const normalThemePalette = document.getElementById('normal-theme-palette');
        const eyeComfortLockedPalette = document.getElementById('eye-comfort-locked-palette');
        const initialProfile = profileForm ? $(profileForm).serialize() : '';
        const initialLanguage = languageSelect ? languageSelect.value : '';
        const initialTheme = getServerThemeState();

        const setHint = function(el, readyText, idleText, isReady) {
            if (!el) return;
            el.textContent = isReady ? readyText : idleText;
            el.classList.toggle('is-ready', isReady);
        };

        const syncProfile = function() {
            if (profileButton && profileForm) {
                const isReady = $(profileForm).serialize() !== initialProfile;
                profileButton.disabled = !isReady;
                setHint(profileHint, 'Kaydetmeye hazir.', 'Degisiklik yok.', isReady);
            }
        };

        const syncPassword = function() {
            if (passwordButton) {
                const isReady = !!($('#input-old-password').val() && $('#input-new-password').val() && $('#input-new-password-confirm').val());
                passwordButton.disabled = !isReady;
                setHint(passwordHint, 'Sifre degisikligi onaya hazir.', 'Sifre alanlari tamamlaninca aktif olur.', isReady);
            }
        };

        const syncLanguage = function() {
            if (languageButton && languageSelect) {
                const isReady = languageSelect.value !== initialLanguage;
                languageButton.disabled = !isReady;
                setHint(languageHint, 'Dil kaydedilince sayfa yenilenir.', 'Dil degisince kaydetme aktif olur.', isReady);
            }
        };

        const syncTheme = function() {
            const selectedModeEl = document.querySelector('input[name="mode"]:checked');
            const selectedColorEl = document.querySelector('input[name="theme"]:checked');
            const selectedEyeComfortEl = document.querySelector('input[name="eye_comfort_level"]:checked');
            if (themeButton && selectedModeEl && selectedColorEl) {
                const selectedEyeComfortLevel = selectedEyeComfortEl ? selectedEyeComfortEl.value : 'balanced';
                const usesEyeComfort = selectedModeEl.value === 'archive';
                const selectedColor = usesEyeComfort ? 'amber' : selectedColorEl.value;
                document.documentElement.setAttribute('data-eye-comfort', usesEyeComfort ? selectedEyeComfortLevel : 'balanced');
                if (eyeComfortPanel) eyeComfortPanel.classList.toggle('is-visible', usesEyeComfort);
                if (eyeComfortPaletteNote) eyeComfortPaletteNote.classList.toggle('hidden', !usesEyeComfort);
                if (normalThemePalette) normalThemePalette.classList.toggle('hidden', usesEyeComfort);
                if (eyeComfortLockedPalette) eyeComfortLockedPalette.classList.toggle('is-visible', usesEyeComfort);
                document.querySelectorAll('input[name="theme"]').forEach(function(input) {
                    input.disabled = usesEyeComfort;
                });
                const isReady = selectedModeEl.value !== initialTheme.mode || selectedColor !== initialTheme.color || selectedEyeComfortLevel !== initialTheme.eyeComfortLevel;
                themeButton.disabled = !isReady;
                setHint(themeHint, 'Kaydet ve yenile.', 'Arayuz veya renk secimi degisince aktif olur.', isReady);
            }
        };

        if (profileForm) $(profileForm).on('input change', syncProfile);
        if (passwordForm) $(passwordForm).on('input change', syncPassword);
        if (languageSelect) languageSelect.addEventListener('change', syncLanguage);
        $('input[name="mode"], input[name="theme"], input[name="eye_comfort_level"]').on('change', syncTheme);

        syncProfile();
        syncPassword();
        syncLanguage();
        syncTheme();
    }

    function setupNotificationSettings() {
        const form = document.getElementById('notification-settings-form');
        const button = document.getElementById('notification-save-btn');
        const hint = document.getElementById('notification-save-hint');
        const quietToggle = document.getElementById('notif-quiet');
        const quietStart = document.getElementById('notif-quiet-start');
        const quietEnd = document.getElementById('notif-quiet-end');

        if (!form || !button) return;

        const getPayload = function() {
            return {
                dm_enabled: document.getElementById('notif-dm').checked ? '1' : '0',
                news_enabled: document.getElementById('notif-news').checked ? '1' : '0',
                system_enabled: document.getElementById('notif-system').checked ? '1' : '0',
                quiet_hours_enabled: quietToggle.checked ? '1' : '0',
                quiet_start: quietStart.value || '22:00',
                quiet_end: quietEnd.value || '08:00'
            };
        };

        const serializePayload = function(payload) {
            return [
                payload.dm_enabled,
                payload.news_enabled,
                payload.system_enabled,
                payload.quiet_hours_enabled,
                payload.quiet_start,
                payload.quiet_end
            ].join('|');
        };

        let initial = serializePayload(getPayload());

        const sync = function() {
            const quietEnabled = quietToggle.checked;
            quietStart.disabled = !quietEnabled;
            quietEnd.disabled = !quietEnabled;

            const changed = serializePayload(getPayload()) !== initial;
            button.disabled = !changed;
            if (hint) {
                hint.textContent = changed ? 'Kaydetmeye hazir.' : 'Degisiklik yok.';
                hint.classList.toggle('is-ready', changed);
            }
        };

        $(form).on('change input', sync);
        form._resetNotificationInitial = function() {
            initial = serializePayload(getPayload());
            sync();
        };

        sync();
    }

