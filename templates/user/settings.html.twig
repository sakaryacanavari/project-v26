        .mode-radio:checked + .mode-card { background: color-mix(in srgb, var(--brand-primary) 12%, rgba(0,0,0,0.72)); border-color: var(--brand-primary); box-shadow: 0 8px 18px -14px var(--brand-glow), inset 3px 0 0 var(--brand-primary); }

