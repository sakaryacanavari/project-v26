<!DOCTYPE html>
<html lang="{{ lang|default('tr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ t('auth.forgot.title') }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=IBM+Plex+Mono:wght@500;700&family=Rajdhani:wght@500;700&display=swap" rel="stylesheet">
    <style>
        :root { --auth-canvas:#07090b; --auth-panel:rgba(11,15,18,.92); --auth-ink:#f3efe4; --auth-muted:#8c948f; --auth-line:rgba(231,222,196,.14); --auth-signal:#35d3c8; --auth-gold:#c89b3c; --auth-seal:#d94b3d; }
        * { box-sizing:border-box; }
        body { min-height:100vh; margin:0; color:var(--auth-ink); background:radial-gradient(circle at 45% 78%,rgba(200,155,60,.1),transparent 22rem),radial-gradient(circle at 16% 24%,rgba(53,211,200,.18),transparent 30rem),radial-gradient(circle at 82% 18%,rgba(217,75,61,.13),transparent 26rem),linear-gradient(115deg,rgba(53,211,200,.055),transparent 28%,rgba(200,155,60,.035) 68%,transparent),linear-gradient(135deg,rgba(255,255,255,.035) 0 1px,transparent 1px 20px),var(--auth-canvas); font-family:'Rajdhani',sans-serif; overflow-x:hidden; }
        body::before { content:""; position:fixed; inset:0; pointer-events:none; background:linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.02) 1px,transparent 1px); background-size:64px 64px; mask-image:radial-gradient(circle at center,black,transparent 76%); }
        .display-font { font-family:'Archivo Black',sans-serif; } .mono-font { font-family:'IBM Plex Mono',monospace; }
        .terminal-panel { background:linear-gradient(145deg,rgba(255,255,255,.035),transparent 28%),var(--auth-panel); border:1px solid var(--auth-line); box-shadow:0 24px 70px rgba(0,0,0,.46), inset 0 1px 0 rgba(255,255,255,.04); backdrop-filter:blur(18px); }
        .auth-shell { animation:enter .7s cubic-bezier(.16,1,.3,1) both; }
        .auth-side { isolation:isolate; position:relative; overflow:hidden; background:radial-gradient(circle at 84% 24%,rgba(53,211,200,.14),transparent 17rem),radial-gradient(circle at 28% 72%,rgba(200,155,60,.1),transparent 16rem),linear-gradient(180deg,rgba(17,24,27,.94),rgba(5,8,10,.92)); }
        .auth-side::before { content:""; position:absolute; inset:1rem; z-index:0; border:1px solid rgba(53,211,200,.08); background:linear-gradient(90deg,rgba(53,211,200,.06) 0 1px,transparent 1px),linear-gradient(rgba(255,255,255,.025) 0 1px,transparent 1px); background-size:28px 28px; mask-image:linear-gradient(180deg,black,transparent 86%); }
        .auth-brand-stage { position:relative; z-index:1; border:1px solid rgba(231,222,196,.1); background:linear-gradient(135deg,rgba(53,211,200,.08),transparent 34%),linear-gradient(180deg,rgba(0,0,0,.18),rgba(0,0,0,.05)); box-shadow:inset 0 1px 0 rgba(255,255,255,.035); }
        .auth-brand-stage::before { content:""; position:absolute; left:0; top:1.25rem; bottom:1.25rem; width:3px; background:linear-gradient(var(--auth-signal),var(--auth-gold)); box-shadow:0 0 18px rgba(53,211,200,.28); }
        .auth-brand { text-shadow:0 18px 42px rgba(0,0,0,.52); }
        .auth-card { position:relative; overflow:hidden; background:radial-gradient(circle at 88% 18%,rgba(53,211,200,.12),transparent 13rem),linear-gradient(180deg,rgba(15,20,23,.96),rgba(5,8,10,.94)); box-shadow:0 28px 80px rgba(0,0,0,.5),0 0 0 1px rgba(53,211,200,.05),inset 0 1px 0 rgba(255,255,255,.05); }
        .auth-card::before { content:""; position:absolute; inset:0 0 auto 0; height:1px; background:linear-gradient(90deg,transparent,rgba(53,211,200,.65),rgba(200,155,60,.45),transparent); }
        .auth-card-logo { position:absolute; right:1.25rem; top:.9rem; width:8rem; height:8rem; opacity:.14; pointer-events:none; z-index:0; filter:saturate(.92) drop-shadow(0 0 28px rgba(53,211,200,.18)); }
        .auth-card-logo img { width:100%; height:100%; object-fit:contain; }
        .auth-locale-btn { border:1px solid var(--auth-line); background:rgba(255,255,255,.025); color:#b9b4a8; min-width:2.35rem; }
        .auth-locale-btn.is-active,.auth-locale-btn:hover { border-color:rgba(53,211,200,.62); background:rgba(53,211,200,.1); color:var(--auth-signal); }
        .field-input { background:linear-gradient(180deg,rgba(245,248,255,.96),rgba(220,228,241,.96)); color:#111820; border:1px solid rgba(231,222,196,.16); font-family:'IBM Plex Mono',monospace; transition:border-color .18s ease, box-shadow .18s ease, background .18s ease; }
        .field-input:focus { border-color:rgba(53,211,200,.72); box-shadow:0 0 0 3px rgba(53,211,200,.12); background:linear-gradient(180deg,rgba(255,255,255,.98),rgba(228,239,247,.98)); outline:none; }
        .field-input::placeholder { color:rgba(17,24,32,.48); }
        .auth-error { border-left:4px solid var(--auth-seal); background:rgba(217,75,61,.13); }
        .auth-success { border-left:4px solid var(--auth-signal); background:rgba(53,211,200,.09); }
        .auth-debug { border-left:4px solid var(--auth-gold); background:rgba(200,155,60,.1); }
        .auth-btn-primary { position:relative; isolation:isolate; min-height:46px; overflow:hidden; border-radius:2px; background:linear-gradient(135deg,rgba(255,255,255,.28),transparent 34%),linear-gradient(135deg,#43efe3,var(--auth-signal)); border:1px solid rgba(126,255,247,.7); color:#04100f; box-shadow:0 0 0 1px rgba(53,211,200,.14),0 12px 28px rgba(53,211,200,.16); }
        .auth-btn-primary::before { content:""; position:absolute; inset:0; z-index:-1; background:linear-gradient(90deg,transparent,rgba(255,255,255,.55),transparent); transform:translateX(-115%) skewX(-18deg); transition:transform .55s cubic-bezier(.16,1,.3,1); }
        .auth-btn-primary:hover::before { transform:translateX(115%) skewX(-18deg); }
        .auth-btn-secondary { min-height:46px; border-radius:2px; background:rgba(255,255,255,.025); border:1px solid var(--auth-line); color:#d8d0bb; }
        .auth-btn-secondary:hover { border-color:rgba(200,155,60,.55); background:rgba(200,155,60,.08); color:var(--auth-ink); }
        .loader { border:3px solid rgba(53,211,200,.12); border-left-color:var(--auth-signal); border-radius:50%; width:18px; height:18px; animation:spin 1s linear infinite; display:inline-block; }
        @keyframes enter { from { opacity:0; transform:translateY(18px) scale(.985); } to { opacity:1; transform:translateY(0) scale(1); } }
        @keyframes spin { to { transform:rotate(360deg); } }
        @media (max-width: 860px) { .auth-shell { grid-template-columns:1fr !important; max-width:36rem !important; } .auth-side { display:none !important; } }
    </style>
</head>
<body class="min-h-screen px-4 py-6 selection:bg-cyan-400 selection:text-black">
    <main class="auth-shell mx-auto grid min-h-[calc(100vh-3rem)] w-full max-w-5xl items-center gap-5 lg:grid-cols-[.9fr_1.1fr]">
        <section class="auth-side terminal-panel rounded-3xl p-6 sm:p-8 lg:min-h-[520px]">
            <div class="auth-brand-stage mt-8 p-5">
                <p class="mono-font text-[10px] font-bold uppercase tracking-[0.42em] text-[color:var(--auth-muted)]">{{ t('auth.forgot.panel_kicker') }}</p>
                <h1 class="auth-brand display-font mt-4 text-5xl uppercase leading-[.9] tracking-[-0.05em] text-[color:var(--auth-ink)] sm:text-7xl">{{ t('auth.project_name') }}</h1>
                <p class="mt-5 max-w-md text-lg font-bold leading-7 text-[#b8b5a9]">{{ t('auth.forgot.hero_copy') }}</p>
            </div>
        </section>

        <section class="auth-card terminal-panel rounded-3xl p-5 sm:p-7">
            <div class="auth-card-logo"><img src="{{ base_url() }}/img/projectv26LOGO2.png" alt=""></div>
            <div class="mb-6 border-b border-[color:var(--auth-line)] pb-5">
                <div class="relative z-10 flex items-start justify-between gap-4">
                    <div>
                        <p class="mono-font text-[10px] font-bold uppercase tracking-[0.32em] text-[color:var(--auth-muted)]">{{ t('auth.forgot.panel_kicker') }}</p>
                        <h2 class="display-font mt-2 text-3xl uppercase tracking-[-0.04em]">{{ t('auth.forgot.panel_title') }}</h2>
                    </div>
                    <div class="auth-locale flex items-center gap-1" aria-label="{{ t('auth.language_label') }}">
                        {% for code, locale in availableLocales %}
                            <button type="button" class="auth-locale-btn mono-font px-2 py-1 text-[9px] font-black uppercase tracking-[0.12em] transition{% if code == lang %} is-active{% endif %}" data-locale="{{ code }}">{{ locale.flag }}</button>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div id="errorBox" class="auth-error hidden mb-4 p-4 text-[13px] font-bold leading-relaxed text-red-100"></div>
            <div id="successBox" class="auth-success hidden mb-4 p-4">
                <div class="mono-font text-[10px] font-black uppercase tracking-[0.18em] text-[color:var(--auth-signal)]">{{ t('auth.forgot.success_title') }}</div>
                <p class="mt-1 text-[13px] font-bold leading-relaxed text-[#d8d0bb]">{{ t('auth.forgot.success_detail') }}</p>
            </div>
            <div id="debugBox" class="auth-debug hidden mb-4 p-4">
                <div class="mono-font text-[10px] font-black uppercase tracking-[0.18em] text-[color:var(--auth-gold)]">{{ t('auth.forgot.debug_title') }}</div>
                <div class="mt-2 flex flex-col gap-2 text-[12px] font-bold">
                    <a id="debugLink" href="#" class="text-cyan-300 underline" target="_blank" rel="noopener">{{ t('auth.forgot.debug_link') }}</a>
                    <span id="debugFile" class="text-[#d8d0bb]"></span>
                </div>
            </div>

            <form id="forgotForm" action="{{ path_for('forgotPassword') }}" method="post" class="relative z-10 flex flex-col gap-4">
                <input type="hidden" name="fingerprint" id="forgotFingerprint" value="">
                <div>
                    <label for="forgotEmail" class="mono-font mb-2 block text-[10px] font-bold uppercase tracking-[0.22em] text-[color:var(--auth-signal)]">{{ t('auth.field.email') }}</label>
                    <input type="email" name="email" id="forgotEmail" maxlength="150" autocomplete="email" autocapitalize="none" autocorrect="off" spellcheck="false" class="field-input w-full rounded-none px-4 py-3.5 text-sm font-bold" placeholder="{{ t('auth.placeholder.email') }}" required>
                    <p class="mt-2 text-[12px] font-bold leading-relaxed text-[#a8a397]">{{ t('auth.forgot.email_hint') }}</p>
                </div>
                <div class="grid gap-3 sm:grid-cols-2">
                    <button type="submit" id="submitBtn" class="auth-btn-primary inline-flex w-full items-center justify-center gap-3 px-5 py-3 transition disabled:cursor-wait disabled:opacity-70">
                        <span class="display-font text-xs uppercase tracking-[0.1em]">{{ t('auth.forgot.submit') }}</span>
                    </button>
                    <a href="{{ path_for('login') }}" class="auth-btn-secondary inline-flex w-full items-center justify-center px-5 py-3 text-center mono-font text-[10px] font-bold uppercase tracking-[0.16em] transition">{{ t('auth.forgot.login_link') }}</a>
                </div>
            </form>
        </section>
    </main>

    <script>
        const forgotForm = document.getElementById('forgotForm');
        const forgotEmail = document.getElementById('forgotEmail');
        const fingerprintInput = document.getElementById('forgotFingerprint');
        const errorBox = document.getElementById('errorBox');
        const successBox = document.getElementById('successBox');
        const debugBox = document.getElementById('debugBox');
        const debugLink = document.getElementById('debugLink');
        const debugFile = document.getElementById('debugFile');
        const localeButtons = document.querySelectorAll('[data-locale]');
        const texts = {
            emailRequired: '{{ t("auth.validation.email_required")|e("js") }}',
            emailInvalid: '{{ t("auth.validation.email_invalid")|e("js") }}',
            processing: '{{ t("auth.forgot.processing")|e("js") }}',
            completed: '{{ t("auth.forgot.completed")|e("js") }}',
            genericError: '{{ t("auth.validation.connection_error")|e("js") }}',
            debugFileLabel: '{{ t("auth.forgot.debug_file")|e("js") }}'
        };

        function buildFingerprint() {
            const parts = [navigator.userAgent || '', navigator.language || '', Intl.DateTimeFormat().resolvedOptions().timeZone || '', String(screen.width || 0) + 'x' + String(screen.height || 0), String(window.devicePixelRatio || 1), navigator.platform || ''];
            return btoa(unescape(encodeURIComponent(parts.join('|')))).slice(0, 255);
        }

        function normalizeEmail(value) { return String(value || '').trim().toLowerCase(); }
        function showError(message) { errorBox.textContent = String(message || texts.genericError).slice(0, 300); errorBox.classList.remove('hidden'); successBox.classList.add('hidden'); debugBox.classList.add('hidden'); }
        function hideError() { errorBox.classList.add('hidden'); }

        fingerprintInput.value = buildFingerprint();

        localeButtons.forEach(button => {
            button.addEventListener('click', function () {
                const formData = new FormData();
                formData.append('locale', this.getAttribute('data-locale') || '');
                fetch('{{ path_for("guestLanguage") }}', { method:'POST', body:formData, credentials:'same-origin', headers:{'X-Requested-With':'XMLHttpRequest','Accept':'application/json, */*'} })
                    .then(() => window.location.reload());
            });
        });

        forgotForm.addEventListener('submit', function (e) {
            e.preventDefault();
            forgotEmail.value = normalizeEmail(forgotEmail.value);
            fingerprintInput.value = buildFingerprint();
            hideError();
            debugBox.classList.add('hidden');

            if (!forgotEmail.value) { showError(texts.emailRequired); return; }
            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(forgotEmail.value)) { showError(texts.emailInvalid); return; }

            const submitBtn = document.getElementById('submitBtn');
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span class="loader"></span><span class="mono-font text-[11px] font-black uppercase tracking-[0.2em]">' + texts.processing + '</span>';
            submitBtn.disabled = true;

            fetch(this.action, { method:'POST', body:new FormData(this), credentials:'same-origin', headers:{'X-Requested-With':'XMLHttpRequest','Accept':'application/json, */*'} })
                .then(async response => { const data = await response.json().catch(() => null); if (!response.ok || !data) throw new Error((data && data.message) ? data.message : ('HTTP ' + response.status)); return data; })
                .then(data => {
                    if (data.error !== 0) { showError(data.message || texts.genericError); submitBtn.innerHTML = originalText; submitBtn.disabled = false; return; }
                    successBox.classList.remove('hidden');
                    if (data.debug_reset_url) {
                        debugLink.href = data.debug_reset_url;
                        debugFile.textContent = data.debug_mail_file ? (texts.debugFileLabel + ': ' + data.debug_mail_file) : '';
                        debugBox.classList.remove('hidden');
                    }
                    submitBtn.innerHTML = '<span class="mono-font text-[11px] font-black uppercase tracking-[0.2em] text-black">' + texts.completed + '</span>';
                })
                .catch(error => {
                    showError(error && error.message ? error.message : texts.genericError);
                    submitBtn.innerHTML = originalText;
                    submitBtn.disabled = false;
                });
        });
    </script>
</body>
</html>
