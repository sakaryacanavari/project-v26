<!DOCTYPE html>
<html lang="{{ lang|default('tr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ t('auth.reset.title') }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=IBM+Plex+Mono:wght@500;700&family=Rajdhani:wght@500;700&display=swap" rel="stylesheet">
    <style>
        :root { --auth-canvas:#07090b; --auth-panel:rgba(11,15,18,.92); --auth-ink:#f3efe4; --auth-muted:#8c948f; --auth-line:rgba(231,222,196,.14); --auth-signal:#35d3c8; --auth-gold:#c89b3c; --auth-seal:#d94b3d; }
        * { box-sizing:border-box; }
        body { min-height:100vh; margin:0; color:var(--auth-ink); background:radial-gradient(circle at 45% 78%,rgba(200,155,60,.1),transparent 22rem),radial-gradient(circle at 16% 24%,rgba(53,211,200,.18),transparent 30rem),radial-gradient(circle at 82% 18%,rgba(217,75,61,.13),transparent 26rem),linear-gradient(115deg,rgba(53,211,200,.055),transparent 28%,rgba(200,155,60,.035) 68%,transparent),linear-gradient(135deg,rgba(255,255,255,.035) 0 1px,transparent 1px 20px),var(--auth-canvas); font-family:'Rajdhani',sans-serif; overflow-x:hidden; }
        body::before { content:""; position:fixed; inset:0; pointer-events:none; background:linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.02) 1px,transparent 1px); background-size:64px 64px; mask-image:radial-gradient(circle at center,black,transparent 76%); }
        .display-font { font-family:'Archivo Black',sans-serif; } .mono-font { font-family:'IBM Plex Mono',monospace; }
        .terminal-panel { background:linear-gradient(145deg,rgba(255,255,255,.035),transparent 28%),rgba(11,15,18,.92); border:1px solid rgba(231,222,196,.14); box-shadow:0 24px 70px rgba(0,0,0,.46), inset 0 1px 0 rgba(255,255,255,.04); backdrop-filter:blur(18px); }
        .auth-shell { animation:enter .7s cubic-bezier(.16,1,.3,1) both; }
        .auth-card { position:relative; overflow:hidden; background:radial-gradient(circle at 88% 18%,rgba(53,211,200,.12),transparent 13rem),linear-gradient(180deg,rgba(15,20,23,.96),rgba(5,8,10,.94)); box-shadow:0 28px 80px rgba(0,0,0,.5),0 0 0 1px rgba(53,211,200,.05),inset 0 1px 0 rgba(255,255,255,.05); }
        .auth-card::before { content:""; position:absolute; inset:0 0 auto 0; height:1px; background:linear-gradient(90deg,transparent,rgba(53,211,200,.65),rgba(200,155,60,.45),transparent); }
        .auth-card-logo { position:absolute; right:1.25rem; top:.9rem; width:8rem; height:8rem; opacity:.14; pointer-events:none; z-index:0; filter:saturate(.92) drop-shadow(0 0 28px rgba(53,211,200,.18)); }
        .auth-card-logo img { width:100%; height:100%; object-fit:contain; }
        .field-input { background:linear-gradient(180deg,rgba(245,248,255,.96),rgba(220,228,241,.96)); color:#111820; border:1px solid rgba(231,222,196,.16); font-family:'IBM Plex Mono',monospace; transition:border-color .18s ease, box-shadow .18s ease, background .18s ease; }
        .field-input:focus { border-color:rgba(53,211,200,.72); box-shadow:0 0 0 3px rgba(53,211,200,.12); background:linear-gradient(180deg,rgba(255,255,255,.98),rgba(228,239,247,.98)); outline:none; }
        .field-input::placeholder { color:rgba(17,24,32,.48); }
        .auth-btn-primary { position:relative; isolation:isolate; min-height:46px; overflow:hidden; border-radius:2px; background:linear-gradient(135deg,rgba(255,255,255,.28),transparent 34%),linear-gradient(135deg,#43efe3,var(--auth-signal)); border:1px solid rgba(126,255,247,.7); color:#04100f; box-shadow:0 0 0 1px rgba(53,211,200,.14),0 12px 28px rgba(53,211,200,.16); }
        .auth-btn-secondary { min-height:46px; border-radius:2px; background:rgba(255,255,255,.025); border:1px solid rgba(231,222,196,.14); color:#d8d0bb; }
        .auth-btn-secondary:hover { border-color:rgba(200,155,60,.55); background:rgba(200,155,60,.08); color:var(--auth-ink); }
        .loader { border:3px solid rgba(53,211,200,.12); border-left-color:var(--auth-signal); border-radius:50%; width:18px; height:18px; animation:spin 1s linear infinite; display:inline-block; }
        .auth-error { border-left:4px solid var(--auth-seal); background:rgba(217,75,61,.13); }
        @keyframes enter { from { opacity:0; transform:translateY(18px) scale(.985); } to { opacity:1; transform:translateY(0) scale(1); } }
        @keyframes spin { to { transform:rotate(360deg); } }
    </style>
</head>
<body class="min-h-screen px-4 py-6 selection:bg-cyan-400 selection:text-black">
    <main class="auth-shell mx-auto flex min-h-[calc(100vh-3rem)] max-w-2xl items-center">
        <section class="auth-card terminal-panel w-full rounded-3xl p-5 sm:p-7">
            <div class="auth-card-logo"><img src="{{ base_url() }}/img/projectv26LOGO2.png" alt=""></div>
            <div class="mb-6 border-b border-[color:rgba(231,222,196,.14)] pb-5">
                <div class="relative z-10">
                    <p class="mono-font text-[10px] font-bold uppercase tracking-[0.32em] text-[color:#8c948f]">{{ t('auth.reset.panel_kicker') }}</p>
                    <h2 class="display-font mt-2 text-3xl uppercase tracking-[-0.04em]">{{ t('auth.reset.panel_title') }}</h2>
                    <p class="mt-3 max-w-xl text-sm font-bold leading-6 text-[#b8b5a9]">{{ t('auth.reset.hero_copy') }}</p>
                </div>
            </div>

            <div id="errorBox" class="auth-error hidden mb-4 p-4 text-[13px] font-bold leading-relaxed text-red-100"></div>

            <form id="resetForm" action="{{ path_for('resetPassword', { token: reset_token }) }}" method="post" class="relative z-10 flex flex-col gap-4">
                <div>
                    <label class="mono-font mb-2 block text-[10px] font-bold uppercase tracking-[0.22em] text-[color:var(--auth-signal)]">{{ t('auth.reset.email_label') }}</label>
                    <input type="text" value="{{ reset_email }}" readonly class="field-input w-full rounded-none px-4 py-3.5 text-sm font-bold opacity-80">
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        <label for="password" class="mono-font mb-2 block text-[10px] font-bold uppercase tracking-[0.22em] text-[color:var(--auth-signal)]">{{ t('auth.field.password') }}</label>
                        <div class="relative">
                            <input type="password" name="password" id="password" minlength="10" maxlength="72" autocomplete="new-password" class="field-input w-full rounded-none px-4 py-3.5 pr-12 text-sm font-bold" placeholder="{{ t('auth.placeholder.password') }}" required>
                            <button type="button" id="togglePass1" class="absolute right-3 top-1/2 -translate-y-1/2 border border-[color:rgba(231,222,196,.14)] px-2 py-1 mono-font text-[10px] font-bold uppercase text-[#8c948f] hover:text-[color:var(--auth-signal)]">{{ t('auth.action.show') }}</button>
                        </div>
                    </div>
                    <div>
                        <label for="password2" class="mono-font mb-2 block text-[10px] font-bold uppercase tracking-[0.22em] text-[color:var(--auth-signal)]">{{ t('auth.field.password_repeat') }}</label>
                        <div class="relative">
                            <input type="password" name="password2" id="password2" minlength="10" maxlength="72" autocomplete="new-password" class="field-input w-full rounded-none px-4 py-3.5 pr-12 text-sm font-bold" placeholder="{{ t('auth.placeholder.password') }}" required>
                            <button type="button" id="togglePass2" class="absolute right-3 top-1/2 -translate-y-1/2 border border-[color:rgba(231,222,196,.14)] px-2 py-1 mono-font text-[10px] font-bold uppercase text-[#8c948f] hover:text-[color:var(--auth-signal)]">{{ t('auth.action.show') }}</button>
                        </div>
                    </div>
                </div>
                <div>
                    <div class="mb-2 flex items-center gap-2">
                        <div class="h-2 flex-1 overflow-hidden border border-[color:rgba(231,222,196,.14)] bg-black/40">
                            <div id="passwordStrengthBar" class="h-full w-0 bg-red-500 transition-all duration-200"></div>
                        </div>
                        <span id="passwordStrengthText" class="mono-font text-[10px] font-black uppercase tracking-wider text-red-300">{{ t('auth.strength.weak') }}</span>
                    </div>
                    <p class="text-[12px] font-bold leading-5 text-[#a8a397]">{{ t('auth.reset.password_hint') }}</p>
                </div>
                <div class="grid gap-3 sm:grid-cols-2">
                    <button type="submit" id="submitBtn" class="auth-btn-primary inline-flex w-full items-center justify-center gap-3 px-5 py-3 transition disabled:cursor-wait disabled:opacity-70">
                        <span class="display-font text-xs uppercase tracking-[0.1em]">{{ t('auth.reset.submit') }}</span>
                    </button>
                    <a href="{{ path_for('login') }}" class="auth-btn-secondary inline-flex w-full items-center justify-center px-5 py-3 text-center mono-font text-[10px] font-bold uppercase tracking-[0.16em] transition">{{ t('auth.reset.login_link') }}</a>
                </div>
            </form>
        </section>
    </main>

    <script>
        const resetForm = document.getElementById('resetForm');
        const passwordInput = document.getElementById('password');
        const passwordRepeatInput = document.getElementById('password2');
        const strengthBar = document.getElementById('passwordStrengthBar');
        const strengthText = document.getElementById('passwordStrengthText');
        const errorBox = document.getElementById('errorBox');
        const commonPasswords = new Set(['123456', '12345678', '123456789', '1234567890', 'qwerty', 'qwerty123', 'password', 'password123', 'admin123', 'welcome', 'letmein', 'iloveyou']);
        const texts = {
            passwordRequired: '{{ t("auth.validation.password_required")|e("js") }}',
            passwordMismatch: '{{ t("auth.validation.password_mismatch")|e("js") }}',
            passwordLength: '{{ t("auth.validation.password_length")|e("js") }}',
            passwordLong: '{{ t("auth.validation.password_long")|e("js") }}',
            passwordSpace: '{{ t("auth.validation.password_space")|e("js") }}',
            passwordCommon: '{{ t("auth.validation.password_common")|e("js") }}',
            processing: '{{ t("auth.reset.processing")|e("js") }}',
            completed: '{{ t("auth.reset.completed")|e("js") }}',
            connection: '{{ t("auth.validation.connection_error")|e("js") }}',
            weak: '{{ t("auth.strength.weak")|e("js") }}',
            medium: '{{ t("auth.strength.medium")|e("js") }}',
            strong: '{{ t("auth.strength.strong")|e("js") }}',
            veryStrong: '{{ t("auth.strength.very_strong")|e("js") }}',
            show: '{{ t("auth.action.show")|e("js") }}',
            hide: '{{ t("auth.action.hide")|e("js") }}'
        };

        function showError(message) { errorBox.textContent = String(message || texts.connection).slice(0, 300); errorBox.classList.remove('hidden'); }
        function hideError() { errorBox.classList.add('hidden'); }
        function setupPasswordToggle(buttonId, inputId) {
            const button = document.getElementById(buttonId);
            const input = document.getElementById(inputId);
            button.addEventListener('click', function () {
                const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                input.setAttribute('type', type);
                button.textContent = type === 'text' ? texts.hide : texts.show;
            });
        }
        function updatePasswordStrength() {
            let score = 0;
            const password = passwordInput.value;
            const lowered = password.toLowerCase();
            if (password.length >= 10) score++;
            if (password.length >= 14) score++;
            if (/[a-z]/.test(password) && /[A-Z]/.test(password)) score++;
            if (/\d/.test(password)) score++;
            if (/[^A-Za-z0-9]/.test(password)) score++;
            if (!commonPasswords.has(lowered)) score++;
            const states = password.length === 0 || score <= 2 ? ['0%', texts.weak, 'bg-red-500', 'text-red-300'] : score <= 4 ? ['50%', texts.medium, 'bg-amber-400', 'text-amber-300'] : score <= 5 ? ['75%', texts.strong, 'bg-cyan-400', 'text-cyan-300'] : ['100%', texts.veryStrong, 'bg-emerald-400', 'text-emerald-300'];
            strengthBar.style.width = states[0];
            strengthBar.className = 'h-full transition-all duration-200 ' + states[2];
            strengthText.textContent = states[1];
            strengthText.className = 'mono-font text-[10px] font-black uppercase tracking-wider ' + states[3];
        }
        function validatePassword(password, repeat) {
            if (!password) return texts.passwordRequired;
            if (password !== repeat) return texts.passwordMismatch;
            if (password.length < 10) return texts.passwordLength;
            if (password.length > 72) return texts.passwordLong;
            if (/\s/.test(password)) return texts.passwordSpace;
            if (commonPasswords.has(password.toLowerCase())) return texts.passwordCommon;
            return null;
        }

        setupPasswordToggle('togglePass1', 'password');
        setupPasswordToggle('togglePass2', 'password2');
        updatePasswordStrength();

        passwordInput.addEventListener('input', function () { hideError(); updatePasswordStrength(); });
        passwordRepeatInput.addEventListener('input', function () { hideError(); });

        resetForm.addEventListener('submit', function (e) {
            e.preventDefault();
            hideError();
            const passwordError = validatePassword(passwordInput.value, passwordRepeatInput.value);
            if (passwordError) { showError(passwordError); return; }

            const submitBtn = document.getElementById('submitBtn');
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span class="loader"></span><span class="mono-font text-[11px] font-black uppercase tracking-[0.2em]">' + texts.processing + '</span>';
            submitBtn.disabled = true;

            fetch(this.action, { method:'POST', body:new FormData(this), credentials:'same-origin', headers:{'X-Requested-With':'XMLHttpRequest','Accept':'application/json, */*'} })
                .then(async response => { const data = await response.json().catch(() => null); if (!response.ok || !data) throw new Error((data && data.message) ? data.message : ('HTTP ' + response.status)); return data; })
                .then(data => {
                    if (data.error !== 0) { showError(data.message || texts.connection); submitBtn.innerHTML = originalText; submitBtn.disabled = false; return; }
                    submitBtn.innerHTML = '<span class="mono-font text-[11px] font-black uppercase tracking-[0.2em] text-black">' + texts.completed + '</span>';
                    window.location.href = data.redirect || '{{ path_for("login") }}';
                })
                .catch(error => {
                    showError(error && error.message ? error.message : texts.connection);
                    submitBtn.innerHTML = originalText;
                    submitBtn.disabled = false;
                });
        });
    </script>
</body>
</html>
