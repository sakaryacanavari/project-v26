{% extends isAjax ? "common/ajaxbase.html.twig" : "common/base.html.twig" %}

{% block content %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
    /* =============================
       PRODUCTION CENTER v26.200 Ã¢â‚¬â€ PROJECT-NEXUS HUD
       ============================= */
    :root {
        --company-accent: var(--brand-primary);
        --company-accent-text: color-mix(in srgb, var(--brand-primary) 85%, #ffffff);
        --company-accent-strong: color-mix(in srgb, var(--brand-primary) 60%, #020617);
        --company-accent-soft: color-mix(in srgb, var(--brand-primary) 12%, transparent);
        --company-accent-border: color-mix(in srgb, var(--brand-primary) 25%, transparent);
        --company-accent-glow: color-mix(in srgb, var(--brand-primary) 40%, transparent);
    }

    /* --- Core Layout & Deep Glass Panel --- */
    .home-theme-surface .glass-panel {
        background: linear-gradient(145deg, rgba(6, 9, 17, 0.65) 0%, rgba(2, 4, 10, 0.9) 100%) !important;
        backdrop-filter: blur(32px);
        border: 1px solid rgba(255, 255, 255, 0.03) !important;
        box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.05), 0 20px 40px -10px rgba(0, 0, 0, 0.8);
        border-radius: 20px;
    }

    .company-state { display: inline-flex; align-items: center; gap: 5px; width: fit-content; margin-top: 7px; padding: 4px 7px; border-radius: 7px; font-size: 8px; font-weight: 900; letter-spacing: .06em; text-transform: uppercase; }
    .company-state.is-ready { color: #86efac; background: rgba(34,197,94,.08); }
    .company-state.is-workforce_missing, .company-state.is-input_missing, .company-state.is-control_required { color: #fcd34d; background: rgba(245,158,11,.08); }

    /* --- V26.200 Payroll Layout --- */
    .company-finance-section { width: 100%; }
    .company-finance-section .company-payroll-panel { width: 100%; }
    .company-finance-section > .glass-panel { padding: 14px !important; }
    .payroll-layout { display: grid; grid-template-columns: minmax(0, 1fr); gap: 10px; align-items: start; }
    .payroll-summary-wrap { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 10px; grid-column: 1 / -1; }
    @media (max-width: 900px) { .payroll-layout { grid-template-columns: 1fr; } .payroll-summary-wrap { grid-column: span 1; grid-template-columns: 1fr; } }

    .payroll-summary-card {
        border-radius: 14px; padding: 12px;
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.03);
        box-shadow: inset 0 2px 10px rgba(0,0,0,0.5);
        display: flex; flex-direction: column; position: relative; overflow: hidden;
    }
    .payroll-summary-card::before {
        content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 2px;
        background: linear-gradient(90deg, color-mix(in srgb, var(--brand-primary) 50%, transparent), transparent 70%);
    }

    .payroll-summary-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 9px; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 9px; }
    .currency-tag { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 900; color: #fff; letter-spacing: .1em; text-transform: uppercase; drop-shadow: 0 2px 4px rgba(0,0,0,0.5); }
    .currency-meta { margin-top: 4px; font-size: 9px; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; color: #64748b; }
    .currency-dot { width: 8px; height: 8px; border-radius: 50%; box-shadow: 0 0 10px rgba(255,255,255,0.3); }
    
    .summary-status { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 8px; font-size: 9px; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; box-shadow: inset 0 1px 2px rgba(0,0,0,0.3); }
    .summary-status.ok { color: #34d399; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.15); }
    .summary-status.low { color: #fcd34d; background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.15); }

    .summary-list { display: grid; gap: 8px; grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .summary-line { display: flex; flex-direction: column; gap: 3px; padding: 8px 10px; border-radius: 9px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.02); box-shadow: inset 0 1px 3px rgba(0,0,0,0.5); }
    .summary-line strong { color: #fff; font-weight: 900; font-family: 'JetBrains Mono', monospace; font-size: 13px; }
    .summary-line span { font-size: 8px; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; color: #64748b; }

    .summary-footer { margin-top: 14px; padding-top: 14px; display: flex; align-items: center; justify-content: space-between; gap: 10px; border-top: 1px solid rgba(255,255,255,0.03); }
    .summary-footer-label { font-size: 9px; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; color: #64748b; }
    .summary-footer-value { font-size: 12px; font-weight: 900; color: var(--brand-primary); text-transform: uppercase; letter-spacing: .08em; }

    /* --- V26.200 Table Rows --- */
    .v2-table-row {
        background: rgba(0, 0, 0, 0.3);
        transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
        box-shadow: inset 0 2px 8px rgba(0,0,0,0.5);
    }
    .v2-table-row:hover {
        background: color-mix(in srgb, var(--brand-primary) 5%, rgba(0,0,0,0.5));
        transform: scale(1.01) translateX(4px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.02);
    }
    .v2-table-row td {
        border-top: 1px solid rgba(255,255,255,0.02);
        border-bottom: 1px solid rgba(255,255,255,0.02);
        padding: 14px;
    }
    .v2-table-row:hover td { border-color: color-mix(in srgb, var(--brand-primary) 15%, transparent); border-top-color: color-mix(in srgb, var(--brand-primary) 25%, rgba(255,255,255,0.05)); }
    .v2-table-row td:first-child { border-left: 3px solid transparent; border-top-left-radius: 14px; border-bottom-left-radius: 14px; }
    .v2-table-row:hover td:first-child { border-left: 3px solid var(--brand-primary); }
    .v2-table-row td:last-child { border-right: 1px solid rgba(255,255,255,0.02); border-top-right-radius: 14px; border-bottom-right-radius: 14px; }
    .v2-table-row:hover td:last-child { border-right-color: color-mix(in srgb, var(--brand-primary) 15%, transparent); }

    .company-table-scroll { overflow-x: auto; overflow-y: hidden; padding-bottom: 0; scrollbar-width: none; }
    .company-table-scroll::-webkit-scrollbar { display: none; }

    /* --- Badges & Actions --- */
    .tech-badge { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 6px 12px; border-radius: 8px; font-family: 'JetBrains Mono', monospace; font-weight: 900; font-size: 11px; border: 1px solid transparent; background: rgba(0,0,0,0.4); box-shadow: inset 0 2px 5px rgba(0,0,0,0.5); }
    .tech-badge.red { color: #fca5a5; }
    .tech-badge.green { color: #6ee7b7; }
    .tech-badge.neutral { color: #cbd5e1; }

    .finance-action-btn {
        min-height: 40px; border-radius: 12px; padding: 0 14px; display: inline-flex; align-items: center; justify-content: flex-start; gap: 10px;
        font-size: 10px; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; text-decoration: none;
        border: none; background: rgba(0,0,0,0.4); color: #cbd5e1; cursor: pointer; transition: all 0.3s ease; box-shadow: inset 0 2px 5px rgba(0,0,0,0.5);
    }
    .finance-action-btn:hover { background: rgba(0,0,0,0.6); color: #fff; transform: translateX(2px); }
    .finance-action-btn.primary { background: color-mix(in srgb, var(--company-accent) 15%, rgba(0,0,0,0.5)); color: var(--company-accent-text); }
    .finance-action-btn.primary:hover { background: color-mix(in srgb, var(--company-accent) 25%, rgba(0,0,0,0.6)); transform: translateY(-2px); box-shadow: 0 5px 15px color-mix(in srgb, var(--company-accent) 20%, transparent); }
    .finance-action-btn:disabled { opacity: .4; cursor: not-allowed; transform: none !important; }

    .btn-create-primary {
        background: linear-gradient(135deg, color-mix(in srgb, var(--brand-primary) 85%, white), var(--brand-primary));
        color: #0c0a09; transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
        box-shadow: 0 4px 15px color-mix(in srgb, var(--brand-primary) 20%, transparent), inset 0 1px 0 color-mix(in srgb, var(--brand-primary) 30%, rgba(255,255,255,0.2));
        border: none;
    }
    .btn-create-primary:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 8px 25px color-mix(in srgb, var(--brand-primary) 30%, transparent), inset 0 1px 0 color-mix(in srgb, var(--brand-primary) 40%, rgba(255,255,255,0.3)); filter: brightness(1.05); }
    .btn-create-primary:active:not(:disabled) { transform: translateY(0); box-shadow: 0 2px 8px color-mix(in srgb, var(--brand-primary) 10%, transparent); }

    .btn-amber { background: linear-gradient(135deg, #fde047, #f59e0b); color: #0c0a09; box-shadow: 0 4px 15px rgba(245, 158, 11, 0.15); border: none; }
    .btn-amber:hover:not(:disabled) { background: linear-gradient(135deg, #fef08a, #f59e0b); box-shadow: 0 8px 25px rgba(245, 158, 11, 0.25); transform: translateY(-2px); filter: brightness(1.05); }
    
    .btn-red { background: linear-gradient(135deg, #fca5a5, #ef4444); color: #0c0a09; box-shadow: 0 4px 15px rgba(239, 68, 68, 0.15); border: none; }
    .btn-red:hover:not(:disabled) { background: linear-gradient(135deg, #fecaca, #ef4444); box-shadow: 0 8px 25px rgba(239, 68, 68, 0.25); transform: translateY(-2px); filter: brightness(1.05); }

    /* --- Modal Inputs (Tactile & Deep) --- */
    .cyber-input-field {
        background: rgba(0, 0, 0, 0.5) !important;
        border: 1px solid rgba(255, 255, 255, 0.02) !important;
        color: #f8fafc !important;
        border-radius: 12px !important;
        padding: 14px 16px !important;
        font-size: 13px !important;
        transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
        box-shadow: inset 0 2px 8px rgba(0,0,0,0.6);
        appearance: none;
    }
    .cyber-input-field:focus {
        background: rgba(0, 0, 0, 0.8) !important;
        border-color: color-mix(in srgb, var(--brand-primary) 50%, transparent) !important;
        box-shadow: inset 0 2px 10px rgba(0,0,0,0.8), 0 0 0 1px color-mix(in srgb, var(--brand-primary) 15%, transparent) !important;
        outline: none;
    }
    .cyber-input-field option { background: #0f172a; color: #fff; }

    /* SweetAlert V26.200 */
    .cyber-modal-popup { background: rgba(8, 10, 14, 0.98) !important; backdrop-filter: blur(32px); border: 1px solid rgba(255, 255, 255, 0.03) !important; border-radius: 24px !important; padding: 2rem 1.5rem !important; box-shadow: 0 35px 70px -15px rgba(0,0,0,0.95) !important; }
    .cyber-modal-title { color: #f8fafc !important; text-transform: uppercase !important; letter-spacing: 0.15em !important; font-weight: 900 !important; font-size: 14px !important; border-bottom: 1px solid rgba(255,255,255,0.02); padding-bottom: 14px !important; margin-bottom: 18px !important; display: flex; align-items: center; gap: 8px; }
    .cyber-modal-content { color: #94a3b8 !important; font-size: 12px !important; font-weight: 600 !important; }
    .cyber-confirm-btn {
        min-height: 40px !important; min-width: 150px; padding: 0 18px !important;
        display: inline-flex !important; align-items: center; justify-content: center; gap: 8px;
        border: 1px solid color-mix(in srgb, var(--brand-primary) 55%, transparent) !important;
        border-radius: 10px !important;
        background: linear-gradient(135deg, color-mix(in srgb, var(--brand-primary) 88%, #ffffff), var(--brand-primary)) !important;
        color: #071018 !important; font-size: 10px !important; font-weight: 900 !important;
        letter-spacing: .08em; text-transform: uppercase; cursor: pointer;
        box-shadow: 0 6px 16px color-mix(in srgb, var(--brand-primary) 22%, transparent), inset 0 1px 0 rgba(255,255,255,.25) !important;
        transition: transform .18s ease, filter .18s ease, box-shadow .18s ease;
    }
    .cyber-confirm-btn:hover:not(:disabled) {
        filter: brightness(1.06); transform: translateY(-1px);
        box-shadow: 0 8px 20px color-mix(in srgb, var(--brand-primary) 28%, transparent), inset 0 1px 0 rgba(255,255,255,.3) !important;
    }
    .cyber-confirm-btn:focus-visible {
        outline: 2px solid color-mix(in srgb, var(--brand-primary) 78%, #ffffff) !important;
        outline-offset: 3px;
    }
    .cyber-confirm-btn:disabled { opacity: .55; cursor: not-allowed; transform: none !important; }
    .swal-tech-label { display: block; margin-bottom: 6px; font-size: 10px; font-weight: 900; letter-spacing: .15em; text-transform: uppercase; color: #cbd5e1; }
    .swal-tech-help { font-size: 11px; color: #64748b; margin-bottom: 10px; font-weight: 600; line-height: 1.4; }

    /* Liquid Glass: company data stays opaque; only controls receive the glass material. */
    html.theme-liquid .home-theme-surface {
        --company-surface-bg: rgba(9, 14, 23, .97);
        --company-surface-border: rgba(161, 181, 198, .16);
        --company-surface-text: #eef3f7;
        --company-surface-muted: #aebbc7;
        --company-stat-bg: rgba(20, 29, 42, .97);
        --company-stat-border: rgba(161, 181, 198, .18);
    }
    html.theme-liquid .home-theme-surface .glass-panel,
    html.theme-liquid .home-theme-surface .payroll-summary-card,
    html.theme-liquid .home-theme-surface .summary-line,
    html.theme-liquid .home-theme-surface .company-attention-item,
    html.theme-liquid .home-theme-surface .company-table-scroll,
    html.theme-liquid .home-theme-surface .v2-table-row {
        background: var(--company-surface-bg) !important;
        background-image: none !important;
        border-color: var(--company-surface-border) !important;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        box-shadow: inset 0 1px 0 rgba(210, 225, 236, .045), 0 8px 20px rgba(0, 0, 0, .18) !important;
    }
    html.theme-liquid .home-theme-surface .summary-line {
        background: var(--company-stat-bg) !important;
        border-color: var(--company-stat-border) !important;
    }
    html.theme-liquid .home-theme-surface .currency-meta,
    html.theme-liquid .home-theme-surface .summary-line span,
    html.theme-liquid .home-theme-surface .summary-footer-label {
        color: var(--company-surface-muted) !important;
    }
    html.theme-liquid .home-theme-surface .currency-tag,
    html.theme-liquid .home-theme-surface .summary-line strong {
        color: var(--company-surface-text) !important;
    }
    html.theme-liquid .home-theme-surface .finance-action-btn {
        background: var(--glass-control-bg) !important;
        border: 1px solid var(--glass-control-border) !important;
        color: var(--glass-control-text) !important;
        box-shadow: inset 1px 1px 0 var(--glass-control-highlight), var(--glass-control-shadow) !important;
        backdrop-filter: blur(var(--glass-control-blur)) saturate(var(--glass-control-saturation)) !important;
        -webkit-backdrop-filter: blur(var(--glass-control-blur)) saturate(var(--glass-control-saturation)) !important;
    }
    html.theme-liquid .home-theme-surface .company-filter-control,
    html.theme-liquid .home-theme-surface .company-filter-clear,
    html.theme-liquid .home-theme-surface .company-priority-action-link,
    html.theme-liquid .home-theme-surface .company-attention-action {
        background: var(--glass-control-bg) !important;
        border-color: var(--glass-control-border) !important;
        color: var(--glass-control-text) !important;
        box-shadow: inset 1px 1px 0 var(--glass-control-highlight), var(--glass-control-shadow) !important;
        backdrop-filter: blur(var(--glass-control-blur)) saturate(var(--glass-control-saturation)) !important;
        -webkit-backdrop-filter: blur(var(--glass-control-blur)) saturate(var(--glass-control-saturation)) !important;
    }
    html.theme-liquid .home-theme-surface .finance-action-btn:focus-visible,
    html.theme-liquid .home-theme-surface .company-table-scroll a:focus-visible,
    html.theme-liquid .home-theme-surface .company-table-scroll button:focus-visible {
        outline: 2px solid color-mix(in srgb, var(--brand-primary) 76%, #ffffff) !important;
        outline-offset: 3px;
    }

    .company-filter-bar {
        display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 8px;
        margin: -8px 0 14px; padding: 10px; border-radius: 12px;
        background: rgba(0, 0, 0, .22); border: 1px solid rgba(255,255,255,.04);
    }
    .company-filter-field { min-width: 0; }
    .company-filter-label { display: block; margin: 0 0 5px 2px; color: #94a3b8; font-size: 8px; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; }
    .company-filter-control {
        width: 100%; min-height: 34px; padding: 0 10px; border-radius: 8px;
        background: rgba(6, 10, 18, .72); border: 1px solid rgba(148,163,184,.14);
        color: #dbe5ec; font-size: 10px; font-weight: 800; outline: none;
    }
    .company-filter-control:focus-visible { border-color: color-mix(in srgb, var(--brand-primary) 62%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand-primary) 18%, transparent); }
    .company-filter-actions { display: flex; align-items: end; }
    .company-filter-clear { width: 100%; min-height: 34px; padding: 0 10px; border: 1px solid rgba(148,163,184,.14); border-radius: 8px; background: rgba(6, 10, 18, .48); color: #aebbc7; font-size: 9px; font-weight: 900; letter-spacing: .06em; text-transform: uppercase; }
    .company-filter-clear:hover { color: var(--company-accent-text); border-color: var(--company-accent-border); }
    .company-filter-empty { display: none; padding: 16px 10px; color: #aebbc7; font-size: 10px; font-weight: 800; text-align: center; }
    .company-priority-action { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: 12px; padding: 11px 13px; border-radius: 10px; background: var(--company-accent-soft); border: 1px solid var(--company-accent-border); }
    .company-priority-action-copy { min-width: 0; }
    .company-priority-action-title { color: #e8eef3; font-size: 10px; font-weight: 900; }
    .company-priority-action-sub { margin-top: 3px; color: #aebbc7; font-size: 9px; line-height: 1.35; }
    .company-priority-action-link { display: inline-flex; align-items: center; justify-content: center; min-height: 30px; padding: 0 10px; border-radius: 8px; background: var(--company-accent-soft); color: var(--company-accent-text); font-size: 8px; font-weight: 900; letter-spacing: .06em; text-transform: uppercase; white-space: nowrap; }
    .company-priority-action-link:hover { background: color-mix(in srgb, var(--company-accent) 22%, rgba(0,0,0,.35)); }
    .company-operation-link { display: inline-flex; align-items: center; gap: 5px; width: fit-content; margin-top: 5px; color: var(--brand-primary); font-size: 8px; font-weight: 900; letter-spacing: .06em; text-transform: uppercase; }
    .company-operation-link:hover { color: color-mix(in srgb, var(--brand-primary) 76%, #fff); }
    .company-attention { display: grid; gap: 10px; }
    .company-attention-item { display: grid; grid-template-columns: auto minmax(0,1fr) auto; align-items: center; gap: 10px; padding: 11px 12px; border-radius: 10px; background: rgba(10, 16, 26, .58); border: 1px solid rgba(255,255,255,.05); }
    .company-attention-icon { width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center; border-radius: 8px; background: color-mix(in srgb, var(--brand-primary) 10%, rgba(0,0,0,.35)); color: var(--brand-primary); }
    .company-attention-title { color: #e8eef3; font-size: 10px; font-weight: 900; }
    .company-attention-copy { margin-top: 3px; color: #aebbc7; font-size: 9px; line-height: 1.35; }
    .company-attention-action { display: inline-flex; align-items: center; justify-content: center; min-height: 30px; padding: 0 9px; border-radius: 8px; background: color-mix(in srgb, var(--brand-primary) 12%, rgba(0,0,0,.35)); color: var(--brand-primary); font-size: 8px; font-weight: 900; letter-spacing: .06em; text-transform: uppercase; }
    .company-attention-action:hover { background: color-mix(in srgb, var(--brand-primary) 22%, rgba(0,0,0,.35)); }
    .company-attention-ok { display: flex; align-items: center; gap: 8px; padding: 12px; border-radius: 10px; background: rgba(16, 185, 129, .06); color: #9de2c2; font-size: 10px; font-weight: 800; }
    .company-activity-panel .glass-panel { padding: 14px !important; }
    .company-activity-list { display: grid; gap: 8px; }
    .company-activity-item { display: grid; grid-template-columns: auto minmax(0,1fr) auto; gap: 10px; align-items: center; padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,.05); }
    .company-activity-item:last-child { border-bottom: 0; }
    .company-activity-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--brand-primary); box-shadow: 0 0 8px color-mix(in srgb, var(--brand-primary) 35%, transparent); }
    .company-activity-type { color: #e8eef3; font-size: 9px; font-weight: 900; }
    .company-activity-label { margin-top: 3px; color: #aebbc7; font-size: 9px; }
    .company-activity-time { color: #8f9daa; font-size: 8px; white-space: nowrap; }
    .company-assets-panel { padding: 18px !important; }
    .company-assets-panel .section-head { margin-bottom: 12px !important; padding-bottom: 10px !important; }
    .company-assets-panel .v2-table-row { transition: background .18s ease, border-color .18s ease, transform .18s ease; }
    .company-assets-panel .v2-table-row:hover { transform: translateX(2px); }
    .company-assets-panel .v2-table-row td { padding-top: 11px; padding-bottom: 11px; }
    .company-assets-panel .company-unit { gap: 12px !important; }
    .company-payroll-panel > .flex.justify-between { margin-bottom: 10px !important; padding-bottom: 10px !important; }
    .company-payroll-panel .summary-list { gap: 6px; }
    .company-payroll-panel .summary-line { padding: 7px 8px; }
    .company-offer-actions { gap: 6px !important; }
    .company-offer-actions .finance-action-btn { min-height: 32px !important; }
    .company-layout-table .company-unit > div:last-child { min-width: 0; overflow-wrap: anywhere; }
    .company-finance-section,
    .company-activity-panel { min-width: 0; }
    .company-dashboard-columns { display: grid; grid-template-columns: minmax(0, 1.55fr) minmax(280px, .85fr); gap: 14px; align-items: start; }
    .company-main-column,
    .company-side-column { display: grid; gap: 14px; align-content: start; min-width: 0; }
    .home-theme-surface > .glass-panel { padding: 18px !important; }
    .home-theme-surface > .glass-panel:first-child { padding: 18px 22px !important; }
    .home-theme-surface > .glass-panel:first-child { gap: 12px !important; }
    .home-theme-surface > .glass-panel:first-child > i { font-size: 90px !important; opacity: .01 !important; }
    .home-theme-surface .section-head { margin-bottom: 14px !important; padding-bottom: 10px !important; }
    .home-theme-surface .v2-table-row td { padding-top: 10px; padding-bottom: 10px; }
    .home-theme-surface.gx-density-compact { gap: 12px; }
    .home-theme-surface.gx-density-compact .company-dashboard-columns,
    .home-theme-surface.gx-density-compact .company-main-column,
    .home-theme-surface.gx-density-compact .company-side-column { gap: 12px; }
    .home-theme-surface.gx-density-compact > .glass-panel { padding: 12px !important; }
    .home-theme-surface.gx-density-compact > .glass-panel:first-child { padding: 12px 16px !important; }
    .home-theme-surface.gx-density-compact .payroll-summary-wrap { gap: 7px; }
    .home-theme-surface.gx-density-compact .payroll-summary-card { padding: 10px; }
    .home-theme-surface.gx-density-comfortable { gap: 22px; }
    .home-theme-surface.gx-density-comfortable .company-dashboard-columns,
    .home-theme-surface.gx-density-comfortable .company-main-column,
    .home-theme-surface.gx-density-comfortable .company-side-column { gap: 22px; }
    .home-theme-surface.gx-density-comfortable > .glass-panel { padding: 22px !important; }
    .home-theme-surface.gx-density-comfortable > .glass-panel:first-child { padding: 22px 26px !important; }
    @media (max-width: 680px) {
        .home-theme-surface > .glass-panel,
        .home-theme-surface > .glass-panel:first-child { padding: 14px !important; }
        .home-theme-surface.gx-density-compact > .glass-panel,
        .home-theme-surface.gx-density-compact > .glass-panel:first-child { padding: 10px !important; }
    }
    @media (max-width: 900px) {
        .company-dashboard-columns { display: block; }
        .company-main-column,
        .company-side-column { display: grid; gap: 14px; }
        .company-side-column { margin-top: 14px; }
        .home-theme-surface.gx-density-compact > * + * { margin-top: 12px !important; }
        .home-theme-surface.gx-density-comfortable > * + * { margin-top: 22px !important; }
        .home-theme-surface.gx-density-compact .company-side-column { margin-top: 12px; }
        .home-theme-surface.gx-density-comfortable .company-side-column { margin-top: 22px; }
    }
    @media (max-width: 1100px) { .company-filter-bar { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    @media (max-width: 900px) { .company-filter-bar { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (max-width: 680px) {
        .company-filter-bar { grid-template-columns: 1fr; margin-top: -4px; }
        .company-filter-actions { align-items: stretch; }
        .company-table-scroll { padding: 8px !important; overflow-x: visible; }
        .company-layout-table, .company-layout-table thead, .company-layout-table tbody, .company-layout-table tr, .company-layout-table td { display: block; width: 100%; }
        .company-layout-table thead { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }
        .company-layout-table tbody { display: grid; gap: 10px; }
        .company-layout-table .v2-table-row { display: flex; flex-direction: column; padding: 8px; transform: none !important; }
        .company-layout-table .v2-table-row td,
        .company-layout-table .v2-table-row td:first-child,
        .company-layout-table .v2-table-row td:last-child { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; padding: 8px 4px; border: 0; border-radius: 0; }
        .company-layout-table .v2-table-row td:first-child { order: 1; }
        .company-layout-table .v2-table-row td:nth-child(4) { order: 2; }
        .company-layout-table .v2-table-row td:nth-child(3) { order: 3; }
        .company-layout-table .v2-table-row td:nth-child(2) { order: 4; }
        .company-layout-table .v2-table-row td::before { content: attr(data-label); flex: 0 0 29%; padding-top: 4px; color: #94a3b8; font-size: 8px; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }
        .company-layout-table .v2-table-row td > * { min-width: 0; flex: 1 1 auto; }
        .company-layout-table .company-unit { justify-content: flex-start; }
        .company-layout-table .company-unit > div:last-child { min-width: 0; }
        .company-layout-table .v2-table-row td:last-child .company-offer-actions { max-width: 100%; }
        .company-attention-item { grid-template-columns: auto minmax(0, 1fr); align-items: start; }
        .company-attention-action { grid-column: 2; width: fit-content; }
        .company-priority-action { align-items: flex-start; flex-direction: column; }
        .company-priority-action-link { width: 100%; }
    }
</style>

<div class="home-theme-surface gx-density-{{ gameExperienceSettings.ui_density|default('balanced') }} space-y-6 animate-fade-in w-full max-w-full overflow-hidden">
    
    {# ===== HERO PANEL ===== #}
    <div class="glass-panel p-6 md:p-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 relative">
        <i class="fa-solid fa-microchip absolute -right-6 -bottom-6 text-[140px] text-[color:var(--brand-primary)] opacity-[0.02] pointer-events-none rotate-[-10deg]"></i>

        <div class="flex items-center gap-5 relative z-10">
            <div class="w-14 h-14 rounded-[14px] bg-[color:var(--brand-primary)]/10 flex items-center justify-center shadow-[inset_0_2px_8px_rgba(0,0,0,0.5)] shrink-0">
                <i class="fa-solid fa-microchip text-2xl text-[color:var(--brand-primary)] drop-shadow-sm"></i>
            </div>
            <div>
                <h1 class="text-xl md:text-2xl font-black text-white uppercase tracking-wider leading-tight drop-shadow-md">
                    {{ t('companies.hero.title') }}
                </h1>
                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.15em] mt-1.5 flex items-center gap-2 opacity-80">
                    <span class="w-1.5 h-1.5 bg-[color:var(--brand-primary)] rounded-full animate-pulse shadow-[0_0_5px_var(--brand-primary)]"></span> {{ t('companies.hero.subtitle') }}
                </p>
            </div>
        </div>
    </div>

    {% if priorityAction %}
        <div class="company-priority-action company-priority-panel" aria-label="Sıradaki yönetim adımı">
            <div class="company-priority-action-copy">
                <div class="company-priority-action-title"><i class="fa-solid {{ priorityAction.icon }} text-[color:var(--brand-primary)] mr-1"></i> Sıradaki yönetim adımı</div>
                <div class="company-priority-action-sub">{% if priorityAction.company_name %}{{ priorityAction.company_name }} için {% endif %}{{ priorityAction.label }}.</div>
            </div>
            {% if priorityAction.key == 'marketplace' %}
                <a href="{{ path_for('marketplace') }}" class="company-priority-action-link" aria-label="{{ priorityAction.label }}"><i class="fa-solid fa-arrow-right mr-1"></i> Markete git</a>
            {% elseif priorityAction.key == 'work_offers' %}
                <a href="{{ base_url() }}/work-offers" class="company-priority-action-link" aria-label="{{ priorityAction.label }}"><i class="fa-solid fa-arrow-right mr-1"></i> İlanları yönet</a>
            {% elseif priorityAction.key == 'create_company' %}
                <a href="{{ path_for('createCompany') }}" class="company-priority-action-link" aria-label="{{ priorityAction.label }}"><i class="fa-solid fa-arrow-right mr-1"></i> Tesis kur</a>
            {% else %}
                <span class="company-priority-action-link" aria-label="{{ priorityAction.label }}"><i class="fa-solid fa-eye mr-1"></i> İncele</span>
            {% endif %}
        </div>
    {% endif %}

    <div class="company-dashboard-columns">
        <div class="company-main-column">

    {# ===== ATTENTION CENTER ===== #}
    <section class="glass-panel p-5 md:p-6 relative company-attention-panel" aria-labelledby="company-attention-title">
        <div class="flex items-center justify-between gap-3 mb-4 border-b border-white/5 pb-3">
            <div>
                <h2 id="company-attention-title" class="text-[11px] font-black text-white uppercase tracking-[0.2em] flex items-center gap-2">
                    <i class="fa-solid fa-triangle-exclamation text-[color:var(--brand-primary)]"></i> Dikkat Merkezi
                </h2>
                <p class="text-[9px] text-slate-400 mt-1">Sorun varsa gereken işlemi gösterir.</p>
            </div>
            {% if (blockedFacilityCount|default(0) + payrollRiskCount|default(0)) > 0 %}
                <span class="summary-status low"><i class="fa-solid fa-eye"></i> {{ blockedFacilityCount|default(0) + payrollRiskCount|default(0) }} kontrol</span>
            {% endif %}
        </div>
        <div class="company-attention">
            {% for company in companies %}
                {% set attentionType = companyTypes[company.type]|default({}) %}
                {% set attentionOps = companyOperations[company.id]|default({}) %}
                {% set attentionName = attentionType.display_name|default(attentionType.name|default('Tesis')) %}
                {% set attentionStatus = attentionOps.status|default('control_required') %}
                {% set isPriorityAttention = priorityAction and priorityAction.company_name|default('') == attentionName and priorityAction.key|default('') != 'none' %}
                {% if attentionStatus != 'ready' %}
                    <div class="company-attention-item">
                        <span class="company-attention-icon"><i class="fa-solid {{ attentionStatus == 'input_missing' ? 'fa-box-open' : 'fa-triangle-exclamation' }}"></i></span>
                        <div>
                            <div class="company-attention-title">{{ attentionName }} · {{ attentionStatus == 'input_missing' ? 'Girdi eksik' : (attentionStatus == 'workforce_missing' ? 'İş gücü eksik' : 'Kurulum verisi eksik') }}</div>
                            <div class="company-attention-copy">
                                {% if attentionStatus == 'input_missing' %}Girdi stoğu yetersiz.{% elseif attentionStatus == 'workforce_missing' %}Gerekli çalışan tamamlanmadı.{% else %}Operasyon verisi eksik.{% endif %}
                            </div>
                        </div>
                        {% if not isPriorityAttention and attentionStatus == 'input_missing' %}
                            <a href="{{ path_for('storage') }}" class="company-attention-action" aria-label="{{ attentionName }} için depoyu kontrol et">Depoyu kontrol et</a>
                        {% elseif not isPriorityAttention and attentionStatus == 'workforce_missing' %}
                            <a href="{{ base_url() }}/work-offers" class="company-attention-action" aria-label="{{ attentionName }} için iş ilanlarına git">İlanlara git</a>
                        {% endif %}
                    </div>
                {% endif %}
            {% endfor %}
            {% if companies|length == 0 %}
                <div class="company-attention-ok"><i class="fa-solid fa-circle-info"></i> Henüz kurulmuş bir tesis yok. İlk tesisini kurarak üretim alanını başlatabilirsin.</div>
            {% elseif blockedFacilityCount|default(0) == 0 and payrollRiskCount|default(0) == 0 %}
                <div class="company-attention-ok"><i class="fa-solid fa-circle-check"></i> Tüm tesisler operasyonel görünüyor.</div>
            {% endif %}
            {% for summary in payrollSummary %}
                {% if not summary.is_sufficient %}
                    <div class="company-attention-item">
                        <span class="company-attention-icon"><i class="fa-solid fa-wallet"></i></span>
                        <div>
                            <div class="company-attention-title">{{ summary.code }} maaş bakiyesi düşük</div>
                            <div class="company-attention-copy">Bakiye günlük maaş yükünü karşılamıyor.</div>
                        </div>
                        <a href="{{ base_url() }}/work-offers" class="company-attention-action" aria-label="{{ summary.code }} ilanlarını yönet">İlanları yönet</a>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </section>

    {# ===== MAIN TABLE PANEL ===== #}
    <div class="glass-panel p-6 relative company-assets-panel">
        <div class="section-head mb-6 border-b border-white/5 pb-4 flex flex-col md:flex-row md:items-center justify-between gap-4">
            <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] flex items-center gap-2 drop-shadow-sm">
                <i class="fa-solid fa-city text-[color:var(--brand-primary)] opacity-80"></i> {{ t('companies.panel.title') }}
                <span class="text-[8px] bg-black/40 px-2 py-1 rounded-md border border-white/5 shadow-inner text-slate-500 ml-2">{{ t('companies.panel.badge') }}</span>
            </h2>

            <a href="{{ path_for('createCompany') }}" class="btn-create-primary px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-[0.15em] flex items-center justify-center gap-2">
                <i class="fa-solid fa-plus opacity-80 text-xs"></i> {{ t('companies.actions.create_facility') }}
            </a>
        </div>

        {% if companies|length > 0 %}
            {% if companies|length > 1 %}
                <div class="company-filter-bar" id="company-filters" aria-label="Tesis filtreleri">
                    <div class="company-filter-field">
                        <label class="company-filter-label" for="company-filter-status">Durum</label>
                        <select id="company-filter-status" class="company-filter-control" aria-label="Tesis durumuna göre filtrele">
                            <option value="all">Tümü</option>
                            <option value="ready">Üretime hazır</option>
                            <option value="workforce_missing">İş gücü eksik</option>
                            <option value="input_missing">Girdi eksik</option>
                        </select>
                    </div>
                    <div class="company-filter-field">
                        <label class="company-filter-label" for="company-filter-sector">Sektör</label>
                        <select id="company-filter-sector" class="company-filter-control" aria-label="Sektöre göre filtrele">
                            <option value="all">Tüm sektörler</option>
                        </select>
                    </div>
                    <div class="company-filter-field">
                        <label class="company-filter-label" for="company-filter-quality">Kalite</label>
                        <select id="company-filter-quality" class="company-filter-control" aria-label="Kalite seviyesine göre filtrele">
                            <option value="all">Tüm kademeler</option>
                        </select>
                    </div>
                    <div class="company-filter-field">
                        <label class="company-filter-label" for="company-filter-workforce">İş gücü</label>
                        <select id="company-filter-workforce" class="company-filter-control" aria-label="İş gücü ihtiyacına göre filtrele">
                            <option value="all">Tüm durumlar</option>
                            <option value="missing">Eksik iş gücü</option>
                            <option value="ready">İş gücü tamam</option>
                        </select>
                    </div>
                    <div class="company-filter-field">
                        <label class="company-filter-label" for="company-filter-input">Girdi</label>
                        <select id="company-filter-input" class="company-filter-control" aria-label="Girdi durumuna göre filtrele">
                            <option value="all">Tüm girdiler</option>
                            <option value="missing">Girdi eksik</option>
                            <option value="ready">Girdi hazır</option>
                            <option value="not_needed">Girdi gerekmiyor</option>
                        </select>
                    </div>
                    <div class="company-filter-field">
                        <label class="company-filter-label" for="company-filter-offer">İş ilanı</label>
                        <select id="company-filter-offer" class="company-filter-control" aria-label="İş ilanı durumuna göre filtrele">
                            <option value="all">Tüm ilanlar</option>
                            <option value="open">Açık ilan var</option>
                            <option value="none">İlan yok</option>
                        </select>
                    </div>
                    <div class="company-filter-field">
                        <label class="company-filter-label" for="company-filter-name">Tesis adı</label>
                        <input id="company-filter-name" class="company-filter-control" type="search" placeholder="Tesis ara..." aria-label="Tesis adına göre ara">
                    </div>
                    <div class="company-filter-field">
                        <label class="company-filter-label" for="company-filter-sort">Sıralama</label>
                        <select id="company-filter-sort" class="company-filter-control" aria-label="Tesisleri sırala">
                            <option value="name">Ada göre</option>
                            <option value="quality">Kaliteye göre</option>
                            <option value="capacity">Kapasiteye göre</option>
                            <option value="newest">En yeni tesis</option>
                            <option value="vacancies">Boş pozisyona göre</option>
                            <option value="status">Dikkat gerekenler önce</option>
                        </select>
                    </div>
                    <div class="company-filter-actions">
                        <button type="button" id="company-filter-clear" class="company-filter-clear" aria-label="Tesis filtrelerini temizle">Filtreleri temizle</button>
                    </div>
                </div>
            {% endif %}
            <div class="company-table-scroll bg-black/20 p-4 rounded-2xl border border-white/5 shadow-inner">
                <table id="my-companies" class="w-full text-left company-layout-table">
                    <thead class="text-[10px] font-black text-slate-500 uppercase tracking-[0.15em]">
                        <tr>
                            <th class="p-3 pb-2 pl-5" style="width: 34%;">{{ t('companies.table.company') }}</th>
                            <th class="p-3 pb-2 text-left" style="width: 24%;">{{ t('companies.table.logistics') }}</th>
                            <th class="p-3 pb-2 text-left" style="width: 20%;">{{ t('companies.table.output') }}</th>
                            <th class="p-3 pb-2 text-left" style="width: 22%;">{{ t('companies.table.offer') }}</th>
                        </tr>
                    </thead>
                    <tbody class="text-xs text-white font-bold">
                        {% for company in companies %}
                            {% set offer = openOffers[company.id] is defined ? openOffers[company.id] : null %}
                            {% set companyType = companyTypes[company.type]|default({}) %}
                            {% set qualityData = companyType.qualities[company.quality]|default({}) %}
                            {% set consumeProduct = qualityData.consume_product|default(0) %}
                            {% set consumeAmount = qualityData.consume_amount|default(0) %}
                            {% set outputProduct = companyType.product|default(0) %}
                            {% set outputAmount = qualityData.product_amount|default(0) %}
                            {% set ops = companyOperations[company.id]|default({}) %}
                            {% set companyName = companyType.display_name|default(companyType.name|default('Tesis')) %}
                            {% set companyStatus = ops.status|default('control_required') %}

                            <tr class="v2-table-row group"
                                data-company-name="{{ companyName|lower|e('html_attr') }}"
                                data-company-sector="{{ companyName|e('html_attr') }}"
                                data-company-quality="{{ company.quality }}"
                                data-company-workforce="{{ (ops.required_workers|default(0)) > (ops.assigned_workers|default(0)) ? 'missing' : 'ready' }}"
                                data-company-input="{{ consumeProduct > 0 ? ((ops.input_stock|default(0)) < consumeAmount ? 'missing' : 'ready') : 'not_needed' }}"
                                data-company-offer="{{ offer ? 'open' : 'none' }}"
                                data-company-capacity="{{ outputAmount }}"
                                data-company-created="{{ company.created_at|default('')|e('html_attr') }}"
                                data-company-vacancies="{{ ops.open_positions|default(0) }}"
                                data-company-status="{{ companyStatus }}">
                                <td class="p-4 pl-5" data-label="{{ t('companies.table.company') }}">
                                    <div class="flex items-center gap-4 company-cell company-unit">
                                        <div class="w-14 h-14 bg-black/80 rounded-xl flex items-center justify-center shadow-[inset_0_2px_8px_rgba(0,0,0,0.8)] group-hover:shadow-[inset_0_2px_8px_color-mix(in_srgb,var(--brand-primary)_20%,transparent)] transition-all">
                                            <img src="img/companies/{{ company.type }}.png" class="w-8 h-8 drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)] group-hover:scale-110 transition-transform">
                                        </div>
                                        <div class="flex flex-col">
                                            <span class="uppercase tracking-widest text-[12px] font-black text-slate-200 group-hover:text-white transition-colors">{{ companyName }}</span>
                                            <div class="flex items-center gap-2 mt-1.5 flex-wrap">
                                                <span class="text-[10px] font-black px-2.5 py-0.5 rounded-md tracking-widest bg-black/50 border border-white/5 shadow-inner text-[color:var(--brand-primary)]">Q{{ company.quality }}</span>
                                                <span class="bg-black/50 border border-white/5 text-slate-500 text-[9px] font-black tracking-widest px-2 py-0.5 rounded shadow-inner">{{ t('companies.table.active') }}</span>
                                            </div>
                                            <span class="company-state is-{{ companyStatus }}">
                                                <i class="fa-solid {{ companyStatus == 'ready' ? 'fa-check' : 'fa-triangle-exclamation' }}"></i>
                                                {% if companyStatus == 'input_missing' %}Girdi eksik{% elseif companyStatus == 'workforce_missing' %}İş gücü eksik{% elseif companyStatus == 'control_required' %}Kontrol gerekli{% else %}Üretime hazır{% endif %}
                                            </span>
                                        </div>
                                    </div>
                                </td>

                                <td class="p-4 text-left" data-label="{{ t('companies.table.logistics') }}">
                                    <div class="flex flex-col gap-1.5">
                                        {% if consumeProduct > 0 %}
                                            <div class="tech-badge red w-fit">
                                                <span class="text-[12px]">-{{ consumeAmount }}</span>
                                                <img class="w-4 h-4 object-contain drop-shadow-sm" src="img/products/{{ consumeProduct }}.png">
                                            </div>
                                            <div class="text-[9px] font-bold text-slate-500">Stok: {{ ops.input_stock|default(0) }}</div>
                                        {% else %}
                                            <span class="bg-black/40 border border-white/5 px-3 py-1.5 rounded-lg text-slate-600 font-mono font-black tracking-widest text-[10px] shadow-inner w-fit">{{ t('companies.table.no_input') }}</span>
                                        {% endif %}
                                        <div class="text-[9px] font-black uppercase tracking-widest text-slate-500">
                                            {% if consumeProduct > 0 %}Girdi tüketir{% else %}{{ t('companies.table.no_input_label') }}{% endif %}
                                        </div>
                                    </div>
                                </td>

                                <td class="p-4 text-left" data-label="{{ t('companies.table.output') }}">
                                    <div class="flex flex-col gap-1.5">
                                        <div class="tech-badge green w-fit">
                                            <strong class="text-[14px]">+{{ outputAmount }}</strong>
                                            <img class="w-4 h-4 drop-shadow-sm" src="img/products/{{ outputProduct }}.png">
                                        </div>
                                        <div class="text-[9px] font-bold text-slate-500">Günlük kapasite: {{ ops.capacity|default(outputAmount) }}</div>
                                        <div class="text-[9px] font-bold text-slate-500">Çalışan: {{ ops.assigned_workers|default(0) }} / {{ ops.required_workers|default(0) }} · Boş: {{ ops.open_positions|default(0) }}</div>
                                        <div class="flex items-center gap-1.5">
                                            {% if consumeProduct > 0 %}
                                                <span class="text-[9px] font-black uppercase tracking-widest bg-red-950/30 text-red-400 px-2 py-0.5 rounded border border-red-500/20 shadow-inner">
                                                    <i class="fa-solid fa-arrow-down opacity-70"></i> -{{ consumeAmount }}
                                                </span>
                                            {% else %}
                                                <span class="text-[9px] font-black uppercase tracking-widest bg-black/40 text-slate-400 px-2 py-0.5 rounded border border-white/5 shadow-inner">
                                                    <i class="fa-solid fa-box-open opacity-70"></i> {{ t('companies.table.direct') }}
                                                </span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </td>

                                <td class="p-4 text-left" data-label="{{ t('companies.table.offer') }}">
                                    <div class="mb-2 text-[9px] font-black text-slate-400">Açık ilan: {{ ops.open_offer_count|default(0) }} · İhtiyaç: {{ ops.offer_gap|default(0) }}</div>
                                    {% if companyStatus == 'input_missing' %}
                                        <div class="mb-2">
                                            <div class="flex flex-wrap gap-x-3">
                                                <a href="{{ path_for('marketplace') }}" class="company-operation-link" aria-label="{{ companyName }} için eksik girdiyi markette ara"><i class="fa-solid fa-store"></i> Girdiyi ara</a>
                                            </div>
                                        </div>
                                    {% endif %}
                                    {% if companyStatus == 'control_required' %}
                                        <span class="text-[9px] font-black uppercase tracking-widest text-slate-500">Veri kontrolü gerekli</span>
                                    {% elseif offer %}
                                        <div class="company-offer-actions flex flex-col gap-2 w-full max-w-[140px]">
                                            <button
                                                type="button"
                                                class="finance-action-btn primary !py-2.5 !text-[9px] !rounded-lg w-full flex items-center justify-center gap-2"
                                                onclick="openOfferModal({
                                                    mode: 'edit',
                                                    companyId: {{ company.id }},
                                                    companyName: '{{ companyName|e('js') }}',
                                                    companyQuality: {{ company.quality }},
                                                    requiredSkill: {{ offer.required_skill|default(0) }},
                                                    salary: {{ offer.salary|default(0) }},
                                                    currency: '{{ offer.currency|default('')|upper|e('js') }}'
                                                })">
                                                <i class="fa-solid fa-pen-to-square"></i> {{ t('companies.table.edit') }}
                                            </button>
                                            <button
                                                type="button"
                                                class="finance-action-btn w-full !min-h-[30px] !py-2 !text-[9px] justify-center"
                                                onclick="cancelWorkOffer({{ company.id }})">
                                                <i class="fa-solid fa-xmark text-sm text-red-500 opacity-80"></i> {{ t('companies.table.remove') }}
                                            </button>
                                        </div>
                                    {% else %}
                                        <div class="company-offer-actions w-full max-w-[140px]">
                                            <button
                                                type="button"
                                                class="{{ companyStatus == 'input_missing' ? 'finance-action-btn' : 'btn-create-primary' }} !py-3 !text-[10px] !rounded-xl w-full flex items-center justify-center gap-2 shadow-lg"
                                                onclick="openOfferModal({
                                                    mode: 'create',
                                                    companyId: {{ company.id }},
                                                    companyName: '{{ companyName|e('js') }}',
                                                    companyQuality: {{ company.quality }},
                                                    requiredSkill: {{ company.quality }},
                                                    salary: 1.00,
                                                    currency: '{{ currencyList|length > 0 ? currencyList[0].code|upper|e('js') : '' }}'
                                                })">
                                                <i class="fa-solid fa-bullhorn text-sm opacity-80"></i> {{ t('companies.table.open_offer') }}
                                            </button>
                                        </div>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="py-16 text-center bg-black/30 rounded-2xl border border-white/5 shadow-[inset_0_2px_15px_rgba(0,0,0,0.6)] mt-4 relative z-10 flex flex-col items-center justify-center">
                <div class="w-16 h-16 bg-black/60 rounded-[14px] flex items-center justify-center mb-4 border border-white/5 shadow-inner">
                    <i class="fa-solid fa-industry text-2xl text-slate-500 opacity-60"></i>
                </div>
                <p class="text-slate-300 text-[13px] font-black uppercase tracking-[0.2em] mb-2 drop-shadow-sm">{{ t('companies.empty.title') }}</p>
                <p class="text-slate-500 text-[10px] font-bold uppercase tracking-[0.1em]">{{ t('companies.empty.subtitle') }}</p>
            </div>
        {% endif %}
    </div>

        </div>
        <div class="company-side-column">

    {# ===== FINANCE ===== #}
    {% if payrollSummary|length > 0 %}
    <section class="company-finance-section" aria-label="Finans görünümü">
        <div class="glass-panel p-6 relative company-payroll-panel {{ payrollSummary|length == 1 ? 'is-single' : '' }}">
            <div class="flex justify-between items-center mb-6 relative z-10 border-b border-white/5 pb-4">
                <h2 class="text-sm font-black text-slate-200 uppercase tracking-[0.25em] flex items-center gap-2 drop-shadow-sm">
                    <i class="fa-solid fa-vault text-[color:var(--brand-primary)]"></i> {{ t('companies.payroll.title') }}
                </h2>
            </div>

            <div class="payroll-layout">
                <div class="payroll-summary-wrap">
                    {% for summary in payrollSummary %}
                        <div class="payroll-summary-card">
                            <div class="payroll-summary-top">
                                <div>
                                    <div class="currency-tag">
                                        <span class="currency-dot" style="background-color: {{ summary.color ?: '#64748b' }}"></span>
                                        {{ summary.code }}
                                    </div>
                                    {% if summary.country_name %}
                                        <div class="currency-meta">{{ summary.country_name }}</div>
                                    {% endif %}
                                </div>
                                <span class="summary-status {{ summary.is_sufficient ? 'ok' : 'low' }}">
                                    <i class="fa-solid {{ summary.is_sufficient ? 'fa-check' : 'fa-exclamation' }}"></i>
                                    {{ summary.is_sufficient ? t('companies.payroll.ok') : t('companies.payroll.watch') }}
                                </span>
                            </div>

                            <div class="summary-list">
                                <div class="summary-line">
                                    <span>{{ t('companies.payroll.open_offer') }}</span>
                                    <strong>{{ summary.offer_count }}</strong>
                                </div>
                                <div class="summary-line">
                                    <span>{{ t('companies.payroll.daily_salary') }}</span>
                                    <strong>{{ summary.total_salary|number_format(2) }} <span class="text-[10px] text-slate-500">{{ summary.code }}</span></strong>
                                </div>
                                <div class="summary-line">
                                    <span>{{ t('companies.payroll.current_balance') }}</span>
                                    <strong>{{ summary.balance|number_format(2) }} <span class="text-[10px] text-slate-500">{{ summary.code }}</span></strong>
                                </div>
                                <div class="summary-line">
                                    <span>{{ t('companies.payroll.coverage_day') }}</span>
                                    <strong>{{ summary.coverage_days }}</strong>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>
    {% endif %}

    {# ===== RECENT ACTIVITY ===== #}
    <section class="company-activity-panel" aria-label="Son şirket hareketleri">
        <div class="glass-panel p-5">
            <div class="flex items-center justify-between gap-3 mb-3 border-b border-white/5 pb-3">
                <div>
                    <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] flex items-center gap-2">
                        <i class="fa-solid fa-clock-rotate-left text-[color:var(--brand-primary)]"></i> Son şirket hareketleri
                    </h2>
                    <p class="text-[9px] text-slate-400 mt-1">Tesis ve ilan kayıtlarından son hareketler.</p>
                </div>
            </div>
            <div class="company-activity-list">
                {% if recentActions|length > 0 %}
                    {% for action in recentActions %}
                        <div class="company-activity-item">
                            <span class="company-activity-dot" aria-hidden="true"></span>
                            <div>
                                <div class="company-activity-type">
                                    {% if action.type|default('') in ['Ilan acildi', 'İlan açıldı'] %}İş ilanı açıldı
                                    {% elseif action.type|default('') in ['Ilan guncellendi', 'İlan güncellendi'] %}İş ilanı güncellendi
                                    {% else %}{{ action.type|default('Şirket hareketi') }}{% endif %}
                                </div>
                                <div class="company-activity-label">{{ action.label|default('Tesis') }}</div>
                            </div>
                            {% if action.timestamp %}<time class="company-activity-time" datetime="{{ action.timestamp|e('html_attr') }}">{{ action.timestamp|date('d.m.Y H:i') }}</time>{% endif %}
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="company-attention-ok"><i class="fa-solid fa-circle-info"></i> Henüz gösterilecek bir şirket hareketi yok.</div>
                {% endif %}
            </div>
        </div>
    </section>
        </div>
    </div>
</div>

<script>
    const COMPANY_CURRENCIES = [
        {% for currency in currencyList %}
            {
                code: '{{ currency.code|upper|e('js') }}',
                name: '{{ (attribute(currency, 'name') is defined and attribute(currency, 'name') ? attribute(currency, 'name') : currency.code)|e('js') }}',
                minimum_wage: {{ attribute(currency, 'minimum_wage') is defined and attribute(currency, 'minimum_wage') is not null ? attribute(currency, 'minimum_wage') + 0 : 0 }},
                country_name: '{{ (attribute(currency, 'country_name') is defined and attribute(currency, 'country_name') ? attribute(currency, 'country_name') : '')|e('js') }}',
                color: '{{ (attribute(currency, 'color') is defined and attribute(currency, 'color') is not null ? attribute(currency, 'color') : '')|e('js') }}'
            }{% if not loop.last %},{% endif %}
        {% endfor %}
    ];

    window.companyFinanceBalanceMap = {
        {% for code, balance in currencyBalances|default({}) %}
            '{{ code|upper|e('js') }}': {{ balance + 0 }}{% if not loop.last %},{% endif %}
        {% endfor %}
    };

    window.companyQuickActions = {
        offers: [
            {% for offer in openOffers %}
                {
                    companyId: {{ offer.company|default(0) }},
                    companyName: '{{ offer.company_name|default('Tesis')|e('js') }}',
                    companyQuality: {{ offer.company_quality|default(0) }},
                    requiredSkill: {{ offer.required_skill|default(0) }},
                    salary: {{ offer.salary|default(0) }},
                    currency: '{{ offer.currency|default('')|upper|e('js') }}'
                }{% if not loop.last %},{% endif %}
            {% endfor %}
        ]
    };

    const companyI18n = {
        currencyMissing: '{{ t('companies.js.currency_missing')|e('js') }}',
        minimumWageMissing: '{{ t('companies.js.minimum_wage_missing')|e('js') }}',
        coverageMissing: '{{ t('companies.js.coverage_missing')|e('js') }}',
        coverageWaiting: '{{ t('companies.js.coverage_waiting')|e('js') }}',
        coverageCurrent: '{{ t('companies.js.coverage_current')|e('js') }}',
        selectOffer: '{{ t('companies.js.select_offer')|e('js') }}',
        continueText: '{{ t('companies.js.continue')|e('js') }}',
        cancelText: '{{ t('companies.js.cancel')|e('js') }}',
        chooseOffer: '{{ t('companies.js.choose_offer')|e('js') }}',
        editOfferTitle: '{{ t('companies.js.edit_offer_title')|e('js') }}',
        createOfferTitle: '{{ t('companies.js.create_offer_title')|e('js') }}',
        requiredSkill: '{{ t('companies.js.required_skill')|e('js') }}',
        requiredSkillHint: '{{ t('companies.js.required_skill_hint')|e('js') }}',
        dailySalary: '{{ t('companies.js.daily_salary')|e('js') }}',
        dailySalaryHint: '{{ t('companies.js.daily_salary_hint')|e('js') }}',
        currencyLabel: '{{ t('companies.js.currency')|e('js') }}',
        currencyHint: '{{ t('companies.js.currency_hint')|e('js') }}',
        saveChanges: '{{ t('companies.js.save_changes')|e('js') }}',
        publishOffer: '{{ t('companies.js.publish_offer')|e('js') }}',
        invalidSkill: '{{ t('companies.js.invalid_skill')|e('js') }}',
        invalidSalary: '{{ t('companies.js.invalid_salary')|e('js') }}',
        currencyRequired: '{{ t('companies.js.currency_required')|e('js') }}',
        salaryBelowMin: '{{ t('companies.js.salary_below_min')|e('js') }}',
        processing: '{{ t('companies.js.processing')|e('js') }}',
        actionFailed: '{{ t('companies.js.action_failed')|e('js') }}',
        offerUpdated: '{{ t('companies.js.offer_updated')|e('js') }}',
        offerPublished: '{{ t('companies.js.offer_published')|e('js') }}',
        offerUpdatedOk: '{{ t('companies.js.offer_updated_ok')|e('js') }}',
        offerPublishedOk: '{{ t('companies.js.offer_published_ok')|e('js') }}',
        connectionError: '{{ t('companies.js.connection_error')|e('js') }}',
        connectionErrorText: '{{ t('companies.js.connection_error_text')|e('js') }}',
        removeOffer: '{{ t('companies.js.remove_offer')|e('js') }}',
        removeOfferText: '{{ t('companies.js.remove_offer_text')|e('js') }}',
        removeText: '{{ t('companies.js.remove')|e('js') }}',
        abortText: '{{ t('companies.js.abort')|e('js') }}',
        removing: '{{ t('companies.js.removing')|e('js') }}',
        offerRemoveFailed: '{{ t('companies.js.offer_remove_failed')|e('js') }}',
        offerRemoved: '{{ t('companies.js.offer_removed')|e('js') }}',
        offerRemovedOk: '{{ t('companies.js.offer_removed_ok')|e('js') }}'
    };

    function getCurrencyMeta(code) {
        const normalized = (code || '').toUpperCase();
        for (let i = 0; i < COMPANY_CURRENCIES.length; i++) {
            if (COMPANY_CURRENCIES[i].code === normalized) {
                return COMPANY_CURRENCIES[i];
            }
        }
        return null;
    }

        function buildCurrencyOptions(selectedCurrency) {
        const normalizedSelected = (selectedCurrency || '').toUpperCase();
        let html = '';

        if (!COMPANY_CURRENCIES.length) {
            html += '<option value="">' + companyI18n.currencyMissing + '</option>';
            return html;
        }

        COMPANY_CURRENCIES.forEach(function(currency) {
            const selected = currency.code === normalizedSelected ? ' selected' : '';
            const countryPart = currency.country_name ? ' - ' + currency.country_name : '';
            html += '<option value="' + currency.code + '"' + selected + '>' + currency.code + countryPart + '</option>';
        });

        return html;
    }

        function renderMinimumWageInfo(currencyCode) {
        const meta = getCurrencyMeta(currencyCode);
        const salaryEl = document.getElementById('offer-salary');
        const salaryValue = salaryEl ? parseFloat(salaryEl.value || '0') : 0;

        if (!meta) {
            return companyI18n.minimumWageMissing;
        }

        const minWage = Number(meta.minimum_wage || 0);
        const ratio = minWage > 0 ? (salaryValue / minWage).toFixed(2) : '0.00';

        return 'Min. Ucret: ' + minWage.toFixed(2) + ' ' + meta.code + ' | Oran: ' + ratio + 'x';
    }

        function renderCoverageInfo(currencyCode) {
        const meta = getCurrencyMeta(currencyCode);
        const salaryEl = document.getElementById('offer-salary');
        const infoEl = document.getElementById('offer-coverage-info');

        if (!infoEl) return;
        if (!meta || !salaryEl) {
            infoEl.textContent = companyI18n.coverageMissing;
            return;
        }

        const salaryValue = parseFloat(salaryEl.value || '0');
        const balanceValue = parseFloat(salaryEl.getAttribute('data-balance') || '0');

        if (!(salaryValue > 0)) {
            infoEl.textContent = companyI18n.coverageWaiting;
            return;
        }

        const coverage = Math.floor(balanceValue / salaryValue);
        infoEl.textContent = companyI18n.coverageCurrent
            .replace(':balance', balanceValue.toFixed(2))
            .replace(':code', meta.code)
            .replace(':days', coverage);
    }

    function bindCurrencyInfo() {
        const currencyEl = document.getElementById('offer-currency');
        const salaryEl = document.getElementById('offer-salary');
        const infoEl = document.getElementById('offer-minimum-wage-info');

        if (!currencyEl || !infoEl) return;

        const updateInfo = function() {
            const meta = getCurrencyMeta(currencyEl.value);
            infoEl.textContent = renderMinimumWageInfo(currencyEl.value);

            if (meta && salaryEl) {
                const min = Number(meta.minimum_wage || 0);
                salaryEl.setAttribute('min', min > 0 ? min.toFixed(2) : '0.01');
            }
            renderCoverageInfo(currencyEl.value);
        };

        currencyEl.addEventListener('change', updateInfo);

        if (salaryEl) {
            salaryEl.addEventListener('input', function() {
                infoEl.textContent = renderMinimumWageInfo(currencyEl.value);
                renderCoverageInfo(currencyEl.value);
            });
        }
        updateInfo();
    }

    $(function() {
        if (typeof peque !== 'undefined' && peque.company) {
            peque.company.init = function() {};
        }
    });

        function openOfferQuickActionPicker() {
        const quickState = window.companyQuickActions || {};
        const offers = Array.isArray(quickState.offers) ? quickState.offers : [];

        if (!offers.length) return;

        if (offers.length === 1) {
            openOfferModal({
                mode: 'edit', companyId: offers[0].companyId, companyName: offers[0].companyName,
                companyQuality: offers[0].companyQuality, requiredSkill: offers[0].requiredSkill,
                salary: offers[0].salary, currency: offers[0].currency
            });
            return;
        }

        const selectOptions = {};
        offers.forEach(function(offer) {
            selectOptions[String(offer.companyId)] = offer.companyName + ' (Q' + offer.companyQuality + ') - ' + Number(offer.salary || 0).toFixed(2) + ' ' + (offer.currency || '');
        });

        Swal.fire({
            title: companyI18n.selectOffer,
            input: 'select',
            inputOptions: selectOptions,
            showCancelButton: true,
            confirmButtonText: companyI18n.continueText,
            cancelButtonText: companyI18n.cancelText,
            customClass: {
                popup: 'cyber-modal-popup',
                title: 'cyber-modal-title',
                confirmButton: 'cyber-confirm-btn',
                cancelButton: 'finance-action-btn !text-[11px] !py-3',
                actions: 'gap-3 mt-6',
                input: 'cyber-input-field mt-4'
            },
            buttonsStyling: false,
            background: '#0a0c14',
            color: '#f8fafc',
            didOpen: function() {
                const selectEl = Swal.getInput();
                if (!selectEl) return;
                Array.from(selectEl.options || []).forEach(function(option) {
                    option.style.backgroundColor = '#0f172a';
                    option.style.color = '#f8fafc';
                });
            },
            inputValidator: function(value) {
                if (!value) return companyI18n.chooseOffer;
                return null;
            }
        }).then(function(result) {
            if (!result.isConfirmed) return;
            const selectedOffer = offers.find(function(offer) { return String(offer.companyId) === String(result.value); });
            if (!selectedOffer) return;
            openOfferModal({
                mode: 'edit', companyId: selectedOffer.companyId, companyName: selectedOffer.companyName,
                companyQuality: selectedOffer.companyQuality, requiredSkill: selectedOffer.requiredSkill,
                salary: selectedOffer.salary, currency: selectedOffer.currency
            });
        });
    }

        function openOfferModal(config) {
        const mode = config.mode || 'create';
        const companyId = parseInt(config.companyId, 10) || 0;
        const companyName = config.companyName || '';
        const companyQuality = parseInt(config.companyQuality, 10) || 0;
        const requiredSkill = typeof config.requiredSkill !== 'undefined'
            ? parseInt(config.requiredSkill, 10)
            : (typeof config.skill !== 'undefined' ? parseInt(config.skill, 10) : companyQuality);
        const salary = typeof config.salary !== 'undefined'
            ? parseFloat(config.salary)
            : (typeof config.money !== 'undefined' ? parseFloat(config.money) : 1.00);
        const fallbackCurrency = COMPANY_CURRENCIES.length ? COMPANY_CURRENCIES[0].code : '';
        const currency = (config.currency || fallbackCurrency).toUpperCase();
        const balanceMap = window.companyFinanceBalanceMap || {};
        const startingBalance = balanceMap[currency] ? Number(balanceMap[currency]) : 0;
        const isEdit = mode === 'edit';

        Swal.fire({
            title: isEdit
                ? '<i class="fa-solid fa-pen-to-square text-[color:var(--brand-primary)] mr-2"></i> ' + companyI18n.editOfferTitle
                : '<i class="fa-solid fa-bullhorn text-[color:var(--brand-primary)] mr-2"></i> ' + companyI18n.createOfferTitle,
            html: `
                <div style="text-align:left; margin-top:20px;">
                    <div style="font-size:11px; font-weight:900; letter-spacing:.15em; text-transform:uppercase; color:#f8fafc; margin-bottom:20px; padding-bottom:15px; border-bottom:1px solid rgba(255,255,255,0.05); display:flex; align-items:center; gap:10px;">
                        <div style="width:28px; height:28px; border-radius:8px; background:color-mix(in srgb, var(--brand-primary) 15%, transparent); display:flex; align-items:center; justify-content:center; box-shadow:inset 0 2px 5px rgba(0,0,0,0.5);"><i class="fa-solid fa-industry text-[color:var(--brand-primary)] text-xs"></i></div>
                        ${companyName} <span style="color:#94a3b8;">/</span> <span style="color:var(--brand-primary); background:color-mix(in srgb, var(--brand-primary) 10%, transparent); padding:2px 8px; border-radius:6px; font-size:10px; border: 1px solid color-mix(in srgb, var(--brand-primary) 20%, transparent);">Q${companyQuality}</span>
                    </div>

                    <div style="margin-bottom:20px;">
                        <label for="offer-required-skill" class="swal-tech-label">${companyI18n.requiredSkill}</label>
                        <div class="swal-tech-help">${companyI18n.requiredSkillHint}</div>
                        <input id="offer-required-skill" type="number" min="0" value="${isNaN(requiredSkill) ? 0 : requiredSkill}" class="cyber-input-field w-full">
                    </div>

                    <div style="margin-bottom:20px;">
                        <label for="offer-salary" class="swal-tech-label">${companyI18n.dailySalary}</label>
                        <div class="swal-tech-help">${companyI18n.dailySalaryHint}</div>
                        <input id="offer-salary" type="number" min="0.01" step="0.01" value="${isNaN(salary) ? 1 : salary}" data-balance="${startingBalance}" class="cyber-input-field w-full">
                    </div>

                    <div style="margin-bottom:10px;">
                        <label for="offer-currency" class="swal-tech-label">${companyI18n.currencyLabel}</label>
                        <div class="swal-tech-help">${companyI18n.currencyHint}</div>
                        <div class="relative">
                            <select id="offer-currency" class="cyber-input-field w-full pr-10">
                                ${buildCurrencyOptions(currency)}
                            </select>
                            <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none text-xs"></i>
                        </div>
                        <div class="p-3 mt-4 rounded-xl bg-black/40 border border-white/5 shadow-[inset_0_2px_8px_rgba(0,0,0,0.5)]">
                            <div id="offer-minimum-wage-info" class="swal-tech-help dynamic !mt-0 !text-[10px] text-yellow-500 font-black"></div>
                            <div id="offer-coverage-info" class="swal-tech-help dynamic !mt-1.5 !text-[10px] text-[color:var(--brand-primary)] font-black"></div>
                        </div>
                    </div>
                </div>
            `,
            background: '#0a0c14',
            color: '#f8fafc',
            width: 500,
            showCancelButton: true,
            confirmButtonText: isEdit ? companyI18n.saveChanges : companyI18n.publishOffer,
            cancelButtonText: companyI18n.cancelText,
            customClass: {
                popup: 'cyber-modal-popup',
                title: 'cyber-modal-title',
                confirmButton: 'cyber-confirm-btn',
                cancelButton: 'finance-action-btn !text-[11px] !py-3',
                actions: 'gap-4 mt-6 w-full flex-col-reverse md:flex-row justify-end',
            },
            buttonsStyling: false,
            focusConfirm: false,
            didOpen: () => {
                bindCurrencyInfo();
            },
            preConfirm: () => {
                const requiredSkillValue = parseInt(document.getElementById('offer-required-skill').value, 10);
                const salaryValue = parseFloat(document.getElementById('offer-salary').value);
                const currencyValue = document.getElementById('offer-currency').value.trim().toUpperCase();
                const currencyMeta = getCurrencyMeta(currencyValue);
                const minimumWage = currencyMeta ? Number(currencyMeta.minimum_wage || 0) : 0;

                if (isNaN(requiredSkillValue) || requiredSkillValue < 0) {
                    Swal.showValidationMessage(companyI18n.invalidSkill);
                    return false;
                }

                if (isNaN(salaryValue) || salaryValue <= 0) {
                    Swal.showValidationMessage(companyI18n.invalidSalary);
                    return false;
                }

                if (!currencyValue) {
                    Swal.showValidationMessage(companyI18n.currencyRequired);
                    return false;
                }

                if (currencyMeta && salaryValue < minimumWage) {
                    Swal.showValidationMessage(
                        companyI18n.salaryBelowMin
                            .replace(':amount', minimumWage.toFixed(2))
                            .replace(':code', currencyValue)
                    );
                    return false;
                }

                return {
                    mode: mode,
                    company_id: companyId,
                    required_skill: requiredSkillValue,
                    salary: salaryValue,
                    currency: currencyValue
                };
            }
        }).then((result) => {
            if (!result.isConfirmed) {
                return;
            }

            const endpoint = result.value.mode === 'edit'
                ? "{{ base_url() }}/api/company/work-offer/update"
                : "{{ base_url() }}/api/company/work-offer/create";

            Swal.fire({
                title: '<i class="fa-solid fa-spinner fa-spin text-[color:var(--brand-primary)] mr-2"></i> ' + companyI18n.processing,
                showConfirmButton: false,
                allowOutsideClick: false,
                background: '#0a0c14', color: '#f8fafc',
                customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title' }
            });

            $.ajax({
                url: endpoint,
                type: "POST",
                data: {
                    company_id: result.value.company_id,
                    required_skill: result.value.required_skill,
                    salary: result.value.salary,
                    currency: result.value.currency,
                    csrf_token: $('meta[name="csrf-token"]').attr('content')
                },
                success: function(res) {
                    if (typeof res === 'string') { try { res = JSON.parse(res); } catch (e) {} }

                    if (res.error) {
                        Swal.fire({
                            icon: 'error',
                            title: '<i class="fa-solid fa-ban text-red-500 mr-2"></i> ' + companyI18n.actionFailed,
                            text: res.message,
                            background: '#0a0c14', color: '#f8fafc',
                            customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title', confirmButton: 'cyber-confirm-btn' },
                            buttonsStyling: false
                        });
                    } else {
                        Swal.fire({
                            icon: 'success',
                            title: result.value.mode === 'edit'
                                ? '<i class="fa-solid fa-check-circle text-[color:var(--brand-primary)] mr-2"></i> ' + companyI18n.offerUpdated
                                : '<i class="fa-solid fa-check-circle text-[color:var(--brand-primary)] mr-2"></i> ' + companyI18n.offerPublished,
                            text: res.message || (result.value.mode === 'edit' ? companyI18n.offerUpdatedOk : companyI18n.offerPublishedOk),
                            background: '#0a0c14', color: '#f8fafc',
                            timer: 2000,
                            showConfirmButton: false,
                            customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title' }
                        }).then(() => location.reload());
                    }
                },
                error: function() {
                    Swal.fire({
                        icon: 'error',
                        title: '<i class="fa-solid fa-plug-circle-xmark text-red-500 mr-2"></i> ' + companyI18n.connectionError,
                        text: companyI18n.connectionErrorText,
                        background: '#0a0c14', color: '#f8fafc',
                        customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title', confirmButton: 'cyber-confirm-btn' },
                        buttonsStyling: false
                    });
                }
            });
        });
    }

    function cancelWorkOffer(companyId) {
        Swal.fire({
            icon: 'warning',
            title: '<i class="fa-solid fa-triangle-exclamation text-yellow-500 mr-2"></i> ' + companyI18n.removeOffer,
            text: companyI18n.removeOfferText,
            background: '#0a0c14', color: '#f8fafc',
            showCancelButton: true,
            confirmButtonText: companyI18n.removeText,
            cancelButtonText: companyI18n.abortText,
            customClass: {
                popup: 'cyber-modal-popup',
                title: 'cyber-modal-title',
                confirmButton: 'cyber-confirm-btn !bg-red-600',
                cancelButton: 'finance-action-btn !text-[11px] !py-3',
                actions: 'gap-4 mt-6 w-full flex-col-reverse md:flex-row justify-center'
            },
            buttonsStyling: false
        }).then((result) => {
            if (!result.isConfirmed) return;

            Swal.fire({
                title: '<i class="fa-solid fa-spinner fa-spin text-[color:var(--brand-primary)] mr-2"></i> ' + companyI18n.removing,
                showConfirmButton: false,
                allowOutsideClick: false,
                background: '#0a0c14', color: '#f8fafc',
                customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title' }
            });

            $.ajax({
                url: "{{ base_url() }}/api/company/work-offer/cancel",
                type: "POST",
                data: {
                    company_id: companyId,
                    csrf_token: $('meta[name="csrf-token"]').attr('content')
                },
                success: function(res) {
                    if (typeof res === 'string') { try { res = JSON.parse(res); } catch (e) {} }

                    if (res.error) {
                        Swal.fire({
                            icon: 'error',
                            title: '<i class="fa-solid fa-ban text-red-500 mr-2"></i> ' + companyI18n.actionFailed,
                            text: res.message || companyI18n.offerRemoveFailed,
                            background: '#0a0c14', color: '#f8fafc',
                            customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title', confirmButton: 'cyber-confirm-btn' },
                            buttonsStyling: false
                        });
                    } else {
                        Swal.fire({
                            icon: 'success',
                            title: '<i class="fa-solid fa-check-circle text-[color:var(--brand-primary)] mr-2"></i> ' + companyI18n.offerRemoved,
                            text: res.message || companyI18n.offerRemovedOk,
                            background: '#0a0c14', color: '#f8fafc',
                            timer: 1600,
                            showConfirmButton: false,
                            customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title' }
                        }).then(() => location.reload());
                    }
                },
                error: function() {
                    Swal.fire({
                        icon: 'error',
                        title: '<i class="fa-solid fa-plug-circle-xmark text-red-500 mr-2"></i> ' + companyI18n.connectionError,
                        text: companyI18n.connectionErrorText,
                        background: '#0a0c14', color: '#f8fafc',
                        customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title', confirmButton: 'cyber-confirm-btn' },
                        buttonsStyling: false
                    });
                }
            });
        });
    }

    (function() {
        const table = document.getElementById('my-companies');
        const statusFilter = document.getElementById('company-filter-status');
        const sectorFilter = document.getElementById('company-filter-sector');
        const qualityFilter = document.getElementById('company-filter-quality');
        const workforceFilter = document.getElementById('company-filter-workforce');
        const inputFilter = document.getElementById('company-filter-input');
        const offerFilter = document.getElementById('company-filter-offer');
        const nameFilter = document.getElementById('company-filter-name');
        const sortFilter = document.getElementById('company-filter-sort');
        const clearFilter = document.getElementById('company-filter-clear');
        if (!table || !statusFilter || !sectorFilter || !qualityFilter || !workforceFilter || !inputFilter || !offerFilter || !nameFilter || !sortFilter || !clearFilter) return;

        const rows = Array.from(table.querySelectorAll('tbody .v2-table-row'));
        const tbody = table.querySelector('tbody');
        const emptyState = document.createElement('div');
        emptyState.className = 'company-filter-empty';
        emptyState.setAttribute('role', 'status');
        emptyState.setAttribute('aria-live', 'polite');
        emptyState.textContent = 'Bu filtrelerle eşleşen tesis bulunamadı.';
        table.parentElement.appendChild(emptyState);

        const addOptions = function(select, values, prefix) {
            Array.from(values).sort((a, b) => a.localeCompare(b, 'tr')).forEach(function(value) {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = prefix ? prefix + value : value;
                select.appendChild(option);
            });
        };

        addOptions(sectorFilter, new Set(rows.map(row => row.dataset.companySector)), '');
        addOptions(qualityFilter, new Set(rows.map(row => row.dataset.companyQuality)), 'Q');

        const applyFilters = function() {
            const status = statusFilter.value;
            const sector = sectorFilter.value;
            const quality = qualityFilter.value;
            const workforce = workforceFilter.value;
            const input = inputFilter.value;
            const offer = offerFilter.value;
            const name = nameFilter.value.trim().toLocaleLowerCase('tr-TR');
            let visibleCount = 0;

            rows.forEach(function(row) {
                const matches = (status === 'all' || row.dataset.companyStatus === status)
                    && (sector === 'all' || row.dataset.companySector === sector)
                    && (quality === 'all' || row.dataset.companyQuality === quality)
                    && (workforce === 'all' || row.dataset.companyWorkforce === workforce)
                    && (input === 'all' || row.dataset.companyInput === input)
                    && (offer === 'all' || row.dataset.companyOffer === offer)
                    && (!name || row.dataset.companyName.indexOf(name) !== -1);
                row.hidden = !matches;
                if (matches) visibleCount++;
            });

            const sortMode = sortFilter.value;
            rows.sort(function(a, b) {
                if (sortMode === 'quality') {
                    return Number(b.dataset.companyQuality) - Number(a.dataset.companyQuality);
                }
                if (sortMode === 'capacity') {
                    return Number(b.dataset.companyCapacity) - Number(a.dataset.companyCapacity);
                }
                if (sortMode === 'newest') {
                    return b.dataset.companyCreated.localeCompare(a.dataset.companyCreated);
                }
                if (sortMode === 'vacancies') {
                    return Number(b.dataset.companyVacancies) - Number(a.dataset.companyVacancies);
                }
                if (sortMode === 'status') {
                    const rank = { input_missing: 0, workforce_missing: 1, control_required: 2, ready: 3 };
                    return (rank[a.dataset.companyStatus] ?? 2) - (rank[b.dataset.companyStatus] ?? 2);
                }
                return a.dataset.companyName.localeCompare(b.dataset.companyName, 'tr');
            }).forEach(function(row) {
                tbody.appendChild(row);
            });

            emptyState.style.display = visibleCount ? 'none' : 'block';
        };

        [statusFilter, sectorFilter, qualityFilter, workforceFilter, inputFilter, offerFilter, sortFilter].forEach(function(control) {
            control.addEventListener('change', applyFilters);
        });
        nameFilter.addEventListener('input', applyFilters);
        clearFilter.addEventListener('click', function() {
            statusFilter.value = 'all';
            sectorFilter.value = 'all';
            qualityFilter.value = 'all';
            workforceFilter.value = 'all';
            inputFilter.value = 'all';
            offerFilter.value = 'all';
            nameFilter.value = '';
            sortFilter.value = 'status';
            applyFilters();
        });
    })();
</script>
{% endblock %}

