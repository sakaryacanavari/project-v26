{% extends "common/base.html.twig" %}

{% block content %}
{% set displayAvatar = citizen.avatar ?: (base_url() ~ '/img/avatars/' ~ citizen.id ~ '.png') %}
{% set badgeSlots = citizen.badges|slice(0, 4) %}
{% set medalSlots = citizen.achievements|slice(0, 10) %}

{# Profil Asıl Tema V15: "Gamified Elite" (Progress Lines Yok - Saf Tok Sayılar) #}
<div class="mx-auto w-full max-w-none space-y-6 px-2 xl:px-0">
    <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_300px]">
        
        {# ==== SAĞ KOLON (V15 STAT & KİMLİK ÜNİTESİ) ==== #}
        <aside class="space-y-6 xl:order-2 flex flex-col">
            
            {# ========================================== #}
            {# 1. OYUNCU KART / ABOUT (GLASS PANEL)       #}
            {# ========================================== #}
            <section class="glass-panel overflow-hidden flex-shrink-0">
                <div class="flex items-center justify-between border-b border-light/5 bg-black/20 px-6 py-4">
                    <div class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">
                        <i class="fa-solid fa-address-card text-[color:var(--brand-primary)] drop-shadow-[0_0_8px_color-mix(in_srgb,var(--brand-primary)_40%,transparent)]"></i>
                        {{ t('citizen.profile.about') }}
                    </div>
                    <div class="flex items-center gap-2 rounded-full bg-emerald-500/10 px-2.5 py-1 text-[9px] font-black uppercase tracking-widest text-emerald-400 ring-1 ring-emerald-500/30">
                        <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-400 shadow-[0_0_6px_theme(colors.emerald.400)]"></span>
                        {{ t('citizen.profile.active') }}
                    </div>
                </div>
                
                <div class="p-6 flex flex-col items-center">
                    <div class="relative mx-auto flex h-[112px] w-[112px] items-center justify-center rounded-[20px] p-1 border border-[color:var(--brand-primary)]/50 transition-all duration-300 hover:scale-105 hover:border-[color:var(--brand-primary)] hover:shadow-[0_0_20px_color-mix(in_srgb,var(--brand-primary)_40%,transparent)] bg-black/20 cursor-pointer">
                        <img src="{{ displayAvatar }}" onerror="this.src='{{ base_url() }}/img/default_avatar.jpg'" class="h-full w-full rounded-[16px] object-cover transition-all" alt="{{ citizen.nick }}">
                    </div>
                    
                    <div class="mt-5 text-center">
                        <div class="text-[17px] font-black text-white tracking-widest uppercase drop-shadow-md">{{ citizen.nick }}</div>
                        <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-1 opacity-80">{{ t('base.sidebar.operator')|default('OPERATOR') }}</div>
                    </div>
                </div>
                
                {% if citizen.bio %}
                    <div class="border-t border-white/5 bg-black/10 px-6 py-4 text-center text-[11px] font-medium leading-relaxed text-slate-300 italic">
                        "{{ citizen.bio }}"
                    </div>
                {% endif %}
                
                <div class="bg-black/20 p-5 border-t border-white/5 text-center">
                    <a href="{{ path_for('messagesThread', { uid: citizen.id }) }}" class="inline-flex w-full justify-center items-center gap-2 rounded-xl bg-[linear-gradient(135deg,color-mix(in_srgb,var(--brand-primary)_90%,white),var(--brand-primary))] px-4 py-3 text-[11px] font-black uppercase tracking-[0.15em] text-black shadow-[0_4px_15px_color-mix(in_srgb,var(--brand-primary)_30%,transparent)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_25px_color-mix(in_srgb,var(--brand-primary)_50%,transparent)] active:scale-95">
                        <i class="fa-solid fa-paper-plane text-black/90"></i> {{ t('citizen.profile.message') }}
                    </a>
                </div>

                {# TAŞINAN SON BAŞARILAR (ELITE BADGES) KISMI #}
                <div class="bg-black/30 p-5 text-center border-t border-white/5 relative">
                    <div class="absolute inset-0 bg-amber-500/5 mix-blend-overlay"></div>
                    <div class="relative z-10 flex items-center justify-center gap-2 text-[9px] font-bold uppercase tracking-widest text-[#94a3b8] mb-4"><i class="fa-solid fa-crown opacity-50 text-amber-500"></i> {{ t('citizen.profile.achievements_title') }}</div>
                    
                    <div class="relative z-10 flex items-center justify-center gap-3 flex-wrap">
                        {% for badge in badgeSlots %}
                            <div class="group relative flex h-12 w-12 cursor-pointer flex-col items-center justify-center rounded-xl border border-white/5 bg-gradient-to-br from-black/40 to-black/10 transition-all duration-300 hover:-translate-y-1 hover:border-amber-500/40 hover:bg-black/40 hover:shadow-[0_8px_20px_rgba(245,158,11,0.2)] z-10 hover:z-[100]">
                                <div class="absolute inset-0 bg-amber-500/10 blur-md rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                                <i class="fa-solid {{ badge.icon }} text-[18px] text-amber-500/90 drop-shadow-[0_2px_5px_rgba(0,0,0,0.5)] transition-all duration-300 group-hover:scale-[1.15] group-hover:text-amber-400 group-hover:drop-shadow-[0_0_10px_theme(colors.amber.400/80)] relative z-10"></i>
                                
                                {# V15 Tooltip Fixed #}
                                <div class="pointer-events-none absolute bottom-[calc(100%+8px)] left-1/2 w-max min-w-[90px] -translate-x-1/2 translate-y-3 rounded-lg border border-white/10 bg-black/95 backdrop-blur-xl px-3 py-2 text-center opacity-0 shadow-[0_15px_30px_rgba(0,0,0,0.9)] transition-all duration-200 ease-out group-hover:translate-y-0 group-hover:opacity-100 z-50">
                                    <div class="absolute -bottom-[4px] left-1/2 -translate-x-1/2 w-2.5 h-2.5 rotate-45 border-r border-b border-white/10 bg-black/95"></div>
                                    <div class="relative font-bold text-amber-400 uppercase tracking-widest text-[9px] drop-shadow-md whitespace-nowrap">{{ badge.label }}</div>
                                </div>
                            </div>
                        {% else %}
                            <div class="p-3 text-center text-[9px] uppercase tracking-widest font-bold text-slate-600 bg-black/10 rounded-xl border border-white/5 border-dashed w-full">
                                {{ t('citizen.profile.no_badge_records') }}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </section>

            {# ========================================== #}
            {# 2. STATS (TOK VE TEXT-TABANLI VERİLER)     #}
            {# ========================================== #}
            <section class="glass-panel overflow-hidden flex-shrink-0">
                <div class="flex items-center gap-2 border-b border-light/5 bg-black/20 px-6 py-4 text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">
                    <i class="fa-solid fa-chart-line text-[color:var(--brand-primary)]"></i> {{ t('citizen.profile.stats') }}
                </div>
                
                <div class="flex flex-col">
                    {# LEVEL #}
                    <div class="px-6 py-4 border-b border-white/5 hover:bg-white/5 transition-colors">
                        <div class="flex items-center justify-between">
                            <span class="text-[9px] font-bold uppercase tracking-widest text-slate-500"><i class="fa-solid fa-star text-amber-500/80 mr-1.5 opacity-80"></i> {{ t('citizen.profile.level') }}</span>
                            <span class="font-black text-white text-[15px] drop-shadow-sm px-2 py-0.5 rounded-lg bg-white/5 ring-1 ring-white/10">{{ citizen.level }}</span>
                        </div>
                    </div>

                    {# ECO XP & SKILL (GRID) #}
                    <div class="grid grid-cols-2 divide-x divide-white/5 border-b border-white/5 bg-black/10">
                        <div class="px-6 py-4 hover:bg-black/20 transition-colors">
                            <div class="text-[9px] font-bold uppercase tracking-widest text-slate-500 mb-1.5">{{ t('citizen.profile.stat_economic_xp') }}</div>
                            <div class="font-black text-cyan-400 text-[14px]">{{ citizen.economic_xp }}</div>
                        </div>
                        <div class="px-6 py-4 hover:bg-black/20 transition-colors">
                            <div class="text-[9px] font-bold uppercase tracking-widest text-slate-500 mb-1.5">{{ t('citizen.profile.stat_economic_skill') }}</div>
                            <div class="font-black text-white text-[14px]">{{ citizen.economic_skill }}</div>
                        </div>
                    </div>

                    {# STRENGTH VE HASAR (LISTE) #}
                    <div class="px-6 py-4 border-b border-white/5 hover:bg-white/5 transition-colors">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2"><i class="fa-solid fa-dumbbell text-[color:var(--brand-primary)] opacity-80"></i> <span class="text-[9px] font-bold uppercase tracking-widest text-slate-400">{{ t('citizen.profile.stat_strength') }}</span></div>
                            <span class="font-black text-white text-[14px]">{{ citizen.strength|number_format(2) }}</span>
                        </div>
                    </div>
                    <div class="px-6 py-4 border-b border-white/5 hover:bg-white/5 transition-colors bg-black/10">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2"><i class="fa-solid fa-crosshairs text-rose-500 opacity-80"></i> <span class="text-[9px] font-bold uppercase tracking-widest text-slate-400">{{ t('citizen.profile.war_total_damage') }}</span></div>
                            <span class="font-black text-rose-400 text-[14px] drop-shadow-[0_0_8px_theme(colors.rose.400/20)]">{{ citizen.war.total_damage|number_format(0, '.', ',') }}</span>
                        </div>
                    </div>

                    {# LOkASYON (FLAG) #}
                    <div class="px-6 py-4 bg-black/20 hover:bg-black/30 transition-colors">
                        <div class="flex items-center justify-between">
                            <span class="text-[9px] font-bold uppercase tracking-widest text-slate-500">{{ t('base.sidebar.region') }}</span>
                            <span class="flex items-center gap-2 font-black text-white text-[11px] uppercase tracking-wide">
                                {% if citizen.country_id > 0 %}<img src="{{ base_url() }}/img/flags/{{ citizen.country_id }}.png" class="h-3 w-4 rounded-sm shadow-[0_2px_5px_rgba(0,0,0,0.5)]" alt="flag">{% endif %}
                                {{ citizen.region_name ?: '-' }}
                            </span>
                        </div>
                    </div>
                </div>
            </section>



            {# ========================================== #}
            {# 4. KARİYER VE GİRİŞİM TABLOLARI (COMPANIES)#}
            {# ========================================== #}
            <section class="glass-panel overflow-hidden flex-shrink-0">
                <div class="flex items-center gap-2 border-b border-light/5 bg-black/20 px-6 py-4 text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">
                    <i class="fa-solid fa-building text-[color:var(--brand-primary)]"></i> {{ t('citizen.profile.enterprise') }}
                </div>
                
                <div class="divide-y divide-white/5 bg-black/5">
                    {# Political Party #}
                    <div class="relative flex items-center gap-4 p-5 transition-all duration-300 hover:bg-black/20 group border-l-[3px] border-transparent hover:border-[color:var(--brand-primary)]">
                        <div class="absolute inset-0 bg-gradient-to-r from-[color-mix(in_srgb,var(--brand-primary)_10%,transparent)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[12px] bg-black/40 ring-1 ring-white/10 shadow-[inset_0_2px_10px_rgba(255,255,255,0.05)] transition-all group-hover:ring-white/20 group-hover:shadow-[0_5px_15px_rgba(0,0,0,0.5)] relative z-10">
                            {% if citizen.party_logo_url %}<img src="{{ citizen.party_logo_url }}" class="h-8 w-8 object-cover rounded-md opacity-90 group-hover:opacity-100">{% else %}<i class="fa-solid fa-flag text-slate-400 group-hover:text-slate-200 transition-colors"></i>{% endif %}
                        </div>
                        <div class="min-w-0 flex-1 relative z-10">
                            <div class="text-[8px] font-bold uppercase tracking-widest text-slate-500 mb-1">{{ t('citizen.profile.political_party') }}</div>
                            <div class="truncate font-black text-white text-[12px] group-hover:text-[color:var(--brand-primary)] transition-colors">{{ citizen.party_name ?: '-' }}</div>
                        </div>
                    </div>
                    
                    {# Newspaper #}
                    <div class="relative flex items-center gap-4 p-5 transition-all duration-300 hover:bg-black/20 group border-l-[3px] border-transparent hover:border-fuchsia-500">
                        <div class="absolute inset-0 bg-gradient-to-r from-fuchsia-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[12px] bg-black/40 ring-1 ring-white/10 shadow-[inset_0_2px_10px_rgba(255,255,255,0.05)] transition-all group-hover:ring-fuchsia-500/30 group-hover:shadow-[0_5px_15px_theme(colors.fuchsia.500/20)] relative z-10">
                            <i class="fa-solid fa-newspaper text-slate-400 group-hover:text-fuchsia-400 transition-colors"></i>
                        </div>
                        <div class="min-w-0 flex-1 relative z-10">
                            <div class="text-[8px] font-bold uppercase tracking-widest text-slate-500 mb-1">{{ t('citizen.profile.economy_newspaper') }}</div>
                            <div class="truncate font-black text-white text-[12px]">{{ citizen.economy.has_newspaper ? citizen.economy.newspaper_name : '-' }}</div>
                        </div>
                    </div>
                    
                    {# Working At #}
                    <div class="relative flex items-center gap-4 p-5 transition-all duration-300 hover:bg-black/20 group bg-black/10 border-l-[3px] border-transparent hover:border-emerald-500">
                        <div class="absolute inset-0 bg-gradient-to-r from-emerald-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[12px] bg-black/40 ring-1 ring-white/10 shadow-[inset_0_2px_10px_rgba(255,255,255,0.05)] transition-all group-hover:ring-emerald-500/40 group-hover:shadow-[0_5px_15px_theme(colors.emerald.500/20)] relative z-10">
                            <i class="fa-solid fa-briefcase text-slate-400 group-hover:text-emerald-400 transition-colors"></i>
                        </div>
                        <div class="min-w-0 flex-1 relative z-10">
                            <div class="text-[8px] font-bold uppercase tracking-widest text-slate-500 mb-1">{{ t('citizen.profile.economy_active_job') }}</div>
                            <div class="truncate font-black text-white text-[12px]">{{ citizen.economy.active_job_name ?: '-' }}</div>
                            {% if citizen.economy.active_job_name %}
                            <div class="text-[9px] font-bold text-emerald-400 mt-1 opacity-90">{{ citizen.economy.active_job_salary|number_format(2) }} {{ citizen.economy.active_job_currency }}</div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </section>
        </aside>

        {# ==== ORTA KOLON (V15 GÖNDERİLER, PERFORMANS, MADALYALAR, EKİPMAN) ==== #}
        <div class="space-y-6 xl:order-1 min-w-0 flex flex-col">
            
            {# ========================================== #}
            {# SİLAH & EKİPMAN ENVANTERİ (SAHTE/STATİK PANEL - V15 Premium) #}
            {# ========================================== #}
            <section class="glass-panel overflow-hidden flex-shrink-0 relative group">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.02)_0%,transparent_100%)] mix-blend-overlay"></div>
                <div class="border-b border-light/5 bg-black/30 px-6 py-4 flex items-center justify-between text-[11px] font-bold uppercase tracking-widest text-slate-300">
                    <div class="flex items-center gap-2"><i class="fa-solid fa-gun text-cyan-400/80 drop-shadow-[0_0_5px_theme(colors.cyan.400/40)]"></i> {{ t('citizen.profile.combat_equipment_beta') }}</div>
                    <span class="bg-indigo-500/10 text-indigo-400 px-2 py-0.5 rounded-full text-[9px] border border-indigo-500/20 ring-1 ring-indigo-500/40 drop-shadow-[0_0_8px_theme(colors.indigo.500/30)]">{{ t('citizen.profile.gear_score') }}: 8,420</span>
                </div>

                <div class="grid lg:grid-cols-[1.2fr_1fr] divide-y lg:divide-y-0 lg:divide-x divide-white/5 bg-black/10">
                    
                    {# Sol Taraf: Oyuncu Silueti ve Slotlar #}
                    <div class="relative p-6 flex items-center justify-center min-h-[280px] overflow-hidden">
                        {# Siber Radar/Hedef Hologramı (Yavaş Dönen Kırmızı/Mavi Çember) #}
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-10">
                            <i class="fa-solid fa-crosshairs text-[300px] text-[color:var(--brand-primary)] animate-[spin_20s_linear_infinite]"></i>
                            <div class="absolute w-[250px] h-[250px] rounded-full border border-[color:var(--brand-primary)]/30 border-dashed animate-[spin_30s_linear_infinite_reverse]"></div>
                        </div>
                        
                        {# Ortadaki Holografik İnsan / Operatör Silueti #}
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-[0.05]">
                            <i class="fa-solid fa-person-military-rifle text-[240px] text-white drop-shadow-[0_0_15px_theme(colors.white/50)]"></i>
                        </div>
                        
                        {# E-Sim Tarzı Item Grid (6 veya 8 Slot) #}
                        <div class="relative z-10 w-full max-w-[320px] aspect-square flex flex-col justify-between p-2">
                            {# Üst Satır (Head, Eyes, Acc) #}
                            <div class="flex justify-between items-center w-full px-2">
                                {# Kask (Epic/Mor) #}
                                <div class="relative h-[68px] w-[68px] rounded-[14px] bg-gradient-to-br from-indigo-900/60 to-purple-900/40 border-[2px] border-purple-500/50 shadow-[0_0_20px_theme(colors.purple.500/20),inset_0_2px_15px_theme(colors.purple.500/30)] flex items-center justify-center group/item cursor-pointer hover:-translate-y-1 transition-all hover:shadow-[0_0_25px_theme(colors.purple.500/40),inset_0_2px_15px_theme(colors.purple.500/50)]">
                                    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.2)_0%,transparent_50%,rgba(0,0,0,0.4)_100%)] rounded-[12px]"></div>
                                    <i class="fa-solid fa-helmet-safety text-[32px] text-zinc-300 drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] relative z-10"></i>
                                    <div class="absolute -bottom-1 -right-1 bg-black/80 text-white text-[9px] font-black w-5 h-5 rounded flex items-center justify-center border border-white/10 shadow shadow-black">Q5</div>
                                </div>
                                {# Gözlük / Visor (Rare/Mavi) #}
                                <div class="relative h-[68px] w-[68px] rounded-[14px] bg-gradient-to-br from-blue-900/60 to-sky-900/40 border-[2px] border-sky-500/50 shadow-[0_0_20px_theme(colors.sky.500/20),inset_0_2px_15px_theme(colors.sky.500/30)] flex items-center justify-center group/item cursor-pointer hover:-translate-y-1 transition-all hover:shadow-[0_0_25px_theme(colors.sky.500/40),inset_0_2px_15px_theme(colors.sky.500/50)] -mt-8">
                                    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.2)_0%,transparent_50%,rgba(0,0,0,0.4)_100%)] rounded-[12px]"></div>
                                    <i class="fa-solid fa-glasses text-[32px] text-zinc-300 drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] relative z-10"></i>
                                    <div class="absolute -bottom-1 -right-1 bg-black/80 text-white text-[9px] font-black w-5 h-5 rounded flex items-center justify-center border border-white/10 shadow shadow-black">Q3</div>
                                </div>
                                {# Şans/Aksesuar (Legendary/Altın) #}
                                <div class="relative h-[68px] w-[68px] rounded-[14px] bg-gradient-to-br from-amber-900/60 to-orange-900/40 border-[2px] border-amber-500/50 shadow-[0_0_20px_theme(colors.amber.500/20),inset_0_2px_15px_theme(colors.amber.500/30)] flex items-center justify-center group/item cursor-pointer hover:-translate-y-1 transition-all hover:shadow-[0_0_25px_theme(colors.amber.500/40),inset_0_2px_15px_theme(colors.amber.500/50)]">
                                    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.2)_0%,transparent_50%,rgba(0,0,0,0.4)_100%)] rounded-[12px]"></div>
                                    <div class="relative z-10 flex h-8 w-8 items-center justify-center rounded-full bg-black border-2 border-white/20 shadow-[0_2px_5px_rgba(0,0,0,0.8)]">
                                        <span class="text-white font-black text-xs">8</span>
                                    </div>
                                    <div class="absolute -bottom-1 -right-1 bg-black/80 text-white text-[9px] font-black w-5 h-5 rounded flex items-center justify-center border border-white/10 shadow shadow-black">Q6</div>
                                </div>
                            </div>
                            
                            {# Orta Satır (Sol Silah, Gövde, Sağ Silah/Bomba) #}
                            <div class="flex justify-between items-center w-full mt-6">
                                {# Birincil Silah #}
                                <div class="relative h-[80px] w-[68px] rounded-[14px] bg-gradient-to-br from-blue-900/60 to-cyan-900/40 border-[2px] border-cyan-500/50 shadow-[0_0_20px_theme(colors.cyan.500/20),inset_0_2px_15px_theme(colors.cyan.500/30)] flex items-center justify-center group/item cursor-pointer hover:scale-105 transition-all outline outline-2 outline-offset-2 outline-cyan-500/30">
                                    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.2)_0%,transparent_50%,rgba(0,0,0,0.4)_100%)] rounded-[12px]"></div>
                                    <i class="fa-solid fa-gun text-[34px] text-zinc-200 drop-shadow-[0_2px_4px_rgba(0,0,0,0.9)] relative z-10 -rotate-[30deg]"></i>
                                    <div class="absolute -bottom-1 -right-1 bg-black/80 text-white text-[10px] font-black w-6 h-5 rounded flex items-center justify-center border border-cyan-500/50 shadow shadow-black text-cyan-400">Q6</div>
                                </div>
                                {# Gövde Zırhı #}
                                <div class="relative h-[90px] w-[80px] rounded-[16px] bg-gradient-to-br from-emerald-900/60 to-teal-900/40 border-[2px] border-emerald-500/50 shadow-[0_0_25px_theme(colors.emerald.500/20),inset_0_2px_20px_theme(colors.emerald.500/30)] flex items-center justify-center group/item cursor-pointer hover:scale-105 transition-all outline outline-2 outline-offset-2 outline-emerald-500/30 z-20">
                                    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.2)_0%,transparent_50%,rgba(0,0,0,0.4)_100%)] rounded-[14px]"></div>
                                    <i class="fa-solid fa-shield-halved text-[46px] text-zinc-300 drop-shadow-[0_3px_6px_rgba(0,0,0,0.9)] relative z-10"></i>
                                    <div class="absolute -bottom-2 right-1/2 translate-x-1/2 bg-black/90 text-white text-[10px] font-black w-8 h-5 rounded flex items-center justify-center border border-emerald-500/50 shadow shadow-black text-emerald-400">Q5</div>
                                </div>
                                {# İkincil Silah/Bomba #}
                                <div class="relative h-[80px] w-[68px] rounded-[14px] bg-gradient-to-br from-rose-900/60 to-red-900/40 border-[2px] border-rose-500/50 shadow-[0_0_20px_theme(colors.rose.500/20),inset_0_2px_15px_theme(colors.rose.500/30)] flex items-center justify-center group/item cursor-pointer hover:scale-105 transition-all">
                                    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.2)_0%,transparent_50%,rgba(0,0,0,0.4)_100%)] rounded-[12px]"></div>
                                    <i class="fa-solid fa-bomb text-[34px] text-zinc-300 drop-shadow-[0_2px_4px_rgba(0,0,0,0.9)] relative z-10"></i>
                                    <div class="absolute -bottom-1 -right-1 bg-black/80 text-white text-[9px] font-black w-5 h-5 rounded flex items-center justify-center border border-white/10 shadow shadow-black">Q4</div>
                                </div>
                            </div>
                            
                            {# Alt Satır (Pantolon, Bot) #}
                            <div class="flex justify-center gap-10 items-center w-full px-4 mt-6">
                                {# Bacaklar (Normal/Yeşil) #}
                                <div class="relative h-[68px] w-[68px] rounded-[14px] bg-gradient-to-br from-green-900/50 to-emerald-900/30 border-[2px] border-green-500/40 shadow-[inset_0_2px_15px_theme(colors.green.500/20)] flex items-center justify-center group/item cursor-pointer hover:-translate-y-1 transition-all">
                                    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.1)_0%,transparent_50%,rgba(0,0,0,0.4)_100%)] rounded-[12px]"></div>
                                    {# Kargo pantolon ikonu olmadığı için simgeleyen bir şey #}
                                    <i class="fa-solid fa-person-walking text-[32px] text-zinc-400 opacity-90 drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] relative z-10"></i>
                                    <div class="absolute -bottom-1 -right-1 bg-black/80 text-white text-[9px] font-black w-5 h-5 rounded flex items-center justify-center border border-white/10 shadow shadow-black">Q1</div>
                                </div>
                                {# Ayakkabı/Bot (Common/Gri) #}
                                <div class="relative h-[68px] w-[68px] rounded-[14px] bg-gradient-to-br from-slate-800/60 to-zinc-900/40 border-[2px] border-slate-500/30 shadow-[inset_0_2px_15px_theme(colors.slate.500/20)] flex items-center justify-center group/item cursor-pointer hover:-translate-y-1 transition-all">
                                    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.1)_0%,transparent_50%,rgba(0,0,0,0.4)_100%)] rounded-[12px]"></div>
                                    <i class="fa-solid fa-shoe-prints text-[28px] text-zinc-400 drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)] relative z-10 rotate-90"></i>
                                    <div class="absolute -bottom-1 -right-1 bg-black/80 text-white text-[9px] font-black w-5 h-5 rounded flex items-center justify-center border border-white/10 shadow shadow-black">Q2</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    {# Sağ Taraf: İstatistik Listesi (Combat Stats) #}
                    <div class="p-0 flex flex-col h-full bg-black/20">
                        <div class="p-4 bg-gradient-to-b from-black/20 to-transparent border-b border-light/5 text-center flex-shrink-0">
                            <div class="text-[9px] font-bold uppercase tracking-[0.2em] text-slate-400 mb-1">{{ t('citizen.profile.combat_damage') }}</div>
                            <div class="text-[22px] font-black text-white tracking-wide">13,926 - 52,592</div>
                        </div>
                        
                        <div class="p-4 bg-black/10 border-b border-light/5 text-center flex-shrink-0">
                            <div class="text-[9px] font-bold uppercase tracking-[0.2em] text-slate-400 mb-1">{{ t('citizen.profile.combat_critical_hit') }}</div>
                            <div class="text-[17px] font-black text-white tracking-wide">27,852 - 105,184</div>
                        </div>

                        <div class="flex-1 divide-y divide-white/5 px-2 overflow-hidden flex flex-col justify-center text-[13px] font-black uppercase">
                            <div class="flex justify-between items-center px-4 py-3 hover:bg-white/5 transition-colors">
                                <div class="flex items-center gap-3 text-slate-400"><i class="fa-solid fa-certificate w-4 text-center"></i></div>
                                <div class="text-white drop-shadow-sm">36.01 <span class="text-[10px] text-slate-500">%</span></div>
                            </div>
                            <div class="flex justify-between items-center px-4 py-3 hover:bg-white/5 transition-colors">
                                <div class="flex items-center gap-3 text-slate-400"><i class="fa-solid fa-crosshairs w-4 text-center"></i></div>
                                <div class="text-white drop-shadow-sm">3.64 <span class="text-[10px] text-slate-500">%</span></div>
                            </div>
                            <div class="flex justify-between items-center px-4 py-3 hover:bg-white/5 transition-colors">
                                <div class="flex items-center gap-3 text-slate-400"><i class="fa-solid fa-shield w-4 text-center"></i></div>
                                <div class="text-white drop-shadow-sm">36.23 <span class="text-[10px] text-slate-500">%</span></div>
                            </div>
                            <div class="flex justify-between items-center px-4 py-3 hover:bg-white/5 transition-colors opacity-50">
                                <div class="flex items-center gap-3 text-slate-400"><i class="fa-solid fa-plane w-4 text-center"></i></div>
                                <div class="text-slate-300">0.0 <span class="text-[10px] text-slate-600">%</span></div>
                            </div>
                            <div class="flex justify-between items-center px-4 py-3 hover:bg-white/5 transition-colors opacity-50">
                                <div class="flex items-center gap-3 text-slate-400"><i class="fa-solid fa-gun w-4 text-center"></i></div>
                                <div class="text-slate-300">0.0 <span class="text-[10px] text-slate-600">%</span></div>
                            </div>
                            <div class="flex justify-between items-center px-4 py-3 hover:bg-white/5 transition-colors text-emerald-400">
                                <div class="flex items-center gap-3"><i class="fa-solid fa-chart-line w-4 text-center text-emerald-500/80"></i></div>
                                <div class="drop-shadow-[0_0_5px_theme(colors.emerald.400/30)]">+0.0</div>
                            </div>
                        </div>
                        
                        <div class="p-4 bg-black/30 border-t border-white/5 mt-auto flex-shrink-0">
                            <button class="w-full flex justify-center items-center gap-2 rounded border border-white/10 bg-black/50 px-4 py-2.5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-300 shadow-inner transition-all hover:bg-white/10 hover:text-white">
                                {{ t('citizen.profile.equip_items') }}
                            </button>
                        </div>
                    </div>
                </div>
            </section>
            

            {# ========================================== #}
            {# E-SİM MADALYA ŞERİDİ (MEDALS BAR - UX UPGRADE) #}
            {# ========================================== #}
            <section class="glass-panel overflow-hidden flex-shrink-0">
                <div class="border-b border-white/5 bg-black/20 px-6 py-4 flex items-center justify-between text-[11px] font-bold uppercase tracking-widest text-slate-300">
                    <div class="flex items-center gap-2"><i class="fa-solid fa-medal text-amber-500/80"></i> {{ t('citizen.profile.medals_and_rewards') }}</div>
                    <span class="bg-black/40 text-slate-400 px-2 py-0.5 rounded-full text-[9px] border border-white/5">{{ medalSlots|length }}</span>
                </div>
                
                {% if medalSlots is not empty %}
                    <div class="flex flex-wrap flex-row justify-center gap-3.5 p-7 bg-black/5 relative min-h-[140px]">
                        {% for achievement in medalSlots %}
                            <div class="group relative flex w-[68px] cursor-pointer flex-col items-center transition-all duration-300 z-10 hover:z-[100]">
                                {# Klasik E-Sim Madalya (Premium Efektli + Alt Yansıma Deep Glow) #}
                                <div class="relative flex h-[52px] w-[52px] items-center justify-center rounded-full bg-gradient-to-b from-[#fcd34d] via-[#fbbf24] to-[#b45309] shadow-[0_5px_15px_rgba(0,0,0,0.5),inset_0_2px_4px_rgba(255,255,255,0.6),inset_0_-2px_6px_rgba(0,0,0,0.6)] border border-black/80 ring-[3px] ring-black transition-all duration-300 group-hover:-translate-y-2 group-hover:ring-amber-500/50 group-hover:shadow-[0_15px_25px_rgba(245,158,11,0.5),inset_0_2px_4px_rgba(255,255,255,0.8)] z-10">
                                    {# Altındaki Zemin Yansıması (Glow Reflection) #}
                                    <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 w-8 h-2 bg-amber-500/60 blur-[6px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 -z-10"></div>
                                    
                                    <div class="absolute inset-0 rounded-full bg-[linear-gradient(135deg,rgba(255,255,255,0.4)_0%,transparent_50%,rgba(0,0,0,0.2)_100%)]"></div>
                                    <i class="fa-solid {{ achievement.icon }} text-[20px] text-white drop-shadow-[0_2px_3px_rgba(0,0,0,0.6)] relative z-10 group-hover:scale-110 transition-transform"></i>
                                </div>
                                <div class="mt-3 text-center text-[8px] font-black uppercase tracking-wider text-slate-400 group-hover:text-amber-100 transition-colors line-clamp-2 leading-[1.3] px-1 group-hover:-translate-y-1">
                                    {{ achievement.title }}
                                </div>
                                
                                {# V15 Ultra Premium Tooltip #}
                                <div class="pointer-events-none absolute bottom-[calc(100%+12px)] left-1/2 w-[240px] -translate-x-1/2 translate-y-4 rounded-xl border border-white/10 bg-black/80 backdrop-blur-2xl p-4 text-center opacity-0 shadow-[0_20px_40px_rgba(0,0,0,0.8)] transition-all duration-400 ease-out group-hover:translate-y-0 group-hover:opacity-100 flex flex-col">
                                    {# Ok İsareti Kusursuz #}
                                    <div class="absolute -bottom-[7px] left-1/2 -translate-x-1/2 w-4 h-4 rotate-45 border-r border-b border-white/10 bg-black/80 backdrop-blur-3xl"></div>
                                    
                                    <div class="relative font-black text-amber-400 mb-2 uppercase tracking-widest text-[11px] pb-2 border-b border-white/5 drop-shadow-md">{{ achievement.title }}</div>
                                    <div class="relative text-[10px] font-medium text-slate-300 leading-relaxed">{{ achievement.text }}</div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="px-6 py-12 text-center text-[11px] font-bold text-slate-500 bg-black/5 flex flex-col items-center justify-center gap-3">
                        <i class="fa-solid fa-medal text-slate-700/50 text-[32px]"></i>
                        {{ t('citizen.profile.no_achievements') }}
                    </div>
                {% endif %}
            </section>

            {# ========================================== #}
            {# TIMELINE VE İLETİŞİM LOGLARI (SİSTEM)      #}
            {# ========================================== #}
            <div class="grid gap-6 lg:grid-cols-2 flex-grow">
                <section class="glass-panel flex flex-col overflow-hidden h-full">
                    <div class="flex items-center gap-2 border-b border-light/5 bg-black/20 py-4 px-6 text-[10px] font-bold uppercase tracking-widest text-slate-400">
                        <i class="fa-solid fa-clock-rotate-left text-[color:var(--brand-primary)]"></i> {{ t('citizen.profile.timeline_title') }} 
                    </div>
                    <div class="flex-1 divide-y divide-white/5 bg-black/5">
                        {% if citizen.timeline is not empty %}
                            {% for item in citizen.timeline|slice(0, 4) %}
                                <div class="group px-6 py-4 transition-colors hover:bg-black/20">
                                    <div class="flex items-center justify-between gap-3 mb-2">
                                        <div class="text-[9px] font-black uppercase tracking-wider text-[color:var(--brand-primary)] opacity-90">{{ item.label }}</div>
                                        <div class="text-[8px] font-bold uppercase text-slate-500 bg-black/40 px-2 py-0.5 rounded-full border border-white/5">{{ item.time_label }}</div>
                                    </div>
                                    <div class="text-[11px] text-slate-300 font-medium leading-relaxed">{{ item.text }}</div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="px-6 py-10 text-center text-[10px] uppercase font-bold text-slate-500 tracking-wider">{{ t('citizen.profile.timeline_empty') }}</div>
                        {% endif %}
                    </div>
                </section>

                <section class="glass-panel flex flex-col overflow-hidden h-full">
                    <div class="flex items-center gap-2 border-b border-light/5 bg-black/20 py-4 px-6 text-[10px] font-bold uppercase tracking-widest text-slate-400">
                        <i class="fa-solid fa-bullhorn text-rose-500/80"></i> {{ t('citizen.profile.recent_shouts') }}
                    </div>
                    <div class="flex-1 divide-y divide-white/5 bg-black/5">
                        {% if citizen.recent_shouts is not empty %}
                            {% for shout in citizen.recent_shouts|slice(0, 3) %}
                                <div class="group px-6 py-4 transition-colors hover:bg-black/20">
                                    <div class="flex items-center justify-between gap-3 mb-2">
                                        <div class="text-[8px] font-bold uppercase text-slate-500 tracking-widest">{{ shout.created_at_label }}</div>
                                        <div class="flex items-center gap-1.5 text-[11px] font-black text-rose-400">
                                            <i class="fa-solid fa-heart drop-shadow-[0_0_5px_theme(colors.rose.400/30)]"></i> {{ shout.likes_count }}
                                        </div>
                                    </div>
                                    <div class="break-words text-[11px] text-slate-200 font-medium leading-relaxed italic opacity-90">"{{ shout.body_html|raw }}"</div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="px-6 py-10 text-center text-[10px] uppercase font-bold text-slate-500 tracking-wider">{{ t('citizen.profile.no_recent_shouts') }}</div>
                        {% endif %}
                    </div>
                </section>
            </div>
            
        </div>
    </div>
</div>
{% endblock %}
