                    <div id="winnerTag" class="px-2.5 py-1 rounded-md text-[8px] font-black tracking-[0.15em] uppercase border border-slate-600/50 bg-slate-600/10 text-slate-400">{{ t('box.status.common') }}</div>
                </div>
            </div>
        </div>

    </div>

    <div id="upgraderModal">
        <div class="upgrader-modal-content text-center p-6 relative max-w-xs w-full mx-4 transition-colors">
            <h2 class="text-[13px] font-black text-white tracking-[0.2em] mb-2 uppercase drop-shadow-sm flex justify-center items-center gap-2"><i class="fa-solid fa-arrow-trend-up text-emerald-400"></i> {{ t('box.upgrader_title') }}</h2>
            <p class="text-[8px] text-slate-500 font-bold uppercase tracking-widest mb-5 border-b border-white/5 pb-4">
                {{ t('box.upgrader_risk') }}
            </p>

            <div class="upgrader-wheel-container">
                <div class="absolute top-0 left-1/2 -translate-x-1/2 -mt-1 w-0 h-0 border-l-[5px] border-r-[5px] border-t-[8px] border-transparent border-t-white z-20 filter drop-shadow-[0_0_4px_rgba(0,0,0,0.8)]"></div>
                <div id="upgradeWheel"></div>
                <div class="upgrade-center-hub">
                    <i class="fa-solid fa-gem text-slate-500 text-lg drop-shadow-sm" id="upgradeCenterIcon"></i>
                </div>
            </div>

            <div class="mt-5 text-[9px] font-black uppercase tracking-widest text-slate-400 bg-black/60 py-2 rounded-lg border border-white/5 shadow-[inset_0_2px_8px_rgba(0,0,0,0.6)]">
                {{ t('box.success_chance') }}: <span id="upgradeChanceText" class="text-emerald-400 drop-shadow-sm">%</span>
            </div>

            <div class="mt-4">
                <button id="btnSpinUpgrade" class="btn btnPrimary w-full py-3.5 text-[10px]"><i class="fa-solid fa-dice text-black opacity-80"></i> {{ t('box.try_luck') }}</button>
                <button id="btnCloseUpgrade" class="mt-3 text-[8px] text-slate-500 font-black uppercase tracking-[0.2em] hover:text-red-400 transition-colors w-full py-1.5">{{ t('box.cancel') }}</button>
            </div>

            <div id="upgradeResultText" class="absolute inset-0 bg-black/95 rounded-[24px] flex items-center justify-center flex-col hidden backdrop-blur-md z-30">
                <div id="urIcon" class="text-4xl mb-2 drop-shadow-lg"></div>
                <div id="urText" class="text-[16px] font-black tracking-widest uppercase drop-shadow-md"></div>
                <button onclick="document.getElementById('upgraderModal').classList.remove('active');" class="mt-5 btn btnPrimary px-6 py-2.5 text-[9px]">{{ t('box.continue') }}</button>
            </div>
        </div>
    </div>

    <script>
    function showCyberAlert(icon, title, text) {
        Swal.fire({
            icon: icon,
            title: title,
            text: text,
            customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title', confirmButton: 'cyber-confirm-btn' },
            buttonsStyling: false,
            background: '#080a0f',
            color: '#f8fafc'
        });
    }

    $(function(){
        const BASE = "{{ base_url() }}";
        const CSRF = $('meta[name="csrf-token"]').attr('content') || '';
        const itemsPool = {{ itemsPool|raw }};

        const track = document.getElementById('rouletteTrack');
        const rouletteBox = document.getElementById('rouletteBox');
        const beam = document.getElementById('beam');
        const confetti = document.getElementById('confetti');

        const resultDisplay = document.getElementById('resultDisplay');
        const winCard = document.getElementById('winCard');
        const winIconBox = document.getElementById('winIconBox');
        const winIcon = document.getElementById('winIcon');
        const winnerText = document.getElementById('winnerText');
        const winnerMeta = document.getElementById('winnerMeta');
        const winnerExtra = document.getElementById('winnerExtra');
        const winnerTag = document.getElementById('winnerTag');
        const btnOpenUpgrader = document.getElementById('btnOpenUpgrader');

        const itemWidth = 136 + 16;
        let isOpening = false;

        let pityCount = {{ pityCount|default(0) }};
        const PITY_MAX = 10;

        let lastWonItemId = {{ lastWonItemId|default(0) }};
        let lastWonRarity = {{ lastWonRarity|default('""')|raw }};

        // anti-exploit token
        let upgradeToken = "";

        updatePityUI();

        function safeItem(i){ return itemsPool[i] || itemsPool[0] || { id:0, name:'{{ t('box.unknown_item') }}', icon:'â“', rarity:'rarity-common', type:'{{ t('box.reward')|upper }}' }; }

        function clearFX(){
            beam.classList.remove('on'); confetti.classList.remove('on'); confetti.innerHTML = '';
            document.getElementById('flashUncommon').classList.remove('on');
            document.getElementById('flashRare').classList.remove('on');
            document.getElementById('legendaryText').style.opacity = '0'; document.getElementById('legendaryText').classList.remove('on');
            document.getElementById('v5-box').classList.remove('heavy-shake','near-miss','slow-mo');
            track.querySelectorAll('.item.winnerGlow').forEach(el => el.classList.remove('winnerGlow'));
            track.querySelectorAll('.tickGlow').forEach(el => el.classList.remove('tickGlow'));
            btnOpenUpgrader.classList.add('hidden');
            winnerExtra.classList.add('hidden');
            winnerExtra.textContent = '';
        }

        function setBtnsLoading(isLoading){
            const b1 = $('#btn1x'), b5 = $('#btn5x');
            if(isLoading){
                b1.prop('disabled', true); b5.prop('disabled', true);
            }else{
                b1.prop('disabled', false); b5.prop('disabled', false);
                b1.html('<i class="fa-solid fa-key"></i><span>{{ t("box.open_1x") }}</span>');
                b5.html('<i class="fa-solid fa-bolt"></i><span>{{ t("box.open_5x") }}</span>');
            }
        }

        function updatePityUI() {
            let displayPity = Math.min(pityCount, PITY_MAX);
            const pct = (displayPity / PITY_MAX) * 100;
            document.getElementById('pityBar').style.width = pct + '%';
            document.getElementById('pityText').innerText = displayPity + ' / ' + PITY_MAX;

            if(pityCount >= PITY_MAX) {
                document.getElementById('pityBar').className = 'bg-gradient-to-r from-yellow-400 to-orange-500 transition-all duration-500 h-full';
                document.getElementById('pityText').innerHTML = '<span class="text-yellow-500 animate-pulse drop-shadow-sm">{{ t('box.next_guaranteed_rare') }}</span>';
            } else {
                document.getElementById('pityBar').className = 'bg-gradient-to-r from-[color:var(--brand-primary)] to-[color:var(--brand-primary)]/50 transition-all duration-500 h-full';
            }
        }

        function mulberry32(seed){
            let t = seed >>> 0;
            return function(){
                t += 0x6D2B79F5;
                let r = Math.imul(t ^ (t >>> 15), 1 | t);
                r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
                return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
            };
        }

        function buildDeterministicTrack(seedInt, winningItemIndex){
            const rng = mulberry32(seedInt || 123456);
            const win = safeItem(winningItemIndex);

            track.style.transition = 'none';
            track.style.transform = 'translateX(0px)';
            track.innerHTML = '';

            for (let i = 0; i < 75; i++) {
                let item;
                if(i === 60){
                    item = win;
                }else{
                    const idx = Math.floor(rng() * itemsPool.length);
                    item = safeItem(idx);
                }

                const card = document.createElement('div');
                card.className = `item ${item.rarity || 'rarity-common'}`;
                card.dataset.i = String(i);
                card.dataset.r = String(item.rarity || 'rarity-common');
                card.innerHTML = `<div class="icon">${item.icon || 'â“'}</div><div class="name">${item.name || '{{ t('box.unknown_item') }}'}</div>`;
                track.appendChild(card);
            }

            void track.offsetWidth;
        }

        function renderIdleTrack(){
            track.style.transition = 'none';
            track.innerHTML = '';

            const count = 25;
            const mid = Math.floor(count / 2);

            for (let i = 0; i < count; i++) {
                const item = safeItem(Math.floor(Math.random() * itemsPool.length));
                const card = document.createElement('div');
                card.className = `item ${item.rarity || 'rarity-common'}`;
                card.dataset.i = String(i);
                card.dataset.r = String(item.rarity || 'rarity-common');
                card.innerHTML = `<div class="icon">${item.icon || 'â“'}</div><div class="name">${item.name || '{{ t('box.unknown_item') }}'}</div>`;
                track.appendChild(card);
            }

            const targetX = (mid * itemWidth) - (rouletteBox.offsetWidth / 2) + (itemWidth / 2);
            track.style.transform = `translateX(-${Math.max(0, targetX)}px)`;
        }
        renderIdleTrack();

        let rafId = 0;
        let lastTickIndex = -1;
        function readTranslateX(el){
            const tr = getComputedStyle(el).transform;
            if(!tr || tr === 'none') return 0;
            const m = tr.match(/matrix\(([^)]+)\)/);
            if(!m) return 0;
            const parts = m[1].split(',').map(s => parseFloat(s));
            return parts.length >= 6 ? parts[4] : 0;
        }
        function tickLoop(){
            const tx = readTranslateX(track);
            const center = rouletteBox.offsetWidth / 2;
            const absX = (-tx) + center;
            const idx = Math.floor(absX / itemWidth);

            if(idx !== lastTickIndex){
                lastTickIndex = idx;
                const el = track.querySelector(`.item[data-i="${idx}"]`);
                if(el){
                    el.classList.add('tickGlow');
                    setTimeout(() => el.classList.remove('tickGlow'), 120);
                }
            }
            rafId = requestAnimationFrame(tickLoop);
        }
        function startTick(){ stopTick(); rafId = requestAnimationFrame(tickLoop); }
        function stopTick(){ if(rafId){ cancelAnimationFrame(rafId); rafId = 0; } lastTickIndex = -1; }

        function spawnConfetti(rarity){
            if(rarity === 'rarity-common') return;
            confetti.innerHTML = ''; confetti.classList.add('on');
            let count = rarity === 'rarity-rare' ? 80 : 30;
            let colors = rarity === 'rarity-rare'
                ? ['rgba(168,85,247,', 'rgba(250,204,21,', 'rgba(236,72,153,', 'rgba(255,255,255,']
                : ['rgba(59,130,246,', 'rgba(34,211,238,', 'rgba(255,255,255,'];
            for(let i=0; i<count; i++){
                const p = document.createElement('i');
                p.style.position = 'absolute';
                const x = Math.floor(Math.random() * 100), delay = Math.floor(Math.random() * 300), w = 5 + Math.floor(Math.random() * 6), h = 8 + Math.floor(Math.random() * 10);
                const cBase = colors[Math.floor(Math.random() * colors.length)], op = (0.7 + Math.random() * 0.3).toFixed(2);
                p.style.left = x+'%'; p.style.top = '-20px'; p.style.animation = `fall ${1+Math.random()}s linear ${delay}ms forwards`; p.style.width = w+'px'; p.style.height = h+'px';
                p.style.background = cBase+op+')'; p.style.boxShadow = `0 0 10px ${cBase} 0.5)`; p.style.transform = `rotate(${Math.floor(Math.random() * 360)}deg)`;
                confetti.appendChild(p);
            }
            if(!document.getElementById('confettiKeyframes')){
                const style = document.createElement('style');
                style.id = 'confettiKeyframes';
                style.innerHTML = `@keyframes fall { to { transform: translateY(100vh) rotate(720deg); } }`;
                document.head.appendChild(style);
            }
            setTimeout(() => { confetti.classList.remove('on'); }, 3000);
        }

        function applyNearMissIfNeeded(winnerRarity){
            if(winnerRarity === 'rarity-rare') return;
            const left = track.querySelector('.item[data-i="59"]');
            const right = track.querySelector('.item[data-i="61"]');
            const isNearRare = (left && left.dataset.r === 'rarity-rare') || (right && right.dataset.r === 'rarity-rare');
            if(!isNearRare) return;

            document.getElementById('v5-box').classList.add('near-miss','slow-mo');
            setTimeout(() => document.getElementById('v5-box').classList.remove('near-miss','slow-mo'), 520);
        }

        function showWin(winnerItem, extra){
            let tagCls = 'border-slate-600/50 bg-slate-600/10 text-slate-400', rTxt = '{{ t('box.status.common') }}', iconBgCls = 'border-slate-700/50 text-slate-300 bg-slate-800/80';

            if(winnerItem.rarity === 'rarity-rare'){
                tagCls = 'border-purple-500/50 bg-purple-500/10 text-purple-400'; rTxt = '{{ t('box.status.rare') }}';
                iconBgCls = 'border-purple-500/50 text-purple-400 bg-purple-900/30 shadow-[0_0_20px_rgba(168,85,247,0.3),inset_0_2px_10px_rgba(0,0,0,0.8)]';
            } else if(winnerItem.rarity === 'rarity-uncommon'){
                tagCls = 'border-blue-500/50 bg-blue-500/10 text-blue-400'; rTxt = '{{ t('box.status.uncommon') }}';
                iconBgCls = 'border-blue-500/50 text-blue-400 bg-blue-900/30 shadow-[0_0_20px_rgba(59,130,246,0.3),inset_0_2px_10px_rgba(0,0,0,0.8)]';
            }

            resultDisplay.classList.remove('hidden');

            winIconBox.className = `w-12 h-12 rounded-[10px] flex items-center justify-center text-2xl border ${iconBgCls}`;
            winIcon.innerHTML = winnerItem.icon || 'ğŸ';
            winnerText.textContent = winnerItem.name || '{{ t('box.unknown_item') }}';
            winnerMeta.textContent = (winnerItem.type ? String(winnerItem.type).toUpperCase() : '{{ t('box.reward')|upper }}');

            winnerTag.textContent = rTxt;
            winnerTag.className = `px-2.5 py-1 rounded-md text-[8px] font-black tracking-[0.15em] uppercase border ${tagCls}`;

            if(extra && extra.note){
                winnerExtra.textContent = extra.note;
                winnerExtra.classList.remove('hidden');
            }else{
                winnerExtra.classList.add('hidden');
                winnerExtra.textContent = '';
            }

            if(rTxt !== '{{ t('box.status.rare') }}' && (winnerItem.id || 0) > 0 && String(winnerItem.type || '').toUpperCase() !== 'CURRENCY'){
                btnOpenUpgrader.classList.remove('hidden');
            } else {
                btnOpenUpgrader.classList.add('hidden');
            }
        }

        $('#btn1x').on('click', function() {
            if(isOpening) return;
            isOpening = true;
            clearFX();
            setBtnsLoading(true);

            $('#btn1x').html('<i class="fa-solid fa-spinner fa-spin text-black opacity-80"></i> <span class="label">{{ t('box.opening') }}</span>');
            resultDisplay.classList.add('hidden');

            const clientSeed = Date.now() ^ Math.floor(Math.random() * 1e9);

            $.post(BASE + '/api/box/open', { csrf_token: CSRF, client_seed: clientSeed })
                .done(function(res) {
                    if(!res || res.error === 1 || !res.winner_item){
                        showCyberAlert('error', '{{ t('box.alert.action_failed') }}', res && res.message ? res.message : '{{ t('box.alert.generic_error') }}');
                        setBtnsLoading(false); isOpening = false;
                        return;
                    }

                    const spinSeed = (res.spin_seed !== undefined) ? parseInt(res.spin_seed, 10) : clientSeed;
                    const winnerIndex = res.winner_index || 0;

                    upgradeToken = String(res.upgrade_token || "");

                    setTimeout(() => {

                        $('#flashBang').addClass('on'); setTimeout(() => $('#flashBang').removeClass('on'), 1000);

                        buildDeterministicTrack(spinSeed, winnerIndex);

                        startTick();

                        track.style.transition = 'transform 6.8s cubic-bezier(0.12, 0.95, 0.1, 1)';
                        let targetX = (60 * itemWidth) - (rouletteBox.offsetWidth / 2) + (itemWidth / 2) + (Math.floor(Math.random() * 40) - 20);

                        rouletteBox.classList.remove('shake'); void rouletteBox.offsetWidth; rouletteBox.classList.add('shake');
                        track.style.transform = `translateX(-${targetX}px)`;

                        setTimeout(() => {
                            track.style.transition = 'transform 300ms cubic-bezier(0.2, 1, 0.3, 1)';
                            track.style.transform = `translateX(-${Math.max(0, targetX - 18)}px)`;
                        }, 6600);

                        setTimeout(() => {
                            stopTick();

                            track.style.transition = 'transform 200ms ease-out';
                            track.style.transform = `translateX(-${targetX}px)`;

                            beam.classList.add('on');
                            track.querySelector('.item[data-i="60"]')?.classList.add('winnerGlow');

                            if(res.pity_count !== undefined) {
                                pityCount = parseInt(res.pity_count, 10) || 0;
                                updatePityUI();
                            }

                            applyNearMissIfNeeded(res.winner_item.rarity);

                            if (res.winner_item.rarity === 'rarity-uncommon') {
                                document.getElementById('flashUncommon').classList.add('on');
                                spawnConfetti(res.winner_item.rarity);
                            } else if (res.winner_item.rarity === 'rarity-rare') {
                                document.getElementById('flashRare').classList.add('on');
                                document.getElementById('v5-box').classList.add('heavy-shake');
                                document.getElementById('legendaryText').style.opacity = '1';
                                document.getElementById('legendaryText').classList.add('on');
                                spawnConfetti(res.winner_item.rarity);
                            }

                            lastWonItemId = parseInt(res.last_won_item_id || res.winner_item.id || 0, 10) || 0;
                            lastWonRarity = String(res.last_won_rarity || res.winner_item.rarity || '');

                            const extra = {};
                            if(res.duplicate_converted){
                                const sc = parseInt(res.scrap_gained || 0, 10) || 0;
                                extra.note = `{{ t('box.duplicate_scrap')|replace({ ':amount': '${sc}' }) }}`;
                            }

                            showWin(res.winner_item, extra);
                            setBtnsLoading(false); isOpening = false;
                        }, 6920);
                    }, 800);
                })
                .fail(function() {
                    showCyberAlert('error', '{{ t('box.alert.connection_title') }}', '{{ t('box.alert.connection_copy') }}');
                    stopTick();
                    setBtnsLoading(false); isOpening = false;
                });
        });

        $('#btn5x').on('click', function() {
            showCyberAlert('info', '{{ t('box.alert.info') }}', '{{ t('box.alert.five_open_missing') }}');
        });

        let upgradeSpinning = false;

        function upgradeChanceFor(rarity){
            if(rarity === 'rarity-common') return 0.55;
            if(rarity === 'rarity-uncommon') return 0.30;
            return 0;
        }

        function updateUpgradeUI(){
            const ch = upgradeChanceFor(lastWonRarity);
            document.getElementById('upgradeChanceText').textContent = '%' + Math.round(ch * 100);
            const greenPct = Math.max(0, Math.min(100, Math.round(ch * 100)));
            document.getElementById('upgradeWheel').style.background =
                `conic-gradient(var(--green) 0% ${greenPct}%, var(--red) ${greenPct}% 100%)`;
        }

        btnOpenUpgrader.addEventListener('click', () => {
            if(!lastWonItemId || upgradeChanceFor(lastWonRarity) <= 0){
                btnOpenUpgrader.classList.add('hidden');
                return;
            }
            updateUpgradeUI();
            document.getElementById('upgraderModal').classList.add('active');
            document.getElementById('upgradeResultText').classList.add('hidden');
            document.getElementById('upgradeWheel').style.transition = 'none';
            document.getElementById('upgradeWheel').style.transform = 'rotate(0deg)';
            document.getElementById('upgradeCenterIcon').className = 'fa-solid fa-gem text-slate-500 text-xl drop-shadow-sm';
        });

        document.getElementById('btnCloseUpgrade').addEventListener('click', () => {
            if(!upgradeSpinning) document.getElementById('upgraderModal').classList.remove('active');
        });

        document.getElementById('btnSpinUpgrade').addEventListener('click', () => {
            if(upgradeSpinning) return;
            if(!lastWonItemId) return;

            upgradeSpinning = true;
            document.getElementById('btnSpinUpgrade').innerHTML = '<i class="fa-solid fa-spinner fa-spin text-black opacity-80"></i> {{ t('box.upgrade.spinning') }}';
            document.getElementById('btnCloseUpgrade').style.opacity = '0.3';
            document.getElementById('upgradeCenterIcon').className = 'fa-solid fa-spinner fa-spin text-slate-500 text-xl';

            $.post(BASE + '/api/box/upgrade', {
                csrf_token: CSRF,
                item_id: lastWonItemId,
                upgrade_token: upgradeToken
            }).done(function(res){
                if(!res || res.error === 1){
                    showCyberAlert('error', '{{ t('base.dropdown.bug') }}', res && res.message ? res.message : '{{ t('box.upgrade.failed_action') }}');
                    upgradeSpinning = false;
                    document.getElementById('btnSpinUpgrade').innerHTML = '<i class="fa-solid fa-dice text-black opacity-80"></i> {{ t('box.try_luck') }}';
                    document.getElementById('btnCloseUpgrade').style.opacity = '1';
                    document.getElementById('upgradeCenterIcon').className = 'fa-solid fa-gem text-slate-500 text-xl drop-shadow-sm';
                    return;
                }

                const ch = parseFloat(res.chance || upgradeChanceFor(lastWonRarity)) || 0.30;
                const isWin = !!res.win;
                const greenPct = Math.round(ch * 100);

                let targetDegree = 0;
                if(isWin){
                    const winAngle = Math.floor(Math.random() * Math.max(10, Math.min(100, greenPct) - 10)) + 5;
                    targetDegree = (360 * 5) + (360 - Math.floor((winAngle / 100) * 360));
                }else{
                    const loseAngle = Math.floor(Math.random() * 200) + 120;
                    targetDegree = (360 * 5) + (360 - loseAngle);
                }

                const wheel = document.getElementById('upgradeWheel');
                wheel.style.transition = 'transform 4s cubic-bezier(0.1, 0.8, 0.15, 1)';
                wheel.style.transform = `rotate(${targetDegree}deg)`;

                setTimeout(() => {
                    const resPanel = document.getElementById('upgradeResultText');
                    const urIcon = document.getElementById('urIcon');
                    const urText = document.getElementById('urText');

                    resPanel.classList.remove('hidden');

                    if(isWin){
                        const toName = res.to_item && res.to_item.name ? String(res.to_item.name) : '{{ t('box.upgrade.top_tier') }}';
                        urIcon.innerHTML = 'âœ¨';
                        urText.innerHTML = '<span class="text-emerald-400 drop-shadow-md">{{ t('box.upgrade_success')|upper }}</span>';
                        urText.innerHTML += `<div class="text-[11px] text-slate-300 mt-1.5 font-bold">${toName}</div>`;
                    }else{
                        urIcon.innerHTML = 'ğŸ’¥';
                        urText.innerHTML = '<span class="text-red-500 drop-shadow-md">{{ t('box.upgrade_failed')|upper }}</span>';
                        urText.innerHTML += '<div class="text-[10px] text-slate-400 mt-1.5 font-bold">{{ t('box.item_destroyed') }}</div>';
                    }

                    btnOpenUpgrader.classList.add('hidden');
                    lastWonItemId = 0;
                    lastWonRarity = '';
                    upgradeToken = '';

                    upgradeSpinning = false;
                    document.getElementById('btnSpinUpgrade').innerHTML = '<i class="fa-solid fa-dice text-black opacity-80"></i> {{ t('box.try_luck') }}';
                    document.getElementById('btnCloseUpgrade').style.opacity = '1';
                    document.getElementById('upgradeCenterIcon').className = 'fa-solid fa-gem text-slate-500 text-xl drop-shadow-sm';
                }, 4200);

            }).fail(function(){
                showCyberAlert('error', '{{ t('box.alert.connection_title') }}', '{{ t('box.alert.server_unreachable') }}');
                upgradeSpinning = false;
                document.getElementById('btnSpinUpgrade').innerHTML = '<i class="fa-solid fa-dice text-black opacity-80"></i> {{ t('box.try_luck') }}';
                document.getElementById('btnCloseUpgrade').style.opacity = '1';
                document.getElementById('upgradeCenterIcon').className = 'fa-solid fa-gem text-slate-500 text-xl drop-shadow-sm';
            });
        });
    });
    </script>
{% endblock %}
