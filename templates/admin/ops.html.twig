{% extends "common/base.html.twig" %}

{% block content %}
<div class="space-y-6">
    <div class="glass-panel p-6 border-l-4 border-[color:var(--brand-primary)] bg-[color:var(--brand-primary)]/6">
        <h1 class="text-lg font-black text-white uppercase tracking-[0.18em]">{{ t('admin.ops.title') }}</h1>
        <p class="mt-2 text-[12px] font-bold text-slate-400">{{ t('admin.ops.subtitle') }}</p>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-4">
        <div class="glass-panel p-5">
            <div class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">{{ t('admin.ops.kpi.open_work') }}</div>
            <div class="mt-2 text-2xl font-black text-white">{{ stats.open_work_offers|default(0) }}</div>
        </div>
        <div class="glass-panel p-5">
            <div class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">{{ t('admin.ops.kpi.active_ads') }}</div>
            <div class="mt-2 text-2xl font-black text-white">{{ stats.active_ads|default(0) }}</div>
        </div>
        <div class="glass-panel p-5">
            <div class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">{{ t('admin.ops.kpi.pending_applications') }}</div>
            <div class="mt-2 text-2xl font-black text-white">{{ stats.pending_party_applications|default(0) }}</div>
        </div>
        <div class="glass-panel p-5">
            <div class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">{{ t('admin.ops.kpi.recent_notifications') }}</div>
            <div class="mt-2 text-2xl font-black text-white">{{ stats.recent_notifications|default(0) }}</div>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-5 gap-4">
        <div class="glass-panel p-5">
            <div class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">{{ t('admin.ops.kpi.active_wars') }}</div>
            <div class="mt-2 text-2xl font-black text-white">{{ stats.active_wars|default(0) }}</div>
        </div>
        <div class="glass-panel p-5">
            <div class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">{{ t('admin.ops.kpi.today_articles') }}</div>
            <div class="mt-2 text-2xl font-black text-white">{{ stats.today_articles|default(0) }}</div>
        </div>
        <div class="glass-panel p-5">
            <div class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">{{ t('admin.ops.kpi.gym_sync_pending') }}</div>
            <div class="mt-2 text-2xl font-black {% if stats.gym_sync_pending|default(0) > 0 %}text-amber-300{% else %}text-white{% endif %}">{{ stats.gym_sync_pending|default(0) }}</div>
        </div>
        <div class="glass-panel p-5">
            <div class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">{{ t('admin.ops.kpi.broken_party_applications') }}</div>
            <div class="mt-2 text-2xl font-black {% if stats.broken_party_applications|default(0) > 0 %}text-amber-300{% else %}text-white{% endif %}">{{ stats.broken_party_applications|default(0) }}</div>
        </div>
        <div class="glass-panel p-5">
            <div class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">{{ t('admin.ops.kpi.dual_message_system') }}</div>
            <div class="mt-2 text-2xl font-black {% if stats.dual_message_system|default(0) > 0 %}text-amber-300{% else %}text-white{% endif %}">{{ stats.dual_message_system|default(0) ? t('admin.ops.kpi.var') : t('admin.ops.kpi.yok') }}</div>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-4">
        <div class="glass-panel p-5">
            <div class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">{{ t('admin.ops.kpi.total_shouts') }}</div>
            <div class="mt-2 text-2xl font-black text-white">{{ stats.total_shouts|default(0) }}</div>
        </div>
        <div class="glass-panel p-5">
            <div class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">{{ t('admin.ops.kpi.total_shout_reports') }}</div>
            <div class="mt-2 text-2xl font-black {% if stats.reported_shouts|default(0) > 0 %}text-amber-300{% else %}text-white{% endif %}">{{ stats.reported_shouts|default(0) }}</div>
        </div>
        <div class="glass-panel p-5">
            <div class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">{{ t('admin.ops.kpi.active_mutes') }}</div>
            <div class="mt-2 text-2xl font-black {% if stats.muted_shout_users|default(0) > 0 %}text-rose-300{% else %}text-white{% endif %}">{{ stats.muted_shout_users|default(0) }}</div>
        </div>
    </div>

    <div class="glass-panel p-6">
        <div class="flex flex-wrap items-center justify-between gap-4 border-b border-[color:var(--brand-primary)]/12 pb-4">
            <div>
                <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em]">{{ t('admin.ops.beta.title') }}</h2>
                <p class="mt-2 text-[12px] font-bold text-slate-400">{{ t('admin.ops.beta.subtitle') }}</p>
            </div>
            <span class="rounded-full px-3 py-2 text-[10px] font-black uppercase tracking-[0.16em] {% if betaHealth.ready %}bg-emerald-500/12 text-emerald-300 border border-emerald-500/20{% else %}bg-amber-500/12 text-amber-300 border border-amber-500/20{% endif %}">
                {{ betaHealth.ready ? t('admin.ops.beta.ready') : t('admin.ops.beta.not_ready') }}
            </span>
        </div>

        <div class="mt-5 grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="rounded-2xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4">
                <div class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-500">{{ t('admin.ops.beta.healthy_crons') }}</div>
                <div class="mt-2 text-xl font-black text-emerald-300">{{ betaHealth.healthy_crons|default(0) }}</div>
            </div>
            <div class="rounded-2xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4">
                <div class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-500">{{ t('admin.ops.beta.stale_crons') }}</div>
                <div class="mt-2 text-xl font-black {% if betaHealth.stale_crons|default(0) > 0 %}text-amber-300{% else %}text-white{% endif %}">{{ betaHealth.stale_crons|default(0) }}</div>
            </div>
            <div class="rounded-2xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4">
                <div class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-500">{{ t('admin.ops.beta.error_crons') }}</div>
                <div class="mt-2 text-xl font-black {% if betaHealth.error_crons|default(0) > 0 %}text-red-300{% else %}text-white{% endif %}">{{ betaHealth.error_crons|default(0) }}</div>
            </div>
        </div>

        <div class="mt-4 grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_340px] gap-4">
            <div class="rounded-2xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4">
                <div class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-500">{{ t('admin.ops.beta.blockers') }}</div>
                <div class="mt-3 space-y-2">
                    {% for blocker in betaHealth.blockers %}
                        <div class="rounded-xl border border-amber-500/20 bg-amber-500/8 px-3 py-3 text-[11px] font-bold text-amber-100">{{ blocker }}</div>
                    {% else %}
                        <div class="rounded-xl border border-emerald-500/20 bg-emerald-500/8 px-3 py-3 text-[11px] font-bold text-emerald-100">{{ t('admin.ops.beta.no_blockers') }}</div>
                    {% endfor %}
                </div>
            </div>

            <div class="rounded-2xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4 space-y-3">
                <div class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-500">{{ t('admin.ops.beta.docs') }}</div>
                <div class="rounded-xl border border-[color:var(--brand-primary)]/10 bg-black/25 px-3 py-3 text-[11px] font-bold text-slate-300 break-all">{{ betaHealth.smoke_doc_path }}</div>
                <div class="rounded-xl border border-[color:var(--brand-primary)]/10 bg-black/25 px-3 py-3 text-[11px] font-bold text-slate-300 break-all">{{ betaHealth.runbook_doc_path }}</div>
                <div class="rounded-xl border border-[color:var(--brand-primary)]/10 bg-black/25 px-3 py-3 text-[11px] font-bold text-slate-300 break-all">{{ betaHealth.schema_doc_path }}</div>
            </div>
        </div>
    </div>

    <div class="glass-panel p-6">
        <div class="border-b border-[color:var(--brand-primary)]/12 pb-4">
            <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em]">{{ t('admin.ops.pulse.title') }}</h2>
            <p class="mt-2 text-[12px] font-bold text-slate-400">{{ t('admin.ops.pulse.subtitle') }}</p>
        </div>

        <div class="mt-5 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            <div class="rounded-2xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4">
                <div class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-500">{{ t('admin.ops.kpi.active_wars') }}</div>
                <div class="mt-2 text-xl font-black text-white">{{ stats.active_wars|default(0) }}</div>
            </div>
            <div class="rounded-2xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4">
                <div class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-500">{{ t('admin.ops.pulse.open_jobs') }}</div>
                <div class="mt-2 text-xl font-black text-white">{{ stats.open_work_offers|default(0) }}</div>
            </div>
            <div class="rounded-2xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4">
                <div class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-500">{{ t('admin.ops.kpi.today_articles') }}</div>
                <div class="mt-2 text-xl font-black text-white">{{ stats.today_articles|default(0) }}</div>
            </div>
            <div class="rounded-2xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4">
                <div class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-500">{{ t('admin.ops.pulse.total_parties') }}</div>
                <div class="mt-2 text-xl font-black text-white">{{ stats.party_count|default(0) }}</div>
            </div>
            <div class="rounded-2xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4">
                <div class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-500">{{ t('admin.ops.pulse.newspapers') }}</div>
                <div class="mt-2 text-xl font-black text-white">{{ stats.newspaper_count|default(0) }}</div>
            </div>
            <div class="rounded-2xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4">
                <div class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-500">{{ t('admin.ops.pulse.party_ads') }}</div>
                <div class="mt-2 text-xl font-black text-white">{{ stats.active_ads|default(0) }}</div>
            </div>
        </div>

        {% if stats.pending_party_applications|default(0) > 0 %}
            <div class="mt-4 rounded-2xl border border-amber-500/20 bg-amber-500/8 px-4 py-4">
                <div class="text-[10px] font-black uppercase tracking-[0.14em] text-amber-300">{{ t('admin.ops.pulse.pending_party') }}</div>
                <div class="mt-2 text-xl font-black text-white">{{ stats.pending_party_applications|default(0) }}</div>
            </div>
        {% endif %}
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        <div class="glass-panel p-6 space-y-4">
            <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em]">{{ t('admin.ops.emergency.title') }}</h2>

            <form class="admin-op-form space-y-3" data-success="Kullanici durumu guncellendi." method="post" action="{{ base_url() }}/api/admin/user-status">
                <div class="grid grid-cols-2 gap-3">
                    <input class="w-full rounded-xl bg-black/40 border border-[color:var(--brand-primary)]/12 px-4 py-3 text-sm text-white" type="number" name="uid" placeholder="Kullanici ID">
                    <select class="w-full rounded-xl bg-black/40 border border-[color:var(--brand-primary)]/12 px-4 py-3 text-sm text-white" name="status">
                        <option value="1">{{ t('admin.ops.user_active') }}</option>
                        <option value="2">{{ t('admin.ops.status.banned') }}</option>
                        <option value="0">{{ t('admin.ops.status.pending') }}</option>
                    </select>
                </div>
                <button class="rounded-xl bg-cyan-600 hover:bg-cyan-500 px-4 py-3 text-[11px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.update_user_status') }}</button>
            </form>

            <form class="admin-op-form space-y-3" data-success="Parti reklami sifirlandi." method="post" action="{{ base_url() }}/api/admin/cancel-party-ad">
                <input class="w-full rounded-xl bg-black/40 border border-[color:var(--brand-primary)]/12 px-4 py-3 text-sm text-white" type="number" name="party_id" placeholder="Parti ID">
                <button class="rounded-xl bg-amber-600 hover:bg-amber-500 px-4 py-3 text-[11px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.pulse.party_ads') }}ni Kapat</button>
            </form>

            <form class="admin-op-form space-y-3" data-success="Is ilani kaldirildi." method="post" action="{{ base_url() }}/api/admin/cancel-work-offer">
                <input class="w-full rounded-xl bg-black/40 border border-[color:var(--brand-primary)]/12 px-4 py-3 text-sm text-white" type="number" name="offer_id" placeholder="Is Ilani ID">
                <button class="rounded-xl bg-red-600 hover:bg-red-500 px-4 py-3 text-[11px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.remove_job') }}</button>
            </form>

            <form class="admin-op-form" data-success="Koalisyon baglari onarildi." method="post" action="{{ base_url() }}/api/admin/repair-party-coalitions">
                <button class="rounded-xl bg-indigo-600 hover:bg-indigo-500 px-4 py-3 text-[11px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.repair_coalitions') }}</button>
            </form>

            <form class="admin-op-form" data-success="Gym gecmisi senkronlandi." method="post" action="{{ base_url() }}/api/admin/sync-user-gyms">
                <button class="rounded-xl bg-emerald-600 hover:bg-emerald-500 px-4 py-3 text-[11px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.sync_gyms') }}</button>
            </form>

            <form class="admin-op-form" data-success="Parti basvurulari onarildi." method="post" action="{{ base_url() }}/api/admin/repair-party-applications">
                <button class="rounded-xl bg-fuchsia-600 hover:bg-fuchsia-500 px-4 py-3 text-[11px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.repair_party_apps') }}</button>
            </form>

            <form class="admin-op-form space-y-3" data-success="Makale kaldirildi." method="post" action="{{ base_url() }}/api/admin/delete-article">
                <input class="w-full rounded-xl bg-black/40 border border-[color:var(--brand-primary)]/12 px-4 py-3 text-sm text-white" type="number" name="article_id" placeholder="Makale ID">
                <button class="rounded-xl bg-rose-600 hover:bg-rose-500 px-4 py-3 text-[11px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.remove_article') }}</button>
            </form>
        </div>

        <div class="glass-panel p-6">
            <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] mb-4">{{ t('admin.ops.cron.title') }}</h2>
            <div class="space-y-3">
                {% for cron in cronEntries %}
                    <div class="rounded-xl border border-[color:var(--brand-primary)]/12 bg-black/30 px-4 py-3">
                        <div class="flex items-center justify-between gap-3">
                            <div class="text-[11px] font-black text-white">{{ cron.name }}</div>
                            <div class="text-[9px] font-black uppercase tracking-[0.14em] {% if cron.has_error %}text-red-300{% elseif cron.stale %}text-amber-300{% else %}text-emerald-300{% endif %}">
                                {% if cron.has_error %}{{ t('admin.ops.cron.error') }}{% elseif cron.stale %}{{ t('admin.ops.cron.delayed') }}{% else %}{{ t('admin.ops.cron.tracked') }}{% endif %}
                            </div>
                        </div>
                        {% if cron.updated_at %}
                            <div class="mt-1 text-[9px] font-black uppercase tracking-[0.14em] text-slate-500">Son durum: {{ cron.updated_at|date('d.m.Y H:i') }}</div>
                        {% endif %}
                        {% if cron.last_success_at %}
                            <div class="mt-1 text-[9px] font-black uppercase tracking-[0.14em] text-emerald-300">Son basari: {{ cron.last_success_at|date('d.m.Y H:i') }}</div>
                        {% endif %}
                        {% if cron.last_error_at %}
                            <div class="mt-1 text-[9px] font-black uppercase tracking-[0.14em] text-red-300">Son hata: {{ cron.last_error_at|date('d.m.Y H:i') }}</div>
                        {% endif %}
                        <div class="mt-1 text-[9px] font-black uppercase tracking-[0.14em] text-slate-500">Boyut: {{ cron.size }} byte</div>
                        {% if cron.age_hours is not null %}
                            <div class="mt-1 text-[9px] font-black uppercase tracking-[0.14em] text-slate-500">Yas: {{ cron.age_hours }} saat</div>
                        {% endif %}
                        {% if cron.last_error_message %}
                            <div class="mt-2 text-[11px] font-bold text-red-200 break-words">{{ cron.last_error_message }}</div>
                        {% endif %}
                        {% if cron.last_meta_json %}
                            <div class="mt-2 text-[10px] font-bold text-slate-400 break-words">{{ cron.last_meta_json }}</div>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="rounded-xl border border-[color:var(--brand-primary)]/12 bg-black/30 px-4 py-4 text-[12px] font-bold text-slate-500">{{ t('admin.ops.cron.none') }}</div>
                {% endfor %}
            </div>
            <div class="mt-4 rounded-xl border border-[color:var(--brand-primary)]/12 bg-black/30 px-4 py-4">
                <div class="text-[10px] font-black uppercase tracking-[0.16em] text-slate-500">{{ t('admin.ops.app_log') }}</div>
                <div class="mt-2 text-[11px] font-bold text-slate-300 break-all">{{ appLogPath }}</div>
            </div>
        </div>
    </div>

    <div class="glass-panel p-6">
        <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] mb-4">{{ t('admin.ops.recent_articles') }}</h2>
        <div class="space-y-3">
            {% for article in recentArticles %}
                <div class="rounded-xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-3 flex items-center justify-between gap-3">
                    <div class="min-w-0">
                        <div class="text-[12px] font-black text-white truncate">#{{ article.id }} {{ article.title }}</div>
                        <div class="mt-1 text-[9px] font-black uppercase tracking-[0.14em] text-slate-500">{{ article.nick|default('Bilinmeyen') }} / {{ article.created_at|date('d.m.Y H:i') }}</div>
                    </div>
                    <form class="admin-op-form shrink-0" data-success="Makale kaldirildi." method="post" action="{{ base_url() }}/api/admin/delete-article">
                        <input type="hidden" name="article_id" value="{{ article.id }}">
                        <button class="rounded-xl bg-rose-600 hover:bg-rose-500 px-3 py-2 text-[10px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.remove') }}</button>
                    </form>
                </div>
            {% else %}
                <div class="rounded-xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4 text-[12px] font-bold text-slate-500">{{ t('admin.ops.no_recent_articles') }}</div>
            {% endfor %}
        </div>
    </div>

    <div class="glass-panel p-6">
        <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] mb-4">{{ t('admin.ops.active_shout_restrictions') }}</h2>
        <div class="space-y-3">
            {% for restriction in activeShoutRestrictions %}
                <div class="rounded-xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-3 flex items-center justify-between gap-3">
                    <div class="min-w-0">
                        <div class="text-[12px] font-black text-white truncate">{{ restriction.nick|default('Vatandas') }}</div>
                        <div class="mt-2 text-[11px] font-semibold text-slate-300 break-words">{{ restriction.reason|default('Gecici shout kisiti') }}</div>
                        <div class="mt-2 text-[9px] font-black uppercase tracking-[0.14em] text-rose-300">Kisit bitisi: {{ restriction.muted_until|date('d.m.Y H:i') }}</div>
                    </div>
                    <div class="shrink-0">
                        <form class="admin-op-form" data-success="Shout kisiti kaldirildi." method="post" action="{{ base_url() }}/api/admin/clear-shout-restriction">
                            <input type="hidden" name="uid" value="{{ restriction.uid }}">
                            <button class="rounded-xl bg-emerald-600 hover:bg-emerald-500 px-3 py-2 text-[10px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.remove_restriction') }}</button>
                        </form>
                    </div>
                </div>
            {% else %}
                <div class="rounded-xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4 text-[12px] font-bold text-slate-500">{{ t('admin.ops.no_active_shout_restriction') }}</div>
            {% endfor %}
        </div>
    </div>

    <div class="glass-panel p-6">
        <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] mb-4">{{ t('admin.ops.reported_shouts') }}</h2>
        <div class="space-y-3">
            {% for shout in recentShouts %}
                <div class="rounded-xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-3 flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <div class="flex flex-wrap items-center gap-2">
                            <div class="text-[12px] font-black text-white truncate">#{{ shout.id }} {{ shout.nick|default(t('admin.ops.citizen')) }}</div>
                            <span class="rounded-full px-2 py-1 text-[9px] font-black uppercase tracking-[0.14em] {% if shout.is_deleted %}bg-rose-500/10 text-rose-300 border border-rose-500/20{% else %}bg-emerald-500/10 text-emerald-300 border border-emerald-500/20{% endif %}">
                                {{ shout.is_deleted ? t('admin.ops.report_hidden') : t('admin.ops.report_visible') }}
                            </span>
                            <span class="rounded-full bg-amber-500/10 border border-amber-500/20 px-2 py-1 text-[9px] font-black uppercase tracking-[0.14em] text-amber-300">
                                {{ t('admin.ops.report_count', {':count': shout.reports_count|default(0)}) }}
                            </span>
                        </div>
                        <div class="mt-2 text-[12px] font-semibold text-slate-300 break-words">{{ shout.body }}</div>
                        <div class="mt-2 text-[9px] font-black uppercase tracking-[0.14em] text-slate-500">
                            Like {{ shout.likes_count|default(0) }} / {{ shout.created_at|date('d.m.Y H:i') }}
                        </div>
                        <div class="mt-3 rounded-xl border border-[color:var(--brand-primary)]/10 bg-black/25 px-3 py-3 space-y-2">
                            <div class="text-[9px] font-black uppercase tracking-[0.14em] text-slate-500">
                                {{ t('admin.ops.report_reason') }}:
                                <span class="ml-1 text-[11px] font-semibold normal-case tracking-normal text-slate-200">{{ shout.latest_reason|default(t('admin.ops.no_reason')) }}</span>
                            </div>
                            <div class="text-[9px] font-black uppercase tracking-[0.14em] text-slate-500 flex flex-wrap items-center gap-2">
                                <span>{{ t('admin.ops.report_source') }}:</span>
                                {% if shout.latest_reporter_country_id|default(0) > 0 %}
                                    <img class="h-3.5 w-5 rounded-[3px] object-cover border border-white/10" src="{{ base_url() }}/img/flags/{{ shout.latest_reporter_country_id }}.png" alt="flag">
                                {% endif %}
                                <span class="text-[11px] font-semibold normal-case tracking-normal text-slate-200">{{ shout.latest_reporter_nick|default(t('admin.ops.unknown')) }}</span>
                                {% if shout.latest_reported_at %}
                                    <span class="text-[9px] font-black uppercase tracking-[0.14em] text-slate-500">{{ shout.latest_reported_at|date('d.m.Y H:i') }}</span>
                                {% endif %}
                            </div>
                            {% if shout.muted_until %}
                                <div class="text-[9px] font-black uppercase tracking-[0.14em] text-rose-300">{{ t('admin.ops.muted_until') }}: {{ shout.muted_until|date('d.m.Y H:i') }}</div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="shrink-0 flex flex-col gap-2">
                        {% if shout.uid %}
                            {% if shout.muted_until %}
                                <form class="admin-op-form" data-success="Shout kisiti kaldirildi." method="post" action="{{ base_url() }}/api/admin/clear-shout-restriction">
                                    <input type="hidden" name="uid" value="{{ shout.uid }}">
                                    <button class="rounded-xl bg-emerald-600 hover:bg-emerald-500 px-3 py-2 text-[10px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.remove_restriction') }}</button>
                                </form>
                            {% else %}
                                <form class="admin-op-form" data-success="Kullanici 24 saat shouttan susturuldu." method="post" action="{{ base_url() }}/api/admin/mute-shout-user">
                                    <input type="hidden" name="uid" value="{{ shout.uid }}">
                                    <button class="rounded-xl bg-amber-600 hover:bg-amber-500 px-3 py-2 text-[10px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.mute_24h') }}</button>
                                </form>
                            {% endif %}
                        {% endif %}
                        {% if shout.is_deleted %}
                            <form class="admin-op-form" data-success="Shout tekrar gorunur hale getirildi." method="post" action="{{ base_url() }}/api/admin/reopen-shout">
                                <input type="hidden" name="shout_id" value="{{ shout.id }}">
                                <button class="rounded-xl bg-cyan-600 hover:bg-cyan-500 px-3 py-2 text-[10px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.reopen') }}</button>
                            </form>
                        {% else %}
                            <form class="admin-op-form" data-success="Shout gizlendi." method="post" action="{{ base_url() }}/api/admin/delete-shout">
                                <input type="hidden" name="shout_id" value="{{ shout.id }}">
                                <button class="rounded-xl bg-rose-600 hover:bg-rose-500 px-3 py-2 text-[10px] font-black uppercase tracking-[0.16em] text-white" type="submit">{{ t('admin.ops.hide') }}</button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            {% else %}
                <div class="rounded-xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-4 text-[12px] font-bold text-slate-500">{{ t('admin.ops.no_reported_shouts') }}</div>
            {% endfor %}
        </div>
    </div>

    <div class="glass-panel p-6">
        <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] mb-4">{{ t('admin.ops.recent_users') }}</h2>
        <div class="space-y-3">
            {% for user in recentUsers %}
                <div class="rounded-xl border border-[color:var(--brand-primary)]/12 bg-black/20 px-4 py-3 flex items-center justify-between gap-3">
                    <div>
                        <div class="text-[12px] font-black text-white">{{ user.nick }}</div>
                        <div class="mt-1 text-[9px] font-black uppercase tracking-[0.14em] text-slate-500">#{{ user.id }} / {{ user.email }}</div>
                    </div>
                    <div class="text-right">
                        <div class="text-[10px] font-black uppercase tracking-[0.14em] {% if user.status == 2 %}text-red-400{% elseif user.status == 1 %}text-emerald-400{% else %}text-amber-400{% endif %}">
                            {% if user.status == 2 %}Banli{% elseif user.status == 1 %}Aktif{% else %}Beklemede{% endif %}
                        </div>
                        <div class="mt-1 text-[9px] font-black uppercase tracking-[0.14em] text-slate-500">{{ user.created_at|date('d.m.Y H:i') }}</div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var forms = document.querySelectorAll('.admin-op-form');
    for (var i = 0; i < forms.length; i++) {
        forms[i].addEventListener('submit', function (event) {
            event.preventDefault();
            var form = event.currentTarget;
            var formData = $(form).serialize();

            $.post(form.getAttribute('action'), formData, function (res) {
                if (typeof res === 'string') { try { res = JSON.parse(res); } catch (e) {} }
                if (res && (res.error === true || res.error === 1)) {
                    alert('{{ t('admin.ops.error') }}: ' + (res.message || '{{ t('admin.ops.action_failed') }}'));
                    return;
                }
                alert(res.message || form.getAttribute('data-success') || '{{ t('admin.ops.done') }}');
                window.location.reload();
            }).fail(function () {
                alert('{{ t('admin.ops.connection_error') }}');
            });
        });
    }
});
</script>
{% endblock %}

