{% extends isAjax ? "common/ajaxbase.html.twig" : "common/base.html.twig" %}

{% block content %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<div class="space-y-6 animate-fade-in w-full max-w-4xl mx-auto">

    {% if isOhalActive %}
    <div class="bg-red-950/60 border-2 border-red-500 p-4 rounded-xl flex flex-col md:flex-row items-center justify-center gap-4 shadow-[0_0_30px_rgba(220,38,38,0.4)] animate-pulse relative overflow-hidden">
        <i class="fa-solid fa-triangle-exclamation text-red-500 text-4xl relative z-10 drop-shadow-[0_0_15px_rgba(220,38,38,0.8)]"></i>
        <div class="text-center md:text-left relative z-10">
            <div class="text-red-400 font-black uppercase tracking-[0.2em] text-lg">DİKKAT: ÜLKE GENELİNDE OHAL İLAN EDİLDİ!</div>
            <div class="text-red-200 text-[10px] font-bold tracking-widest mt-1">Meclis yetkileri askıya alınmıştır. Başkanın sunduğu tüm yasalar oylamasız onaylanmaktadır.</div>
        </div>
    </div>
    {% endif %}

    <div class="glass-panel p-6 border-l-4 border-indigo-500 bg-indigo-950/20 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 shadow-[0_0_20px_rgba(99,102,241,0.15)] relative overflow-hidden">
        <div class="flex items-center gap-4 relative z-10">
            <div class="w-14 h-14 rounded-xl bg-indigo-600/20 border border-indigo-500/30 flex items-center justify-center text-indigo-400 shadow-inner">
                <i class="fa-solid fa-file-signature text-2xl"></i>
            </div>
            <div>
                <h1 class="text-sm font-black text-white uppercase tracking-[0.2em] mb-1">Resmi Yasa Tasarısı</h1>
                <p class="text-[10px] text-slate-400 font-bold tracking-widest">Meclis Oylama Protokolü #{{ law.id }}</p>
                {# YENİ: ZAMAN AŞIMI GÖSTERGESİ #}
                {% if not law.finished %}
                    <p class="text-[10px] text-orange-400 font-black tracking-widest mt-1 animate-pulse"><i class="fa-solid fa-hourglass-half"></i> Oylama Bitiş Zamanı: {{ law.expires_at_formatted }}</p>
                {% endif %}
            </div>
        </div>
        <div class="bg-black/60 border border-indigo-500/30 px-5 py-2.5 rounded-xl text-center relative z-10 shadow-inner">
            <div class="text-[9px] text-indigo-400 font-black uppercase tracking-widest mb-1"><i class="fa-solid fa-users mr-1"></i> Toplam Katılım</div>
            <div class="text-lg font-black text-white leading-none">{{ law.yes + law.no }} <span class="text-xs text-slate-500 font-bold">/ {{ law.expected_votes }}</span></div>
        </div>
    </div>

    <div class="glass-panel p-8 md:p-10 bg-black/40 border border-white/5 text-center relative overflow-hidden shadow-xl">
        <i class="fa-solid fa-quote-left absolute top-4 left-4 text-4xl text-white/5 pointer-events-none"></i>
        <h2 class="text-lg md:text-2xl font-black text-white leading-relaxed tracking-wide relative z-10">{{ law.phrase }}</h2>
        <i class="fa-solid fa-quote-right absolute bottom-4 right-4 text-4xl text-white/5 pointer-events-none"></i>
    </div>

    {% if not law.finished %}
        {% if isPartyLeader %}
            <div class="bg-indigo-950/40 border border-indigo-500/50 p-5 rounded-xl flex items-center justify-between shadow-[0_0_15px_rgba(99,102,241,0.2)]">
                <div>
                    <div class="text-indigo-400 text-[10px] font-black uppercase tracking-widest flex items-center gap-2 mb-1">
                        <i class="fa-solid fa-crown"></i> Lider Komuta Merkezi
                    </div>
                    <div class="text-white text-sm font-bold">Partiniz için bağlayıcı bir <span class="text-indigo-300">Grup Kararı</span> belirleyin.</div>
                </div>
                <div class="flex gap-3">
                    <button onclick="setPartyWhip({{ law.id }}, 'yes')" class="px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all {{ whipDecision == 'yes' ? 'bg-green-600 text-white shadow-[0_0_15px_rgba(34,197,94,0.5)]' : 'bg-green-900/30 text-green-500 hover:bg-green-800/50 border border-green-500/30' }}">EVET EMRİ VER</button>
                    <button onclick="setPartyWhip({{ law.id }}, 'no')" class="px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all {{ whipDecision == 'no' ? 'bg-red-600 text-white shadow-[0_0_15px_rgba(220,38,38,0.5)]' : 'bg-red-900/30 text-red-500 hover:bg-red-800/50 border border-red-500/30' }}">HAYIR EMRİ VER</button>
                </div>
            </div>
        {% endif %}

        {% if whipDecision and not isPartyLeader %}
            <div class="bg-black border-l-4 {{ whipDecision == 'yes' ? 'border-green-500' : 'border-red-500' }} p-4 rounded-r-xl flex items-center gap-4 animate-pulse">
                <i class="fa-solid fa-bullhorn text-3xl {{ whipDecision == 'yes' ? 'text-green-500' : 'text-red-500' }}"></i>
                <div>
                    <div class="text-white text-sm font-black uppercase tracking-widest mb-1">⚠️ Parti Disiplini Uyarısı</div>
                    <div class="text-slate-300 text-[11px] font-bold">
                        Parti lideriniz bu yasa tasarısı için <span class="font-black text-lg {{ whipDecision == 'yes' ? 'text-green-400' : 'text-red-400' }} underline">{{ whipDecision == 'yes' ? 'EVET' : 'HAYIR' }}</span> oyu kullanmanızı emretmiştir. Karara uymamak ihraç sebebidir.
                    </div>
                </div>
            </div>
        {% endif %}
    {% endif %}

    {% if law.finished %}
        <div class="mt-8 animate-[bounce_0.5s_ease-out]">
            {% if law.yes > law.no %}
                <div class="bg-green-950/60 border-4 border-green-500 p-8 rounded-2xl text-center shadow-[0_0_50px_rgba(34,197,94,0.3)]">
                    <div class="text-6xl text-green-500 mb-4 drop-shadow-[0_0_15px_rgba(34,197,94,0.8)]"><i class="fa-solid fa-check-circle"></i></div>
                    <h2 class="text-4xl font-black text-green-400 uppercase tracking-[0.3em]">YASA KABUL EDİLDİ</h2>
                </div>
            {% else %}
                <div class="bg-red-950/60 border-4 border-red-600 p-8 rounded-2xl text-center shadow-[0_0_50px_rgba(220,38,38,0.3)]">
                    <div class="text-6xl text-red-500 mb-4 drop-shadow-[0_0_15px_rgba(220,38,38,0.8)]"><i class="fa-solid fa-times-circle"></i></div>
                    <h2 class="text-4xl font-black text-red-500 uppercase tracking-[0.3em]">YASA REDDEDİLDİ</h2>
                </div>
            {% endif %}
        </div>
        <div class="grid grid-cols-2 gap-6 mt-6 opacity-70">
            <div class="bg-black/40 border border-green-500/30 p-4 rounded-xl text-center">
                <div class="text-[10px] text-green-500 font-black uppercase tracking-widest">Kabul Oyu</div><div class="text-3xl font-black text-white">{{ law.yes }}</div>
            </div>
            <div class="bg-black/40 border border-red-500/30 p-4 rounded-xl text-center">
                <div class="text-[10px] text-red-500 font-black uppercase tracking-widest">Ret Oyu</div><div class="text-3xl font-black text-white">{{ law.no }}</div>
            </div>
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="glass-panel p-6 border-t-4 border-green-500 bg-green-950/10 flex flex-col items-center justify-center gap-6 shadow-[0_0_15px_rgba(34,197,94,0.05)]">
                <div class="text-[11px] font-black text-green-400 uppercase tracking-[0.3em] flex items-center gap-2"><i class="fa-solid fa-thumbs-up"></i> Kabul Oyları</div>
                <div class="text-6xl font-black text-white drop-shadow-md">{{ law.yes }}</div>
                <button id="btn-vote-yes" onclick="submitCustomVote({{ law.id }}, true)" {% if not isCongressist %}disabled{% endif %} class="w-full bg-green-600/20 hover:bg-green-500/40 text-green-400 hover:text-white py-4 rounded-xl text-[11px] font-black uppercase tracking-widest transition-all border border-green-500/30 disabled:opacity-30 disabled:cursor-not-allowed">
                    <i class="fa-solid fa-check mr-2"></i> Teklifi Onayla
                </button>
            </div>
            <div class="glass-panel p-6 border-t-4 border-red-500 bg-red-950/10 flex flex-col items-center justify-center gap-6 shadow-[0_0_15px_rgba(239,68,68,0.05)]">
                <div class="text-[11px] font-black text-red-400 uppercase tracking-[0.3em] flex items-center gap-2"><i class="fa-solid fa-thumbs-down"></i> Ret Oyları</div>
                <div class="text-6xl font-black text-white drop-shadow-md">{{ law.no }}</div>
                <button id="btn-vote-no" onclick="submitCustomVote({{ law.id }}, false)" {% if not isCongressist %}disabled{% endif %} class="w-full bg-red-600/20 hover:bg-red-500/40 text-red-400 hover:text-white py-4 rounded-xl text-[11px] font-black uppercase tracking-widest transition-all border border-red-500/30 disabled:opacity-30 disabled:cursor-not-allowed">
                    <i class="fa-solid fa-xmark mr-2"></i> Teklifi Reddet
                </button>
            </div>
        </div>
    {% endif %}

    <script>
        window.submitCustomVote = function(lawId, voteValue) {
            var targetBtn = voteValue === true ? $('#btn-vote-yes') : $('#btn-vote-no');
            targetBtn.prop('disabled', true).html('<i class="fa-solid fa-spinner animate-spin"></i> BAĞLANTI KURULUYOR...');
            $.ajax({
                url: "{{ base_url() }}/api/congress/law/vote", type: 'POST', data: { id: lawId, value: voteValue },
                success: function(res) {
                    if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                    if(res && res.error) { Swal.fire('Hata', res.message || 'Zaten oy kullandınız', 'error'); }
                    setTimeout(() => window.location.reload(), 1000);
                }
            });
        };

        window.setPartyWhip = function(lawId, decision) {
            Swal.fire({
                title: decision === 'yes' ? 'EVET Emri Verilecek' : 'HAYIR Emri Verilecek',
                text: "Tüm parti üyelerine bu yasada bu yönde oy kullanmaları emredilecek. Onaylıyor musunuz?",
                icon: 'warning', showCancelButton: true, confirmButtonColor: '#6366f1', confirmButtonText: 'Emri Yayınla'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post("{{ base_url() }}/api/congress/law/whip", { law_id: lawId, decision: decision }, function(res) {
                        Swal.fire('Başarılı', 'Grup kararı parti teşkilatına iletildi!', 'success').then(() => window.location.reload());
                    }).fail(function() { Swal.fire('Hata', 'İletişim koptu', 'error'); });
                }
            });
        };
    </script>
</div>
{% endblock %}