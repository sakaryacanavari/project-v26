{% extends isAjax ? "common/ajaxbase.html.twig" : "common/base.html.twig" %}

{% block content %}
<div class="flex items-center justify-center min-h-[60vh] animate-fade-in w-full">
    <div class="glass-panel max-w-lg w-full p-8 border-t-4 border-red-600 bg-black/60 shadow-[0_0_30px_rgba(220,38,38,0.15)] relative overflow-hidden text-center">
        
        {# Arka Plan Simgesi #}
        <i class="fa-solid fa-triangle-exclamation absolute -right-10 -bottom-10 text-9xl text-red-600/5 pointer-events-none"></i>

        {# Kilit İkonu (Animasyonlu) #}
        <div class="w-20 h-20 mx-auto rounded-full bg-red-600/20 flex items-center justify-center border-2 border-red-500/50 shadow-[0_0_20px_rgba(220,38,38,0.4)] mb-6 animate-pulse">
            <i class="fa-solid fa-lock text-3xl text-red-500"></i>
        </div>

        <h1 class="text-2xl font-black text-white uppercase tracking-[0.2em] mb-2">GİZLİ BÖLGE: ERİŞİM REDDEDİLDİ</h1>
        <div class="h-1 w-16 bg-red-600 mx-auto rounded mb-4"></div>

        <p class="text-xs text-slate-300 font-bold tracking-widest leading-relaxed mb-8">
            Ulusal Meclis komuta merkezine ve yasama tutanaklarına erişim yetkiniz bulunmuyor. Bu alana sadece seçilmiş <span class="text-red-400">Kongre Üyeleri</span> girebilir. Siyasi kariyere adım atmak ve meclis dokunulmazlığı kazanmak için bir organizasyona katılın.
        </p>

        {# Yönlendirme Butonları #}
        <div class="flex flex-col sm:flex-row gap-4 justify-center relative z-10">
            <a href="{{ path_for('partyList') }}" class="bg-indigo-600/20 hover:bg-indigo-500/40 text-indigo-400 hover:text-white px-6 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all border border-indigo-500/30 flex items-center justify-center gap-2 shadow-lg shadow-indigo-500/10">
                <i class="fa-solid fa-users-viewfinder text-lg"></i> Siyasi Partileri İncele
            </a>
            <a href="{{ path_for('home') }}" class="bg-slate-800/50 hover:bg-slate-700 text-slate-300 px-6 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all border border-white/5 flex items-center justify-center gap-2">
                <i class="fa-solid fa-house"></i> Karargaha Dön
            </a>
        </div>
        
    </div>
</div>
{% endblock %}