{% extends isAjax ? "common/ajaxbase.html.twig" : "common/base.html.twig" %}

{% block content %}
<style>
    .archive-shell{background:linear-gradient(180deg,rgba(8,12,22,.92),rgba(4,8,16,.96));border:1px solid color-mix(in srgb,var(--brand-primary) 18%,rgba(255,255,255,.04));border-radius:22px;box-shadow:inset 0 1px 0 rgba(255,255,255,.03),0 20px 40px -18px rgba(0,0,0,.8)}
    .archive-card{background:rgba(5,10,18,.82);border:1px solid rgba(255,255,255,.04);border-radius:18px}
    .archive-chip{display:inline-flex;align-items:center;gap:8px;padding:9px 13px;border-radius:999px;background:rgba(8,12,20,.72);border:1px solid color-mix(in srgb,var(--brand-primary) 14%,rgba(255,255,255,.03));color:#cbd5e1;font-size:10px;font-weight:800;letter-spacing:.12em;text-transform:uppercase}
    .archive-chip.active{background:color-mix(in srgb,var(--brand-primary) 18%,rgba(8,12,20,.88));color:#fff;border-color:color-mix(in srgb,var(--brand-primary) 34%,rgba(255,255,255,.05))}
    .archive-history{background:linear-gradient(180deg,rgba(2,6,14,.74),rgba(5,10,18,.88));border:1px solid rgba(255,255,255,.04);border-radius:14px;padding:14px}
    .archive-mini{display:inline-flex;align-items:center;gap:6px;padding:6px 9px;border-radius:999px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.05);font-size:9px;font-weight:900;letter-spacing:.1em;text-transform:uppercase;color:#cbd5e1}
</style>

{% macro archive_item(item) %}
<div class="archive-history space-y-3">
    <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
            <div class="text-[10px] font-black uppercase tracking-[0.16em] text-[color:var(--brand-primary)]">Secim Sonucu</div>
            <div class="text-sm font-black uppercase tracking-[0.08em] text-white mt-1 truncate">{{ item.winner_nick|default('Kayit yok') }}</div>
            <div class="text-[10px] font-bold text-slate-500 mt-1">{{ item.finished_at }}</div>
        </div>
        <div class="text-right shrink-0">
            <div class="text-lg font-black text-white">{{ item.winner_votes|default(0) }}</div>
            <div class="text-[9px] font-bold uppercase tracking-[0.14em] text-slate-500">Kazanan Oyu</div>
        </div>
    </div>
    <div class="flex flex-wrap gap-2">
        <span class="archive-mini"><i class="fa-solid fa-check-to-slot"></i>{{ item.total_votes|default(0) }} toplam oy</span>
        {% if item.candidate_count is defined %}
            <span class="archive-mini"><i class="fa-solid fa-users"></i>{{ item.candidate_count }} aday</span>
        {% endif %}
        {% if item.seat_count is defined and item.seat_count %}
            <span class="archive-mini"><i class="fa-solid fa-landmark"></i>{{ item.seat_count }} sandalye</span>
        {% endif %}
    </div>
    {% if item.summary is defined and item.summary %}
        <div class="space-y-2">
            <div class="text-[9px] font-black uppercase tracking-[0.16em] text-slate-400">Aday Siralamasi</div>
            <div class="flex flex-wrap gap-2">
                {% for row in item.summary|slice(0, 6) %}
                    <span class="archive-mini">{{ row.nick|default('Aday') }} · {{ row.votes|default(0) }}</span>
                {% endfor %}
            </div>
        </div>
    {% elseif item.winners is defined and item.winners %}
        <div class="space-y-2">
            <div class="text-[9px] font-black uppercase tracking-[0.16em] text-slate-400">Secilenler</div>
            <div class="flex flex-wrap gap-2">
                {% for row in item.winners|slice(0, 6) %}
                    <span class="archive-mini">#{{ loop.index }} · {{ row.votes|default(0) }} oy</span>
                {% endfor %}
            </div>
        </div>
    {% endif %}
</div>
{% endmacro %}

<div class="home-theme-surface space-y-6 w-full max-w-[1500px] mx-auto">
    <section class="archive-shell p-6 md:p-8 space-y-5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div class="space-y-2">
                <div class="text-[10px] font-black uppercase tracking-[0.3em] text-[color:var(--brand-primary)]">Secim Arsivi</div>
                <h1 class="text-2xl md:text-3xl font-black uppercase tracking-[0.14em] text-white">Tum Sonuclar ve Gecmis Turlar</h1>
                <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-slate-500">Cumhurbaskanligi, parti liderligi ve kongre secim gecmisini tek ekranda incele.</p>
            </div>
            <div class="flex flex-wrap gap-2">
                <a href="{{ base_url() }}/elections/archive" class="archive-chip {{ activeType == 'all' ? 'active' : '' }}">Tum Arsiv</a>
                <a href="{{ base_url() }}/elections/archive/presidential" class="archive-chip {{ activeType == 'presidential' ? 'active' : '' }}">Cumhurbaskanligi</a>
                <a href="{{ base_url() }}/elections/archive/party" class="archive-chip {{ activeType == 'party' ? 'active' : '' }}">Parti Liderligi</a>
                <a href="{{ base_url() }}/elections/archive/congress" class="archive-chip {{ activeType == 'congress' ? 'active' : '' }}">Kongre</a>
            </div>
        </div>
    </section>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
        {% for section in sections %}
            <section class="archive-shell p-6 space-y-4">
                <div class="flex items-center justify-between gap-3 border-b border-white/5 pb-4">
                    <div>
                        <div class="text-[10px] font-black uppercase tracking-[0.22em] text-[color:var(--brand-primary)]">Arsiv</div>
                        <div class="text-lg font-black uppercase tracking-[0.1em] text-white mt-1">{{ section.title }}</div>
                    </div>
                    <a href="{{ base_url() }}/elections" class="archive-chip">Secim Merkezine Don</a>
                </div>

                <div class="space-y-3">
                    {% for item in section.items %}
                        {{ _self.archive_item(item) }}
                    {% else %}
                        <div class="archive-card p-5 text-center text-[10px] font-bold uppercase tracking-[0.12em] text-slate-500">{{ section.empty }}</div>
                    {% endfor %}
                </div>
            </section>
        {% endfor %}
    </div>
</div>
{% endblock %}
