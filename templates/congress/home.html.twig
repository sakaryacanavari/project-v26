        });
    });
};

window.toggleLawDropdown = function() {
    var dropdown = document.getElementById('custom-law-dropdown');
    if (!dropdown) return;

    var isHidden = dropdown.classList.contains('hidden');
    dropdown.classList.toggle('hidden', !isHidden);
    dropdown.style.display = isHidden ? 'block' : 'none';
};
$(document).on('click', function(e) { 
    if (!$(e.target).closest('.custom-dropdown-container').length) { 
        var dropdown = document.getElementById('custom-law-dropdown');
        if (dropdown && !dropdown.classList.contains('hidden')) {
            dropdown.classList.add('hidden');
            dropdown.style.display = 'none';
        }
    } 
});

$('.law-option').on('click', function() {
    if ($(this).data('roleLock') === 'congress') {
        Swal.fire('Bilgi', 'Bu yasa turu sadece aktif milletvekilleri tarafindan sunulabilir.', 'info');
        return;
    }
    var val = $(this).data('value');
    $('#law_type_input').val(val);
    $('#selected-law-text').html($(this).html()).removeClass('text-slate-400').addClass('text-white');
    $('#custom-law-dropdown').addClass('hidden');
    
    // YENİ DÜZENLEME: Tüm kutuları gizle ve sıfırla (law_region eklendi)
    $('#law_uid_wrapper, #law_country_wrapper, #law_amount_wrapper, #torba_wrapper, #law_region_wrapper').addClass('hidden');
    $('#law_uid_input, #law_country_input, #law_amount_input, #law_region_input').val('');
    
    var v = val.toString();
    if(['3', '4', '6', '8', '13'].includes(v)) $('#law_amount_wrapper').removeClass('hidden');
    if(['1', '2', '7', '13', '19'].includes(v)) $('#law_country_wrapper').removeClass('hidden');
    if(['5', '6', '11', '15', '16'].includes(v)) $('#law_uid_wrapper').removeClass('hidden');
    if(v === '17') $('#torba_wrapper').removeClass('hidden');
    if(v === '1') $('#law_region_wrapper').removeClass('hidden'); // SADECE SAVAŞ İLANINDA AÇILIR!
});

window.filterLaws = function(status, tab) {
    $('.law-tab').removeClass('active bg-indigo-600/50 text-white').addClass('text-slate-400');
    $(tab).removeClass('text-slate-400').addClass('active bg-indigo-600/50 text-white');
    if (status === 'all') { $('.law-card').fadeIn(300); } else { $('.law-card').hide(); $('.law-card[data-status="' + status + '"]').fadeIn(300); }
};

window.submitCustomLaw = function() {
    var $btn = $('#btn-submit-law'); var originalHtml = $btn.html();
    var typeVal = $('#law_type_input').val(); var reasonVal = $('#law_reason_input').val().trim();
    if(!typeVal || reasonVal.length < 5) { Swal.fire('Hata', 'Tür seçin ve geçerli gerekçe yazın.', 'warning'); return; }
    
    $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner animate-spin"></i> İŞLENİYOR...');

    $.ajax({
        url: "{{ base_url() }}/api/congress/law/propose",
        type: 'POST',
        data: {
            type: typeVal, reason: reasonVal, amount: $('#law_amount_input').val() || 0,
            currency: 'local', country: $('#law_country_input').val() || 0, uid: $('#law_uid_input').val() || 0,
            region_id: $('#law_region_input').val() || null, // YENİ VERİ EKLENDİ
            torba_w: $('#torba_w_input').val() || 0, torba_m: $('#torba_m_input').val() || 0, torba_mw: $('#torba_mw_input').val() || 0,
            csrf_token: $('meta[name="csrf-token"]').attr('content') 
        },
        success: function(res) {
            if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
            if (res && res.error) {
                Swal.fire({ icon: 'error', title: 'İşlem Reddedildi', html: '<div class="text-red-400 font-bold">' + (res.message || "Hata") + '</div>', background: '#1e1e2f', color: '#fff' });
                $btn.prop('disabled', false).html(originalHtml);
            } else {
                Swal.fire({ icon: 'success', title: 'Başarılı!', text: 'Yasa sunuldu.', background: '#1e1e2f', color: '#fff', timer: 2000, showConfirmButton: false }).then(() => location.reload());
            }
        },
        error: function(xhr) {
            console.error("AJAX Hatası:", xhr.responseText); 
            Swal.fire({ icon: 'error', title: 'Sistem Hatası', text: 'Bağlantı koptu veya sunucu isteği reddetti.', background: '#1e1e2f', color: '#fff' });
            $btn.prop('disabled', false).html(originalHtml);
        }
    });
};

window.submitCongressApplication = function() {
    Swal.fire({
        title: 'Kongre Adayligi',
        text: 'Adayligini secim listesine gondermek istiyor musun? Oylama 48 saat acik kalacak.',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Aday Ol',
        cancelButtonText: 'Iptal',
        background: '#0f172a',
        color: '#fff'
    }).then((result) => {
        if (!result.isConfirmed) return;
        $.post("{{ base_url() }}/api/congress/candidate/apply", {
            csrf_token: $('meta[name="csrf-token"]').attr('content')
        }, function(res) {
            if (res && res.error) {
                Swal.fire('Hata', res.message || 'Adaylik gonderilemedi.', 'error');
                return;
            }
            Swal.fire({ icon: 'success', title: 'Adaylik kaydedildi', text: 'Secim listesine eklendin.', background: '#1e1e2f', color: '#fff', timer: 1800, showConfirmButton: false }).then(() => location.reload());
        });
    });
};

window.voteCongressCandidate = function(candidateId, voteValue) {
    Swal.fire({
        title: voteValue ? 'Adaya Destek Ver' : 'Adayi Reddet',
        text: voteValue ? 'Bu adayin kongreye girmesini destekliyorsun.' : 'Bu adayliga red oyu veriyorsun.',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: voteValue ? 'Destekle' : 'Reddet',
        cancelButtonText: 'Iptal',
        background: '#0f172a',
        color: '#fff'
    }).then((result) => {
        if (!result.isConfirmed) return;
        $.post("{{ base_url() }}/api/congress/candidate/vote", {
            candidate: candidateId,
            vote: voteValue ? 1 : 0,
            csrf_token: $('meta[name="csrf-token"]').attr('content')
        }, function(res) {
            if (res && res.error) {
                Swal.fire('Hata', res.message || 'Oy kaydedilemedi.', 'error');
                return;
            }
            Swal.fire({ icon: 'success', title: 'Oy kaydedildi', text: voteValue ? 'Destek oyun alindi.' : 'Red oyun alindi.', background: '#1e1e2f', color: '#fff', timer: 1600, showConfirmButton: false }).then(() => location.reload());
        });
    });
};

window.resignCongressSeat = function() {
    Swal.fire({
        title: 'Kongre Pozisyonundan Ayril',
        text: 'Aktif adayligin veya kongre uyeligin varsa sonlandirilacak. Emin misin?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc2626',
        confirmButtonText: 'Ayril',
        cancelButtonText: 'Iptal',
        background: '#0f172a',
        color: '#fff'
    }).then((result) => {
        if (!result.isConfirmed) return;
        $.post("{{ base_url() }}/api/congress/candidate/resign", {
            csrf_token: $('meta[name="csrf-token"]').attr('content')
        }, function(res) {
            if (res && res.error) {
                Swal.fire('Hata', res.message || 'Ayrilma islemi basarisiz.', 'error');
                return;
            }
            Swal.fire({ icon: 'success', title: 'Ayrilma tamamlandi', text: 'Secim pozisyonun sonlandirildi.', background: '#1e1e2f', color: '#fff', timer: 1600, showConfirmButton: false }).then(() => location.reload());
        });
    });
};

window.vetoLawByPresident = function(lawId) {
    Swal.fire({
        title: 'Başkanlık Vetosu', text: "Yasayı veto ederseniz süre sıfırlanır ve %66 mutlak oy gerekir! Onaylıyor musunuz?",
        icon: 'warning', showCancelButton: true, confirmButtonColor: '#dc2626', confirmButtonText: 'Evet, VETO ET!'
    }).then((result) => {
        if (result.isConfirmed) {
            $.post("{{ base_url() }}/api/congress/law/veto", { law_id: lawId, csrf_token: $('meta[name="csrf-token"]').attr('content') }, function(res) {
                if (res.error) Swal.fire('Hata', res.message, 'error'); else location.reload();
            });
        }
    });
};

window.callEmergency = function() {
    Swal.fire({
        title: 'Acil Durum İlanı', text: "Ülkede 48 saatlik Acil Durum ilan edilecek. Tüm barajlar %15 düşecek. Onaylıyor musunuz?",
        icon: 'warning', showCancelButton: true, confirmButtonColor: '#f97316', confirmButtonText: 'Başlat'
    }).then((result) => {
        if (result.isConfirmed) {
            $.post("{{ base_url() }}/api/congress/emergency", { csrf_token: $('meta[name="csrf-token"]').attr('content') }, function(res) {
                if (res.error) Swal.fire('Hata', res.message, 'error'); else location.reload();
            });
        }
    });
};

window.revokeEmergencyState = function(type) {
    let title = ''; let text = '';
    
    if(type === 'mobilization') { title = 'SEFERBERLİĞİ BİTİR'; text = 'Milli Seferberlik durumu anında iptal edilecek. Savaş hasarı ve tüketim normale dönecek. Emin misiniz?'; }
    else if(type === 'borders') { title = 'SINIRLARI AÇ'; text = 'Ülke sınırları tekrar açılacak ve yeni vatandaş alımı başlayacak. Emin misiniz?'; }
    else if(type === 'emergency') { title = 'ACİL DURUMU İPTAL ET'; text = 'Acil durum oturumu sona erecek ve yasa geçme barajları eski haline dönecek. Emin misiniz?'; }
    else if(type === 'ohal') { title = 'OHALİ KALDIR'; text = 'Olağanüstü Hal durumu sona erecek. Meclis yetkileri tekrar aktif olacak. Emin misiniz?'; }

    Swal.fire({
        title: title, text: text, icon: 'warning',
        showCancelButton: true, confirmButtonColor: '#dc2626', confirmButtonText: 'EVET, SONLANDIR', cancelButtonText: 'İPTAL',
        background: '#0f172a', color: '#fff'
    }).then((result) => {
        if (result.isConfirmed) {
            Swal.fire({ title: 'İŞLENİYOR...', background: '#020617', color: '#fff', showConfirmButton: false, didOpen: () => { Swal.showLoading(); } });
            
            $.post("{{ base_url() }}/api/congress/revoke_state", { 
                type: type, 
                csrf_token: $('meta[name="csrf-token"]').attr('content') 
            }, function(res) {
                if (typeof res === 'string') { try { res = JSON.parse(res); } catch(e) {} }
                if (res && res.error) {
                    Swal.fire({ icon: 'error', title: 'ERİŞİM REDDEDİLDİ', text: res.message, background: '#020617', color: '#fff' });
                } else {
                    location.reload();
                }
            }).fail(function() {
                Swal.fire({ icon: 'error', title: 'SİSTEM HATASI', text: 'Karargah veritabanına bağlanılamadı.', background: '#020617', color: '#fff' });
            });
        }
    });
};
</script>
{% endblock %}

