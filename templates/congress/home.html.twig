                    {% else %}
                        <div class="text-center py-6 text-slate-500 opacity-70"><i class="fa-solid fa-landmark text-3xl mb-2"></i><div class="text-[10px] font-black uppercase tracking-widest">Kayitli temsilci yok</div><div class="mt-2 text-[9px] font-medium normal-case tracking-normal">Temsilci kayitlari olustugunda burada listelenir.</div></div>
                    {% endif %}
                </div>
            </div>
        </aside>

        <section class="xl:col-span-7">
            <div class="glass-panel min-h-[500px] flex flex-col">
                <div class="p-6 border-b border-white/5 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-black/20">
                    <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] flex items-center gap-2"><i class="fa-solid fa-box-archive text-slate-500"></i> Son Yasa Tasarıları & Oylamalar</h2>
                    <div class="flex items-center gap-3">
                        <div class="flex bg-black/40 p-1 rounded-lg border border-white/5 hidden sm:flex">
                            <button onclick="filterLaws('all', this)" class="law-tab active px-3 py-1.5 rounded text-[9px] font-black uppercase text-white bg-indigo-600/50">Tümü</button>
                            <button onclick="filterLaws('active', this)" class="law-tab px-3 py-1.5 rounded text-[9px] font-black uppercase text-slate-400">Aktif</button>
                            <button onclick="filterLaws('accepted', this)" class="law-tab px-3 py-1.5 rounded text-[9px] font-black uppercase text-slate-400">Kabul</button>
                            <button onclick="filterLaws('rejected', this)" class="law-tab px-3 py-1.5 rounded text-[9px] font-black uppercase text-slate-400">Red</button>
                        </div>
                    </div>
                </div>

                <div class="p-6 flex-1 bg-black/10">
                    {% if latestLaws|length > 0 %}
                        <div class="space-y-3" id="law-list-container">
                            {% for law in latestLaws %}
                                {% set isFinished = law.finished %}
                                {% set totalVotes = law.yes + law.no %}
                                {% set yesRatio = totalVotes > 0 ? (law.yes / totalVotes) * 100 : 0 %}
                                {% set isAccepted = isFinished and yesRatio >= law.required_majority and law.yes > law.no %}
                                {% set isRejected = isFinished and not isAccepted %}
                                {% set lawStatus = isAccepted ? 'accepted' : (isRejected ? 'rejected' : 'active') %}
                                
                                <div class="relative group block law-card" data-status="{{ lawStatus }}">
                                    <div class="bg-black/40 border {% if law.is_vetoed %} border-red-500/80 shadow-[0_0_15px_rgba(220,38,38,0.4)] {% elseif isAccepted %} border-green-500/50 shadow-[0_0_10px_rgba(34,197,94,0.1)] {% elseif isRejected %} border-red-900/50 bg-red-950/20 {% else %} border-white/5 {% endif %} p-4 rounded-xl flex items-center justify-between transition-all group-hover:bg-black/60">
                                        <a href="{{ path_for('congressLaw', {id : law.id}) }}" class="flex items-center gap-4 flex-1">
                                            <div class="w-10 h-10 rounded-lg bg-slate-800/50 flex items-center justify-center border transition-colors flex-shrink-0 {% if law.is_vetoed %} border-red-500/80 text-red-500 animate-pulse {% elseif isAccepted %} border-green-500/30 text-green-500 {% elseif isRejected %} border-red-900/50 text-red-500 {% else %} border-white/5 text-slate-400 group-hover:text-white {% endif %}">
                                                <i class="fa-solid {% if law.type == 17 %}fa-box-open{% elseif law.type == 19 %}fa-ban{% elseif law.type == 20 %}fa-passport{% elseif law.type == 21 %}fa-jet-fighter{% elseif law.is_vetoed %}fa-ban{% elseif isAccepted %}fa-check-double{% elseif isRejected %}fa-xmark{% else %}fa-file-contract{% endif %}"></i>
                                            </div>
                                            <div class="flex-1 min-w-0">
                                                <div class="text-[11px] font-black tracking-widest leading-snug mb-1 flex items-center gap-2 truncate {% if law.type == 17 %}text-fuchsia-300{% elseif law.type == 21 %}text-blue-300{% elseif isAccepted %}text-green-100{% elseif isRejected %}text-red-200{% else %}text-slate-300{% endif %}">
                                                    {{ law.phrase }}
                                                    {% if law.is_vetoed %}<span class="bg-red-600 text-white text-[8px] px-1.5 py-0.5 rounded shadow-[0_0_10px_rgba(220,38,38,0.8)]"><i class="fa-solid fa-gavel"></i> VETO EDİLDİ</span>{% endif %}
                                                    {% if isAccepted %} <span class="bg-green-500/20 text-green-400 text-[8px] px-1.5 py-0.5 rounded">KABUL</span>{% elseif isRejected %} <span class="bg-red-900/40 text-red-400 text-[8px] px-1.5 py-0.5 rounded">RED</span>{% endif %}
                                                </div>
                                                <div class="text-[8px] font-bold uppercase text-slate-500 flex items-center gap-2">
                                                    <span class="text-cyan-400 border border-cyan-500/30 bg-cyan-950/30 px-1.5 py-0.5 rounded" title="Geçmesi için gereken oran">%{{ law.required_majority }} Gerekli</span>
                                                    <span>|</span>
                                                    {% if isFinished %} <span class="text-slate-400">{{ law.yes }} EVET - {{ law.no }} HAYIR</span> 
                                                    {% else %} <span class="text-orange-400 animate-pulse"><i class="fa-solid fa-hourglass-half"></i> {{ law.expires_at_formatted }} Bitiş</span> {% endif %}
                                                </div>
                                            </div>
                                        </a>
                                        {% if not isFinished and law.has_my_vote %}
                                            <span class="shrink-0 rounded-lg bg-black/35 px-2 py-1 text-[8px] font-black uppercase tracking-widest text-[color:var(--brand-primary)]">Oyun: {{ law.my_vote ? 'Kabul' : 'Ret' }}</span>
                                        {% elseif not isFinished and law.can_vote %}
                                            <span class="shrink-0 rounded-lg bg-emerald-500/10 px-2 py-1 text-[8px] font-black uppercase tracking-widest text-emerald-400">Oy kullanabilirsin</span>
                                        {% endif %}
                                        <div class="flex items-center gap-3">
                                            {% if isPresident and not isFinished and not law.is_vetoed %}
                                                <button onclick="vetoLawByPresident({{ law.id }})" class="bg-red-900/40 hover:bg-red-600 border border-red-500/50 text-red-500 hover:text-white px-3 py-1.5 rounded text-[8px] font-black uppercase tracking-widest transition-all z-20 relative"><i class="fa-solid fa-ban"></i> VETO ET</button>
                                            {% endif %}
                                            <a href="{{ path_for('congressLaw', {id : law.id}) }}" class="text-slate-600 hover:text-indigo-400"><i class="fa-solid fa-chevron-right text-sm transition-transform"></i></a>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="h-full flex flex-col items-center justify-center py-20 text-center opacity-70"><i class="fa-solid fa-folder-open text-4xl text-slate-600 mb-4"></i><div class="text-[11px] font-black text-slate-400 uppercase">Aktif Tasarı Yok</div></div>
                    {% endif %}
                </div>
            </div>
        </section>
    </div>
</div>

<script>
if (window.jQuery) {
    $.ajaxSetup({ headers: { 'X-CSRF-TOKEN': $('meta[name="csrf-token"]').attr('content') } });
}

