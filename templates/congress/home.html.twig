function setupCongressLocalization() {
    const replaceText = (selector, text) => {
        const el = document.querySelector(selector);
        if (el) el.textContent = text;
    };

    replaceText('.bg-blue-950\\/60 .text-blue-400.font-black', congressUiI18n.mobilizationTitle);
    replaceText('.bg-blue-950\\/60 .text-blue-200', congressUiI18n.mobilizationCopy);
    replaceText('button[onclick=\"revokeEmergencyState(\\'mobilization\\')\"]', congressUiI18n.mobilizationEnd);
    replaceText('.bg-zinc-950\\/60 .text-zinc-400.font-black', congressUiI18n.bordersTitle);
    replaceText('.bg-zinc-950\\/60 .text-zinc-300', congressUiI18n.bordersCopy);
    replaceText('button[onclick=\"revokeEmergencyState(\\'borders\\')\"]', congressUiI18n.bordersEnd);
    replaceText('.bg-orange-950\\/60 .text-orange-400.font-black', congressUiI18n.emergencyTitle);
    replaceText('.bg-orange-950\\/60 .text-orange-200', congressUiI18n.emergencyCopy);
    const emergencyUntil = document.querySelector('.bg-orange-950\\/60 .text-orange-500');
    if (emergencyUntil && emergencyUntil.textContent.includes(':')) {
        emergencyUntil.textContent = `${congressUiI18n.emergencyUntil}: ${emergencyUntil.textContent.split(':').slice(1).join(':').trim()}`;
    }
    replaceText('button[onclick=\"revokeEmergencyState(\\'emergency\\')\"]', congressUiI18n.emergencyEnd);
    replaceText('.bg-red-950\\/60 .text-red-400.font-black', congressUiI18n.ohalTitle);
    replaceText('.bg-red-950\\/60 .text-red-200', congressUiI18n.ohalCopy);
    replaceText('button[onclick=\"revokeEmergencyState(\\'ohal\\')\"]', congressUiI18n.ohalEnd);
    replaceText('.border-amber-500 h2 span', congressUiI18n.commandTitle);
    replaceText('button[onclick=\"callEmergency()\"]', congressUiI18n.commandStartEmergency);
    replaceText('.border-amber-500 .text-amber-200\\/70', congressUiI18n.commandSubtitle);
    replaceText('.border-cyan-500 h2', congressUiI18n.speakerTitle);
    replaceText('.border-cyan-500 .text-cyan-200\\/70', congressUiI18n.speakerSubtitle);
    replaceText('.backdrop-blur-\\[4px\\] h2', congressUiI18n.lockedTitle);
    replaceText('.backdrop-blur-\\[4px\\] p', congressUiI18n.lockedSubtitle);
    const proposalTitle = document.querySelector('#propose-law-box')?.closest('.glass-panel')?.querySelector('.mb-6 h2');
    if (proposalTitle) proposalTitle.textContent = congressUiI18n.proposalTitle;
    const proposalLabel = document.querySelector('label[for], #propose-law-box .custom-dropdown-container label');
    if (proposalLabel) proposalLabel.textContent = congressUiI18n.protocol;
    const selectedLawText = document.getElementById('selected-law-text');
    if (selectedLawText && selectedLawText.textContent.includes('Yasa')) selectedLawText.textContent = congressUiI18n.selectType;
    const proposalSubmit = document.getElementById('btn-submit-law');
    if (proposalSubmit) proposalSubmit.textContent = congressUiI18n.proposalSubmit;
    const uidInput = document.getElementById('law_uid_input');
    if (uidInput) uidInput.placeholder = congressUiI18n.targetUid;
    const countryInput = document.getElementById('law_country_input');
    if (countryInput) countryInput.placeholder = congressUiI18n.targetCountry;
    const regionInput = document.getElementById('law_region_input');
    if (regionInput) regionInput.placeholder = congressUiI18n.targetRegion;
    const amountInput = document.getElementById('law_amount_input');
    if (amountInput) amountInput.placeholder = congressUiI18n.amount;
    const reasonInput = document.getElementById('law_reason_input');
    if (reasonInput) reasonInput.placeholder = congressUiI18n.reason;
    const torbaTitle = document.querySelector('#torba_wrapper .text-fuchsia-400');
    if (torbaTitle) torbaTitle.textContent = congressUiI18n.reformTitle;
    const torbaW = document.getElementById('torba_w_input');
    if (torbaW) torbaW.placeholder = congressUiI18n.reformWorkTax;
    const torbaM = document.getElementById('torba_m_input');
    if (torbaM) torbaM.placeholder = congressUiI18n.reformManagerTax;
    const torbaMw = document.getElementById('torba_mw_input');
    if (torbaMw) torbaMw.placeholder = congressUiI18n.reformMinWage;
    replaceText('.border-indigo-500 h2', congressUiI18n.membersTitle);
    replaceText('.text-slate-400.uppercase', congressUiI18n.membersEmpty);
    const lawsPanelTitle = document.querySelector('section.xl\\:col-span-7 h2');
    if (lawsPanelTitle) lawsPanelTitle.textContent = congressUiI18n.lawsTitle;
    document.querySelectorAll('.law-tab').forEach((tab) => {
        const action = tab.getAttribute('onclick') || '';
        if (action.includes(\"'all'\")) tab.textContent = congressUiI18n.filterAll;
        if (action.includes(\"'active'\")) tab.textContent = congressUiI18n.filterActive;
        if (action.includes(\"'accepted'\")) tab.textContent = congressUiI18n.filterAccepted;
        if (action.includes(\"'rejected'\")) tab.textContent = congressUiI18n.filterRejected;
    });
    document.querySelectorAll('.law-option').forEach((option) => {
        const value = option.dataset.value;
        const icon = option.querySelector('i');
        const iconHtml = icon ? icon.outerHTML + ' ' : '';
        const map = {
            '1': congressUiI18n.lawNaturalEnemy,
            '2': congressUiI18n.lawMpp,
            '3': congressUiI18n.lawWorkTax,
            '4': congressUiI18n.lawManagerTax,
            '5': congressUiI18n.lawImpeachment,
            '6': congressUiI18n.lawFundTransfer,
            '7': congressUiI18n.lawCeasefire,
            '8': congressUiI18n.lawMinimumWage,
            '11': congressUiI18n.lawElectSpeaker,
            '13': congressUiI18n.lawCustomsTax,
            '14': congressUiI18n.lawEarlyElection,
            '15': congressUiI18n.lawRemoveImmunity,
            '16': congressUiI18n.lawElectPresident,
            '17': congressUiI18n.lawBagBill,
            '19': congressUiI18n.lawEmbargo,
            '20': congressUiI18n.lawCloseBorders,
            '21': congressUiI18n.lawMobilization,
            '22': congressUiI18n.lawBlackout,
            '9': congressUiI18n.lawOhal
        };
        if (map[value]) option.innerHTML = iconHtml + map[value];
    });
}

try {
    setupCongressLocalization();
} catch (error) {
    // UI metinleri başarısız olsa bile yasa seçimi ve gönderme akışı çalışmaya devam eder.
    console.warn('Congress UI localization skipped.', error);
}

window.submitPresidentialApplication = function() {
    Swal.fire({
        title: 'Baskanliga Aday Ol',
        html: `
            <div class="space-y-3 text-left">
                <input id="swal-campaign-title" class="swal2-input" placeholder="Kampanya basligi">
                <textarea id="swal-campaign-message" class="swal2-textarea" placeholder="Kisa propaganda metni"></textarea>
            </div>
        `,
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Aday Ol',
        cancelButtonText: 'Iptal',
        background: '#0f172a',
        color: '#fff',
        preConfirm: () => {
            const campaignTitle = document.getElementById('swal-campaign-title').value.trim();
            const campaignMessage = document.getElementById('swal-campaign-message').value.trim();
            if (campaignTitle.length < 3) {
                Swal.showValidationMessage('Kampanya basligi en az 3 karakter olmali.');
                return false;
            }
            if (campaignMessage.length < 12) {
                Swal.showValidationMessage('Propaganda metni en az 12 karakter olmali.');
                return false;
            }
            return { campaignTitle, campaignMessage };
        }
    }).then((result) => {
        if (!result.isConfirmed || !result.value) return;
        $.post("{{ base_url() }}/api/congress/presidential/apply", {
            campaign_title: result.value.campaignTitle,
            campaign_message: result.value.campaignMessage,
            csrf_token: $('meta[name="csrf-token"]').attr('content')
        }, function(res) {
            if (res && res.error) {
                Swal.fire('Hata', res.message || 'Adaylik kaydedilemedi.', 'error');
                return;
            }
            Swal.fire({ icon: 'success', title: 'Adaylik basladi', text: 'Halk secimi listesine girdin.', background: '#1e1e2f', color: '#fff', timer: 1800, showConfirmButton: false }).then(() => location.reload());
        });
    });
};

window.votePresidentialCandidate = function(candidateId) {
    Swal.fire({
        title: 'Cumhurbaskanligi Oyu',
        text: 'Bu adaya tek oyunu vereceksin. Onayliyor musun?',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Oy Ver',
        cancelButtonText: 'Iptal',
        background: '#0f172a',
        color: '#fff'
    }).then((result) => {
        if (!result.isConfirmed) return;
        $.post("{{ base_url() }}/api/congress/presidential/vote", {
            candidate: candidateId,
            csrf_token: $('meta[name="csrf-token"]').attr('content')
        }, function(res) {
            if (res && res.error) {
                Swal.fire('Hata', res.message || 'Oy kaydedilemedi.', 'error');
                return;
            }
            Swal.fire({ icon: 'success', title: 'Oy kaydedildi', text: 'Halk oylamasindaki tercihin alindi.', background: '#1e1e2f', color: '#fff', timer: 1600, showConfirmButton: false }).then(() => location.reload());
        });
    });
};

window.resignPresidentialApplication = function() {
    Swal.fire({
        title: 'Adayliktan Cekil',
        text: 'Bu secim turundaki baskanlik adayligin kaldirilacak. Emin misin?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc2626',
        confirmButtonText: 'Cekil',
        cancelButtonText: 'Iptal',
        background: '#0f172a',
