{% extends isAjax ? "common/ajaxbase.html.twig" : "common/base.html.twig" %}

{% block content %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<meta name="csrf-token" content="{{ csrf_token|default('') }}">

<div class="space-y-6 animate-fade-in w-full">
    
    {# MİLLİ SEFERBERLİK PANELİ #}
    {% if isMobilizationActive %}
    <div class="bg-blue-950/60 border-2 border-blue-500 p-4 rounded-xl flex flex-col md:flex-row items-center justify-between gap-4 animate-pulse shadow-[0_0_30px_rgba(59,130,246,0.4)] relative">
        <div class="flex items-center gap-4">
            <i class="fa-solid fa-jet-fighter text-blue-500 text-4xl drop-shadow-[0_0_15px_rgba(59,130,246,0.8)]"></i>
            <div class="text-center md:text-left">
                <div class="text-blue-400 font-black uppercase tracking-[0.2em] text-lg">MİLLİ SEFERBERLİK AKTİF!</div>
                <div class="text-blue-200 text-[10px] font-bold mt-1 uppercase tracking-widest">Tüm savaş hasarları +%20 artırıldı. Vatandaşların tüketimi +%10 yükseldi.</div>
            </div>
        </div>
        {# BAŞKAN İÇİN İPTAL BUTONU #}
        {% if isPresident %}
            <button onclick="revokeEmergencyState('mobilization')" class="bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-widest shadow-[0_0_15px_rgba(220,38,38,0.5)] transition-all flex-shrink-0">
                <i class="fa-solid fa-power-off mr-1"></i> Seferberliği Sonlandır
            </button>
        {% endif %}
    </div>
    {% endif %}

    {# SINIRLAR KAPATILDI PANELİ #}
    {% if isBordersClosed %}
    <div class="bg-zinc-950/60 border-2 border-zinc-500 p-4 rounded-xl flex flex-col md:flex-row items-center justify-between gap-4 animate-pulse shadow-[0_0_30px_rgba(113,113,122,0.4)] relative">
        <div class="flex items-center gap-4">
            <i class="fa-solid fa-passport text-zinc-500 text-4xl drop-shadow-[0_0_15px_rgba(113,113,122,0.8)]"></i>
            <div class="text-center md:text-left">
                <div class="text-zinc-400 font-black uppercase tracking-[0.2em] text-lg">{{ t('congress.banner.borders_title') }}</div>
                <div class="text-zinc-300 text-[10px] font-bold mt-1 uppercase tracking-widest">Meclis kararıyla ülkeye yeni vatandaş alımı geçici olarak durdurulmuştur.</div>
            </div>
        </div>
        {# BAŞKAN İÇİN İPTAL BUTONU #}
        {% if isPresident %}
            <button onclick="revokeEmergencyState('borders')" class="bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-widest shadow-[0_0_15px_rgba(220,38,38,0.5)] transition-all flex-shrink-0">
                <i class="fa-solid fa-lock-open mr-1"></i> Sınırları Aç
            </button>
        {% endif %}
    </div>
    {% endif %}

    {# ACİL DURUM PANELİ #}
    {% if isEmergencySession %}
    <div class="bg-orange-950/60 border-2 border-orange-500 p-4 rounded-xl flex flex-col md:flex-row items-center justify-between gap-4 animate-pulse shadow-[0_0_30px_rgba(249,115,22,0.4)] relative">
        <div class="flex items-center gap-4">
            <i class="fa-solid fa-bolt text-orange-500 text-4xl drop-shadow-[0_0_15px_rgba(249,115,22,0.8)]"></i>
            <div class="text-center md:text-left">
                <div class="text-orange-400 font-black uppercase tracking-[0.2em] text-lg">ACİL DURUM OTURUMU AKTİF!</div>
                <div class="text-orange-200 text-[10px] font-bold tracking-widest mt-1">Tüm yasaların geçme barajı %15 düşürülmüştür.</div>
                <div class="text-orange-500 text-[9px] font-black uppercase mt-1 bg-black/40 inline-block px-2 py-0.5 rounded border border-orange-900/50">Bitiş: {{ emergencyUntil }}</div>
            </div>
        </div>
        {# BAŞKAN İÇİN İPTAL BUTONU #}
        {% if isPresident %}
            <button onclick="revokeEmergencyState('emergency')" class="bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-widest shadow-[0_0_15px_rgba(220,38,38,0.5)] transition-all flex-shrink-0">
                <i class="fa-solid fa-power-off mr-1"></i> Oturumu İptal Et
            </button>
        {% endif %}
    </div>
    {% endif %}

    {# OHAL PANELİ #}
    {% if isOhalActive %}
    <div class="bg-red-950/60 border-2 border-red-500 p-4 rounded-xl flex flex-col md:flex-row items-center justify-between gap-4 animate-pulse shadow-[0_0_30px_rgba(220,38,38,0.4)] relative">
        <div class="flex items-center gap-4">
            <i class="fa-solid fa-triangle-exclamation text-red-500 text-4xl drop-shadow-[0_0_15px_rgba(220,38,38,0.8)]"></i>
            <div class="text-center md:text-left">
                <div class="text-red-400 font-black uppercase tracking-[0.2em] text-lg">DİKKAT: ÜLKE GENELİNDE OHAL İLAN EDİLDİ!</div>
                <div class="text-red-200 text-[10px] font-bold mt-1 uppercase tracking-widest">Sadece Başkan yasa sunabilir. Oylamalar askıya alınmıştır, kararlar anında geçer.</div>
            </div>
        </div>
        {# BAŞKAN İÇİN İPTAL BUTONU #}
        {% if isPresident %}
            <button onclick="revokeEmergencyState('ohal')" class="bg-red-600 hover:bg-red-500 text-white px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-widest shadow-[0_0_15px_rgba(220,38,38,0.5)] transition-all flex-shrink-0">
                <i class="fa-solid fa-power-off mr-1"></i> OHAL'i Kaldır
            </button>
        {% endif %}
    </div>
    {% endif %}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="glass-panel p-6 border-t-2 border-amber-500 bg-gradient-to-br from-black/80 to-amber-950/30 shadow-lg relative">
            <h2 class="text-[10px] font-black text-amber-500 uppercase tracking-[0.3em] mb-4 flex items-center justify-between">
                <span><i class="fa-solid fa-crown text-amber-400"></i> Başkomutanlık Makamı</span>
                {% if isPresident and not isEmergencySession %}
                    <button onclick="callEmergency()" class="bg-orange-600/20 hover:bg-orange-500/40 text-orange-400 px-3 py-1 rounded border border-orange-500/30 text-[8px] font-bold transition-all animate-pulse shadow-[0_0_10px_rgba(249,115,22,0.3)]">Acil Oturum Başlat</button>
                {% endif %}
            </h2>
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-amber-500/20 border border-amber-500/50 flex items-center justify-center text-amber-400 overflow-hidden">
                    {% if presidentUser %}
                        <img src="{{ presidentUser.avatar ?: (base_url() ~ '/img/avatars/' ~ presidentUser.id ~ '.png') }}" onerror="this.src='{{ base_url() }}/img/default_avatar.jpg'" class="w-full h-full object-cover" alt="{{ presidentUser.nick }}">
                    {% else %}
                        <i class="fa-solid fa-user-tie text-2xl"></i>
                    {% endif %}
                </div>
                <div>
                    <div class="text-lg font-black text-white tracking-widest">{{ presidentUser ? presidentUser.nick : 'Makam Boş' }}</div>
                    <div class="text-[9px] text-amber-200/70 font-bold uppercase tracking-widest">Devlet Başkanı / Başkomutan</div>
                </div>
            </div>
        </div>

        <div class="glass-panel p-6 border-t-2 border-cyan-500 bg-gradient-to-br from-black/80 to-cyan-950/30 shadow-lg">
            <h2 class="text-[10px] font-black text-cyan-500 uppercase tracking-[0.3em] mb-4 flex items-center gap-2">
                <i class="fa-solid fa-gavel text-cyan-400"></i> Meclis Başkanlığı (Speaker)
            </h2>
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-xl bg-cyan-500/20 border border-cyan-500/50 flex items-center justify-center text-cyan-400 overflow-hidden">
                    {% if speakerUser %}
                        <img src="{{ speakerUser.avatar ?: (base_url() ~ '/img/avatars/' ~ speakerUser.id ~ '.png') }}" onerror="this.src='{{ base_url() }}/img/default_avatar.jpg'" class="w-full h-full object-cover" alt="{{ speakerUser.nick }}">
                    {% else %}
                        <i class="fa-solid fa-landmark text-2xl"></i>
                    {% endif %}
                </div>
                <div>
                    <div class="text-lg font-black text-white tracking-widest">{{ speakerUser ? speakerUser.nick : t('congress.speaker.waiting') }}</div>
                    <div class="text-[9px] text-cyan-200/70 font-bold uppercase tracking-widest">Meclis Başkanı (Başkan Vekili)</div>
                </div>
            </div>
        </div>
    </div>

    {% if false %}
    <div class="glass-panel p-6 border-t-2 border-sky-500 relative overflow-hidden bg-black/40 shadow-xl">
        <div class="flex flex-col gap-4 border-b border-white/5 pb-4 md:flex-row md:items-center md:justify-between">
            <div>
                <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] flex items-center gap-2">
                    <i class="fa-solid fa-flag text-sky-400"></i> Cumhurbaskanligi Secimi
                </h2>
                <div class="mt-1 text-[9px] font-bold uppercase tracking-widest text-slate-500">
                    {{ presidentialElection.phase_note }}
                </div>
            </div>
            <div class="flex flex-wrap items-center gap-2">
                <div class="px-3 py-1.5 rounded-lg border border-sky-500/30 bg-sky-950/20 text-[9px] font-black uppercase tracking-widest text-sky-300">
                    Faz: <span class="text-[10px] text-white">{{ presidentialElection.phase_label }}</span>
                </div>
                <div class="px-3 py-1.5 rounded-lg border border-white/10 bg-black/40 text-[9px] font-black uppercase tracking-widest text-slate-400">
                    Kalan: <span class="text-[10px] text-white">{{ presidentialElection.remaining_label }}</span>
                </div>
                <div class="px-3 py-1.5 rounded-lg border border-white/10 bg-black/40 text-[9px] font-black uppercase tracking-widest text-slate-400">
                    Toplam Oy: <span class="text-[10px] text-sky-300">{{ presidentialElection.total_votes }}</span>
                </div>
                {% if presidentialElection.can_apply %}
                    <button type="button" onclick="submitPresidentialApplication()" class="bg-sky-600 hover:bg-sky-500 text-white px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-widest shadow-[0_0_15px_rgba(14,165,233,0.25)] transition-all">
                        <i class="fa-solid fa-user-plus mr-1"></i> Aday Ol
                    </button>
                {% endif %}
                {% if presidentialElection.my_candidate and presidentialElection.phase == 'candidacy' %}
                    <button type="button" onclick="resignPresidentialApplication()" class="bg-red-600/20 hover:bg-red-500/35 border border-red-500/30 text-red-300 px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-widest transition-all">
                        <i class="fa-solid fa-right-from-bracket mr-1"></i> Adayliktan Cekil
                    </button>
                {% endif %}
            </div>
        </div>

        <div class="mt-4 grid grid-cols-1 xl:grid-cols-2 gap-4">
            <div class="bg-black/35 border border-white/5 rounded-2xl p-4">
                <div class="text-[9px] font-black uppercase tracking-widest text-sky-300 mb-3">Adaylik Sartlari</div>
                <div class="space-y-2">
                    {% for item in presidentialElection.requirements %}
                        <div class="flex items-center justify-between gap-3 rounded-xl border {{ item.ok ? 'border-emerald-500/20 bg-emerald-950/10 text-emerald-300' : 'border-red-500/20 bg-red-950/10 text-red-300' }} px-3 py-2">
                            <span class="text-[9px] font-black uppercase tracking-widest">{{ item.label }}</span>
                            <span class="text-[8px] font-black uppercase tracking-widest">{{ item.ok ? 'Tamam' : 'Eksik' }}</span>
                        </div>
                    {% endfor %}
                </div>
            </div>
            <div class="bg-black/35 border border-white/5 rounded-2xl p-4">
                <div class="text-[9px] font-black uppercase tracking-widest text-sky-300 mb-3">Secim Gecmisi</div>
                {% if presidentialElection.history|length > 0 %}
                    <div class="space-y-2">
                        {% for item in presidentialElection.history %}
                            <div class="rounded-xl border border-white/5 bg-black/40 px-3 py-2">
                                <div class="flex items-center justify-between gap-3">
                                <div class="text-[10px] font-black text-white tracking-wider">{{ item.winner_nick }}</div>
                                    <div class="text-[8px] font-black uppercase tracking-widest text-slate-500">{{ item.finished_at }}</div>
                                </div>
                                <div class="mt-1 text-[8px] font-bold uppercase tracking-widest text-slate-500">
                                    {{ item.candidate_count }} aday · {{ item.total_votes }} oy · kazanan {{ item.winner_votes }} oy
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-[9px] font-bold uppercase tracking-widest text-slate-500">Kayitli secim gecmisi yok.</div>
                {% endif %}
            </div>
        </div>

        {% if presidentialElection.candidates|length > 0 %}
            <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 mt-5">
                {% for candidate in presidentialElection.candidates %}
                    <div class="bg-black/45 border border-white/5 rounded-2xl p-4 shadow-inner flex flex-col gap-4">
                        <div class="flex items-start justify-between gap-3">
                            <div class="flex items-center gap-3 min-w-0">
                                <div class="w-12 h-12 rounded-xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center overflow-hidden">
                                    <img src="{{ candidate.avatar ?: (base_url() ~ '/img/avatars/' ~ candidate.uid ~ '.png') }}" onerror="this.src='{{ base_url() }}/img/default_avatar.jpg'" class="w-full h-full object-cover" alt="{{ candidate.nick }}">
                                </div>
                                <div class="min-w-0">
                                    <div class="text-[12px] font-black text-white tracking-wider truncate">{{ candidate.nick }}</div>
                                    <div class="mt-1 text-[8px] font-bold uppercase tracking-widest text-slate-500 truncate">{{ candidate.party_name }}</div>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="text-[18px] font-black text-white">{{ candidate.votes }}</div>
                                <div class="text-[8px] font-bold uppercase tracking-widest text-slate-500">Oy</div>
                            </div>
                        </div>

                        <div>
                            <div class="flex items-center justify-between text-[8px] font-black uppercase tracking-widest text-sky-300 mb-1">
                                <span>Halk Destegi</span>
                                <span>%{{ candidate.vote_percentage }}</span>
                            </div>
                            <div class="h-2 rounded-full bg-black/50 overflow-hidden border border-white/5">
                                <div class="h-full bg-sky-500" style="width: {{ candidate.vote_percentage }}%;"></div>
                            </div>
                        </div>

                        {% if candidate.campaign_title or candidate.campaign_message %}
                            <div class="rounded-2xl border border-sky-500/15 bg-sky-950/10 px-4 py-3">
                                {% if candidate.campaign_title %}
                                    <div class="text-[10px] font-black text-sky-300 uppercase tracking-widest">{{ candidate.campaign_title }}</div>
                                {% endif %}
                                {% if candidate.campaign_message %}
                                    <div class="mt-2 text-[11px] font-bold text-slate-200 leading-relaxed">{{ candidate.campaign_message }}</div>
                                {% endif %}
                            </div>
                        {% endif %}

                        <div class="flex flex-wrap items-center gap-2 pt-1">
                            {% if candidate.is_me %}
                                <div class="px-3 py-2 rounded-lg border border-sky-500/20 bg-sky-950/20 text-[8px] font-black uppercase tracking-widest text-sky-300">
                                    Bu adaylik senin
                                </div>
                            {% elseif candidate.has_voted %}
                                <div class="px-3 py-2 rounded-lg border border-sky-500/20 bg-sky-950/20 text-[8px] font-black uppercase tracking-widest text-sky-300">
                                    Oyun bu adaya kayitli
                                </div>
                            {% elseif presidentialElection.can_vote %}
                                <button type="button" onclick="votePresidentialCandidate({{ candidate.uid }})" class="bg-sky-600/20 hover:bg-sky-500/35 border border-sky-500/30 text-sky-300 px-3 py-2 rounded-lg text-[8px] font-black uppercase tracking-widest transition-all">
                                    <i class="fa-solid fa-check-to-slot mr-1"></i> Oy Ver
                                </button>
                            {% else %}
                                <div class="px-3 py-2 rounded-lg border border-white/10 bg-black/40 text-[8px] font-black uppercase tracking-widest text-slate-400">
                                    Oylama bekleniyor
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="py-10 text-center text-slate-500 opacity-80">
                <i class="fa-solid fa-landmark-dome text-4xl mb-4"></i>
                <div class="text-[11px] font-black uppercase tracking-widest text-slate-400">Aktif baskanlik adayi yok</div>
                <div class="text-[9px] font-bold uppercase tracking-widest mt-2">Ilk adaylik basvurusuyla halk secim turu acilir.</div>
            </div>
        {% endif %}
    </div>

    <div class="glass-panel p-6 border-t-2 border-fuchsia-500 relative overflow-hidden bg-black/40 shadow-xl">
        <div class="flex flex-col gap-4 border-b border-white/5 pb-4 md:flex-row md:items-center md:justify-between">
            <div>
                <h2 class="text-[11px] font-black text-white uppercase tracking-[0.2em] flex items-center gap-2">
                    <i class="fa-solid fa-check-to-slot text-fuchsia-400"></i> Kongre Secim Hatti
                </h2>
                <div class="mt-1 text-[9px] font-bold uppercase tracking-widest text-slate-500">
                    Adaylik suresi {{ election.duration_hours }} saat. Sure sonunda destek oylarin red oylarindan fazla ise kongreye girersin.
                </div>
            </div>
            <div class="flex flex-wrap items-center gap-2">
                <div class="px-3 py-1.5 rounded-lg border border-white/10 bg-black/40 text-[9px] font-black uppercase tracking-widest text-slate-400">
                    Aktif Aday: <span class="text-fuchsia-400 text-[11px]">{{ election.active_count }}</span>
                </div>
                {% if election.my_candidate %}
                    <div class="px-3 py-1.5 rounded-lg border border-fuchsia-500/30 bg-fuchsia-950/30 text-[9px] font-black uppercase tracking-widest text-fuchsia-300">
                        Adayligin aktif
                    </div>
                {% elseif election.is_congress_member %}
                    <div class="px-3 py-1.5 rounded-lg border border-emerald-500/30 bg-emerald-950/30 text-[9px] font-black uppercase tracking-widest text-emerald-300">
                        Aktif kongre uyesi
                    </div>
                {% endif %}
                {% if election.can_apply %}
                    <button type="button" onclick="submitCongressApplication()" class="bg-fuchsia-600 hover:bg-fuchsia-500 text-white px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-widest shadow-[0_0_15px_rgba(217,70,239,0.25)] transition-all">
                        <i class="fa-solid fa-user-plus mr-1"></i> Aday Ol
                    </button>
                {% endif %}
                {% if election.my_candidate or election.is_congress_member %}
                    <button type="button" onclick="resignCongressSeat()" class="bg-red-600/20 hover:bg-red-500/35 border border-red-500/30 text-red-300 px-4 py-2 rounded-lg text-[9px] font-black uppercase tracking-widest transition-all">
                        <i class="fa-solid fa-right-from-bracket mr-1"></i> Ayril
                    </button>
                {% endif %}
            </div>
        </div>

        {% if election.candidates|length > 0 %}
            <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 mt-5">
                {% for candidate in election.candidates %}
                    <div class="bg-black/45 border border-white/5 rounded-2xl p-4 shadow-inner flex flex-col gap-4">
                        <div class="flex items-start justify-between gap-3">
                            <div class="flex items-center gap-3 min-w-0">
                                <div class="w-12 h-12 rounded-xl bg-fuchsia-500/10 border border-fuchsia-500/20 flex items-center justify-center overflow-hidden">
                                    <img src="{{ candidate.avatar ?: (base_url() ~ '/img/avatars/' ~ candidate.uid ~ '.png') }}" onerror="this.src='{{ base_url() }}/img/default_avatar.jpg'" class="w-full h-full object-cover" alt="{{ candidate.nick }}">
                                </div>
                                <div class="min-w-0">
                                    <div class="text-[12px] font-black text-white tracking-wider truncate">{{ candidate.nick }}</div>
                                    <div class="mt-1 text-[8px] font-bold uppercase tracking-widest text-slate-500 truncate">{{ candidate.party_name }}</div>
                                    <div class="mt-1 text-[8px] font-black uppercase tracking-widest text-fuchsia-300">Kalan sure: {{ candidate.remaining_label }}</div>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="text-[18px] font-black text-white">{{ candidate.total_votes }}</div>
                                <div class="text-[8px] font-bold uppercase tracking-widest text-slate-500">Toplam oy</div>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <div>
                                <div class="flex items-center justify-between text-[8px] font-black uppercase tracking-widest text-emerald-300 mb-1">
                                    <span>Destek</span>
                                    <span>%{{ candidate.yes_percentage }}</span>
                                </div>
                                <div class="h-2 rounded-full bg-black/50 overflow-hidden border border-white/5">
                                    <div class="h-full bg-emerald-500" style="width: {{ candidate.yes_percentage }}%;"></div>
                                </div>
                            </div>
                            <div>
                                <div class="flex items-center justify-between text-[8px] font-black uppercase tracking-widest text-rose-300 mb-1">
                                    <span>Red</span>
                                    <span>%{{ candidate.no_percentage }}</span>
                                </div>
                                <div class="h-2 rounded-full bg-black/50 overflow-hidden border border-white/5">
                                    <div class="h-full bg-rose-500" style="width: {{ candidate.no_percentage }}%;"></div>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-wrap items-center gap-2 pt-1">
                            {% if candidate.is_me %}
                                <div class="px-3 py-2 rounded-lg border border-fuchsia-500/20 bg-fuchsia-950/20 text-[8px] font-black uppercase tracking-widest text-fuchsia-300">
                                    Bu adaylik senin
                                </div>
                            {% elseif candidate.has_voted %}
                                <div class="px-3 py-2 rounded-lg border border-white/10 bg-black/40 text-[8px] font-black uppercase tracking-widest text-slate-400">
                                    Bu adaya oy kullandin
                                </div>
                            {% else %}
                                <button type="button" onclick="voteCongressCandidate({{ candidate.uid }}, 1)" class="bg-emerald-600/20 hover:bg-emerald-500/35 border border-emerald-500/30 text-emerald-300 px-3 py-2 rounded-lg text-[8px] font-black uppercase tracking-widest transition-all">
                                    <i class="fa-solid fa-thumbs-up mr-1"></i> Destekle
                                </button>
                                <button type="button" onclick="voteCongressCandidate({{ candidate.uid }}, 0)" class="bg-rose-600/20 hover:bg-rose-500/35 border border-rose-500/30 text-rose-300 px-3 py-2 rounded-lg text-[8px] font-black uppercase tracking-widest transition-all">
                                    <i class="fa-solid fa-thumbs-down mr-1"></i> Reddet
                                </button>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
