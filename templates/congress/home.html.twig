        $.post("{{ base_url() }}/api/congress/presidential/resign", {
            csrf_token: $('meta[name="csrf-token"]').attr('content')
        }, function(res) {
            if (res && res.error) {
                Swal.fire('Hata', res.message || 'Adaylik cekilemedi.', 'error');
