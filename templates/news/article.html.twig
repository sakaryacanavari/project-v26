window.sendComment = function(articleId) {
    var msg = $('#comment-msg').val().trim();
    if (msg.length < 2) {
        Swal.fire({ icon: 'warning', title: '{{ t(''news.article.warning'') }}', text: '{{ t(''news.article.short_message'') }}', customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title title-amber', confirmButton: 'cyber-confirm-btn btn-amber' } });
        return;
    }
    if (msg.length > window.commentMaxLength) {
        Swal.fire({ icon: 'warning', title: '{{ t(''news.article.limit_exceeded'') }}', text: 'Yorum en fazla ' + window.commentMaxLength + ' karakter olabilir.', customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title title-amber', confirmButton: 'cyber-confirm-btn btn-amber' } });
        return;
    }

    var btn = $('#btn-send-comment');
    btn.prop('disabled', true).addClass('is-loading');

    $.ajax({
        url: "{{ base_url() }}/api/article/comment",
        type: 'POST',
        data: {
            articleId: articleId, message: msg, parentId: $('#comment-parent-id').val(),
            mentionUid: $('#comment-mention-uid').val(), isPinned: window.articleCommentState.pinned ? 1 : 0
        },
        success: function(res) {
            if (typeof res === 'string') { try { res = JSON.parse(res); } catch (e) {} }
            if (res && res.error) {
                Swal.fire({ icon: 'error', title: '{{ t(''news.article.error'') }}', text: res.message || '{{ t(''news.article.comment_send_failed'') }}', customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title title-red', confirmButton: 'cyber-confirm-btn btn-red' } });
                btn.prop('disabled', false).removeClass('is-loading');
                return;
            }
            location.reload();
        },
        error: function() {
            Swal.fire({ icon: 'error', title: '{{ t(''news.article.connection_error'') }}', text: '{{ t(''news.article.connection_lost'') }}', customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title title-red', confirmButton: 'cyber-confirm-btn btn-red' } });
            btn.prop('disabled', false).removeClass('is-loading');
        }
    });
};

window.editComment = function(commentId, currentMessage) {
