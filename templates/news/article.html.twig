                    '<span id="sw-comment-edit-count" class="text-[color:var(--brand-primary)]">0 / ' + window.commentMaxLength + '</span>' +
                '</div>' +
            '</div>',
        showCancelButton: true,
        confirmButtonText: '{{ t(''news.article.comment.save'') }}',
