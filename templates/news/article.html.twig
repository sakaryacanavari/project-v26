        customClass: { popup: 'cyber-modal-popup', title: 'cyber-modal-title', confirmButton: 'cyber-confirm-btn', cancelButton: 'cyber-cancel-btn' },
        buttonsStyling: false,
        didOpen: function() {
            var textarea = document.getElementById('sw-comment-edit');
            var counter = document.getElementById('sw-comment-edit-count');
            var syncCounter = function() {
                if (!textarea || !counter) return;
                counter.textContent = textarea.value.length + ' / ' + window.commentMaxLength;
                counter.className = textarea.value.length > (window.commentMaxLength - 40) ? 'text-amber-400' : 'text-[color:var(--brand-primary)]';
