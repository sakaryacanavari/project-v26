window.applyCommentSort = function() {
    var container = document.getElementById('comment-list');
    if (!container) return;
    var roots = Array.prototype.slice.call(container.querySelectorAll('.comment-thread-root'));
    if (!roots.length) return;

    roots.sort(function(a, b) {
        var sortKey = window.commentSortKey || 'vip';
        if (sortKey === 'latest') return parseInt(b.getAttribute('data-sort-latest') || '0', 10) - parseInt(a.getAttribute('data-sort-latest') || '0', 10);
        if (sortKey === 'oldest') return parseInt(a.getAttribute('data-sort-oldest') || '0', 10) - parseInt(b.getAttribute('data-sort-oldest') || '0', 10);
        if (sortKey === 'useful') {
            var usefulDiff = parseInt(b.getAttribute('data-sort-votes') || '0', 10) - parseInt(a.getAttribute('data-sort-votes') || '0', 10);
            if (usefulDiff !== 0) return usefulDiff;
        }
        var vipDiff = parseInt(b.getAttribute('data-sort-vip') || '0', 10) - parseInt(a.getAttribute('data-sort-vip') || '0', 10);
        if (vipDiff !== 0) return vipDiff;
        var voteDiff = parseInt(b.getAttribute('data-sort-votes') || '0', 10) - parseInt(a.getAttribute('data-sort-votes') || '0', 10);
        if (voteDiff !== 0) return voteDiff;
        return parseInt(b.getAttribute('data-sort-latest') || '0', 10) - parseInt(a.getAttribute('data-sort-latest') || '0', 10);
    });

    roots.forEach(function(root) { container.appendChild(root); });
    window.refreshCommentVisibility();
};

