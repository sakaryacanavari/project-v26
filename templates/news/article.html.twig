                    '<textarea id="sw-comment-edit" class="cyber-input" style="min-height:160px; resize:none;">' + $('<div>').text(currentMessage).html() + '</textarea>' +
                '</div>' +
                '<div class="flex items-center justify-between text-[10px] font-black uppercase tracking-[0.14em]">' +
