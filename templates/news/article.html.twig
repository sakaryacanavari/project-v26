<script>
window.articleCommentState = {
    parentId: 0,
    mentionUid: 0,
    pinned: false
};
window.commentMaxLength = {{ commentMaxLength }};
window.commentSortKey = 'vip';
window.commentInitialVisible = 8;
window.commentLoadStep = 8;
window.commentVisibleCount = 8;

window.replyToComment = function(commentId, nick, uid) {
    window.articleCommentState.parentId = parseInt(commentId, 10) || 0;
    window.articleCommentState.mentionUid = parseInt(uid, 10) || 0;
    $('#comment-parent-id').val(window.articleCommentState.parentId);
    $('#comment-mention-uid').val(window.articleCommentState.mentionUid);
    $('#reply-target-nick').text('@' + nick);
    $('#reply-target-shell').removeClass('hidden').addClass('flex');
    var textarea = $('#comment-msg');
    var current = textarea.val().trim();
    if (current.indexOf('@' + nick) !== 0) {
        textarea.val('@' + nick + ' ' + (current ? current + ' ' : ''));
    }
    textarea.trigger('focus');
    document.getElementById('comment-msg').scrollIntoView({ behavior: 'smooth', block: 'center' });
};

window.clearReplyTarget = function() {
    window.articleCommentState.parentId = 0;
    window.articleCommentState.mentionUid = 0;
    $('#comment-parent-id').val('0');
    $('#comment-mention-uid').val('0');
    $('#reply-target-shell').removeClass('flex').addClass('hidden');
};

window.togglePinnedComment = function() {
    window.articleCommentState.pinned = !window.articleCommentState.pinned;
    if(window.articleCommentState.pinned) {
        $('#vip-comment-toggle').removeClass('border-amber-500/30 text-amber-500 hover:bg-amber-500/10').addClass('bg-amber-500/20 border-amber-500 text-amber-400 shadow-[0_0_15px_rgba(245,158,11,0.2)]');
    } else {
        $('#vip-comment-toggle').addClass('border-amber-500/30 text-amber-500 hover:bg-amber-500/10').removeClass('bg-amber-500/20 border-amber-500 text-amber-400 shadow-[0_0_15px_rgba(245,158,11,0.2)]');
    }
};

window.copyArticleLink = function() {
    var link = window.location.href;
    var onSuccess = function() {
        Swal.fire({
            toast: true, position: 'top-end', icon: 'success', title: 'Baglanti kopyalandi',
            showConfirmButton: false, timer: 1800, timerProgressBar: true,
            background: '#0f172a', color: '#fff'
        });
    };
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(link).then(onSuccess).catch(function() {});
        return;
    }
    var temp = $('<input>').val(link).appendTo('body').select();
    document.execCommand('copy');
    temp.remove();
    onSuccess();
};

window.scrollToComments = function() {
    var target = document.getElementById('comments-section');
    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
};

window.scrollToTopArea = function() {
    var target = document.getElementById('article-page');
    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
};

window.updateCommentCharCount = function() {
    var textarea = document.getElementById('comment-msg');
    var counter = document.getElementById('comment-char-count');
    if (!textarea || !counter) return;
    var length = textarea.value.length;
    counter.textContent = length;
    if(length >= window.commentMaxLength - 20) {
        counter.classList.add('text-rose-400');
        counter.classList.remove('text-slate-300');
    } else {
        counter.classList.remove('text-rose-400');
        counter.classList.add('text-slate-300');
    }
};

window.refreshCommentVisibility = function() {
    var container = document.getElementById('comment-list');
    if (!container) return;
    var roots = Array.prototype.slice.call(container.querySelectorAll('.comment-thread-root'));
    roots.forEach(function(root, index) {
        root.classList.toggle('comment-thread-hidden', index >= window.commentVisibleCount);
    });
    var loadMoreBtn = document.getElementById('comment-load-more-btn');
    if (loadMoreBtn) {
        var hiddenCount = Math.max(0, roots.length - window.commentVisibleCount);
        if (hiddenCount <= 0) {
            loadMoreBtn.classList.add('hidden');
        } else {
            loadMoreBtn.classList.remove('hidden');
            loadMoreBtn.querySelector('.label').textContent = '+' + hiddenCount + ' {{ t('news.article.comment_count') }}u daha goster';
        }
    }
};

window.loadMoreComments = function() {
    window.commentVisibleCount += window.commentLoadStep;
    window.refreshCommentVisibility();
};

window.toggleReplies = function(buttonElement) {
    var wrapper = buttonElement ? buttonElement.closest('.rounded-xl') : null;
    var container = wrapper ? wrapper.querySelector('[data-replies-container]') : null;
    if (!container) return;
    var hiddenReplies = Array.prototype.slice.call(container.querySelectorAll('.reply-thread-hidden'));
    var isOpening = !buttonElement.classList.contains('is-open');
    hiddenReplies.forEach(function(reply) { reply.classList.toggle('hidden', !isOpening); });
    buttonElement.classList.toggle('is-open', isOpening);
    if (isOpening) {
