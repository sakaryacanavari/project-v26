{% extends isAjax ? "common/ajaxbase.html.twig" : "common/base.html.twig" %}

{% block content %}
<style>
    .media-scrollbar::-webkit-scrollbar { height: 6px; width: 6px; }
    .media-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .media-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.10); border-radius: 999px; }
    .media-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(217,70,239,0.45); }

    .media-filter-btn,
    .media-sort-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        min-height: 36px;
        padding: 0 14px;
        border-radius: 12px;
        background: rgba(0,0,0,0.34);
        border: 1px solid rgba(255,255,255,0.06);
        color: #94a3b8;
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .12em;
        transition: all .2s ease;
        white-space: nowrap;
    }

    .media-filter-btn:hover,
    .media-sort-btn:hover {
        border-color: rgba(217,70,239,0.24);
        color: #fff;
    }

    .media-filter-btn.is-active,
    .media-sort-btn.is-active {
        background: rgba(217,70,239,0.16);
        border-color: rgba(217,70,239,0.42);
        color: #f5d0fe;
        box-shadow: 0 0 18px rgba(217,70,239,0.12);
    }

    .media-focus-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 36px;
        padding: 0 14px;
        border-radius: 12px;
        background: rgba(8,11,23,0.72);
        border: 1px solid rgba(34,211,238,0.18);
        color: #a5f3fc;
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .12em;
        transition: all .2s ease;
        white-space: nowrap;
    }

    .media-focus-btn:hover {
        background: rgba(34,211,238,0.12);
        border-color: rgba(34,211,238,0.32);
        color: #ecfeff;
        box-shadow: 0 0 18px rgba(34,211,238,0.10);
    }

    .media-share-btn {
        position: absolute;
        top: 14px;
        right: 14px;
        z-index: 20;
        width: 34px;
        height: 34px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(15, 23, 42, 0.72);
        color: #f0abfc;
        border: 1px solid rgba(217,70,239,0.22);
        transition: all .2s ease;
        box-shadow: 0 10px 18px rgba(0,0,0,0.20);
    }

    .media-share-btn:hover {
        background: rgba(217,70,239,0.18);
        color: #fff;
        border-color: rgba(217,70,239,0.42);
        box-shadow: 0 0 18px rgba(217,70,239,0.16);
    }

    .media-share-btn.inline-share {
        position: static;
        top: auto;
        right: auto;
        width: 40px;
        height: 40px;
        flex: 0 0 auto;
        background: rgba(217,70,239,0.10);
        border-color: rgba(217,70,239,0.20);
        box-shadow: none;
    }

    .media-share-btn.inline-share:hover {
        background: rgba(217,70,239,0.18);
        box-shadow: 0 0 14px rgba(217,70,239,0.14);
    }

    .media-toast-wrap {
        position: fixed;
        top: 96px;
        right: 24px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        z-index: 1200;
        pointer-events: none;
    }

    .media-toast {
        min-width: 240px;
        max-width: 320px;
        padding: 12px 14px;
        border-radius: 16px;
        color: #fff;
        background:
            radial-gradient(circle at left top, rgba(217,70,239,0.18), transparent 28%),
            linear-gradient(180deg, rgba(20, 10, 32, 0.96), rgba(7, 10, 20, 0.98));
        border: 1px solid rgba(217,70,239,0.24);
        box-shadow: 0 12px 30px rgba(0,0,0,0.28);
        opacity: 0;
        transform: translateY(-6px);
        transition: opacity .18s ease, transform .18s ease;
    }

    .media-toast.is-visible {
        opacity: 1;
        transform: translateY(0);
    }

    .media-toast-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .14em;
        color: #f5d0fe;
    }

    .media-toast-body {
        margin-top: 6px;
        font-size: 11px;
        font-weight: 800;
        color: #cbd5e1;
        line-height: 1.45;
    }

    .article-card,
    .follow-strip-card {
        transition: opacity .18s ease, filter .18s ease, transform .2s ease, background .2s ease, box-shadow .2s ease;
    }

    .article-read-state {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 9px;
        border-radius: 999px;
        font-size: 8px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .14em;
        line-height: 1;
        flex-shrink: 0;
    }

    .article-read-state.is-new {
        background: rgba(217,70,239,0.14);
        color: #f5d0fe;
        box-shadow: 0 0 16px rgba(217,70,239,0.14);
        display: inline-flex;
    }

    .article-read-state.is-read {
        background: rgba(15,23,42,0.48);
        color: #94a3b8;
        display: none;
    }

    .article-card.has-read-state,
    .follow-strip-card.has-read-state {
        overflow: hidden;
    }

    .article-card.has-read-state.is-read,
    .follow-strip-card.has-read-state.is-read {
        opacity: .66;
        filter: saturate(.78);
    }

    .article-card.has-read-state.is-read .article-read-state.is-new,
    .follow-strip-card.has-read-state.is-read .article-read-state.is-new {
        display: none;
    }

    .article-card.has-read-state.is-read .article-read-state.is-read,
    .follow-strip-card.has-read-state.is-read .article-read-state.is-read {
        display: inline-flex;
    }

    .article-feed-skeleton {
        display: none;
        grid-template-columns: 1fr;
        gap: 16px;
    }

    .article-feed-skeleton.is-visible {
        display: grid;
    }

    .article-skeleton-card {
        position: relative;
        overflow: hidden;
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(8, 11, 23, 0.92), rgba(5, 8, 18, 0.98));
        padding: 20px;
    }

    .article-skeleton-card::after {
        content: "";
        position: absolute;
        inset: 0;
        transform: translateX(-100%);
        background: linear-gradient(90deg, transparent, rgba(217,70,239,0.10), transparent);
        animation: articleSkeletonWave 1.1s linear infinite;
    }

    .article-skeleton-line {
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.14);
    }

    .article-skeleton-chip {
        width: 84px;
        height: 22px;
    }

    .article-skeleton-chip.small {
        width: 62px;
    }

    .article-skeleton-title {
        width: 62%;
        height: 16px;
        margin-top: 16px;
    }

    .article-skeleton-text {
        width: 100%;
        height: 11px;
        margin-top: 14px;
    }

    .article-skeleton-text.short {
        width: 76%;
    }

    .article-skeleton-meta {
        width: 132px;
        height: 44px;
        margin-left: auto;
        margin-top: 18px;
    }

    @keyframes articleSkeletonWave {
        100% {
            transform: translateX(100%);
        }
    }

    .follow-strip-shell {
        background:
            radial-gradient(circle at right center, rgba(217,70,239,0.10), transparent 26%),
            linear-gradient(180deg, rgba(34, 9, 49, 0.18), rgba(8, 10, 22, 0.92));
        border-top: 2px solid rgba(217,70,239,0.52);
        box-shadow:
            0 0 18px rgba(217,70,239,0.06),
            inset 0 1px 0 rgba(255,255,255,0.02);
    }

    .follow-strip-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
    }

    .follow-strip-title {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: #fff;
        font-size: 11px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .18em;
    }

    .follow-strip-title i {
        color: #e879f9;
        text-shadow: 0 0 12px rgba(217,70,239,0.24);
    }

    .follow-strip-count {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.56);
        color: #e9d5ff;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .14em;
    }

    .follow-strip-count strong {
        color: #fff;
    }

    .follow-strip-card {
        background:
            radial-gradient(circle at top right, rgba(244,114,182,0.06), transparent 28%),
            linear-gradient(180deg, rgba(24, 10, 34, 0.92), rgba(10, 10, 22, 0.98));
        border-radius: 18px;
        box-shadow:
            0 10px 22px rgba(0,0,0,0.20);
    }

    .follow-strip-card:hover {
        background:
            radial-gradient(circle at top right, rgba(244,114,182,0.10), transparent 26%),
            linear-gradient(180deg, rgba(34, 12, 44, 0.94), rgba(12, 10, 24, 0.98));
        box-shadow:
            0 14px 28px rgba(0,0,0,0.24);
        transform: translateY(-2px);
    }

    .follow-strip-newspaper {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 10px;
        border-radius: 999px;
        background: rgba(217,70,239,0.10);
        color: #f5d0fe;
        font-size: 8px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .14em;
    }

    .follow-strip-category {
        display: inline-flex;
        align-items: center;
        padding: 5px 10px;
        border-radius: 999px;
        background: rgba(148,163,184,0.10);
        color: #cbd5e1;
        font-size: 8px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .14em;
    }

    .follow-strip-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-top: 12px;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .12em;
    }

    .follow-strip-author {
        color: #94a3b8;
    }

    .follow-strip-reads {
        color: #e9d5ff;
    }

    .article-focus-overlay {
        position: fixed;
        inset: 0;
        z-index: 1400;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 28px;
        background:
            radial-gradient(circle at top, rgba(217,70,239,0.14), transparent 28%),
            linear-gradient(180deg, rgba(3,6,18,0.95), rgba(2,4,12,0.98));
        backdrop-filter: blur(16px);
    }

    .article-focus-overlay.is-open {
        display: flex;
    }

    .article-focus-stage {
        width: min(920px, 100%);
        display: grid;
        gap: 18px;
    }

    .article-focus-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .article-focus-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(217,70,239,0.10);
        color: #f5d0fe;
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .14em;
    }

    .article-focus-close {
        width: 42px;
        height: 42px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(15,23,42,0.58);
        color: #f8fafc;
        border: 1px solid rgba(255,255,255,0.08);
        transition: all .2s ease;
    }

    .article-focus-close:hover {
        background: rgba(239,68,68,0.16);
        color: #fff;
        border-color: rgba(239,68,68,0.24);
    }

    .article-focus-card {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        padding: 34px;
        background:
            radial-gradient(circle at top right, rgba(217,70,239,0.12), transparent 28%),
            linear-gradient(180deg, rgba(18,10,30,0.96), rgba(6,8,18,0.98));
        border: 1px solid rgba(217,70,239,0.16);
        box-shadow: 0 28px 80px rgba(0,0,0,0.34), inset 0 1px 0 rgba(255,255,255,0.03);
        transform: translateX(0);
        opacity: 1;
        transition: transform .26s ease, opacity .26s ease;
    }

    .article-focus-card.is-shifting-next {
        transform: translateX(28px);
        opacity: 0;
    }

    .article-focus-card.is-shifting-prev {
        transform: translateX(-28px);
        opacity: 0;
    }

    .article-focus-meta {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .article-focus-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .14em;
    }

    .article-focus-chip.primary {
        background: rgba(217,70,239,0.14);
        color: #f5d0fe;
    }

    .article-focus-chip.secondary {
        background: rgba(15,23,42,0.56);
        color: #cbd5e1;
    }

    .article-focus-title {
        color: #fff;
        font-size: clamp(1.4rem, 3vw, 2.4rem);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .05em;
        line-height: 1.1;
    }

    .article-focus-excerpt {
        margin-top: 18px;
        color: #cbd5e1;
        font-size: 14px;
        font-weight: 700;
        line-height: 1.7;
        max-width: 760px;
    }

    .article-focus-stats {
        margin-top: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .article-focus-stat {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 44px;
        padding: 0 14px;
        border-radius: 14px;
        background: rgba(15,23,42,0.56);
        color: #e2e8f0;
        font-size: 11px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .12em;
    }

    .article-focus-stat i {
        color: #f0abfc;
    }

    .article-focus-actions {
        margin-top: 26px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        flex-wrap: wrap;
    }

    .article-focus-nav {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .article-focus-nav button,
    .article-focus-open {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 44px;
        padding: 0 16px;
        border-radius: 14px;
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .14em;
        transition: all .2s ease;
    }

    .article-focus-nav button {
        background: rgba(15,23,42,0.58);
        border: 1px solid rgba(255,255,255,0.08);
        color: #e2e8f0;
    }

    .article-focus-nav button:hover {
        border-color: rgba(217,70,239,0.24);
        color: #fff;
    }

    .article-focus-open {
        background: rgba(217,70,239,0.18);
        border: 1px solid rgba(217,70,239,0.32);
        color: #fff;
    }

    .article-focus-open:hover {
        box-shadow: 0 0 18px rgba(217,70,239,0.14);
    }

    .article-focus-hint {
        color: #94a3b8;
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .14em;
        margin-top: 18px;
    }

    @media (max-width: 768px) {
        .article-focus-overlay {
            padding: 18px;
        }

        .article-focus-card {
            padding: 22px;
            border-radius: 22px;
        }
    }
</style>

{% set quickWritePath = myNewspaper ? path_for('createArticle') : path_for('createNewspaper') %}
{% set quickWriteLabel = myNewspaper ? 'Makale Yaz' : 'Gazete Kur' %}

<div class="space-y-8 animate-fade-in w-full">
    {% if weeklyStars|length > 0 %}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            {% for star in weeklyStars %}
                <div class="glass-panel p-5 border-b-2 {{ loop.index == 1 ? 'border-amber-500 bg-amber-950/10 shadow-[0_0_20px_rgba(245,158,11,0.15)]' : (loop.index == 2 ? 'border-slate-300 bg-slate-800/20' : 'border-amber-700 bg-amber-900/10') }} relative overflow-hidden group transition-all hover:-translate-y-1">
                    <div class="absolute -right-4 -top-4 opacity-5 text-7xl group-hover:scale-110 transition-transform duration-500">
                        <i class="fa-solid {{ loop.index == 1 ? 'fa-crown text-amber-500' : 'fa-medal text-slate-400' }}"></i>
                    </div>

                    <div class="flex items-center gap-4 relative z-10">
                        <div class="w-12 h-12 rounded-xl bg-black/50 flex items-center justify-center border border-white/10 text-xl font-black {{ loop.index == 1 ? 'text-amber-500 shadow-[0_0_10px_rgba(245,158,11,0.3)]' : 'text-slate-400' }}">
                            {{ loop.index }}
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="text-[9px] font-black uppercase tracking-widest text-slate-400 mb-1 flex items-center gap-2">
                                <i class="fa-solid fa-fire text-amber-500 animate-pulse"></i> Haftanin {{ loop.index == 1 ? 'Devi' : 'Yildizi' }}
                            </div>
                            <a href="{{ path_for('showArticle', {id: star.id}) }}" class="text-sm font-black text-white uppercase group-hover:text-fuchsia-400 transition-colors block truncate w-full" title="{{ star.title }}">
                                {{ star.title }}
                            </a>
                            <div class="text-[10px] text-fuchsia-400 font-bold uppercase mt-1.5 flex items-center gap-2 flex-wrap">
                                <span class="bg-fuchsia-500/20 px-2 py-0.5 rounded border border-fuchsia-500/30">
                                    <i class="fa-solid fa-star mr-1"></i> {{ star.votes|default(0) }} Destek
                                </span>
                                <span class="text-slate-500"><i class="fa-solid fa-pen-nib"></i> {{ star.creator.nick|default(t('news.home.author')) }}</span>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <div class="glass-panel p-6 border-l-4 border-fuchsia-500 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 bg-fuchsia-950/10 shadow-[0_0_20px_rgba(217,70,239,0.1)] relative overflow-hidden">
        <div class="absolute right-0 top-0 w-64 h-full bg-gradient-to-l from-fuchsia-500/10 to-transparent pointer-events-none"></div>

        <div class="flex items-center gap-4 relative z-10 min-w-0">
            <div class="w-14 h-14 rounded-2xl bg-fuchsia-600/20 border border-fuchsia-500/30 flex items-center justify-center text-fuchsia-400 shadow-[0_0_15px_rgba(217,70,239,0.2)] shrink-0">
                <i class="fa-solid fa-tower-broadcast text-2xl"></i>
            </div>
            <div class="min-w-0">
                <h1 class="text-lg font-black text-white uppercase tracking-[0.2em] leading-tight">{{ t('news.home.title') }}</h1>
                <p class="text-[10px] text-fuchsia-400 font-black uppercase tracking-widest mt-1 flex items-center gap-2">
                    <span class="w-2 h-2 bg-fuchsia-400 rounded-full animate-pulse shadow-[0_0_8px_rgba(217,70,239,0.8)]"></span> {{ t('news.home.subtitle') }}
                </p>
            </div>
        </div>

        <div class="relative z-10 flex gap-3 w-full md:w-auto">
            <a href="{{ quickWritePath }}" class="w-full md:w-auto bg-fuchsia-600 hover:bg-fuchsia-500 text-white border border-fuchsia-400/40 px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all shadow-[0_0_15px_rgba(217,70,239,0.25)] hover:shadow-[0_0_25px_rgba(217,70,239,0.4)] flex items-center justify-center gap-2">
                <i class="fa-solid {{ myNewspaper ? 'fa-feather-pointed' : 'fa-plus' }}"></i> {{ quickWriteLabel }}
            </a>
        </div>
    </div>

    {% if followingArticles is defined and followingArticles|length > 0 %}
        <div class="glass-panel follow-strip-shell p-4">
            <div class="follow-strip-head">
                <div class="follow-strip-title">
                    <i class="fa-solid fa-rss"></i> {{ t('news.home.following') }}
                </div>
                <div class="follow-strip-count">
                    <strong>{{ followingArticles|slice(0, 5)|length }}</strong> {{ t('news.home.latest_content') }}
                </div>
            </div>

            <div class="flex gap-3 overflow-x-auto media-scrollbar pb-1">
                {% for article in followingArticles|slice(0, 5) %}
                    <a href="{{ path_for('showArticle', {id: article.id}) }}" class="follow-strip-card has-read-state relative min-w-[280px] max-w-[320px] px-4 py-3 transition-all shrink-0" data-article-id="{{ article.id }}">
                        <div class="flex items-center gap-2 mb-2 flex-wrap">
                            <span class="article-read-state is-new"><i class="fa-solid fa-sparkles"></i> {{ t('news.home.new') }}</span>
                            <span class="article-read-state is-read"><i class="fa-solid fa-check"></i> {{ t('news.home.read') }}</span>
                            <span class="follow-strip-newspaper">
                                {{ article.newspaper_name }}
                            </span>
                            <span class="follow-strip-category">
                                {{ article.category_label }}
                            </span>
                        </div>
                        <div class="text-sm font-black text-white uppercase leading-snug line-clamp-2">{{ article.title }}</div>
                        <div class="mt-2 text-[10px] text-slate-400 font-bold leading-relaxed line-clamp-2">{{ article.excerpt }}</div>
                        <div class="follow-strip-meta">
                            <span class="follow-strip-author"><i class="fa-solid fa-user-pen mr-1 text-fuchsia-400/80"></i>{{ article.creator.nick|default(t('news.home.author')) }}</span>
                            <div class="flex items-center gap-2">
                                <span class="follow-strip-reads"><i class="fa-solid fa-eye mr-1"></i>{{ article.views|default(0) }} {{ t('news.home.reads') }}</span>
                                <button type="button" class="media-share-btn inline-share" data-share-url="{{ path_for('showArticle', {id: article.id})|e('html_attr') }}" onclick="shareArticle(event, this)" title="{{ t('news.home.share_title') }}">
                                    <i class="fa-solid fa-link text-xs"></i>
                                </button>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    <div class="glass-panel p-4 border-t-2 border-fuchsia-500 bg-fuchsia-950/8 shadow-[0_0_14px_rgba(217,70,239,0.08)]">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 w-full">
                <div class="rounded-2xl bg-black/25 px-4 py-3 shadow-[inset_0_0_0_1px_rgba(217,70,239,0.06)]">
                    <div class="text-[10px] font-black text-fuchsia-300 uppercase tracking-[0.16em] flex items-center gap-2">
                        <i class="fa-solid fa-wand-magic-sparkles"></i> {{ t('news.home.personal') }}
                    </div>
                    <div class="mt-2 text-[11px] text-slate-300 font-bold leading-relaxed">
                        {{ t('news.home.hero.following_hint') }}
                    </div>
                </div>

                <div class="rounded-2xl bg-black/25 px-4 py-3 shadow-[inset_0_0_0_1px_rgba(217,70,239,0.06)]">
                    <div class="text-[10px] font-black text-fuchsia-300 uppercase tracking-[0.16em] flex items-center gap-2">
                        <i class="fa-solid fa-fire"></i> {{ t('news.home.trend') }}
                    </div>
                    <div class="mt-2 text-[11px] text-slate-300 font-bold leading-relaxed">
                        {{ t('news.home.hero.ranking_hint') }}
                    </div>
                </div>

                <div class="rounded-2xl bg-black/25 px-4 py-3 shadow-[inset_0_0_0_1px_rgba(217,70,239,0.06)]">
                    <div class="text-[10px] font-black text-fuchsia-300 uppercase tracking-[0.16em] flex items-center gap-2">
                        <i class="fa-solid fa-clock-rotate-left"></i> {{ t('news.home.time_effect') }}
                    </div>
                    <div class="mt-2 text-[11px] text-slate-300 font-bold leading-relaxed">
                        {{ t('news.home.hero.decay_hint') }}
                    </div>
                </div>
        </div>
    </div>

    <div class="glass-panel flex flex-col min-h-[500px]">
        <div class="p-4 border-b border-white/5 bg-black/20 flex flex-col gap-4">
            <div class="flex flex-col xl:flex-row xl:items-center xl:justify-between gap-4">
                <div class="flex flex-wrap gap-2" id="article-sorters">
                    <button type="button" onclick="sortArticles('personal', this)" class="media-sort-btn is-active">
                        <i class="fa-solid fa-wand-magic-sparkles"></i> {{ t('news.home.sort.personal') }}
                    </button>
                    <button type="button" onclick="sortArticles('trend', this)" class="media-sort-btn">
                        <i class="fa-solid fa-fire"></i> {{ t('news.home.sort.trend') }}
                    </button>
                    <button type="button" onclick="sortArticles('latest', this)" class="media-sort-btn">
                        <i class="fa-solid fa-clock"></i> {{ t('news.home.sort.latest') }}
                    </button>
                    <button type="button" onclick="sortArticles('views', this)" class="media-sort-btn">
                        <i class="fa-solid fa-eye"></i> {{ t('news.home.sort.views') }}
                    </button>
                    <button type="button" onclick="sortArticles('votes', this)" class="media-sort-btn">
                        <i class="fa-solid fa-star"></i> {{ t('news.home.sort.votes') }}
                    </button>
                    <button type="button" onclick="openFocusMode()" class="media-focus-btn">
                        <i class="fa-solid fa-expand"></i> {{ t('news.home.focus') }}
                    </button>
                </div>

                <div class="relative w-full sm:w-56">
                    <input type="text" id="article-search-input" placeholder="{{ t('news.home.search') }}" class="bg-black/50 border border-white/10 text-white text-[10px] font-bold px-4 py-2 rounded-lg outline-none focus:border-fuchsia-500 transition-colors w-full placeholder-slate-600">
                    <i class="fa-solid fa-magnifying-glass absolute right-3 top-2.5 text-slate-500 text-[10px]"></i>
                </div>
            </div>
        </div>

        <div class="p-6 grid grid-cols-1 gap-4 bg-black/10 flex-1" id="article-list-container">
            <div id="article-skeletons" class="article-feed-skeleton">
                {% for i in 1..4 %}
                    <div class="article-skeleton-card">
                        <div class="flex items-start justify-between gap-6">
                            <div class="flex-1">
                                <div class="flex items-center gap-2 flex-wrap">
                                    <div class="article-skeleton-line article-skeleton-chip"></div>
                                    <div class="article-skeleton-line article-skeleton-chip small"></div>
                                    <div class="article-skeleton-line article-skeleton-chip"></div>
                                </div>
                                <div class="article-skeleton-line article-skeleton-title"></div>
                                <div class="article-skeleton-line article-skeleton-text"></div>
                                <div class="article-skeleton-line article-skeleton-text short"></div>
                            </div>
                            <div class="article-skeleton-line article-skeleton-meta"></div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {% if articles|length > 0 %}
                {% for article in articles %}
                    <a
                        href="{{ path_for('showArticle', {id: article.id}) }}"
                        class="article-card has-read-state relative block glass-panel p-5 hover:bg-black/60 transition-all duration-300 group {{ article.is_promoted ? 'border-l-4 border-amber-500 bg-amber-500/5' : 'border-l-2 border-slate-700 hover:border-fuchsia-500' }}"
                        data-article-id="{{ article.id }}"
                        data-article-url="{{ path_for('showArticle', {id: article.id})|e('html_attr') }}"
                        data-category="{{ article.category_label|e('html_attr') }}"
                        data-title="{{ article.title|lower|e('html_attr') }}"
                        data-display-title="{{ article.title|e('html_attr') }}"
                        data-author="{{ article.creator.nick|default(t('news.home.anonymous_author'))|lower|e('html_attr') }}"
                        data-display-author="{{ article.creator.nick|default(t('news.home.anonymous_author'))|e('html_attr') }}"
                        data-newspaper="{{ article.newspaper_name|default(t('news.home.independent_newspaper'))|lower|e('html_attr') }}"
                        data-display-newspaper="{{ article.newspaper_name|default(t('news.home.independent_newspaper'))|e('html_attr') }}"
                        data-display-category="{{ article.category_label|e('html_attr') }}"
                        data-display-excerpt="{{ article.excerpt|e('html_attr') }}"
                        data-sort-personal="{{ article.sort_personal|default(article.sort_trend|default(0)) }}"
                        data-sort-trend="{{ article.sort_trend|default(0) }}"
                        data-sort-latest="{{ article.sort_latest|default(article.id|default(0)) }}"
                        data-sort-views="{{ article.views|default(0) }}"
                        data-sort-votes="{{ article.votes|default(0) }}"
                        data-comments-count="{{ article.comments_count|default(0) }}"
                        data-created-at="{{ article.created_at|default(t('news.home.recent'))|e('html_attr') }}"
                        data-is-promoted="{{ article.is_promoted ? '1' : '0' }}">

                        <div class="absolute right-0 top-0 bottom-0 w-1/3 bg-gradient-to-l {{ article.is_promoted ? 'from-amber-500/5' : 'from-fuchsia-500/5' }} to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>

                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 relative z-10">
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-3 mb-2.5 flex-wrap">
                                    <span class="article-read-state is-new"><i class="fa-solid fa-sparkles"></i> {{ t('news.home.new') }}</span>
                                    <span class="article-read-state is-read"><i class="fa-solid fa-check"></i> {{ t('news.home.read') }}</span>
                                    {% if article.is_promoted %}
                                        <span class="bg-amber-500 text-black text-[8px] font-black px-2 py-0.5 rounded shadow-[0_0_10px_rgba(245,158,11,0.4)] flex items-center gap-1 uppercase">
                                            <i class="fa-solid fa-bolt"></i> {{ t('news.home.promoted') }}
                                        </span>
                                    {% endif %}

                                    <span class="bg-slate-800 border border-slate-700 text-slate-300 text-[8px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">
                                        {{ article.category_label }}
                                    </span>

                                    <span class="text-[9px] text-cyan-400 font-black uppercase tracking-widest flex items-center gap-1.5">
                                        <i class="fa-solid fa-tower-broadcast text-slate-500"></i> {{ article.newspaper_name|default(t('news.home.independent_newspaper')) }}
                                    </span>

                                    <span class="text-[9px] text-fuchsia-400 font-black uppercase tracking-widest flex items-center gap-1.5 search-target-author">
                                        <i class="fa-solid fa-user-pen text-slate-500"></i> {{ article.creator.nick|default(t('news.home.anonymous_author')) }}
                                    </span>

                                    <span class="text-[9px] text-slate-600 font-bold hidden sm:block">
                                        <i class="fa-regular fa-clock mr-1"></i> {{ article.created_at|default(t('news.home.recent')) }}
                                    </span>
                                </div>

                                <h3 class="text-base font-black text-white uppercase tracking-wider group-hover:text-fuchsia-400 transition-colors mb-2 truncate search-target-title">
                                    {{ article.title }}
                                </h3>

                                <p class="text-[11px] text-slate-400 font-medium leading-relaxed line-clamp-2">
                                    {{ article.excerpt }}
                                </p>
                            </div>

                            <div class="flex items-center justify-between md:justify-end gap-6 border-t md:border-t-0 border-white/5 pt-4 md:pt-0">
                                <div class="flex items-center gap-4 bg-black/40 px-3 py-2 rounded-lg border border-white/5">
                                    <div class="flex flex-col items-center text-slate-400 group-hover:text-white transition-colors" title="{{ t('news.home.views_title') }}">
                                        <i class="fa-solid fa-eye text-xs mb-0.5"></i>
                                        <span class="text-[9px] font-black">{{ article.views|default(0) }}</span>
                                    </div>
                                    <div class="w-px h-6 bg-white/10"></div>
                                    <div class="flex flex-col items-center text-amber-500/80 group-hover:text-amber-400 transition-colors" title="{{ t('news.home.support_title') }}">
                                        <i class="fa-solid fa-star text-xs mb-0.5"></i>
                                        <span class="text-[9px] font-black">{{ article.votes|default(0) }}</span>
                                    </div>
                                    <div class="w-px h-6 bg-white/10"></div>
                                    <div class="flex flex-col items-center text-sky-500/80 group-hover:text-sky-400 transition-colors" title="{{ t('news.home.comments_title') }}">
                                        <i class="fa-solid fa-comments text-xs mb-0.5"></i>
                                        <span class="text-[9px] font-black">{{ article.comments_count|default(0) }}</span>
                                    </div>
                                </div>

                                <button type="button" class="media-share-btn inline-share" data-share-url="{{ path_for('showArticle', {id: article.id})|e('html_attr') }}" onclick="shareArticle(event, this)" title="{{ t('news.home.share_title') }}">
                                    <i class="fa-solid fa-link text-xs"></i>
                                </button>

                                <div class="w-10 h-10 rounded-full bg-fuchsia-600/10 flex items-center justify-center border border-fuchsia-500/30 group-hover:bg-fuchsia-600 group-hover:border-fuchsia-400 transition-all shadow-[0_0_10px_rgba(217,70,239,0)] group-hover:shadow-[0_0_15px_rgba(217,70,239,0.5)]">
                                    <i class="fa-solid fa-arrow-right-long text-fuchsia-500 group-hover:text-white transition-colors group-hover:translate-x-0.5"></i>
                                </div>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            {% else %}
                <div class="glass-panel p-16 text-center opacity-70 flex flex-col items-center justify-center border-dashed border-white/10">
                    <div class="w-20 h-20 bg-slate-800/50 rounded-full flex items-center justify-center mb-4">
                        <i class="fa-solid fa-newspaper text-4xl text-slate-500"></i>
                    </div>
                    <div class="text-[14px] font-black text-slate-300 uppercase tracking-widest mb-1">{{ t('news.home.empty.title') }}</div>
                    <div class="text-[10px] font-bold text-slate-500 uppercase">{{ t('news.home.empty.subtitle') }}</div>

                    <a href="{{ quickWritePath }}" class="mt-6 bg-slate-800 hover:bg-fuchsia-600 text-slate-300 hover:text-white px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all border border-slate-700 hover:border-fuchsia-500">
                        {{ quickWriteLabel }}
                    </a>
                </div>
            {% endif %}

            <div id="no-results-msg" class="hidden glass-panel p-10 text-center opacity-70 flex-col items-center justify-center border-dashed border-white/10">
                <i class="fa-solid fa-magnifying-glass-minus text-3xl text-slate-500 mb-3"></i>
                <div class="text-[11px] font-black text-slate-400 uppercase tracking-widest">{{ t('news.home.empty.search') }}</div>
            </div>
        </div>

        {% if pagination is defined and pagination.total_pages > 1 %}
            <div class="p-4 border-t border-white/5 bg-black/20 flex justify-center">
                <div class="flex gap-1">
                    <button class="w-8 h-8 rounded bg-black/50 border border-white/10 text-slate-400 hover:text-white hover:border-fuchsia-500 flex items-center justify-center transition-colors"><i class="fa-solid fa-chevron-left text-[10px]"></i></button>
                    <button class="w-8 h-8 rounded bg-fuchsia-600 border border-fuchsia-500 text-white font-black text-[10px] flex items-center justify-center shadow-[0_0_10px_rgba(217,70,239,0.3)]">1</button>
                    <button class="w-8 h-8 rounded bg-black/50 border border-white/10 text-slate-400 hover:text-white hover:border-fuchsia-500 font-black text-[10px] flex items-center justify-center transition-colors">2</button>
                    <button class="w-8 h-8 rounded bg-black/50 border border-white/10 text-slate-400 hover:text-white hover:border-fuchsia-500 flex items-center justify-center transition-colors"><i class="fa-solid fa-chevron-right text-[10px]"></i></button>
                </div>
            </div>
        {% endif %}
    </div>
</div>

<div id="media-toast-wrap" class="media-toast-wrap"></div>
<div id="article-focus-overlay" class="article-focus-overlay" aria-hidden="true">
    <div class="article-focus-stage">
        <div class="article-focus-topbar">
            <div class="article-focus-kicker"><i class="fa-solid fa-bolt"></i> {{ t('news.home.focus') }}</div>
            <button type="button" class="article-focus-close" onclick="closeFocusMode()" aria-label="{{ t('news.home.focus_close') }}">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div id="article-focus-card" class="article-focus-card"></div>
    </div>
</div>

<script>
    const newsHomeI18n = {
        anonymousAuthor: {{ t('news.home.anonymous_author')|json_encode|raw }},
        independentNewspaper: {{ t('news.home.independent_newspaper')|json_encode|raw }},
        genericCategory: {{ t('news.home.generic_category')|json_encode|raw }},
        recent: {{ t('news.home.recent')|json_encode|raw }},
        promoted: {{ t('news.home.promoted')|json_encode|raw }},
        reads: {{ t('news.home.reads')|json_encode|raw }},
        support: {{ t('news.home.support')|json_encode|raw }},
        comments: {{ t('news.home.comments')|json_encode|raw }},
        prev: {{ t('news.home.focus.prev')|json_encode|raw }},
        next: {{ t('news.home.focus.next')|json_encode|raw }},
        share: {{ t('news.home.focus.share')|json_encode|raw }},
        open: {{ t('news.home.focus.open')|json_encode|raw }},
        hint: {{ t('news.home.focus.hint')|json_encode|raw }},
        focusTitle: {{ t('news.home.focus.missing_title')|json_encode|raw }},
        focusBody: {{ t('news.home.focus.missing_body')|json_encode|raw }},
        copyTitle: {{ t('news.home.toast.copy_title')|json_encode|raw }},
        copyBody: {{ t('news.home.toast.copy_body')|json_encode|raw }},
        copyErrorTitle: {{ t('news.home.toast.copy_error_title')|json_encode|raw }},
        copyErrorBody: {{ t('news.home.toast.copy_error_body')|json_encode|raw }}
    };

    window.mediaFeedState = {
        category: 'all',
        sort: 'personal',
        search: ''
    };
    window.mediaFeedLoadingTimer = null;
    window.mediaReadStorageKey = 'erepublik.readArticles';
    window.articleFocusIndex = 0;
    window.articleFocusItems = [];

    window.showMediaToast = function(title, body) {
        var wrap = document.getElementById('media-toast-wrap');
        if (!wrap) {
            return;
        }

        var toast = document.createElement('div');
        toast.className = 'media-toast';
        toast.innerHTML = '<div class="media-toast-title"><i class="fa-solid fa-link"></i>' + title + '</div><div class="media-toast-body">' + body + '</div>';
        wrap.appendChild(toast);

        requestAnimationFrame(function() {
            toast.classList.add('is-visible');
        });

        setTimeout(function() {
            toast.classList.remove('is-visible');
            setTimeout(function() {
                if (toast.parentNode) {
                    toast.parentNode.removeChild(toast);
                }
            }, 220);
        }, 2200);
    };

    window.escapeMediaHtml = function(value) {
        return String(value || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    };

    window.copyArticleLink = function(url) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
            return navigator.clipboard.writeText(url);
        }

        return new Promise(function(resolve, reject) {
            var input = document.createElement('input');
            input.value = url;
            document.body.appendChild(input);
            input.select();

            try {
                document.execCommand('copy');
                document.body.removeChild(input);
                resolve();
            } catch (error) {
                document.body.removeChild(input);
                reject(error);
            }
        });
    };

    window.shareArticle = function(event, btnElement) {
        if (event) {
            event.preventDefault();
            event.stopPropagation();
        }

        var sharePath = btnElement ? String(btnElement.getAttribute('data-share-url') || '') : '';
        if (!sharePath) {
            return;
        }

        var absoluteUrl = sharePath.indexOf('http') === 0 ? sharePath : (window.location.origin + sharePath);

        window.copyArticleLink(absoluteUrl)
            .then(function() {
                window.showMediaToast(newsHomeI18n.copyTitle, newsHomeI18n.copyBody);
            })
            .catch(function() {
                window.showMediaToast(newsHomeI18n.copyErrorTitle, newsHomeI18n.copyErrorBody);
            });
    };

    window.getReadArticles = function() {
        try {
            var raw = window.localStorage.getItem(window.mediaReadStorageKey);
            var parsed = raw ? JSON.parse(raw) : [];
            return Array.isArray(parsed) ? parsed.map(function(item) { return String(item); }) : [];
        } catch (error) {
            return [];
        }
    };

    window.saveReadArticles = function(articleIds) {
        try {
            window.localStorage.setItem(window.mediaReadStorageKey, JSON.stringify(articleIds.slice(0, 200)));
        } catch (error) {
        }
    };

    window.markArticleAsRead = function(articleId) {
        if (!articleId) {
            return;
        }

        var current = window.getReadArticles();
        articleId = String(articleId);

        if (current.indexOf(articleId) === -1) {
            current.unshift(articleId);
            window.saveReadArticles(current);
        }

        window.applyReadStates();
    };

    window.applyReadStates = function() {
        var readIds = window.getReadArticles();

        document.querySelectorAll('.has-read-state[data-article-id]').forEach(function(card) {
            var articleId = String(card.getAttribute('data-article-id') || '');
            if (!articleId) {
                return;
            }

            card.classList.toggle('is-read', readIds.indexOf(articleId) > -1);
        });
    };

    window.bindReadTracking = function() {
        document.querySelectorAll('.has-read-state[data-article-id]').forEach(function(card) {
            if (card.getAttribute('data-read-bound') === '1') {
                return;
            }

            card.setAttribute('data-read-bound', '1');
            card.addEventListener('click', function(event) {
                if (event.target.closest('.media-share-btn')) {
                    return;
                }

                window.markArticleAsRead(card.getAttribute('data-article-id'));
            });
        });
    };

    window.collectVisibleFocusItems = function() {
        return Array.prototype.slice.call(document.querySelectorAll('#article-list-container .article-card'))
            .filter(function(card) {
                return card.style.display !== 'none';
            })
            .map(function(card) {
                return {
                    id: String(card.getAttribute('data-article-id') || ''),
                    url: String(card.getAttribute('data-article-url') || ''),
                    title: String(card.getAttribute('data-display-title') || ''),
                    author: String(card.getAttribute('data-display-author') || newsHomeI18n.anonymousAuthor),
                    newspaper: String(card.getAttribute('data-display-newspaper') || newsHomeI18n.independentNewspaper),
                    category: String(card.getAttribute('data-display-category') || newsHomeI18n.genericCategory),
                    excerpt: String(card.getAttribute('data-display-excerpt') || ''),
                    views: String(card.getAttribute('data-sort-views') || '0'),
                    votes: String(card.getAttribute('data-sort-votes') || '0'),
                    comments: String(card.getAttribute('data-comments-count') || '0'),
                    createdAt: String(card.getAttribute('data-created-at') || newsHomeI18n.recent),
                    isPromoted: String(card.getAttribute('data-is-promoted') || '') === '1'
                };
            });
    };

    window.renderFocusItem = function(direction) {
        var card = document.getElementById('article-focus-card');
        if (!card || !window.articleFocusItems.length) {
            return;
        }

        var item = window.articleFocusItems[window.articleFocusIndex];
        if (!item) {
            return;
        }

        if (direction === 'next') {
            card.classList.add('is-shifting-next');
        } else if (direction === 'prev') {
            card.classList.add('is-shifting-prev');
        }

        setTimeout(function() {
            card.classList.remove('is-shifting-next', 'is-shifting-prev');
            var safeCategory = window.escapeMediaHtml(item.category);
            var safeNewspaper = window.escapeMediaHtml(item.newspaper);
            var safeAuthor = window.escapeMediaHtml(item.author);
            var safeTitle = window.escapeMediaHtml(item.title);
            var safeExcerpt = window.escapeMediaHtml(item.excerpt);
            var safeCreatedAt = window.escapeMediaHtml(item.createdAt);
            var safeUrl = window.escapeMediaHtml(item.url);
            card.innerHTML = ''
                + '<div class="article-focus-meta">'
                + (item.isPromoted ? '<span class="article-focus-chip primary"><i class="fa-solid fa-bolt"></i>' + newsHomeI18n.promoted + '</span>' : '')
                + '<span class="article-focus-chip secondary">' + safeCategory + '</span>'
                + '<span class="article-focus-chip secondary"><i class="fa-solid fa-tower-broadcast"></i>' + safeNewspaper + '</span>'
                + '<span class="article-focus-chip secondary"><i class="fa-solid fa-user-pen"></i>' + safeAuthor + '</span>'
                + '</div>'
                + '<div class="article-focus-title">' + safeTitle + '</div>'
                + '<div class="article-focus-excerpt">' + safeExcerpt + '</div>'
                + '<div class="article-focus-stats">'
                + '<div class="article-focus-stat"><i class="fa-solid fa-eye"></i>' + item.views + ' ' + newsHomeI18n.reads + '</div>'
                + '<div class="article-focus-stat"><i class="fa-solid fa-star"></i>' + item.votes + ' ' + newsHomeI18n.support + '</div>'
                + '<div class="article-focus-stat"><i class="fa-solid fa-comments"></i>' + item.comments + ' ' + newsHomeI18n.comments + '</div>'
                + '<div class="article-focus-stat"><i class="fa-regular fa-clock"></i>' + safeCreatedAt + '</div>'
                + '</div>'
                + '<div class="article-focus-actions">'
                + '<div class="article-focus-nav">'
                + '<button type="button" onclick="focusPrevArticle()"><i class="fa-solid fa-arrow-left"></i>' + newsHomeI18n.prev + '</button>'
                + '<button type="button" onclick="focusNextArticle()">' + newsHomeI18n.next + '<i class="fa-solid fa-arrow-right"></i></button>'
                + '</div>'
                + '<div class="article-focus-nav">'
                + '<button type="button" onclick="shareFocusArticle()"><i class="fa-solid fa-link"></i>' + newsHomeI18n.share + '</button>'
                + '<a href="' + safeUrl + '" class="article-focus-open" onclick="markArticleAsRead(\'' + item.id + '\')"><i class="fa-solid fa-arrow-up-right-from-square"></i>' + newsHomeI18n.open + '</a>'
                + '</div>'
                + '</div>'
                + '<div class="article-focus-hint">' + newsHomeI18n.hint + '</div>';

            window.markArticleAsRead(item.id);
        }, direction ? 110 : 0);
    };

    window.openFocusMode = function() {
        var overlay = document.getElementById('article-focus-overlay');
        if (!overlay) {
            return;
        }

        window.articleFocusItems = window.collectVisibleFocusItems();
        if (!window.articleFocusItems.length) {
            window.showMediaToast(newsHomeI18n.focusTitle, newsHomeI18n.focusBody);
            return;
        }

        window.articleFocusIndex = 0;
        overlay.classList.add('is-open');
        overlay.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        window.renderFocusItem();
    };

    window.closeFocusMode = function() {
        var overlay = document.getElementById('article-focus-overlay');
        if (!overlay) {
            return;
        }

        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    };

    window.focusNextArticle = function() {
        if (!window.articleFocusItems.length) {
            return;
        }

        window.articleFocusIndex = (window.articleFocusIndex + 1) % window.articleFocusItems.length;
        window.renderFocusItem('next');
    };

    window.focusPrevArticle = function() {
        if (!window.articleFocusItems.length) {
            return;
        }

        window.articleFocusIndex = (window.articleFocusIndex - 1 + window.articleFocusItems.length) % window.articleFocusItems.length;
        window.renderFocusItem('prev');
    };

    window.shareFocusArticle = function() {
        if (!window.articleFocusItems.length) {
            return;
        }

        var currentItem = window.articleFocusItems[window.articleFocusIndex];
        if (!currentItem) {
            return;
        }

        window.copyArticleLink(window.location.origin + currentItem.url)
            .then(function() {
                window.showMediaToast(newsHomeI18n.copyTitle, newsHomeI18n.copyBody);
            })
            .catch(function() {
                window.showMediaToast(newsHomeI18n.copyErrorTitle, newsHomeI18n.copyErrorBody);
            });
    };

    window.setArticleSkeletonState = function(isLoading) {
        var skeletons = document.getElementById('article-skeletons');
        var noResults = document.getElementById('no-results-msg');
        var cards = document.querySelectorAll('#article-list-container .article-card');

        if (skeletons) {
            skeletons.classList.toggle('is-visible', !!isLoading);
        }

        cards.forEach(function(card) {
            card.style.display = isLoading ? 'none' : card.style.display;
        });

        if (noResults && isLoading) {
            noResults.style.display = 'none';
        }
    };

    window.applyArticleFilters = function() {
        var state = window.mediaFeedState || {};
        var list = document.getElementById('article-list-container');

        if (!list) {
            return;
        }

        var cards = Array.prototype.slice.call(list.querySelectorAll('.article-card'));
        if (!cards.length) {
            return;
        }

        cards.forEach(function(card) {
            var cardCategory = String(card.getAttribute('data-category') || '');
            var haystack = [
                String(card.getAttribute('data-title') || ''),
                String(card.getAttribute('data-author') || ''),
                String(card.getAttribute('data-newspaper') || '')
            ].join(' ').toLowerCase();

            var matchCategory = state.category === 'all' || cardCategory === state.category;
            var matchSearch = !state.search || haystack.indexOf(state.search) > -1;

            card.style.display = (matchCategory && matchSearch) ? '' : 'none';
        });

        var visibleCards = cards.filter(function(card) {
            return card.style.display !== 'none';
        });

        visibleCards.sort(function(a, b) {
            var attr = 'data-sort-personal';
            if (state.sort === 'trend') {
                attr = 'data-sort-trend';
            } else if (state.sort === 'latest') {
                attr = 'data-sort-latest';
            } else if (state.sort === 'views') {
                attr = 'data-sort-views';
            } else if (state.sort === 'votes') {
                attr = 'data-sort-votes';
            }

            return parseInt(b.getAttribute(attr) || '0', 10) - parseInt(a.getAttribute(attr) || '0', 10);
        });

        visibleCards.forEach(function(card) {
            list.appendChild(card);
        });

        var noResults = document.getElementById('no-results-msg');
        if (noResults) {
            noResults.style.display = visibleCards.length === 0 ? 'flex' : 'none';
        }

        window.bindReadTracking();
        window.applyReadStates();
    };

    window.sortArticles = function(sortKey, btnElement) {
        window.mediaFeedState.sort = sortKey;
        $('.media-sort-btn').removeClass('is-active');
        $(btnElement).addClass('is-active');

        if (window.mediaFeedLoadingTimer) {
            clearTimeout(window.mediaFeedLoadingTimer);
        }

        window.setArticleSkeletonState(true);
        window.mediaFeedLoadingTimer = setTimeout(function() {
            window.applyArticleFilters();
            window.setArticleSkeletonState(false);
        }, 450);
    };

    $(function() {
        $('#article-search-input').on('keyup', function() {
            window.mediaFeedState.search = $(this).val().toLowerCase().trim();
            window.applyArticleFilters();
        });

        $(document).on('keydown', function(event) {
            var overlay = document.getElementById('article-focus-overlay');
            if (!overlay || !overlay.classList.contains('is-open')) {
                return;
            }

            if (event.key === 'ArrowRight') {
                event.preventDefault();
                window.focusNextArticle();
            } else if (event.key === 'ArrowLeft') {
                event.preventDefault();
                window.focusPrevArticle();
            } else if (event.key === 'Escape') {
                event.preventDefault();
                window.closeFocusMode();
            }
        });

        $('#article-focus-overlay').on('click', function(event) {
            if (event.target.id === 'article-focus-overlay') {
                window.closeFocusMode();
            }
        });

        window.applyArticleFilters();
        window.bindReadTracking();
        window.applyReadStates();
    });
</script>
{% endblock %}
