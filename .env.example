# Project V26 local environment example.
# Copy this file to .env and replace placeholders with local-only values.
# Do not commit real secrets, production credentials or private tokens.

# Application mode for local development.
# conf.php accepts development or production; use development locally.
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080

# Database connection.
# Docker Compose uses DB_HOST=mysql inside the app container.
# If you run PHP directly on your host, use 127.0.0.1 and your local MySQL port.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=proje
DB_USERNAME=proje
DB_PASSWORD=proje

# Optional Redis cache and session backend.
# Docker Compose starts Redis locally; set REDIS_ENABLED=false to test the MySQL/file fallback.
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=0.25

# Optional background worker/scheduler settings.
QUEUE_ENABLED=true
QUEUE_MAX_ATTEMPTS=3
QUEUE_WORKER_MAX_RUNTIME=3600
QUEUE_WORKER_MAX_JOBS=500
SCHEDULER_INTERVAL=60
SCHEDULER_LOCK_TTL=120

# Lightweight performance observation. Values are local-safe defaults.
SLOW_REQUEST_MS=1000
SLOW_QUERY_MS=250
APP_LOG_LEVEL=debug
LOG_MAX_BYTES=10485760
LOG_MAX_FILES=5
LOG_DEDUPE_SECONDS=60

# Session cookie settings for local development.
SESSION_NAME=project_v26_session
SESSION_SECRET=change_me_local_session_secret

# Optional local mail catcher settings.
# Leave username/password empty unless your local mail service requires them.
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@example.test
MAIL_FROM_NAME="Project V26"

# Marks this checkout as a public/local build.
PUBLIC_BUILD=true
