# Project V26 local environment example
# Copy this file to .env and replace placeholders with local-only values.

APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=project_v26
DB_USERNAME=project_v26_user
DB_PASSWORD=change_me_local_password

SESSION_NAME=project_v26_session
SESSION_SECRET=change_me_local_session_secret

MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@example.test
MAIL_FROM_NAME="Project V26"

PUBLIC_BUILD=true
